{
	"name": "klustered-dev",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "astro dev",
		"build": "astro check && astro build",
		"preview": "astro preview",
		"check": "astro check",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "wrangler d1 migrations apply DB --remote",
		"db:migrate:local": "wrangler d1 migrations apply DB --local",
		"db:seed": "bun scripts/seed.ts",
		"db:setup:local": "wrangler d1 migrations apply DB --local && bun scripts/seed.ts",
		"db:seed:production": "bun scripts/seed-production.ts",
		"db:grant-role": "bun scripts/grant-role.ts",
		"db:migrate:brackets": "bun scripts/migrate-to-platform-brackets.ts"
	},
	"dependencies": {
		"@astrojs/check": "0.9.8",
		"@astrojs/cloudflare": "13.1.4",
		"@astrojs/mdx": "5.0.3",
		"@unocss/astro": "^66.0.0",
		"@unocss/reset": "^66.0.0",
		"astro": "https://pkg.pr.new/astro@16059",
		"better-auth": "^1.5.6",
		"drizzle-orm": "^0.45.1",
		"typescript": "^6.0.2",
		"unocss": "^66.0.0"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20251208.0",
		"drizzle-kit": "^0.31.6",
		"wrangler": "^4.77.0"
	}
}
