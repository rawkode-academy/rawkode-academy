{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "klustered-dev",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"compatibility_date": "2026-03-12",
	"compatibility_flags": ["nodejs_compat"],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist",
		"run_worker_first": true
	},
	"workers_dev": false,
	"preview_urls": true,
	"routes": [
		{
			"pattern": "klustered.dev",
			"custom_domain": true
		}
	],
	"observability": {
		"traces": {
			"enabled": true,
			"destinations": ["grafana-traces"]
		},
		"logs": {
			"enabled": true,
			"destinations": ["grafana-logs"]
		}
	},
	"d1_databases": [
		{
			"binding": "BRACKETS",
			"database_name": "platform-brackets",
			"database_id": "d8241042-0b2b-4d7a-881f-eff9df812c62"
		}
	],
	"kv_namespaces": [
		{
			"binding": "SESSION",
			"id": "bc9a0074b45b43b5825ca58e586f9dd3"
		}
	],
	"vars": {
		"KLUSTERED_ADMIN_IDS": "HmYDQjc3JVFo7visJIL5FneGFzNAJjDT"
	},
	"services": [
		{
			"binding": "BRACKETS_WRITE",
			"service": "platform-brackets-write-model"
		}
	]
}
