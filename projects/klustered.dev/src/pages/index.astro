---
import "../styles/global.css";

const user = Astro.locals.user;
const roles = Astro.locals.roles;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="robots" content="noindex" />
		<title>Klustered Portal</title>
	</head>
	<body class="min-h-dvh bg-slate-950 text-slate-100 antialiased">
		<main class="mx-auto flex min-h-dvh max-w-xl flex-col justify-center gap-6 px-6 py-16">
			<div>
				<p class="text-xs uppercase tracking-[0.2em] text-slate-400">Klustered</p>
				<h1 class="mt-2 text-3xl font-semibold tracking-tight">Portal</h1>
				<p class="mt-4 text-sm text-slate-300">
					Admin and competitor portal for the Klustered game show.
				</p>
			</div>

			{
				user ? (
					<div class="flex flex-col gap-3 text-sm">
						<p class="text-slate-300">
							Signed in as <strong>{user.name}</strong>.
						</p>
						<div class="flex flex-wrap gap-2">
							{roles.includes("admin") && (
								<a
									href="/admin"
									class="rounded-full border border-fuchsia-500/40 bg-fuchsia-500/10 px-4 py-1.5 text-xs font-medium text-fuchsia-200 transition hover:bg-fuchsia-500/20"
								>
									Admin dashboard
								</a>
							)}
							<a
								href="/me"
								class="rounded-full border border-slate-700 bg-slate-800/60 px-4 py-1.5 text-xs font-medium text-slate-100 transition hover:bg-slate-700"
							>
								My competitor area
							</a>
							<form method="POST" action="/api/auth/sign-out">
								<button class="rounded-full border border-slate-700 px-4 py-1.5 text-xs font-medium text-slate-300 transition hover:bg-slate-800">
									Sign out
								</button>
							</form>
						</div>
					</div>
				) : (
					<a
						href="/api/auth/sign-in"
						class="inline-flex w-fit items-center gap-2 rounded-full bg-white px-5 py-2 text-sm font-medium text-slate-900 transition hover:bg-slate-200"
					>
						Sign in →
					</a>
				)
			}
		</main>
	</body>
</html>
