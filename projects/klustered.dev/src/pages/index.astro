---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="robots" content="noindex" />
		<title>Klustered Portal</title>
	</head>
	<body class="min-h-dvh bg-slate-950 text-slate-100 antialiased">
		<main class="mx-auto flex min-h-dvh max-w-xl flex-col justify-center px-6 py-16">
			<p class="text-xs uppercase tracking-[0.2em] text-slate-400">Klustered</p>
			<h1 class="mt-2 text-3xl font-semibold tracking-tight">Portal</h1>
			<p class="mt-4 text-sm text-slate-300">
				Admin and competitor portal for the Klustered game show. Sign-in is coming
				soon.
			</p>
		</main>
	</body>
</html>
