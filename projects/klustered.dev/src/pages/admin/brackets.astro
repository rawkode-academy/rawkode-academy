---
import { env } from "cloudflare:workers";
import { desc, eq } from "drizzle-orm";
import PortalLayout from "@/layouts/PortalLayout.astro";
import { getBracketsDb, schema } from "@/db/client";
import { SHOW_ID } from "@/lib/brackets-write";
import { ADMIN_NAV } from "@/lib/nav";

const db = getBracketsDb(env.BRACKETS);
const brackets = await db
	.select({
		id: schema.brackets.id,
		slug: schema.brackets.slug,
		name: schema.brackets.name,
		kind: schema.brackets.kind,
		teamSize: schema.brackets.teamSize,
		status: schema.brackets.status,
		startsAt: schema.brackets.startsAt,
		seasonName: schema.seasons.name,
	})
	.from(schema.brackets)
	.leftJoin(schema.seasons, eq(schema.brackets.seasonId, schema.seasons.id))
	.orderBy(desc(schema.brackets.createdAt))
	.all();

const seasons = await db
	.select({ id: schema.seasons.id, name: schema.seasons.name })
	.from(schema.seasons)
	.where(eq(schema.seasons.showId, SHOW_ID))
	.orderBy(desc(schema.seasons.createdAt))
	.all();

function formatDateTime(value: Date | null): string {
	if (!value) return "TBD";
	return new Intl.DateTimeFormat("en", {
		dateStyle: "medium",
		timeStyle: "short",
	}).format(value);
}
---

<PortalLayout title="Brackets" section="admin" nav={[...ADMIN_NAV]}>
	<section class="rounded-2xl border border-slate-800 bg-slate-900/60 p-6">
		<h2 class="text-sm font-semibold uppercase tracking-wider text-slate-400">
			New bracket
		</h2>
		{
			seasons.length === 0 ? (
				<p class="mt-3 text-sm text-slate-400">Create a season first.</p>
			) : (
				<form
					method="POST"
					action="/api/admin/brackets"
					class="mt-3 grid gap-3 sm:grid-cols-2 lg:grid-cols-8"
				>
					<label class="flex flex-col gap-1">
						<span class="text-xs text-slate-400">Season</span>
						<select
							name="seasonId"
							required
							class="rounded-lg border border-slate-700 bg-slate-950 px-3 py-1.5 text-sm text-slate-100 focus:border-fuchsia-500 focus:outline-none"
						>
							{seasons.map((s) => (
								<option value={s.id}>{s.name}</option>
							))}
						</select>
					</label>
					<label class="flex flex-col gap-1">
						<span class="text-xs text-slate-400">Slug</span>
						<input
							name="slug"
							required
							pattern="[a-z0-9-]+"
							class="rounded-lg border border-slate-700 bg-slate-950 px-3 py-1.5 text-sm text-slate-100 focus:border-fuchsia-500 focus:outline-none"
						/>
					</label>
					<label class="flex flex-col gap-1">
						<span class="text-xs text-slate-400">Name</span>
						<input
							name="name"
							required
							class="rounded-lg border border-slate-700 bg-slate-950 px-3 py-1.5 text-sm text-slate-100 focus:border-fuchsia-500 focus:outline-none"
						/>
					</label>
					<label class="flex flex-col gap-1">
						<span class="text-xs text-slate-400">Kind</span>
						<select
							name="kind"
							required
							class="rounded-lg border border-slate-700 bg-slate-950 px-3 py-1.5 text-sm text-slate-100 focus:border-fuchsia-500 focus:outline-none"
						>
							<option value="solo">Individual</option>
							<option value="team">Team</option>
						</select>
					</label>
					<label class="flex flex-col gap-1">
						<span class="text-xs text-slate-400">Start date</span>
						<input
							type="date"
							name="startsAtDate"
							required
							class="rounded-lg border border-slate-700 bg-slate-950 px-3 py-1.5 text-sm text-slate-100 focus:border-fuchsia-500 focus:outline-none"
						/>
					</label>
					<label class="flex flex-col gap-1">
						<span class="text-xs text-slate-400">Start time</span>
						<input
							type="time"
							name="startsAtTime"
							value="19:00"
							required
							class="rounded-lg border border-slate-700 bg-slate-950 px-3 py-1.5 text-sm text-slate-100 focus:border-fuchsia-500 focus:outline-none"
						/>
					</label>
					<label class="flex flex-col gap-1">
						<span class="text-xs text-slate-400">Team size</span>
						<input
							type="number"
							name="teamSize"
							min="2"
							value="4"
							class="rounded-lg border border-slate-700 bg-slate-950 px-3 py-1.5 text-sm text-slate-100 focus:border-fuchsia-500 focus:outline-none"
						/>
					</label>
					<div class="flex items-end">
						<button
							class="rounded-lg bg-fuchsia-500 px-4 py-1.5 text-sm font-medium text-white transition hover:bg-fuchsia-400"
						>
							Create
						</button>
					</div>
				</form>
			)
		}
	</section>

	<section class="overflow-hidden rounded-2xl border border-slate-800">
		<table class="w-full text-left text-sm">
			<thead class="bg-slate-900/60 text-xs uppercase tracking-wider text-slate-400">
				<tr>
					<th class="px-6 py-3">Name</th>
					<th class="px-6 py-3">Slug</th>
					<th class="px-6 py-3">Season</th>
					<th class="px-6 py-3">Starts</th>
					<th class="px-6 py-3">Kind</th>
					<th class="px-6 py-3">Status</th>
					<th class="px-6 py-3 text-right">Actions</th>
				</tr>
			</thead>
			<tbody class="divide-y divide-slate-800 bg-slate-950/40">
				{
					brackets.length === 0 ? (
						<tr>
							<td colspan="7" class="px-6 py-6 text-center text-sm text-slate-500">
								No brackets yet.
							</td>
						</tr>
					) : (
						brackets.map((b) => (
							<tr>
								<td class="px-6 py-3">
									<a href={`/admin/brackets/${b.id}`} class="text-fuchsia-300 hover:underline">
										{b.name}
									</a>
								</td>
								<td class="px-6 py-3 font-mono text-xs text-slate-400">{b.slug}</td>
								<td class="px-6 py-3 text-slate-400">{b.seasonName}</td>
								<td class="px-6 py-3 text-slate-400">{formatDateTime(b.startsAt)}</td>
								<td class="px-6 py-3 text-slate-300">
									{b.kind === "team" ? `Team (${b.teamSize})` : "Individual"}
								</td>
								<td class="px-6 py-3">
									<span class="rounded-full bg-slate-800 px-2 py-0.5 text-xs text-slate-300 capitalize">
										{b.status}
									</span>
								</td>
								<td class="px-6 py-3 text-right">
									<form method="POST" action={`/api/admin/brackets/${b.id}/delete`}>
										<button class="text-xs text-rose-400 underline-offset-4 hover:underline">
											Delete
										</button>
									</form>
								</td>
							</tr>
						))
					)
				}
			</tbody>
		</table>
	</section>
</PortalLayout>
