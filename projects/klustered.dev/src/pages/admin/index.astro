---
import "../../styles/global.css";

const user = Astro.locals.user!;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="robots" content="noindex" />
		<title>Klustered Admin</title>
	</head>
	<body class="min-h-dvh bg-slate-950 text-slate-100 antialiased">
		<main class="mx-auto flex min-h-dvh max-w-3xl flex-col gap-6 px-6 py-16">
			<header class="flex items-baseline justify-between">
				<div>
					<p class="text-xs uppercase tracking-[0.2em] text-slate-400">Klustered</p>
					<h1 class="mt-1 text-3xl font-semibold tracking-tight">Admin</h1>
				</div>
				<form method="POST" action="/api/auth/sign-out">
					<button class="text-sm text-slate-400 underline-offset-4 hover:text-slate-100 hover:underline">
						Sign out
					</button>
				</form>
			</header>

			<p class="text-sm text-slate-300">
				Signed in as <strong>{user.name}</strong> ({user.email}).
			</p>

			<section class="rounded-2xl border border-slate-800 bg-slate-900/60 p-6 text-sm text-slate-300">
				Admin features will appear here. CRUD for seasons, competitors, teams,
				scenarios, brackets, matches, and results — all coming in subsequent
				phases.
			</section>
		</main>
	</body>
</html>
