---
import PortalLayout from "@/layouts/PortalLayout.astro";
import { ADMIN_NAV } from "@/lib/nav";
---

<PortalLayout title="Admin overview" section="admin" nav={[...ADMIN_NAV]}>
	<section class="rounded-2xl border border-slate-800 bg-slate-900/60 p-6 text-sm text-slate-300">
		<p>
			Welcome to the Klustered admin portal. Use the sidebar to manage seasons,
			competitors, brackets, scenarios, and match results.
		</p>
		<p class="mt-3 text-slate-400">
			For a launch run, create the season first, add competitors and teams,
			attach scenarios, generate the bracket, then drive the match from the
			live control page.
		</p>
	</section>
</PortalLayout>
