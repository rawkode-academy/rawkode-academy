---
import { env } from "cloudflare:workers";
import { desc, eq } from "drizzle-orm";
import { getCollection } from "astro:content";
import PortalLayout from "@/layouts/PortalLayout.astro";
import { getDb, schema } from "@/db/client";
import { ADMIN_NAV } from "@/lib/nav";

const db = getDb(env.DB);
const competitors = await db
	.select({
		id: schema.competitors.id,
		personSlug: schema.competitors.personSlug,
		displayName: schema.competitors.displayName,
		seasonId: schema.competitors.seasonId,
		seasonSlug: schema.seasons.slug,
		seasonName: schema.seasons.name,
	})
	.from(schema.competitors)
	.leftJoin(schema.seasons, eq(schema.competitors.seasonId, schema.seasons.id))
	.orderBy(desc(schema.competitors.createdAt))
	.all();

const seasons = await db
	.select({ id: schema.seasons.id, slug: schema.seasons.slug, name: schema.seasons.name })
	.from(schema.seasons)
	.orderBy(desc(schema.seasons.createdAt))
	.all();

const people = await getCollection("people");
const peopleSorted = people.sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<PortalLayout title="Competitors" section="admin" nav={[...ADMIN_NAV]}>
	<section class="rounded-2xl border border-slate-800 bg-slate-900/60 p-6">
		<h2 class="text-sm font-semibold uppercase tracking-wider text-slate-400">
			Register competitor
		</h2>
		{
			seasons.length === 0 ? (
				<p class="mt-3 text-sm text-slate-400">
					Create a season first before registering competitors.
				</p>
			) : (
				<form
					method="POST"
					action="/api/admin/competitors"
					class="mt-3 grid gap-3 sm:grid-cols-2 lg:grid-cols-5"
				>
					<label class="flex flex-col gap-1 sm:col-span-1">
						<span class="text-xs text-slate-400">Season</span>
						<select
							name="seasonId"
							required
							class="rounded-lg border border-slate-700 bg-slate-950 px-3 py-1.5 text-sm text-slate-100 focus:border-fuchsia-500 focus:outline-none"
						>
							{seasons.map((s) => (
								<option value={s.id}>{s.name}</option>
							))}
						</select>
					</label>
					<label class="flex flex-col gap-1 sm:col-span-1">
						<span class="text-xs text-slate-400">Person</span>
						<select
							name="personSlug"
							required
							class="rounded-lg border border-slate-700 bg-slate-950 px-3 py-1.5 text-sm text-slate-100 focus:border-fuchsia-500 focus:outline-none"
						>
							<option value="">— select —</option>
							{peopleSorted.map((p) => (
								<option value={p.id}>{p.data.name}</option>
							))}
						</select>
					</label>
					<label class="flex flex-col gap-1 sm:col-span-1">
						<span class="text-xs text-slate-400">Display name</span>
						<input
							name="displayName"
							required
							class="rounded-lg border border-slate-700 bg-slate-950 px-3 py-1.5 text-sm text-slate-100 focus:border-fuchsia-500 focus:outline-none"
						/>
					</label>
					<label class="flex flex-col gap-1 sm:col-span-1">
						<span class="text-xs text-slate-400">Linked user id (optional)</span>
						<input
							name="userId"
							placeholder="OIDC sub"
							class="rounded-lg border border-slate-700 bg-slate-950 px-3 py-1.5 text-sm text-slate-100 focus:border-fuchsia-500 focus:outline-none"
						/>
					</label>
					<div class="flex items-end">
						<button
							class="rounded-lg bg-fuchsia-500 px-4 py-1.5 text-sm font-medium text-white transition hover:bg-fuchsia-400"
						>
							Register
						</button>
					</div>
				</form>
			)
		}
	</section>

	<section class="overflow-hidden rounded-2xl border border-slate-800">
		<table class="w-full text-left text-sm">
			<thead class="bg-slate-900/60 text-xs uppercase tracking-wider text-slate-400">
				<tr>
					<th class="px-6 py-3">Display name</th>
					<th class="px-6 py-3">Person</th>
					<th class="px-6 py-3">Season</th>
					<th class="px-6 py-3 text-right">Actions</th>
				</tr>
			</thead>
			<tbody class="divide-y divide-slate-800 bg-slate-950/40">
				{
					competitors.length === 0 ? (
						<tr>
							<td colspan="4" class="px-6 py-6 text-center text-sm text-slate-500">
								No competitors yet.
							</td>
						</tr>
					) : (
						competitors.map((c) => (
							<tr>
								<td class="px-6 py-3">{c.displayName}</td>
								<td class="px-6 py-3 font-mono text-xs text-slate-400">{c.personSlug}</td>
								<td class="px-6 py-3 text-slate-400">{c.seasonName ?? c.seasonId}</td>
								<td class="px-6 py-3 text-right">
									<form method="POST" action={`/api/admin/competitors/${c.id}/delete`}>
										<button class="text-xs text-rose-400 underline-offset-4 hover:underline">
											Delete
										</button>
									</form>
								</td>
							</tr>
						))
					)
				}
			</tbody>
		</table>
	</section>
</PortalLayout>
