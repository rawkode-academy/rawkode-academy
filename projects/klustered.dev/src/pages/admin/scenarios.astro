---
import { env } from "cloudflare:workers";
import { desc } from "drizzle-orm";
import PortalLayout from "@/layouts/PortalLayout.astro";
import { getDb, schema } from "@/db/client";
import { ADMIN_NAV } from "@/lib/nav";

const db = getDb(env.DB);
const scenarios = await db
	.select()
	.from(schema.scenarios)
	.orderBy(desc(schema.scenarios.createdAt))
	.all();
---

<PortalLayout title="Scenarios" section="admin" nav={[...ADMIN_NAV]}>
	<section class="rounded-2xl border border-slate-800 bg-slate-900/60 p-6">
		<h2 class="text-sm font-semibold uppercase tracking-wider text-slate-400">
			New scenario
		</h2>
		<form
			method="POST"
			action="/api/admin/scenarios"
			class="mt-3 grid gap-3 sm:grid-cols-2"
		>
			<label class="flex flex-col gap-1">
				<span class="text-xs text-slate-400">Slug</span>
				<input
					name="slug"
					required
					pattern="[a-z0-9-]+"
					class="rounded-lg border border-slate-700 bg-slate-950 px-3 py-1.5 text-sm text-slate-100 focus:border-fuchsia-500 focus:outline-none"
				/>
			</label>
			<label class="flex flex-col gap-1">
				<span class="text-xs text-slate-400">Title</span>
				<input
					name="title"
					required
					class="rounded-lg border border-slate-700 bg-slate-950 px-3 py-1.5 text-sm text-slate-100 focus:border-fuchsia-500 focus:outline-none"
				/>
			</label>
			<label class="flex flex-col gap-1 sm:col-span-2">
				<span class="text-xs text-slate-400">Description</span>
				<textarea
					name="description"
					required
					rows="3"
					class="rounded-lg border border-slate-700 bg-slate-950 px-3 py-1.5 text-sm text-slate-100 focus:border-fuchsia-500 focus:outline-none"></textarea>
			</label>
			<label class="flex flex-col gap-1">
				<span class="text-xs text-slate-400">Difficulty</span>
				<select
					name="difficulty"
					class="rounded-lg border border-slate-700 bg-slate-950 px-3 py-1.5 text-sm text-slate-100 focus:border-fuchsia-500 focus:outline-none"
				>
					<option value="easy">Easy</option>
					<option value="medium" selected>Medium</option>
					<option value="hard">Hard</option>
				</select>
			</label>
			<label class="flex flex-col gap-1">
				<span class="text-xs text-slate-400">Tags (comma separated)</span>
				<input
					name="tags"
					placeholder="etcd, control-plane"
					class="rounded-lg border border-slate-700 bg-slate-950 px-3 py-1.5 text-sm text-slate-100 focus:border-fuchsia-500 focus:outline-none"
				/>
			</label>
			<div class="flex items-end sm:col-span-2">
				<button
					class="rounded-lg bg-fuchsia-500 px-4 py-1.5 text-sm font-medium text-white transition hover:bg-fuchsia-400"
				>
					Create
				</button>
			</div>
		</form>
	</section>

	<section class="overflow-hidden rounded-2xl border border-slate-800">
		<table class="w-full text-left text-sm">
			<thead class="bg-slate-900/60 text-xs uppercase tracking-wider text-slate-400">
				<tr>
					<th class="px-6 py-3">Slug</th>
					<th class="px-6 py-3">Title</th>
					<th class="px-6 py-3">Difficulty</th>
					<th class="px-6 py-3">Tags</th>
					<th class="px-6 py-3 text-right">Actions</th>
				</tr>
			</thead>
			<tbody class="divide-y divide-slate-800 bg-slate-950/40">
				{
					scenarios.length === 0 ? (
						<tr>
							<td colspan="5" class="px-6 py-6 text-center text-sm text-slate-500">
								No scenarios yet. Create one above.
							</td>
						</tr>
					) : (
						scenarios.map((s) => (
							<tr>
								<td class="px-6 py-3 font-mono text-xs text-slate-300">{s.slug}</td>
								<td class="px-6 py-3">{s.title}</td>
								<td class="px-6 py-3">
									<span class="rounded-full bg-slate-800 px-2 py-0.5 text-xs text-slate-300 capitalize">
										{s.difficulty}
									</span>
								</td>
								<td class="px-6 py-3 text-xs text-slate-400">{s.tags.join(", ") || "—"}</td>
								<td class="px-6 py-3 text-right">
									<form method="POST" action={`/api/admin/scenarios/${s.id}/delete`}>
										<button class="text-xs text-rose-400 underline-offset-4 hover:underline">
											Delete
										</button>
									</form>
								</td>
							</tr>
						))
					)
				}
			</tbody>
		</table>
	</section>
</PortalLayout>
