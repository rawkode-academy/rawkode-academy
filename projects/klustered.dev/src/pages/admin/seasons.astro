---
import { env } from "cloudflare:workers";
import { desc } from "drizzle-orm";
import PortalLayout from "@/layouts/PortalLayout.astro";
import { getDb, schema } from "@/db/client";
import { ADMIN_NAV } from "@/lib/nav";

const db = getDb(env.DB);
const seasons = await db
	.select()
	.from(schema.seasons)
	.orderBy(desc(schema.seasons.createdAt))
	.all();

function formatDate(value: Date | null): string {
	if (!value) return "—";
	return new Intl.DateTimeFormat("en", { dateStyle: "medium" }).format(value);
}
---

<PortalLayout title="Seasons" section="admin" nav={[...ADMIN_NAV]}>
	<section class="rounded-2xl border border-slate-800 bg-slate-900/60 p-6">
		<h2 class="text-sm font-semibold uppercase tracking-wider text-slate-400">
			New season
		</h2>
		<form
			method="POST"
			action="/api/admin/seasons"
			class="mt-3 grid gap-3 sm:grid-cols-2 lg:grid-cols-4"
		>
			<label class="flex flex-col gap-1">
				<span class="text-xs text-slate-400">Slug</span>
				<input
					name="slug"
					required
					pattern="[a-z0-9-]+"
					class="rounded-lg border border-slate-700 bg-slate-950 px-3 py-1.5 text-sm text-slate-100 focus:border-fuchsia-500 focus:outline-none"
				/>
			</label>
			<label class="flex flex-col gap-1">
				<span class="text-xs text-slate-400">Name</span>
				<input
					name="name"
					required
					class="rounded-lg border border-slate-700 bg-slate-950 px-3 py-1.5 text-sm text-slate-100 focus:border-fuchsia-500 focus:outline-none"
				/>
			</label>
			<label class="flex flex-col gap-1">
				<span class="text-xs text-slate-400">Status</span>
				<select
					name="status"
					class="rounded-lg border border-slate-700 bg-slate-950 px-3 py-1.5 text-sm text-slate-100 focus:border-fuchsia-500 focus:outline-none"
				>
					<option value="interest">Interest</option>
					<option value="active">Active</option>
					<option value="finished">Finished</option>
				</select>
			</label>
			<div class="flex items-end">
				<button
					class="rounded-lg bg-fuchsia-500 px-4 py-1.5 text-sm font-medium text-white transition hover:bg-fuchsia-400"
				>
					Create
				</button>
			</div>
		</form>
	</section>

	<section class="overflow-hidden rounded-2xl border border-slate-800">
		<table class="w-full text-left text-sm">
			<thead class="bg-slate-900/60 text-xs uppercase tracking-wider text-slate-400">
				<tr>
					<th class="px-6 py-3">Slug</th>
					<th class="px-6 py-3">Name</th>
					<th class="px-6 py-3">Status</th>
					<th class="px-6 py-3">Created</th>
					<th class="px-6 py-3 text-right">Actions</th>
				</tr>
			</thead>
			<tbody class="divide-y divide-slate-800 bg-slate-950/40">
				{
					seasons.length === 0 ? (
						<tr>
							<td colspan="5" class="px-6 py-6 text-center text-sm text-slate-500">
								No seasons yet. Create one above.
							</td>
						</tr>
					) : (
						seasons.map((s) => (
							<tr>
								<td class="px-6 py-3 font-mono text-xs text-slate-300">{s.slug}</td>
								<td class="px-6 py-3">{s.name}</td>
								<td class="px-6 py-3">
									<span class="rounded-full bg-slate-800 px-2 py-0.5 text-xs text-slate-300">
										{s.status}
									</span>
								</td>
								<td class="px-6 py-3 text-slate-400">{formatDate(s.createdAt)}</td>
								<td class="px-6 py-3 text-right">
									<form method="POST" action={`/api/admin/seasons/${s.id}/delete`}>
										<button class="text-xs text-rose-400 underline-offset-4 hover:underline">
											Delete
										</button>
									</form>
								</td>
							</tr>
						))
					)
				}
			</tbody>
		</table>
	</section>
</PortalLayout>
