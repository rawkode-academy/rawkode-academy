---
import DefaultHead from "@/components/html/head.astro";
import DefaultLayout from "@/layouts/app.astro";
import type { OpenGraphProps } from "@/types/opengraph";
import "@/styles/global.css";

interface Props extends OpenGraphProps {
	// Astro passes MDX frontmatter under `Astro.props.frontmatter` when this
	// wrapper is used as an MDX `layout:`. Unwrap so the props reach <head>.
	frontmatter?: OpenGraphProps;
}

// Get user ID for PostHog identification (links browser sessions to server-side events)
const userId = Astro.locals.user?.id;

// When invoked via MDX `layout:` frontmatter (e.g. /privacy.mdx), the
// frontmatter object is the only place title/description live. When
// invoked as an Astro component (`<Page title="...">`), the props sit at
// the top level. Merge so either pattern works.
const { frontmatter, ...directProps } = Astro.props;
const headProps = { ...(frontmatter ?? {}), ...directProps };
---

<html lang="en" class="scroll-smooth focus:scroll-auto">
	<DefaultHead {...headProps} userId={userId}>
		<slot name="extra-head" slot="extra-head" />
	</DefaultHead>

	<body class="h-full w-full mx-auto max-w-screen-3xl text-primary-content">
		<slot name="layout">
			<DefaultLayout>
				<slot />
			</DefaultLayout>
		</slot>

	</body>
	<style is:global>
		@reference "../styles/global.css";

		h1,
		h2,
		h3 {
			@apply mt-8 mb-4;
		}
	</style>


</html>
