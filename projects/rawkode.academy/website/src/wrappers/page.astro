---
import DefaultHead from "@/components/html/head.astro";
import DefaultLayout from "@/layouts/app.astro";
import type { OpenGraphProps } from "@/types/opengraph";
import "@/styles/global.css";
import { css } from "../../styled-system/css";

interface Props extends OpenGraphProps {}

// Get user ID for PostHog identification (links browser sessions to server-side events)
const userId = Astro.locals.user?.id;
---

<html lang="en" class={css({ scrollBehavior: 'smooth', _focusWithin: { scrollBehavior: 'auto' } })}>
	<DefaultHead {...Astro.props} userId={userId}>
		<slot name="extra-head" slot="extra-head" />
	</DefaultHead>

	<body class={css({ h: 'full', w: 'full', mx: 'auto', maxW: '8xl', color: { base: 'gray.900', _dark: 'gray.100' } })}>
		<slot name="layout">
			<DefaultLayout>
				<slot />
			</DefaultLayout>
		</slot>

	</body>
	<style is:global>
		:root {
			color-scheme: light dark;
		}

		h1,
		h2,
		h3 {
			margin-top: 2rem;
			margin-bottom: 1rem;
		}
	</style>


</html>
