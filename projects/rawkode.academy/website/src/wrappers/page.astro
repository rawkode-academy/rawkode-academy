---
import DefaultHead from "@/components/html/head.astro";
import DefaultLayout from "@/layouts/app.astro";
import type { OpenGraphProps } from "@/types/opengraph";
import "@/styles/global.css";
import { css } from "../../styled-system/css";

interface Props extends OpenGraphProps {}

const userId = Astro.locals.user?.id;

const htmlClass = css({ scrollBehavior: "smooth", color: "fg.primary", bg: "bg.canvas" });
const bodyClass = css({
	minH: "100vh",
	w: "full",
	mx: "auto",
	maxWidth: "120rem",
	color: "fg.primary",
	bg: "bg.canvas",
	fontFamily: "body",
	"& h1, & h2, & h3": { mt: "8", mb: "4" },
});
---

<html lang="en" class={htmlClass}>
	<DefaultHead {...Astro.props} userId={userId}>
		<slot name="extra-head" slot="extra-head" />
	</DefaultHead>

	<body class={bodyClass}>
		<slot name="layout">
			<DefaultLayout>
				<slot />
			</DefaultLayout>
		</slot>
	</body>
</html>
