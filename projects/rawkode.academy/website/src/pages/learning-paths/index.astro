---
import { css } from "../../../../styled-system/css";
import { getCollection } from "astro:content";
import LearningPathCard from "@/components/learning-paths/LearningPathCard.astro";
import Page from "@/wrappers/page.astro";

export const prerender = true;

const learningPaths = (await getCollection("learningPaths")).sort(
	(a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);

const pageTitle = "Learning Paths | Rawkode Academy";
const pageDescription =
	"Curated, video-driven journeys to help you level up your Kubernetes, platform engineering, and cloud native skills.";
---

<Page title={pageTitle} description={pageDescription}>
	<section class={css({
	pos: 'relative',
	overflow: 'hidden',
	rounded: '3xl',
	borderWidth: '1px',
	borderColor: 'gray.200',
	bg: 'white',
}) + " dark:border-gray-800 dark:bg-gray-900"}>
		<div class={css({
	pos: 'absolute',
	inset: '0',
	bgGradient: 'to-br',
	gradientFrom: 'primary/10',
	gradientVia: 'transparent',
	gradientTo: 'secondary/20',
}) + " dark:from-primary/20 dark:to-secondary/30"}></div>
		<div class={css({
	pos: 'relative',
	zIndex: '10',
	px: '6',
	py: '16',
	md: {
		px: '10',
	},
	lg: {
		px: '16',
	},
})}>
			<div class={css({
	maxW: '3xl',
})}>
				<p class={css({
	fontSize: 'sm',
	fontWeight: 'semibold',
	textTransform: 'uppercase',
	letterSpacing: '0.3em',
	mb: '4',
}) + " text-primary"}>
					Guided Learning
				</p>
				<h1 class={css({
	fontSize: '3xl',
	md: {
		fontSize: '4xl',
	},
	fontWeight: 'extrabold',
	letterSpacing: 'tight',
	mb: '4',
}) + " text-primary-content"}>
					Learning Paths
				</h1>
				<p class={css({
	fontSize: 'lg',
	lineHeight: 'relaxed',
}) + " text-muted"}>
					Each path bundles Rawkode Academy videos into a focused curriculum with clear outcomes, prerequisites, and the context you need to succeed. Start with the challenge you're facing and follow along step-by-step.
				</p>
			</div>
		</div>
	</section>

	<section class={css({
	mt: '12',
})}>
		<div class={css({
	display: 'grid',
	gap: '6',
	sm: {
		gridTemplateColumns: '2',
	},
	xl: {
		gridTemplateColumns: '3',
	},
})}>
			{learningPaths.map((learningPath) => (
				<LearningPathCard learningPath={learningPath} />
			))}
		</div>
	</section>
</Page>
