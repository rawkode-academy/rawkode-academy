---
import { getCollection, getEntries } from "astro:content";
import LearningPathItemListJsonLd from "@/components/html/learning-path-itemlist-jsonld.astro";
import Page from "@/wrappers/page.astro";

import PathsMasthead from "@/components/learning-paths/PathsMasthead.astro";
import PathsLede from "@/components/learning-paths/PathsLede.astro";
import PathCard from "@/components/learning-paths/PathCard.astro";
import FilterRail from "@/components/read/FilterRail.astro";
import MLabel from "@/components/ui/MLabel.vue";

export const prerender = true;

const learningPaths = (await getCollection("learningPaths")).sort(
	(a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);

const allTechnologies = await getCollection("technologies");
const technologyNameById = new Map<string, string>();
for (const technology of allTechnologies) {
	const rawId = technology.id.replace(/\/index$/, "");
	technologyNameById.set(rawId, technology.data.name);
}

const itemListPaths = await Promise.all(
	learningPaths.map(async (path) => {
		const authorEntries = await getEntries(path.data.authors);
		return {
			path,
			authors: authorEntries.map((author) => ({
				id: author.data.id,
				name: author.data.name,
			})),
			technologyLabels: (path.data.technologies ?? []).map(
				(technologyId) => technologyNameById.get(technologyId) ?? technologyId,
			),
		};
	}),
);

// Level counts
const levelCounts = new Map<string, number>();
for (const p of learningPaths) {
	const k = (p.data.difficulty || "beginner").toLowerCase();
	levelCounts.set(k, (levelCounts.get(k) ?? 0) + 1);
}

const levelTopics = [
	{ label: "All", count: learningPaths.length, href: "/learning-paths" },
	...Array.from(levelCounts.entries())
		.sort((a, b) => b[1] - a[1])
		.map(([id, count]) => ({
			label: id.toUpperCase(),
			count,
			href: `/learning-paths?level=${encodeURIComponent(id)}`,
		})),
];

// Lesson counts aren't on the learningPaths schema; approximate by
// counting H2 headings in the body. Good enough for masthead totals.
function lessonCount(p: (typeof learningPaths)[number]): number {
	const body = p.body ?? "";
	const matches = body.match(/^##\s+/gm);
	return matches?.length ?? 0;
}

function formatHours(minutes?: number): string | undefined {
	if (!minutes) return undefined;
	const h = Math.round(minutes / 60);
	return `${h}`;
}

const allLessons = learningPaths.reduce((acc, p) => acc + lessonCount(p), 0);

const [featured, ...rest] = learningPaths;

const pageTitle = "Learning Paths — curriculum, not chaos";
const pageDescription =
	"Curated, video-driven journeys to help you level up your Kubernetes, platform engineering, and cloud native skills.";
---

<Page title={pageTitle} description={pageDescription} pageType="CollectionPage">
	<LearningPathItemListJsonLd
		slot="extra-head"
		paths={itemListPaths}
		listUrl={new URL("/learning-paths", Astro.site ?? Astro.url).href}
		listName="Rawkode Academy Learning Paths"
	/>

	<div class="paths-page">
		<PathsMasthead
			pathCount={learningPaths.length}
			lessonCount={allLessons || undefined}
		/>

		<PathsLede />

		{featured && (
			<section class="paths-page__featured">
				<div class="paths-page__featured-head">
					<MLabel tone="spruce">§01 · Featured path</MLabel>
					<MLabel>Most recent</MLabel>
				</div>
				<PathCard
					big
					href={`/learning-paths/${featured.id}`}
					title={featured.data.title}
					description={featured.data.description}
					level={featured.data.difficulty}
					hours={formatHours(featured.data.estimatedDuration)}
					lessons={lessonCount(featured) || undefined}
				/>
			</section>
		)}

		<FilterRail topics={levelTopics} activeIndex={0} sortLabel="Recommended ↓" />

		<div class="paths-page__grid">
			{rest.map((path) => (
				<PathCard
					href={`/learning-paths/${path.id}`}
					title={path.data.title}
					description={path.data.description}
					level={path.data.difficulty}
					hours={formatHours(path.data.estimatedDuration)}
					lessons={lessonCount(path) || undefined}
				/>
			))}
		</div>

		<footer class="paths-page__footer">
			<MLabel>
				{learningPaths.length} paths · {allLessons.toLocaleString()} lessons total
			</MLabel>
			<MLabel tone="ink">Suggest a path · Roadmap →</MLabel>
		</footer>
	</div>
</Page>

<style>
	.paths-page {
		background: var(--editorial-paper);
		color: var(--editorial-ink);
	}

	.paths-page__featured {
		padding: 2.5rem 2.5rem 1.75rem;
		border-bottom: 1px solid var(--editorial-hairline);
	}

	.paths-page__featured-head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		margin-bottom: 1.125rem;
	}

	.paths-page__grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.75rem;
		padding: 2rem 2.5rem 3rem;
	}

	.paths-page__footer {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1.5rem;
		padding: 1.5rem 2.5rem;
		border-top: 1px solid var(--editorial-ink);
		background: var(--editorial-paper-deep);
	}

	@media (max-width: 880px) {
		.paths-page__featured,
		.paths-page__grid,
		.paths-page__footer {
			padding-left: 1.25rem;
			padding-right: 1.25rem;
		}
		.paths-page__grid {
			grid-template-columns: 1fr;
		}
		.paths-page__footer {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
