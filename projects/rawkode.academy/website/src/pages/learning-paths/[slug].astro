---
import {
	type CollectionEntry,
	getCollection,
	getEntries,
	render,
} from "astro:content";
import type { GetStaticPaths, GetStaticPathsResult } from "astro";
import Page from "@/wrappers/page.astro";
import ArticleHeader from "@/components/read/ArticleHeader.astro";
import ArticleByline from "@/components/read/ArticleByline.astro";
import EditorialButton from "@/components/ui/EditorialButton.vue";
import MLabel from "@/components/ui/MLabel.vue";
import NewsletterCTA from "@/components/newsletter/NewsletterCTA.astro";
import LearningPathJsonLd from "@/components/html/learning-path-jsonld.astro";

export const prerender = true;

type Props = {
	learningPath: CollectionEntry<"learningPaths">;
};

export const getStaticPaths: GetStaticPaths =
	async (): Promise<GetStaticPathsResult> => {
		const learningPaths = await getCollection("learningPaths");

		return learningPaths.map((learningPath) => ({
			params: {
				slug: learningPath.id,
			},
			props: {
				learningPath,
			},
		}));
	};

const { learningPath } = Astro.props;
const { Content, headings } = await render(learningPath);
const authors = await getEntries(learningPath.data.authors);

const allTechnologies = await getCollection("technologies");
const technologyNameById = new Map<string, string>();
for (const technology of allTechnologies) {
	const rawId = technology.id.replace(/\/index$/, "");
	technologyNameById.set(rawId, technology.data.name);
}
const technologyLabels = (learningPath.data.technologies ?? []).map(
	(technologyId) => technologyNameById.get(technologyId) ?? technologyId,
);
const technologyTags = (learningPath.data.technologies ?? []).map(
	(technologyId) => ({
		id: technologyId,
		label: technologyNameById.get(technologyId) ?? technologyId,
	}),
);

function formatDuration(minutes: number): string {
	if (!minutes) {
		return "Self-paced";
	}
	const hours = Math.floor(minutes / 60);
	const mins = minutes % 60;
	if (!hours) return `${mins}m`;
	if (!mins) return `${hours}h`;
	return `${hours}h ${mins}m`;
}

const durationLabel = formatDuration(learningPath.data.estimatedDuration);
const outline = headings.filter((heading) => heading.depth === 2);
const prerequisites = learningPath.data.prerequisites ?? [];

// Dispatch number — position in chronological corpus of paths.
const corpus = (await getCollection("learningPaths")).sort(
	(a, b) => a.data.publishedAt.valueOf() - b.data.publishedAt.valueOf(),
);
const dispatchIndex = corpus.findIndex((p) => p.id === learningPath.id);
const dispatchNum = String(
	dispatchIndex >= 0 ? dispatchIndex + 1 : corpus.length,
).padStart(3, "0");

const difficultyLabel =
	learningPath.data.difficulty.charAt(0).toUpperCase() +
	learningPath.data.difficulty.slice(1);

const publishDate = new Intl.DateTimeFormat("en-US", {
	month: "short",
	day: "numeric",
	year: "numeric",
}).format(learningPath.data.publishedAt);

const pageTitle = `${learningPath.data.title} | Learning Path`;
const pageDescription = learningPath.data.description;
---

<Page
	title={pageTitle}
	description={pageDescription}
	publishedAt={learningPath.data.publishedAt}
	authors={authors}
>
	<LearningPathJsonLd
		slot="extra-head"
		learningPath={learningPath}
		authors={authors}
		technologyLabels={technologyLabels}
	/>

	<div class="path-detail">
		<ArticleHeader
			breadcrumbs={[
				{ label: "Learning Paths", href: "/learning-paths" },
				{ label: difficultyLabel },
				{ label: learningPath.data.title, current: true },
			]}
			dispatchNum={dispatchNum}
			kicker="Learning path"
			categoryTrail={difficultyLabel}
			title={learningPath.data.title}
			dek={learningPath.data.description}
			readingTime={durationLabel}
		>
			<ArticleByline
				authors={authors}
				date={publishDate}
				readingTime={durationLabel}
				tags={technologyTags.map((t) => ({
					label: t.label,
					href: `/technology/${t.id}`,
				}))}
			/>
		</ArticleHeader>

		<section class="path-detail__stat-row">
			<div class="path-detail__stat">
				<MLabel>Difficulty</MLabel>
				<span class="path-detail__stat-value">{difficultyLabel}</span>
			</div>
			<div class="path-detail__stat">
				<MLabel>Estimated time</MLabel>
				<span class="path-detail__stat-value">{durationLabel}</span>
			</div>
			<div class="path-detail__stat">
				<MLabel>Modules</MLabel>
				<span class="path-detail__stat-value">
					{outline.length || "—"}
				</span>
			</div>
			<div class="path-detail__stat">
				<MLabel>Pace</MLabel>
				<span class="path-detail__stat-value">Self-paced</span>
			</div>
		</section>

		<section class="path-detail__body">
			<article class="prose">
				<Content />
			</article>

			<aside class="path-detail__aside">
				{outline.length > 0 && (
					<div class="path-detail__panel">
						<MLabel tone="spruce">§ Curriculum</MLabel>
						<ol class="path-detail__outline">
							{outline.map((heading, index) => (
								<li class="path-detail__outline-row">
									<MLabel tone="muted">
										§{String(index + 1).padStart(2, "0")}
									</MLabel>
									<a
										class="path-detail__outline-link"
										href={`#${heading.slug}`}
									>
										{heading.text}
									</a>
								</li>
							))}
						</ol>
					</div>
				)}

				{prerequisites.length > 0 && (
					<div class="path-detail__panel">
						<MLabel tone="spruce">§ Prerequisites</MLabel>
						<ul class="path-detail__prereqs">
							{prerequisites.map((item) => (
								<li class="path-detail__prereq">
									<span aria-hidden="true">▸</span>
									<span>{item}</span>
								</li>
							))}
						</ul>
					</div>
				)}

				{technologyTags.length > 0 && (
					<div class="path-detail__panel">
						<MLabel tone="spruce">§ Technologies covered</MLabel>
						<div class="path-detail__chips">
							{technologyTags.map((technology) => (
								<a
									class="path-detail__chip"
									href={`/technology/${technology.id}`}
									rel="tag"
								>
									#{technology.label}
								</a>
							))}
						</div>
					</div>
				)}
			</aside>
		</section>

		<NewsletterCTA
			class="not-prose"
			audience="learning-paths"
			badge="New paths weekly"
			headline="Get notified when we ship new learning paths"
			subtitle="Structured roadmaps for cloud native, AI infra, and platform engineering, delivered when they're ready."
		/>

		<footer class="path-detail__footer">
			<div class="path-detail__footer-text">
				<MLabel tone="spruce">§ Keep going</MLabel>
				<h2 class="path-detail__footer-title">Pick another path.</h2>
				<p class="path-detail__footer-body">
					Browse the rest of the curriculum, or jump back into the video archive.
				</p>
			</div>
			<div class="path-detail__footer-actions">
				<EditorialButton variant="solid" size="md" href="/learning-paths" arrow>
					Browse paths
				</EditorialButton>
				<EditorialButton variant="outline" size="md" href="/watch">
					Watch the archive
				</EditorialButton>
			</div>
		</footer>
	</div>
</Page>

<style>
	.path-detail {
		background: var(--editorial-paper);
		color: var(--editorial-ink);
	}

	.path-detail__stat-row {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1.5rem;
		padding: 1.75rem 2.5rem;
		border-bottom: 1px solid var(--editorial-hairline);
		background: var(--editorial-paper-deep);
	}

	.path-detail__stat {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
		padding-right: 1.5rem;
		border-right: 1px solid var(--editorial-hairline);
	}
	.path-detail__stat:last-child {
		border-right: none;
	}

	.path-detail__stat-value {
		font-family: var(--font-instrument-serif), serif;
		font-style: italic;
		font-size: 1.875rem;
		line-height: 1;
		color: var(--editorial-ink);
	}

	.path-detail__body {
		display: grid;
		grid-template-columns: minmax(0, 3fr) minmax(0, 1.1fr);
		gap: 3rem;
		padding: 3rem 2.5rem 3rem;
		max-width: 90rem;
		margin: 0 auto;
		align-items: start;
	}

	.path-detail__body :global(.prose) {
		max-width: none;
	}

	.path-detail__aside {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		position: sticky;
		top: 6rem;
	}

	.path-detail__panel {
		background: var(--editorial-paper-deep);
		border: 1px solid var(--editorial-hairline);
		padding: 1.25rem 1.25rem 1.4rem;
		display: flex;
		flex-direction: column;
		gap: 0.875rem;
	}

	.path-detail__outline {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
	}

	.path-detail__outline-row {
		display: grid;
		grid-template-columns: 2.5rem 1fr;
		gap: 0.5rem;
		padding: 0.55rem 0;
		border-top: 1px solid var(--editorial-hairline);
		align-items: baseline;
	}
	.path-detail__outline-row:first-child {
		border-top: none;
	}

	.path-detail__outline-link {
		font-family: var(--font-inter-tight), sans-serif;
		font-size: 0.875rem;
		line-height: 1.35;
		color: var(--editorial-ink);
		text-decoration: none;
		transition: color var(--duration-base) var(--ease-standard);
	}
	.path-detail__outline-link:hover {
		color: var(--editorial-spruce);
	}

	.path-detail__prereqs {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.path-detail__prereq {
		display: grid;
		grid-template-columns: 1rem 1fr;
		gap: 0.5rem;
		font-family: var(--font-inter-tight), sans-serif;
		font-size: 0.85rem;
		line-height: 1.45;
		color: var(--editorial-ink-soft);
	}
	.path-detail__prereq > span:first-child {
		color: var(--editorial-spruce);
	}

	.path-detail__chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}

	.path-detail__chip {
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 0.6875rem;
		font-weight: 500;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		padding: 0.25rem 0.5rem;
		color: var(--editorial-ink-soft);
		border: 1px solid var(--editorial-hairline-strong);
		border-radius: 2px;
		text-decoration: none;
		transition: color var(--duration-base) var(--ease-standard),
			border-color var(--duration-base) var(--ease-standard);
	}
	.path-detail__chip:hover {
		color: var(--editorial-ink);
		border-color: var(--editorial-ink);
	}

	.path-detail__footer {
		display: grid;
		grid-template-columns: minmax(0, 1.4fr) auto;
		gap: 2rem;
		align-items: end;
		padding: 2.5rem 2.5rem 3rem;
		border-top: 1px solid var(--editorial-ink);
		background: var(--editorial-paper-deep);
	}

	.path-detail__footer-text {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.path-detail__footer-title {
		font-family: var(--font-instrument-serif), serif;
		font-style: italic;
		font-weight: 400;
		font-size: clamp(1.75rem, 3vw, 2.5rem);
		line-height: 1;
		letter-spacing: -0.02em;
		color: var(--editorial-ink);
		margin: 0;
	}

	.path-detail__footer-body {
		font-family: var(--font-inter-tight), sans-serif;
		font-size: 1rem;
		line-height: 1.45;
		color: var(--editorial-ink-soft);
		margin: 0;
		max-width: 36rem;
	}

	.path-detail__footer-actions {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	@media (max-width: 880px) {
		.path-detail__stat-row {
			grid-template-columns: repeat(2, 1fr);
			padding: 1.25rem 1.25rem;
		}
		.path-detail__stat {
			border-right: none;
			padding-right: 0;
		}
		.path-detail__body {
			grid-template-columns: 1fr;
			padding: 2rem 1.25rem;
			gap: 2rem;
		}
		.path-detail__aside { position: static; }
		.path-detail__footer {
			grid-template-columns: 1fr;
			padding: 2rem 1.25rem;
		}
	}
</style>
