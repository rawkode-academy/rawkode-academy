---
import { Image, getImage } from "astro:assets";
import { type CollectionEntry, getCollection, getEntries, render } from "astro:content";
import CourseJsonLd from "@/components/html/course-jsonld.astro";
import Prose from "@/components/prose/Prose.astro";
import { getCourseModuleSlug } from "@/utils/course-path";
import Page from "@/wrappers/page.astro";
import type { GetStaticPaths, GetStaticPathsResult } from "astro";
import { css } from "../../../styled-system/css";

export const prerender = true;

type Props = { course: CollectionEntry<"courses"> };

const computeImageUrl = async (course: CollectionEntry<"courses">): Promise<URL | undefined> => {
	if (course.data.cover) {
		const image = await getImage({ src: course.data.cover.image });
		return new URL(image.src, Astro.site);
	}
	return undefined;
};

export const getStaticPaths: GetStaticPaths = async (): Promise<GetStaticPathsResult> => {
	const courses = await getCollection("courses");
	return courses.map((course) => ({ params: { slug: course.id }, props: { course } }));
};

const { course } = Astro.props;
const { Content } = await render(course);
const authors = await getEntries(course.data.authors);

const allCourseModules = (await getCollection("courseModules"))
	.filter((m) => m.data.course.id === course.id)
	.sort((a, b) => a.data.order - b.data.order);

const totalModules = allCourseModules.length;
const availableModuleCount = allCourseModules.filter((m) => !m.data.draft).length;
const totalDuration = allCourseModules.filter((m) => !m.data.draft).reduce((acc, m) => acc + (m.data.duration || 0), 0);

const formatDuration = (m: number) => {
	if (!m) return "Self-paced";
	const h = Math.floor(m / 60);
	const r = m % 60;
	return !h ? `${r}m` : !r ? `${h}h` : `${h}h ${r}m`;
};

const imageUrl = await computeImageUrl(course);

const getResourceHref = (resource: NonNullable<typeof course.data.resources>[number]) => {
	if (resource.type === "url") return resource.url;
	if (resource.type === "file" && resource.filePath) return `/resources/${resource.filePath}`;
	return undefined;
};

const shell = css({ maxWidth: "80rem", mx: "auto", px: { base: "4", md: "6" }, py: "10" });

const heroCard = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", lg: "1.4fr 1fr" },
	gap: { base: "6", md: "10" },
	alignItems: "stretch",
	p: { base: "5", md: "5" },
	borderRadius: "3xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	overflow: "hidden",
	backgroundImage:
		"radial-gradient(circle at 20% 20%, rgba(95, 94, 215, 0.10), transparent 55%), radial-gradient(circle at 80% 30%, rgba(0, 206, 255, 0.10), transparent 55%)",
	_dark: {
		backgroundImage:
			"radial-gradient(circle at 20% 20%, rgba(95, 94, 215, 0.18), transparent 55%), radial-gradient(circle at 80% 30%, rgba(0, 206, 255, 0.15), transparent 55%)",
	},
});

const heroBody = css({ display: "flex", flexDirection: "column", justifyContent: "center", p: { base: "2", md: "6" } });

const heroMedia = css({
	overflow: "hidden",
	borderRadius: "2xl",
	bg: "bg.sunken",
	boxShadow: "lg",
	minHeight: { lg: "20rem" },
	display: "flex",
	"& img": { width: "full", height: "full", objectFit: "cover" },
});

const heroMediaFallback = css({
	width: "full",
	minHeight: "16rem",
	display: "flex",
	alignItems: "center",
	justifyContent: "center",
	color: "fg.brand",
	fontSize: "8xl",
	fontFamily: "display",
	fontWeight: "bold",
	backgroundImage: "linear-gradient(135deg, rgba(95, 94, 215, 0.15), rgba(0, 206, 255, 0.15))",
});

const heroFlagRow = css({ display: "inline-flex", gap: "2", mb: "4", flexWrap: "wrap" });

const freePill = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "1.5",
	px: "3",
	py: "1",
	borderRadius: "full",
	fontSize: "xs",
	fontWeight: "bold",
	letterSpacing: "wider",
	textTransform: "uppercase",
	color: "fg.on-brand",
	backgroundImage: "linear-gradient(135deg, token(colors.brand.500), token(colors.cyan.500))",
});

const progressTrack = css({
	mt: "8",
	height: "8px",
	bg: "bg.sunken",
	borderRadius: "full",
	overflow: "hidden",
});

const progressFill = css({
	height: "full",
	backgroundImage: "linear-gradient(90deg, token(colors.brand.500), token(colors.cyan.500))",
	borderRadius: "full",
	transition: "width 400ms ease",
});

const progressMeta = css({
	mt: "3",
	display: "flex",
	justifyContent: "space-between",
	fontSize: "xs",
	fontWeight: "semibold",
	color: "fg.muted",
	letterSpacing: "wider",
	textTransform: "uppercase",
});

const instructorRow = css({
	mt: "8",
	display: "flex",
	alignItems: "center",
	gap: "3",
	fontSize: "sm",
	color: "fg.muted",
});

const avatarSm = css({ width: "10", height: "10", borderRadius: "full", objectFit: "cover", borderWidth: "1px", borderColor: "border.muted" });

const ctaRow = css({ mt: "6", display: "flex", flexWrap: "wrap", gap: "3" });

const ctaPrimary = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "6",
	py: "3",
	borderRadius: "lg",
	fontWeight: "semibold",
	color: "fg.on-brand",
	backgroundImage: "linear-gradient(135deg, token(colors.brand.500), token(colors.cyan.500))",
	textDecoration: "none",
	boxShadow: "md",
	transition: "transform 150ms ease",
	_hover: { transform: "translateY(-1px)" },
});

const ctaSecondary = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "6",
	py: "3",
	borderRadius: "lg",
	fontWeight: "semibold",
	color: "fg.primary",
	bg: "bg.surface",
	borderWidth: "1px",
	borderColor: "border.default",
	textDecoration: "none",
	_hover: { bg: "bg.sunken" },
});

const eyebrow = css({
	display: "inline-flex",
	px: "3",
	py: "1",
	borderRadius: "full",
	bg: "bg.brand-subtle",
	color: "fg.brand",
	fontSize: "xs",
	fontWeight: "semibold",
	letterSpacing: "wider",
	textTransform: "uppercase",
	mb: "4",
});

const title = css({
	fontFamily: "display",
	fontSize: { base: "3xl", md: "5xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	lineHeight: "1.1",
	color: "fg.primary",
	textWrap: "balance",
});

const desc = css({ mt: "5", fontSize: { base: "md", md: "lg" }, color: "fg.secondary", lineHeight: "1.7", maxWidth: "44rem" });

const layout = css({
	mt: "12",
	display: "grid",
	gap: "10",
	gridTemplateColumns: { base: "1fr", xl: "1fr 20rem" },
	alignItems: "start",
});

const sectionTitle = css({
	fontFamily: "display",
	fontSize: { base: "2xl", md: "3xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	color: "fg.primary",
	mb: "4",
});

const sectionEyebrow = css({
	fontSize: "xs",
	fontWeight: "bold",
	letterSpacing: "wider",
	textTransform: "uppercase",
	color: "fg.brand",
});

const sectionCard = css({
	p: { base: "6", md: "8" },
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	mb: "8",
});

const moduleList = css({ display: "flex", flexDirection: "column", gap: "3" });

const moduleRow = css({
	display: "flex",
	gap: "4",
	alignItems: "center",
	p: "4",
	borderRadius: "xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.canvas",
	textDecoration: "none",
	color: "fg.primary",
	transition: "transform 200ms ease, border-color 200ms ease",
	_hover: { transform: "translateX(4px)", borderColor: "border.default" },
});

const moduleNum = css({
	display: "inline-flex",
	alignItems: "center",
	justifyContent: "center",
	w: "10",
	h: "10",
	borderRadius: "full",
	bg: "bg.brand-subtle",
	color: "fg.brand",
	fontWeight: "bold",
	fontSize: "sm",
});

const moduleInfo = css({ display: "flex", flexDirection: "column", gap: "1", flex: "1" });
const moduleTitle = css({ fontWeight: "semibold", color: "fg.primary" });
const moduleMeta = css({ fontSize: "xs", color: "fg.muted" });

const draftBadge = css({
	display: "inline-flex",
	px: "2",
	py: "0.5",
	borderRadius: "md",
	fontSize: "xs",
	fontWeight: "semibold",
	color: "fg.muted",
	bg: "bg.sunken",
});

const aside = css({ display: "flex", flexDirection: "column", gap: "5" });

const resourceItem = css({
	display: "flex",
	justifyContent: "space-between",
	gap: "3",
	py: "3",
	borderBottomWidth: "1px",
	borderBottomColor: "border.muted",
	_last: { borderBottomWidth: "0" },
});

const resourceTitle = css({ fontWeight: "semibold", color: "fg.primary", fontSize: "sm" });
const resourceDesc = css({ fontSize: "xs", color: "fg.muted", mt: "1" });

const externalLink = css({
	color: "fg.brand",
	flexShrink: 0,
	_hover: { color: "fg.brand" },
});
---

<Page
	title={course.data.title}
	description={course.data.description}
	image={imageUrl ? { image: imageUrl, text: course.data.title, format: "png" as const } : undefined}
	publishedAt={course.data.publishedAt}
	updatedAt={course.data.updatedAt}
	authors={authors}
>
	{imageUrl && (
		<CourseJsonLd slot="extra-head" course={course} modules={allCourseModules} authors={authors} />
	)}

	<div class={shell}>
		<div class:list={[heroCard, "hero-aurora"]}>
			<div class={heroBody}>
				<div class={heroFlagRow}>
					<span class={eyebrow}>Course · {course.data.difficulty.charAt(0).toUpperCase()}{course.data.difficulty.slice(1)}</span>
					<span class={freePill}>
						<svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
						Free &amp; Open
					</span>
				</div>
				<h1 class={title}>{course.data.title}</h1>
				<p class={desc}>{course.data.description}</p>
				{totalModules > 0 && (
					<>
						<div class={progressTrack} aria-hidden="true">
							<div class={progressFill} style={`width: ${Math.round((availableModuleCount / totalModules) * 100)}%;`}></div>
						</div>
						<div class={progressMeta}>
							<span>{availableModuleCount} of {totalModules} modules live</span>
							<span>{formatDuration(totalDuration)}</span>
						</div>
					</>
				)}
				{authors[0] && (
					<div class={instructorRow}>
						{authors[0].data.avatarUrl && <img src={authors[0].data.avatarUrl} alt="" class={avatarSm} loading="lazy" />}
						<div>
							<div style="font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--colors-fg-muted);">Instructor</div>
							<div style="font-weight: 600; color: var(--colors-fg-primary);">{authors.map((a) => a.data.name).join(", ")}</div>
						</div>
					</div>
				)}
				<div class={ctaRow}>
					{allCourseModules.filter((m) => !m.data.draft)[0] && (
						<a href={`/courses/${getCourseModuleSlug(course.id, allCourseModules.filter((m) => !m.data.draft)[0]!.id)}`} class={ctaPrimary}>
							Start learning
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 5l7 7-7 7"/></svg>
						</a>
					)}
					<a href="#course-content" class={ctaSecondary}>See curriculum</a>
				</div>
			</div>
			{course.data.cover ? (
				<div class={heroMedia}>
					<Image src={course.data.cover.image} alt={course.data.cover.alt || course.data.title} width={800} height={600} loading="eager" />
				</div>
			) : (
				<div class={heroMedia}>
					<div class={heroMediaFallback}>{course.data.title.charAt(0)}</div>
				</div>
			)}
		</div>

		<section class={layout}>
			<div>
				<div class={sectionCard}>
					<span class={sectionEyebrow}>Course Overview</span>
					<h2 class={sectionTitle} style="margin-top: 0.5rem;">What this course covers</h2>
					<Prose>
						<Content />
					</Prose>
				</div>

				<div class={sectionCard} id="course-content">
					<span class={sectionEyebrow}>Curriculum</span>
					<h2 class={sectionTitle} style="margin-top: 0.5rem;">Course content</h2>
					<div class={moduleList}>
						{allCourseModules.map((module, idx) => (
							module.data.draft ? (
								<div class={moduleRow} style="opacity: 0.6;">
									<span class={moduleNum}>{idx + 1}</span>
									<div class={moduleInfo}>
										<span class={moduleTitle}>{module.data.title}</span>
										{module.data.description && <span class={moduleMeta}>{module.data.description}</span>}
									</div>
									<span class={draftBadge}>Coming soon</span>
								</div>
							) : (
								<a href={`/courses/${getCourseModuleSlug(course.id, module.id)}`} class={moduleRow}>
									<span class={moduleNum}>{idx + 1}</span>
									<div class={moduleInfo}>
										<span class={moduleTitle}>{module.data.title}</span>
										<span class={moduleMeta}>
											{module.data.duration ? formatDuration(module.data.duration) : ""}
											{module.data.description && ` · ${module.data.description}`}
										</span>
									</div>
								</a>
							)
						))}
					</div>
				</div>
			</div>

			{course.data.resources && course.data.resources.length > 0 && (
				<aside class={aside}>
					<div class={sectionCard}>
						<span class={sectionEyebrow}>Course Resources</span>
						<h2 class={sectionTitle} style="margin-top: 0.5rem; font-size: 1.25rem;">Reference Material</h2>
						<div>
							{course.data.resources.map((resource) => {
								const href = getResourceHref(resource);
								return (
									<div class={resourceItem}>
										<div>
											<div class={resourceTitle}>{resource.title}</div>
											{resource.description && <div class={resourceDesc}>{resource.description}</div>}
										</div>
										{href && (
											<a href={href} target={resource.type === "url" ? "_blank" : undefined} rel={resource.type === "url" ? "noopener noreferrer" : undefined} class={externalLink} aria-label={`Open ${resource.title}`}>
												<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
											</a>
										)}
									</div>
								);
							})}
						</div>
					</div>
				</aside>
			)}
		</section>
	</div>
</Page>
