---
import { getImage } from "astro:assets";
import { type CollectionEntry, getCollection, render } from "astro:content";
import { dirname, join } from "node:path";
import Breadcrumb from "@/components/breadcrumb/Breadcrumb.astro";
import CourseSignupForm from "@/components/courses/CourseSignupForm.astro";
import ResourceList from "@/components/courses/ResourceList.vue";
import VideoPlayer from "@/components/video/player.vue";
import Page from "@/wrappers/page.astro";
import { createLogger } from "@/lib/logger";
import { getCourseModuleSlug } from "@/utils/course-path";
import { loadWebContainerFiles } from "@/utils/webcontainer-loader";
import type { GetStaticPaths } from "astro";

export const prerender = true;

const logger = createLogger("courses");

type Props = {
	module: CollectionEntry<"courseModules">;
	course: CollectionEntry<"courses">;
};

export const getStaticPaths: GetStaticPaths = async () => {
	const courses = await getCollection("courses");
	const modules = await getCollection("courseModules");

	return modules.map((module) => {
		const course = courses.find((entry) => entry.id === module.data.course.id);
		if (!course) {
			throw new Error(`Course not found for module: ${module.id}`);
		}

		return {
			params: {
				course: course.id,
				slug: getCourseModuleSlug(course.id, module.id),
			},
			props: {
				module,
				course,
			},
		};
	});
};

const computeImageUrl = async (module: CollectionEntry<"courseModules">) => {
	if (!module.data.cover) return null;
	return (
		await getImage({
			src: module.data.cover.image,
			format: "jpeg",
		})
	).src;
};

const { module, course } = Astro.props;

if (module.data.draft) {
	return Astro.redirect("/404");
}

const { Content } = await render(module);

const allResources = [
	...(course.data.resources || []),
	...(module.data.resources || []),
];

const processedResources = await Promise.all(
	allResources.map(async (resource) => {
		if (
			resource.type === "embed" &&
			resource.embedConfig?.container === "webcontainer" &&
			resource.embedConfig.import?.localDir
		) {
			const moduleFilePath = join(
				process.cwd(),
				"content",
				"courses",
				`${module.id}.mdx`,
			);
			const moduleDir = dirname(moduleFilePath);
			const importPath = join(moduleDir, resource.embedConfig.import.localDir);

			try {
				const importedFiles = await loadWebContainerFiles(importPath);
				return {
					...resource,
					embedConfig: {
						...resource.embedConfig,
						files: { ...importedFiles, ...(resource.embedConfig.files || {}) },
					},
				};
			} catch (error) {
				logger.error(`Failed to load files for ${resource.title}`, error);
				return resource;
			}
		}

		return resource;
	}),
);

const dedupedResources = Array.from(
	new Map(
		processedResources.map((resource) => {
			const key = [
				resource.type,
				resource.title,
				resource.url || "",
				resource.filePath || "",
				resource.embedConfig?.src || "",
			].join("::");

			return [key, resource];
		}),
	).values(),
);

const imageUrl = await computeImageUrl(module);
const moduleSlug = getCourseModuleSlug(course.id, module.id);

const breadcrumbElements = [
	{ title: "Home", link: "/" },
	{ title: "Courses", link: "/courses" },
	{ title: course.data.title, link: `/courses/${course.id}` },
	{
		title: module.data.title,
		link: `/courses/${course.id}/${moduleSlug}`,
	},
];

const allCourseModules = (await getCollection("courseModules"))
	.filter((entry) => entry.data.course.id === course.id)
	.filter((entry) => !entry.data.draft)
	.sort((a, b) => a.data.order - b.data.order);

const currentIndex = allCourseModules.findIndex(
	(entry) => entry.id === module.id,
);
const previousModule =
	currentIndex > 0 ? allCourseModules[currentIndex - 1] : null;
const nextModule =
	currentIndex >= 0 && currentIndex < allCourseModules.length - 1
		? allCourseModules[currentIndex + 1]
		: null;

function moduleHref(entry: CollectionEntry<"courseModules">) {
	return `/courses/${course.id}/${getCourseModuleSlug(course.id, entry.id)}`;
}

function formatDuration(minutes?: number) {
	if (!minutes || minutes <= 0) return null;

	const hours = Math.floor(minutes / 60);
	const mins = minutes % 60;

	if (hours > 0 && mins > 0) return `${hours}h ${mins}m`;
	if (hours > 0) return `${hours}h`;
	return `${mins}m`;
}
---

<Page
	title={`${module.data.title} - ${course.data.title}`}
	description={module.data.description}
	image={imageUrl
		? {
				image: imageUrl.startsWith("http")
					? new URL(imageUrl)
					: new URL(imageUrl, Astro.site || "https://rawkode.academy"),
				text: module.data.title,
				format: "png" as const,
			}
		: undefined}
>
	<section class="page-px section-py-tight">
		<div class="mx-auto max-w-7xl space-y-6">
			<Breadcrumb elements={breadcrumbElements} />

			<header class="border-b border-black/10 pb-8 dark:border-white/10">
				<div class="grid gap-8 xl:grid-cols-[minmax(0,1fr)_19rem] xl:items-end">
					<div class="space-y-6">
						<div class="flex flex-wrap items-center gap-3 text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-muted">
							<span class="text-primary">Course Lesson</span>
							{formatDuration(module.data.duration) && (
								<>
									<span class="hidden h-1 w-1 rounded-full bg-black/20 dark:bg-white/20 sm:block"></span>
									<span>{formatDuration(module.data.duration)}</span>
								</>
							)}
							{module.data.difficulty && (
								<>
									<span class="hidden h-1 w-1 rounded-full bg-black/20 dark:bg-white/20 sm:block"></span>
									<span class="capitalize">{module.data.difficulty}</span>
								</>
							)}
						</div>

						<div class="max-w-4xl space-y-4">
							<h1 class="text-4xl font-extrabold tracking-tight text-primary-content md:text-5xl">
								{module.data.title}
							</h1>
							<p class="max-w-[65ch] text-lg leading-8 text-secondary-content">
								{module.data.description}
							</p>
						</div>
					</div>

					<div class="space-y-4 border-t border-black/10 pt-5 dark:border-white/10 xl:border-l xl:border-t-0 xl:pl-8 xl:pt-0">
						<div class="space-y-2">
							<div class="eyebrow-label">Course Context</div>
							<h2 class="text-2xl font-bold tracking-tight text-primary-content">{course.data.title}</h2>
							<p class="text-sm leading-7 text-secondary-content">
								Module {currentIndex + 1} of {allCourseModules.length}. Move through the course in order or jump back to the full curriculum.
							</p>
						</div>

						<div class="flex flex-wrap gap-3">
							<a
								href={`/courses/${course.id}`}
								class="inline-flex min-h-11 items-center justify-center rounded-full border border-black/10 px-4 py-2 text-sm font-semibold text-primary transition-colors hover:border-primary/25 hover:text-primary-content dark:border-white/10 dark:text-white"
							>
								View course
							</a>
							{nextModule && (
								<a
									href={moduleHref(nextModule)}
									class="inline-flex min-h-11 items-center justify-center rounded-full bg-primary px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-primary/90"
								>
									Next lesson
								</a>
							)}
						</div>
					</div>
				</div>
			</header>

			<div class:list={["module-flow", dedupedResources.length > 0 && "module-flow--with-rail"]}>
				{module.data.video && (
					<section class="module-flow__video space-y-5 border-y border-black/10 py-6 dark:border-white/10">
						<div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
							<div class="space-y-2">
								<div class="eyebrow-label">Watch the Lesson</div>
								<h2 class="text-3xl font-bold tracking-tight text-primary-content">Follow the build in real time</h2>
							</div>
							<p class="max-w-xl text-sm leading-7 text-secondary-content sm:text-right sm:text-base">
								Pause, replay, and keep the notes and resources beside you as you work through the module.
							</p>
						</div>
						<div class="overflow-hidden rounded-[1.5rem] bg-black/5 dark:bg-white/5">
							<VideoPlayer
								video={module.data.video.id}
								thumbnailUrl={module.data.video.thumbnailUrl || module.data.video.poster || ""}
								client:only="vue"
								isAuthenticated={false}
							/>
						</div>
					</section>
				)}

				{dedupedResources.length > 0 && (
					<aside class="module-flow__rail xl:sticky xl:top-28 xl:self-start">
						<ResourceList resources={dedupedResources} courseId={course.id} client:load />
					</aside>
				)}

				<article class="module-flow__notes space-y-6">
					<div class="flex flex-col gap-3 border-b border-black/10 pb-6 dark:border-white/10 sm:flex-row sm:items-end sm:justify-between">
						<div class="space-y-2">
							<div class="eyebrow-label">Lesson Notes</div>
							<h2 class="text-3xl font-bold tracking-tight text-primary-content">What you’ll implement</h2>
						</div>
						<p class="max-w-xl text-sm leading-7 text-secondary-content sm:text-right sm:text-base">
							The notes mirror the lesson flow so you can scan, copy, and revisit the important decisions quickly.
						</p>
					</div>
					<div class="prose prose-lg max-w-none dark:prose-invert prose-headings:scroll-mt-24">
						<Content />
					</div>
				</article>

				{(previousModule || nextModule) && (
					<nav class="module-flow__nav border-t border-black/10 pt-6 dark:border-white/10">
						<div class="grid gap-4 md:grid-cols-2">
							{previousModule && (
								<a
									href={moduleHref(previousModule)}
									class="group border-b border-black/8 py-4 transition-colors hover:text-primary dark:border-white/8"
								>
									<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Previous</p>
									<div class="mt-2 flex items-start justify-between gap-4">
										<p class="font-semibold text-primary-content transition-colors group-hover:text-primary">
											{previousModule.data.title}
										</p>
										<span class="text-primary transition-transform duration-200 group-hover:-translate-x-0.5">←</span>
									</div>
								</a>
							)}

							{nextModule && (
								<a
									href={moduleHref(nextModule)}
									class="group border-b border-black/8 py-4 text-left transition-colors hover:text-primary dark:border-white/8 md:text-right"
								>
									<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Next</p>
									<div class="mt-2 flex items-start justify-between gap-4 md:flex-row-reverse">
										<p class="font-semibold text-primary-content transition-colors group-hover:text-primary">
											{nextModule.data.title}
										</p>
										<span class="text-primary transition-transform duration-200 group-hover:translate-x-0.5">→</span>
									</div>
								</a>
							)}
						</div>
					</nav>
				)}
			</div>

			{course.data.signupConfig && (
				<div class="mx-auto max-w-5xl">
					<CourseSignupForm
						courseId={course.id}
						courseTitle={course.data.title}
						signupConfig={course.data.signupConfig}
					/>
				</div>
			)}
		</div>
	</section>
</Page>

<style>
	.module-flow {
		display: grid;
		gap: clamp(2rem, 4vw, 3rem);
	}

	@media (min-width: 1280px) {
		.module-flow--with-rail {
			grid-template-columns: minmax(0, 1fr) 20rem;
			column-gap: clamp(2.5rem, 4vw, 3.5rem);
			align-items: start;
		}

		.module-flow__video,
		.module-flow__notes,
		.module-flow__nav {
			grid-column: 1;
		}

		.module-flow__rail {
			grid-column: 2;
			grid-row: 1 / span 3;
		}
	}
</style>
