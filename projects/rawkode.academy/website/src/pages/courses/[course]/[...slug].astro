---
import { getImage } from "astro:assets";
import { type CollectionEntry, getCollection, render } from "astro:content";
import { dirname, join } from "node:path";
import Breadcrumb from "@/components/breadcrumb/Breadcrumb.astro";
import CourseSignupForm from "@/components/courses/CourseSignupForm.astro";
import ResourceList from "@/components/courses/ResourceList.vue";
import VideoPlayer from "@/components/video/player.vue";
import Page from "@/wrappers/page.astro";
import { createLogger } from "@/lib/logger";
import { getCourseModuleSlug } from "@/utils/course-path";
import { loadWebContainerFiles } from "@/utils/webcontainer-loader";
import type { GetStaticPaths } from "astro";

export const prerender = true;

const logger = createLogger("courses");

type Props = {
	module: CollectionEntry<"courseModules">;
	course: CollectionEntry<"courses">;
};

export const getStaticPaths: GetStaticPaths = async () => {
	const courses = await getCollection("courses");
	const modules = await getCollection("courseModules");

	return modules.map((module) => {
		const course = courses.find((entry) => entry.id === module.data.course.id);
		if (!course) {
			throw new Error(`Course not found for module: ${module.id}`);
		}

		return {
			params: {
				course: course.id,
				slug: getCourseModuleSlug(course.id, module.id),
			},
			props: {
				module,
				course,
			},
		};
	});
};

const computeImageUrl = async (module: CollectionEntry<"courseModules">) => {
	if (!module.data.cover) return null;
	return (
		await getImage({
			src: module.data.cover.image,
			format: "jpeg",
		})
	).src;
};

const { module, course } = Astro.props;

if (module.data.draft) {
	return Astro.redirect("/404");
}

const { Content } = await render(module);

const allResources = [
	...(course.data.resources || []),
	...(module.data.resources || []),
];

const processedResources = await Promise.all(
	allResources.map(async (resource) => {
		if (
			resource.type === "embed" &&
			resource.embedConfig?.container === "webcontainer" &&
			resource.embedConfig.import?.localDir
		) {
			const moduleFilePath = join(
				process.cwd(),
				"content",
				"courses",
				`${module.id}.mdx`,
			);
			const moduleDir = dirname(moduleFilePath);
			const importPath = join(moduleDir, resource.embedConfig.import.localDir);

			try {
				const importedFiles = await loadWebContainerFiles(importPath);
				return {
					...resource,
					embedConfig: {
						...resource.embedConfig,
						files: { ...importedFiles, ...(resource.embedConfig.files || {}) },
					},
				};
			} catch (error) {
				logger.error(`Failed to load files for ${resource.title}`, error);
				return resource;
			}
		}

		return resource;
	}),
);

const dedupedResources = Array.from(
	new Map(
		processedResources.map((resource) => {
			const key = [
				resource.type,
				resource.title,
				resource.url || "",
				resource.filePath || "",
				resource.embedConfig?.src || "",
			].join("::");

			return [key, resource];
		}),
	).values(),
);

const imageUrl = await computeImageUrl(module);
const moduleSlug = getCourseModuleSlug(course.id, module.id);

const breadcrumbElements = [
	{ title: "Home", link: "/" },
	{ title: "Courses", link: "/courses" },
	{ title: course.data.title, link: `/courses/${course.id}` },
	{
		title: module.data.title,
		link: `/courses/${course.id}/${moduleSlug}`,
	},
];

const allCourseModules = (await getCollection("courseModules"))
	.filter((entry) => entry.data.course.id === course.id)
	.filter((entry) => !entry.data.draft)
	.sort((a, b) => a.data.order - b.data.order);

const currentIndex = allCourseModules.findIndex(
	(entry) => entry.id === module.id,
);
const previousModule =
	currentIndex > 0 ? allCourseModules[currentIndex - 1] : null;
const nextModule =
	currentIndex >= 0 && currentIndex < allCourseModules.length - 1
		? allCourseModules[currentIndex + 1]
		: null;

function moduleHref(entry: CollectionEntry<"courseModules">) {
	return `/courses/${course.id}/${getCourseModuleSlug(course.id, entry.id)}`;
}

function formatDuration(minutes?: number) {
	if (!minutes || minutes <= 0) return null;

	const hours = Math.floor(minutes / 60);
	const mins = minutes % 60;

	if (hours > 0 && mins > 0) return `${hours}h ${mins}m`;
	if (hours > 0) return `${hours}h`;
	return `${mins}m`;
}
---

<Page
	title={`${module.data.title} - ${course.data.title}`}
	description={module.data.description}
	image={imageUrl
		? {
				image: imageUrl.startsWith("http")
					? new URL(imageUrl)
					: new URL(imageUrl, Astro.site || "https://rawkode.academy"),
				text: module.data.title,
				format: "png" as const,
			}
		: undefined}
>
	<section class="page-px section-py-tight">
		<div class="mx-auto max-w-7xl space-y-6">
			<Breadcrumb elements={breadcrumbElements} />

			<header class="section-shell card-padding-lg">
				<div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_20rem] xl:items-start">
					<div class="space-y-5">
						<div class="flex flex-wrap gap-3">
							<span class="glass-chip text-primary">Course Lesson</span>
							{formatDuration(module.data.duration) && (
								<span class="glass-chip text-secondary-content">{formatDuration(module.data.duration)}</span>
							)}
							{module.data.difficulty && (
								<span class="glass-chip text-secondary-content capitalize">{module.data.difficulty}</span>
							)}
						</div>

						<div class="max-w-4xl space-y-4">
							<h1 class="text-4xl font-extrabold tracking-tight text-primary-content md:text-5xl">
								{module.data.title}
							</h1>
							<p class="max-w-[65ch] text-lg leading-8 text-secondary-content">
								{module.data.description}
							</p>
						</div>
					</div>

					<div class="section-shell-muted p-5">
						<div class="space-y-4">
							<div class="space-y-2">
								<div class="eyebrow-label">Course Context</div>
								<h2 class="text-2xl font-bold text-primary-content">{course.data.title}</h2>
								<p class="text-sm leading-7 text-secondary-content">
									Module {currentIndex + 1} of {allCourseModules.length}. Move through the course in order or jump back to the full curriculum.
								</p>
							</div>

							<div class="flex flex-wrap gap-3">
								<a
									href={`/courses/${course.id}`}
									class="inline-flex min-h-11 items-center justify-center rounded-full border border-white/60 bg-white/70 px-4 py-2 text-sm font-semibold text-primary transition-colors hover:bg-white dark:border-white/10 dark:bg-gray-900/55 dark:text-white dark:hover:bg-gray-900/80"
								>
									View course
								</a>
								{nextModule && (
									<a
										href={moduleHref(nextModule)}
										class="inline-flex min-h-11 items-center justify-center rounded-full bg-gradient-to-r from-primary to-secondary px-4 py-2 text-sm font-semibold text-white shadow-lg transition-transform duration-200 hover:-translate-y-0.5"
									>
										Next lesson
									</a>
								)}
							</div>
						</div>
					</div>
				</div>
			</header>

			<div class:list={["grid gap-8 xl:items-start", dedupedResources.length > 0 && "xl:grid-cols-[minmax(0,1fr)_21rem]"]}>
				<div class="space-y-8">
					{module.data.video && (
						<section class="section-shell overflow-hidden p-3 sm:p-4">
							<VideoPlayer
								video={module.data.video.id}
								thumbnailUrl={module.data.video.thumbnailUrl || module.data.video.poster || ""}
								client:only="vue"
								isAuthenticated={false}
							/>
						</section>
					)}

					<article class="section-shell card-padding-lg">
						<div class="mb-6 space-y-2">
							<div class="eyebrow-label">Lesson Notes</div>
							<h2 class="text-3xl font-bold tracking-tight text-primary-content">What you’ll implement</h2>
						</div>
						<div class="prose prose-lg max-w-none dark:prose-invert prose-headings:scroll-mt-24">
							<Content />
						</div>
					</article>

					{(previousModule || nextModule) && (
						<nav class="section-shell-muted p-6">
							<div class="flex flex-col gap-4 md:flex-row md:items-stretch md:justify-between">
								{previousModule ? (
									<a
										href={moduleHref(previousModule)}
										class="flex flex-1 items-center justify-between rounded-[1.25rem] border border-white/40 bg-white/65 px-4 py-4 transition-colors hover:bg-white dark:border-white/8 dark:bg-gray-950/30 dark:hover:bg-gray-950/45"
									>
										<div>
											<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Previous</p>
											<p class="mt-1 font-semibold text-primary-content">{previousModule.data.title}</p>
										</div>
										<span class="text-primary">←</span>
									</a>
								) : (
									<div></div>
								)}

								{nextModule && (
									<a
										href={moduleHref(nextModule)}
										class="flex flex-1 items-center justify-between rounded-[1.25rem] border border-white/40 bg-white/65 px-4 py-4 text-right transition-colors hover:bg-white dark:border-white/8 dark:bg-gray-950/30 dark:hover:bg-gray-950/45"
									>
										<div class="ml-auto">
											<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Next</p>
											<p class="mt-1 font-semibold text-primary-content">{nextModule.data.title}</p>
										</div>
										<span class="ml-4 text-primary">→</span>
									</a>
								)}
							</div>
						</nav>
					)}
				</div>

				{dedupedResources.length > 0 && (
					<aside class="xl:sticky xl:top-28">
						<ResourceList resources={dedupedResources} courseId={course.id} client:load />
					</aside>
				)}
			</div>

			{course.data.signupConfig && (
				<div class="mx-auto max-w-5xl">
					<CourseSignupForm
						courseId={course.id}
						courseTitle={course.data.title}
						signupConfig={course.data.signupConfig}
					/>
				</div>
			)}
		</div>
	</section>
</Page>
