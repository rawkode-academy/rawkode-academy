---
import { css } from "../../../../styled-system/css";
import { getCollection } from "astro:content";
import CourseCard from "@/components/courses/CourseCard.astro";
import CoursesHero from "@/components/courses/CoursesHero.vue";
import Page from "@/wrappers/page.astro";

export const prerender = true;

// Get all courses and sort by published date
const allCourses = (await getCollection("courses")).sort(
	(a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);

// Get the Zitadel course as the featured course
const featuredCourse =
	allCourses.find((course) => course.id === "complete-guide-zitadel") ||
	allCourses[0];

// Get course modules for featured course
let featuredModuleCount = 0;
let firstModuleSlug: string | undefined;

if (featuredCourse) {
	const courseModules = (await getCollection("courseModules")).filter(
		(module) => module.data.course.id === featuredCourse.id,
	);
	featuredModuleCount = courseModules.length;

	// Get the first module (lowest order number)
	const sortedModules = courseModules
		.filter((m) => !m.data.draft)
		.sort((a, b) => a.data.order - b.data.order);
	firstModuleSlug = sortedModules[0]?.id;
}

const pageTitle = "Cloud Native Courses | Rawkode Academy";
const pageDescription =
	"Master Zitadel authentication and authorization with our comprehensive, hands-on course. Build secure, scalable identity management systems.";
---

<Page title={pageTitle} description={pageDescription}>
  {featuredCourse ? (
    <!-- Featured Course Hero Section -->
    <CoursesHero
      courseId={featuredCourse.id}
      courseName={featuredCourse.data.title}
      courseDescription={featuredCourse.data.description}
      moduleCount={featuredModuleCount}
      difficulty={featuredCourse.data.difficulty.charAt(0).toUpperCase() + featuredCourse.data.difficulty.slice(1)}
      firstModuleSlug={firstModuleSlug}
      client:only="vue"
    />
  ) : (
    <!-- Fallback if no courses -->
    <div class={css({
	bgGradient: 'to-br',
	gradientFrom: 'gray.50',
	gradientVia: 'gray.100',
	gradientTo: 'gray.200',
}) + " dark:from-gray-900 dark:via-gray-800 dark:to-black text-primary-content"}>
      <div class={css({
	mx: 'auto',
	px: '4',
	py: '20',
	textAlign: 'center',
}) + " container"}>
        <h1 class={css({
	fontSize: '4xl',
	md: {
		fontSize: '5xl',
	},
	fontWeight: 'extrabold',
	mb: '6',
})}>
          Cloud Native Courses Coming Soon
        </h1>
        <p class={css({
	fontSize: 'xl',
	mb: '8',
	maxW: '2xl',
	mx: 'auto',
}) + " text-secondary-content"}>
          We're preparing comprehensive, hands-on courses to help you master cloud-native technologies.
        </p>
      </div>
    </div>
  )}

  <!-- All courses section -->
  <div id="all-courses" class={css({
	bg: 'gray.100',
}) + " dark:bg-gray-900"}>
    <div class={css({
	py: '16',
	px: '4',
	mx: 'auto',
	maxW: 'screen-xl',
	lg: {
		py: '20',
		px: '6',
	},
})}>
      {allCourses.length > 0 ? (
        <>
          <h2 class={css({
	fontSize: '3xl',
	fontWeight: 'bold',
	textAlign: 'center',
	mb: '12',
}) + " text-primary-content"}>
            All Courses
          </h2>
          <div class={allCourses.length === 1 ? "max-w-4xl mx-auto" : "grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"}>
            {allCourses.map((course) => (
              <CourseCard course={course} />
            ))}
          </div>
        </>
      ) : (
        <!-- No courses message -->
        <div class={css({
	textAlign: 'center',
	py: '16',
})}>
          <h2 class={css({
	fontSize: '2xl',
	fontWeight: 'bold',
	mb: '4',
}) + " text-primary-content"}>
            Courses launching soon!
          </h2>
          <p class="text-muted">
            Stay tuned for our upcoming cloud-native courses.
          </p>
        </div>
      )}
    </div>
  </div>

  <!-- Newsletter/Updates section -->
  <div class={css({
	bg: 'gray.50',
}) + " dark:bg-gray-800"}>
    <div class={css({
	py: '16',
	px: '4',
	mx: 'auto',
	maxW: 'screen-xl',
	lg: {
		py: '20',
		px: '6',
	},
})}>
      <div class={css({
	maxW: '2xl',
	mx: 'auto',
	textAlign: 'center',
})}>
        <h3 class={css({
	fontSize: '2xl',
	fontWeight: 'bold',
	mb: '4',
}) + " text-primary-content"}>
          Stay Updated
        </h3>
        <p class={css({
	mb: '8',
}) + " text-muted"}>
          Get notified when new courses and modules are released. Join our community of cloud-native learners.
        </p>
        <div class={css({
	display: 'flex',
	justifyContent: 'center',
	gap: '4',
})}>
          <a
            href="/community"
            class={css({
	display: 'inline-flex',
	alignItems: 'center',
	justifyContent: 'center',
	px: '6',
	py: '3',
	borderWidth: '1px',
	borderColor: 'transparent',
	fontSize: 'base',
	fontWeight: 'medium',
	rounded: 'md',
	color: 'white',
	transition: 'colors',
}) + " bg-primary hover:bg-primary-dark"}
          >
            Join Community
          </a>
          <a
            href="https://github.com/rawkode-academy"
            target="_blank"
            class={css({
	display: 'inline-flex',
	alignItems: 'center',
	justifyContent: 'center',
	px: '6',
	py: '3',
	borderWidth: '1px',
	borderColor: 'gray.300',
	fontSize: 'base',
	fontWeight: 'medium',
	rounded: 'md',
	bg: 'white',
	_hover: {
		bg: 'gray.50',
	},
	transition: 'colors',
}) + " dark:border-gray-600 text-secondary-content dark:bg-gray-900 dark:hover:bg-gray-700"}
          >
            <svg class={css({
	w: '5',
	h: '5',
	mr: '2',
})} fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
            Follow on GitHub
          </a>
        </div>
      </div>
    </div>
  </div>
</Page>
