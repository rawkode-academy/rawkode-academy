---
import { getCollection, getEntries } from "astro:content";
import CourseCard from "@/components/courses/CourseCard.astro";
import CoursesHero from "@/components/courses/CoursesHero.astro";
import CourseItemListJsonLd from "@/components/html/course-itemlist-jsonld.astro";
import CollectionMasthead from "@/components/ui/CollectionMasthead.astro";
import EmptyState from "@/components/ui/EmptyState.vue";
import MLabel from "@/components/ui/MLabel.vue";
import { getCourseModuleSlug } from "@/utils/course-path";
import Page from "@/wrappers/page.astro";

export const prerender = true;

// Get all courses and sort by published date
const allCourses = (await getCollection("courses")).sort(
	(a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);

const featuredCourse = allCourses[0];
const libraryCourses = allCourses.slice(1);

// Get course modules for featured course
let featuredModuleCount = 0;
let featuredAvailableModuleCount = 0;
let firstModuleSlug: string | undefined;
let featuredAuthors: { name: string; avatarUrl?: string | undefined }[] = [];
let featuredPublishedLabel: string | undefined;

if (featuredCourse) {
	const courseModules = (await getCollection("courseModules"))
		.filter((module) => module.data.course.id === featuredCourse.id)
		.sort((a, b) => a.data.order - b.data.order);

	featuredModuleCount = courseModules.length;
	featuredAvailableModuleCount = courseModules.filter(
		(module) => !module.data.draft,
	).length;

	const publishedModules = courseModules.filter((module) => !module.data.draft);
	firstModuleSlug = publishedModules[0]
		? getCourseModuleSlug(featuredCourse.id, publishedModules[0].id)
		: undefined;

	const authors = await getEntries(featuredCourse.data.authors);
	featuredAuthors = authors.map((author) => ({
		name: author.data.name,
		avatarUrl: author.data.avatarUrl,
	}));
	featuredPublishedLabel = featuredCourse.data.publishedAt.toLocaleDateString(
		"en-US",
		{
			month: "short",
			day: "numeric",
			year: "numeric",
		},
	);
}

const pageTitle = "Cloud Native Courses";
const pageDescription =
	"Hands-on cloud native courses, labs, and walkthroughs covering Kubernetes, identity, GraphQL, Rust, and the tooling behind real platform engineering.";
---

<Page title={pageTitle} description={pageDescription} pageType="CollectionPage">
	<CourseItemListJsonLd
		slot="extra-head"
		courses={allCourses}
		listUrl={new URL("/courses", Astro.site ?? Astro.url).href}
		listName="Cloud Native Courses"
	/>
	<div class="courses-page">
		<CollectionMasthead
			title="Courses"
			dek="Structured courses and labs."
		/>

		<section class="courses-page__featured">
			{featuredCourse ? (
				<CoursesHero
					courseId={featuredCourse.id}
					courseName={featuredCourse.data.title}
					courseDescription={featuredCourse.data.description}
					moduleCount={featuredModuleCount}
					availableModuleCount={featuredAvailableModuleCount}
					difficulty={featuredCourse.data.difficulty.charAt(0).toUpperCase() + featuredCourse.data.difficulty.slice(1)}
					firstModuleSlug={firstModuleSlug}
					learningPath={featuredCourse.data.learningPath}
					authors={featuredAuthors}
					publishedLabel={featuredPublishedLabel}
				/>
			) : (
				<div class="courses-page__empty">
					<EmptyState
						title="Courses are on the way"
						body="Practical, engineering-first courses are being built now."
						align="start"
					/>
				</div>
			)}
		</section>

		<section id="all-courses" class="courses-page__library">
			<header class="courses-page__section-head">
				<h2>All courses</h2>
				<MLabel>{libraryCourses.length} more course{libraryCourses.length === 1 ? "" : "s"}</MLabel>
			</header>

			{libraryCourses.length > 0 ? (
				<div class="courses-page__grid">
					{libraryCourses.map((course) => (
						<CourseCard course={course} />
					))}
				</div>
			) : (
				<div class="courses-page__empty">
					<EmptyState
						title="More courses launching soon"
						body="Kubernetes, platform engineering, and identity deep dives are next."
						align="start"
					/>
				</div>
			)}
		</section>
	</div>
</Page>

<style>
	.courses-page {
		background: var(--editorial-paper);
		color: var(--editorial-ink);
	}

	.courses-page__featured {
		border-bottom: 1px solid var(--editorial-hairline);
	}

	.courses-page__library {
		padding: 2rem var(--space-section-pad-x) 3rem;
	}

	.courses-page__section-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1.25rem;
	}

	.courses-page__section-head h2 {
		font-family: var(--font-inter-tight), sans-serif;
		font-size: clamp(1.375rem, 2vw, 1.875rem);
		font-weight: 700;
		line-height: 1.1;
		letter-spacing: 0;
		margin: 0;
	}

	.courses-page__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(17rem, 1fr));
		gap: 1.25rem;
	}

	.courses-page__empty {
		padding: 2rem var(--space-section-pad-x);
	}

	@media (max-width: 720px) {
		.courses-page__library {
			padding: 1.5rem 1rem 2.5rem;
		}
		.courses-page__section-head {
			flex-direction: column;
			gap: 0.375rem;
		}
		.courses-page__empty {
			padding: 1.5rem 1rem;
		}
	}
</style>
