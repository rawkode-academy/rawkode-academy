---
import { getCollection, getEntries } from "astro:content";
import CourseCard from "@/components/courses/CourseCard.astro";
import CoursesHero from "@/components/courses/CoursesHero.astro";
import { getCourseModuleSlug } from "@/utils/course-path";
import Page from "@/wrappers/page.astro";

export const prerender = true;

// Get all courses and sort by published date
const allCourses = (await getCollection("courses")).sort(
	(a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);

const featuredCourse = allCourses[0];
const libraryCourses = allCourses.slice(1);

// Get course modules for featured course
let featuredModuleCount = 0;
let featuredAvailableModuleCount = 0;
let firstModuleSlug: string | undefined;
let featuredAuthors: { name: string; avatarUrl?: string | undefined }[] = [];
let featuredPublishedLabel: string | undefined;

if (featuredCourse) {
	const courseModules = (await getCollection("courseModules"))
		.filter((module) => module.data.course.id === featuredCourse.id)
		.sort((a, b) => a.data.order - b.data.order);

	featuredModuleCount = courseModules.length;
	featuredAvailableModuleCount = courseModules.filter(
		(module) => !module.data.draft,
	).length;

	const publishedModules = courseModules.filter((module) => !module.data.draft);
	firstModuleSlug = publishedModules[0]
		? getCourseModuleSlug(featuredCourse.id, publishedModules[0].id)
		: undefined;

	const authors = await getEntries(featuredCourse.data.authors);
	featuredAuthors = authors.map((author) => ({
		name: author.data.name,
		avatarUrl: author.data.avatarUrl,
	}));
	featuredPublishedLabel = featuredCourse.data.publishedAt.toLocaleDateString("en-US", {
		month: "short",
		day: "numeric",
		year: "numeric",
	});
}

const pageTitle = "Cloud Native Courses | Rawkode Academy";
const pageDescription =
	"Hands-on cloud native courses, labs, and implementation walkthroughs from Rawkode Academy. Learn Kubernetes, identity, GraphQL, Rust, and the tooling behind real platform work.";
---

<Page title={pageTitle} description={pageDescription}>
	<section class="page-px section-py-tight">
		<div class="mx-auto max-w-7xl">
			{featuredCourse ? (
				<CoursesHero
					courseId={featuredCourse.id}
					courseName={featuredCourse.data.title}
					courseDescription={featuredCourse.data.description}
					moduleCount={featuredModuleCount}
					availableModuleCount={featuredAvailableModuleCount}
					difficulty={featuredCourse.data.difficulty.charAt(0).toUpperCase() + featuredCourse.data.difficulty.slice(1)}
					firstModuleSlug={firstModuleSlug}
					learningPath={featuredCourse.data.learningPath}
					authors={featuredAuthors}
					publishedLabel={featuredPublishedLabel}
				/>
			) : (
				<div class="section-shell card-padding-lg text-center">
					<div class="mx-auto max-w-3xl space-y-5">
						<div class="eyebrow-label justify-center">Courses</div>
						<h1 class="text-4xl font-extrabold tracking-tight text-primary-content md:text-5xl">
							Cloud native courses are on the way
						</h1>
						<p class="text-lg leading-8 text-secondary-content">
							We’re building practical, engineering-first courses that stay close to the tools,
							trade-offs, and deployment paths teams actually use.
						</p>
					</div>
				</div>
			)}
		</div>
	</section>

	<section id="all-courses" class="page-px section-py-tight">
		<div class="mx-auto max-w-7xl">
			<div class="mb-10 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
				<div class="max-w-3xl space-y-3">
					<div class="eyebrow-label">Course Library</div>
					<h2 class="text-3xl font-bold tracking-tight text-primary-content md:text-4xl">
						{libraryCourses.length > 0 ? "Explore the rest of the library" : "More courses are on the way"}
					</h2>
					<p class="text-base leading-7 text-secondary-content sm:text-lg">
						{libraryCourses.length > 0
							? "Each course is built from real implementation work, not generic slideware. Pick the next topic that matches the problems you’re solving now."
							: "We’re building out the library with the same engineering-first approach: practical modules, implementation detail, and zero marketing padding."}
					</p>
				</div>
				<p class="text-sm font-medium uppercase tracking-[0.2em] text-muted">
					{libraryCourses.length} more course{libraryCourses.length === 1 ? "" : "s"}
				</p>
			</div>

			{libraryCourses.length > 0 ? (
				<div class="grid grid-auto-cards gap-6">
					{libraryCourses.map((course) => (
						<CourseCard course={course} />
					))}
				</div>
			) : (
				<div class="section-shell-muted card-padding text-center">
					<h2 class="text-2xl font-bold text-primary-content">More courses launching soon</h2>
					<p class="mt-3 text-secondary-content">
						Stay tuned for upcoming Kubernetes, platform engineering, and identity deep dives.
					</p>
				</div>
			)}
		</div>
	</section>

	<section class="page-px section-py-tight">
		<div class="mx-auto max-w-5xl">
			<div class="section-shell card-padding-lg text-center">
				<div class="mx-auto max-w-3xl space-y-5">
					<div class="eyebrow-label justify-center">Stay in the Loop</div>
					<h2 class="text-3xl font-bold tracking-tight text-primary-content md:text-4xl">
						Get notified when new lessons ship
					</h2>
					<p class="text-base leading-7 text-secondary-content sm:text-lg">
						Follow the academy for new course releases, module drops, and the implementation notes
						that usually make the best lessons.
					</p>
				</div>

				<div class="mt-8 flex flex-wrap justify-center gap-4">
					<a
						href="/watch"
						class="inline-flex min-h-11 items-center justify-center rounded-full bg-gradient-to-r from-primary to-secondary px-6 py-3 text-sm font-semibold text-white shadow-lg transition-transform duration-200 hover:-translate-y-0.5"
					>
						Start with free videos
					</a>
					<a
						href="https://github.com/rawkode-academy"
						target="_blank"
						rel="noreferrer"
						class="inline-flex min-h-11 items-center justify-center rounded-full border border-white/60 bg-white/70 px-6 py-3 text-sm font-semibold text-primary shadow-sm transition-colors duration-200 hover:bg-white dark:border-white/10 dark:bg-gray-900/55 dark:text-white dark:hover:bg-gray-900/80"
					>
						Follow on GitHub
					</a>
				</div>
			</div>
		</div>
	</section>
</Page>
