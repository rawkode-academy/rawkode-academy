---
import { css } from "../../../../styled-system/css";
import { getCollection, getEntries } from "astro:content";
import Page from "@/wrappers/page.astro";
import { createLogger } from "@/lib/logger";

export const prerender = true;

const logger = createLogger("adrs");

// Get all ADRs and sort alphanumerically by ID
const allAdrs = await getCollection("adrs");
allAdrs.sort((a, b) => {
	// Extract the numeric ID from the slug (e.g., "0001-name" -> 1)
	const adrNumberA = a.id.match(/^(\d{4})-/)?.[1] || "0000";
	const adrNumberB = b.id.match(/^(\d{4})-/)?.[1] || "0000";
	return Number.parseInt(adrNumberA) - Number.parseInt(adrNumberB);
});

// Get authors for each ADR
const adrAuthors = await Promise.all(
	allAdrs.map(async (adr) => {
		try {
			return {
				id: adr.id,
				authors: await getEntries(adr.data.authors),
			};
		} catch (error) {
			logger.error(`Error fetching authors for ADR ${adr.id}`, error);
			return {
				id: adr.id,
				authors: [],
			};
		}
	}),
);

const formatDate = (date: Date): string => {
	return new Intl.DateTimeFormat("en-US", {
		year: "numeric",
		month: "long",
		day: "numeric",
	}).format(date);
};

// Function to extract ADR number from ID
const getAdrNumber = (id: string): string => {
	return id.match(/^(\d{4})-/)?.[1] || "0000";
};
---

<Page title="Architecture Decision Records" subtitle="Documentation of architecture decisions">
  <div class={css({
	maxW: '(--breakpoint-xl)',
	mx: 'auto',
})}>
    <h1 class={css({
	fontSize: '5xl',
	fontWeight: 'extrabold',
	mb: '6',
}) + " text-primary-content"}>
      Architecture Decision Records
    </h1>

    <p class={css({
	mb: '10',
	fontSize: 'lg',
	color: 'gray.700',
}) + " dark:text-gray-300"}>
      This page lists all architecture decisions made in this project. ADRs are a lightweight method to document architectural decisions including their context and consequences.
    </p>

    <div class={css({
	display: 'grid',
	gap: '6',
	lg: {
		gap: '8',
	},
})}>
      {allAdrs.map((adr) => {
        const authorData = adrAuthors.find(a => a.id === adr.id);
        const authors = authorData?.authors || [];
        const adrNumber = getAdrNumber(adr.id);

        return (
          <a href={`/adrs/${adr.id}`} class={css({
	display: 'block',
})}>
            <div class={css({
	transition: 'all',
	transitionDuration: '300ms',
	transitionTimingFunction: 'ease-in-out',
	_hover: {
		translateY: '-1',
		shadow: 'xl',
	},
	rounded: 'xl',
	overflow: 'hidden',
	backdropBlur: 'sm',
	bg: 'white/30',
	borderWidth: '1px',
	borderColor: 'gray.200',
	shadow: 'md',
}) + " transform dark:bg-gray-800/30 dark:border-gray-700"}>
              <div class={css({
	p: '6',
})}>
                <div class={css({
	display: 'flex',
	alignItems: 'center',
	gap: '4',
	mb: '4',
})}>
                  <h2 class={css({
	fontSize: '2xl',
	fontWeight: 'bold',
	my: 'auto',
}) + " text-primary-content"}>
                    <span class="text-secondary dark:text-secondary">ADR-{adrNumber}:</span> {adr.data.title}
                  </h2>
                </div>

                <div class={css({
	display: 'flex',
	flexWrap: 'wrap',
	alignItems: 'center',
	gap: '4',
	mt: '2',
})}>
                  <div class={css({
	display: 'flex',
	alignItems: 'center',
	fontSize: 'sm',
}) + " text-muted"}>
                    <svg xmlns="http://www.w3.org/2000/svg" class={css({
	h: '5',
	w: '5',
	mr: '1',
	color: 'gray.500',
})} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    {formatDate(adr.data.adoptedAt)}
                  </div>

                  <div class={css({
	display: 'flex',
	alignItems: 'center',
})}>
                    <span class={css({
	px: '3',
	py: '1',
	fontSize: 'xs',
	fontWeight: 'medium',
	rounded: 'full',
	bg: 'green.100',
	color: 'green.800',
}) + " dark:bg-green-900 dark:text-green-200"}>
                      Adopted
                    </span>
                  </div>

                  {authors.length > 0 && (
                    <div class={css({
	display: 'flex',
	alignItems: 'center',
})}>
                      <div class={css({
	display: 'flex',
	gap: '-3',
	mr: '2',
})}>
                        {authors.filter(author => author && author.data).slice(0, 3).map((author, index) => (
                          <div class={css({
	pos: 'relative',
})} style={`z-index: ${10 - index}`}>
                            <img
                              class={css({
	w: '8',
	h: '8',
	rounded: 'full',
	objectFit: 'cover',
	borderWidth: '2px',
	p: '0.5',
	bg: 'white',
}) + " border-secondary dark:bg-gray-800"}
                              src={author.data.avatarUrl}
                              alt={`Profile picture of ${author.data.name}`}
                              title={author.data.name}
                            />
                          </div>
                        ))}
                        {authors.filter(author => author && author.data).length > 3 && (
                          <div class={css({
	pos: 'relative',
	zIndex: '0',
})}>
                            <div class={css({
	w: '8',
	h: '8',
	rounded: 'full',
	bg: 'white',
	borderWidth: '2px',
	p: '0.5',
	display: 'flex',
	alignItems: 'center',
	justifyContent: 'center',
	fontSize: 'xs',
	fontWeight: 'medium',
}) + " dark:bg-secondary/20 border-secondary dark:bg-gray-800 text-secondary dark:text-secondary"}>
                              +{authors.filter(author => author && author.data).length - 3}
                            </div>
                          </div>
                        )}
                      </div>
                      <span class={css({
	fontSize: 'sm',
}) + " text-muted"}>
                        {authors.filter(author => author && author.data).map(author => author.data.name).join(", ")}
                      </span>
                    </div>
                  )}
                </div>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</Page>
