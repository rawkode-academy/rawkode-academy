---
import { getCollection, getEntries } from "astro:content";
import Page from "@/wrappers/page.astro";
import { createLogger } from "@/lib/logger";
import { css } from "../../../styled-system/css";

export const prerender = true;

const logger = createLogger("adrs");

// Get all ADRs and sort alphanumerically by ID
const allAdrs = await getCollection("adrs");
allAdrs.sort((a, b) => {
	// Extract the numeric ID from the slug (e.g., "0001-name" -> 1)
	const adrNumberA = a.id.match(/^(\d{4})-/)?.[1] || "0000";
	const adrNumberB = b.id.match(/^(\d{4})-/)?.[1] || "0000";
	return Number.parseInt(adrNumberA) - Number.parseInt(adrNumberB);
});

// Get authors for each ADR
const adrAuthors = await Promise.all(
	allAdrs.map(async (adr) => {
		try {
			return {
				id: adr.id,
				authors: await getEntries(adr.data.authors),
			};
		} catch (error) {
			logger.error(`Error fetching authors for ADR ${adr.id}`, error);
			return {
				id: adr.id,
				authors: [],
			};
		}
	}),
);

const formatDate = (date: Date): string => {
	return new Intl.DateTimeFormat("en-US", {
		year: "numeric",
		month: "long",
		day: "numeric",
	}).format(date);
};

// Function to extract ADR number from ID
const getAdrNumber = (id: string): string => {
	return id.match(/^(\d{4})-/)?.[1] || "0000";
};
---

<Page title="Architecture Decision Records" subtitle="Documentation of architecture decisions">
	<div class={css({ maxW: "breakpoint-xl", mx: "auto" })}>
		<h1 class={css({ fontSize: "5xl", fontWeight: "extrabold", mb: "6", color: "fg.default" })}>
			Architecture Decision Records
		</h1>

		<p class={css({ mb: "10", fontSize: "lg", color: "fg.muted" })}>
			This page lists all architecture decisions made in this project. ADRs are a lightweight method to document architectural decisions including their context and consequences.
		</p>

		<div class={css({ display: "grid", gap: { base: "6", lg: "8" } })}>
			{allAdrs.map((adr) => {
				const authorData = adrAuthors.find(a => a.id === adr.id);
				const authors = authorData?.authors || [];
				const validAuthors = validAuthors;
				const adrNumber = getAdrNumber(adr.id);

				return (
					<a href={`/adrs/${adr.id}`} class={css({ display: "block" })}>
						<div class={css({
							transition: "all",
							transitionDuration: "300ms",
							transitionTimingFunction: "ease-in-out",
							_hover: { transform: "translateY(-4px)", shadow: "xl" },
							borderRadius: "xl",
							overflow: "hidden",
							backdropFilter: "blur(4px)",
							bg: { base: "white/30", _dark: "gray.800/30" },
							borderWidth: "1px",
							borderColor: { base: "gray.200", _dark: "gray.700" },
							shadow: "md",
						})}>
							<div class={css({ p: "6" })}>
								<div class={css({ display: "flex", alignItems: "center", gap: "4", mb: "4" })}>
									<h2 class={css({ fontSize: "2xl", fontWeight: "bold", color: "fg.default", my: "auto" })}>
										<span class={css({ color: "green.500" })}>ADR-{adrNumber}:</span> {adr.data.title}
									</h2>
								</div>

								<div class={css({ display: "flex", flexWrap: "wrap", alignItems: "center", gap: "4", mt: "2" })}>
									<div class={css({ display: "flex", alignItems: "center", fontSize: "sm", color: "fg.muted" })}>
										<svg xmlns="http://www.w3.org/2000/svg" class={css({ h: "5", w: "5", mr: "1", color: "fg.subtle" })} fill="none" viewBox="0 0 24 24" stroke="currentColor">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
										</svg>
										{formatDate(adr.data.adoptedAt)}
									</div>

									<div class={css({ display: "flex", alignItems: "center" })}>
										<span class={css({
											px: "3",
											py: "1",
											fontSize: "xs",
											fontWeight: "medium",
											borderRadius: "full",
											bg: { base: "green.100", _dark: "green.900" },
											color: { base: "green.800", _dark: "green.200" },
										})}>
											Adopted
										</span>
									</div>

									{authors.length > 0 && (
										<div class={css({ display: "flex", alignItems: "center" })}>
											<div class={css({ display: "flex", mr: "2" })}>
												{validAuthors.slice(0, 3).map((author, index) => (
													<div class={css({ position: "relative", ml: index > 0 ? "-3" : "0" })} style={`z-index: ${10 - index}`}>
														<img
															class={css({
																w: "8",
																h: "8",
																borderRadius: "full",
																objectFit: "cover",
																borderWidth: "2px",
																borderColor: "green.500",
																p: "0.5",
																bg: { base: "white", _dark: "gray.800" },
															})}
															src={author.data.avatarUrl}
															alt={`Profile picture of ${author.data.name}`}
															title={author.data.name}
														/>
													</div>
												))}
												{validAuthors.length > 3 && (
													<div class={css({ position: "relative", zIndex: "0", ml: "-3" })}>
														<div class={css({
															w: "8",
															h: "8",
															borderRadius: "full",
															bg: { base: "green.500/10", _dark: "green.500/20" },
															borderWidth: "2px",
															borderColor: "green.500",
															display: "flex",
															alignItems: "center",
															justifyContent: "center",
															fontSize: "xs",
															color: "green.500",
															fontWeight: "medium",
														})}>
															+{validAuthors.length - 3}
														</div>
													</div>
												)}
											</div>
											<span class={css({ fontSize: "sm", color: "fg.muted" })}>
												{validAuthors.map(author => author.data.name).join(", ")}
											</span>
										</div>
									)}
								</div>
							</div>
						</div>
					</a>
				);
			})}
		</div>
	</div>
</Page>
