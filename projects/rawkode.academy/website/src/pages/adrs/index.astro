---
import { getCollection, getEntries } from "astro:content";
import PageHero from "@/components/layout/PageHero.astro";
import Page from "@/wrappers/page.astro";
import { createLogger } from "@/lib/logger";
import { css } from "../../../styled-system/css";

export const prerender = true;

const logger = createLogger("adrs");

const allAdrs = await getCollection("adrs");
allAdrs.sort((a, b) => {
	const an = a.id.match(/^(\d{4})-/)?.[1] || "0000";
	const bn = b.id.match(/^(\d{4})-/)?.[1] || "0000";
	return Number.parseInt(an) - Number.parseInt(bn);
});

const adrAuthors = await Promise.all(
	allAdrs.map(async (adr) => {
		try {
			return { id: adr.id, authors: await getEntries(adr.data.authors) };
		} catch (error) {
			logger.error(`Error fetching authors for ADR ${adr.id}`, error);
			return { id: adr.id, authors: [] };
		}
	}),
);

const formatDate = (date: Date) =>
	new Intl.DateTimeFormat("en-US", { year: "numeric", month: "long", day: "numeric" }).format(date);

const getAdrNumber = (id: string) => id.match(/^(\d{4})-/)?.[1] || "0000";

const shell = css({ maxWidth: "72rem", mx: "auto", px: { base: "4", md: "6" }, py: "12" });

const list = css({ display: "flex", flexDirection: "column", gap: "5" });

const card = css({
	display: "block",
	p: "6",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textDecoration: "none",
	color: "fg.primary",
	transition: "transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease",
	_hover: { transform: "translateY(-2px)", boxShadow: "lg", borderColor: "border.default" },
});

const titleClass = css({
	fontFamily: "display",
	fontSize: "xl",
	fontWeight: "bold",
	letterSpacing: "tight",
	color: "fg.primary",
	mb: "3",
});

const numberClass = css({ color: "fg.brand" });

const meta = css({
	display: "flex",
	flexWrap: "wrap",
	alignItems: "center",
	gap: "4",
	fontSize: "sm",
	color: "fg.muted",
});

const status = css({
	display: "inline-flex",
	px: "2.5",
	py: "0.5",
	borderRadius: "full",
	fontSize: "xs",
	fontWeight: "semibold",
	color: "fg.on-brand",
	bg: "bg.brand",
});

const authorRow = css({ display: "flex", alignItems: "center", gap: "2" });
const avatarStack = css({ display: "flex" });
const avatar = css({
	width: "8",
	height: "8",
	borderRadius: "full",
	objectFit: "cover",
	borderWidth: "2px",
	borderColor: "bg.raised",
	marginLeft: "-0.5rem",
	_first: { marginLeft: "0" },
});
---

<Page title="Architecture Decision Records" description="Documentation of architecture decisions">
	<PageHero eyebrow="ADRs" title="Architecture Decision Records" subtitle="A lightweight log of the architectural decisions behind Rawkode Academy — context, consequences, and rationale." align="left" />

	<div class={shell}>
		<div class={list}>
			{allAdrs.map((adr) => {
				const authorData = adrAuthors.find((a) => a.id === adr.id);
				const authors = (authorData?.authors || []).filter((a) => a && a.data);
				const adrNumber = getAdrNumber(adr.id);
				return (
					<a href={`/adrs/${adr.id}`} class={card}>
						<h2 class={titleClass}>
							<span class={numberClass}>ADR-{adrNumber}:</span> {adr.data.title}
						</h2>
						<div class={meta}>
							<span>{formatDate(adr.data.adoptedAt)}</span>
							<span class={status}>Adopted</span>
							{authors.length > 0 && (
								<span class={authorRow}>
									<span class={avatarStack}>
										{authors.slice(0, 3).map((author) => (
											<img class={avatar} src={author.data.avatarUrl} alt={author.data.name} title={author.data.name} />
										))}
									</span>
									<span>{authors.map((a) => a.data.name).join(", ")}</span>
								</span>
							)}
						</div>
					</a>
				);
			})}
		</div>
	</div>
</Page>
