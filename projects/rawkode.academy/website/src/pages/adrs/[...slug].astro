---
import { getCollection, getEntries, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import type { GetStaticPaths, GetStaticPathsResult } from "astro";
import AdrJsonLd from "@/components/html/adr-jsonld.astro";
import { createLogger } from "@/lib/logger";
import EditorialShell from "@/components/ui/EditorialShell.astro";
import Page from "@/wrappers/page.astro";

export const prerender = true;

const logger = createLogger("adrs");

type Props = {
	adr: CollectionEntry<"adrs">;
};

export const getStaticPaths: GetStaticPaths =
	async (): Promise<GetStaticPathsResult> => {
		const adrs = await getCollection("adrs");

		return adrs.map((adr) => ({
			params: {
				slug: adr.id,
			},
			props: {
				adr,
			},
		}));
	};

const { adr } = Astro.props;
const { Content } = await render(adr);

let authors: CollectionEntry<"people">[] = [];
try {
	authors = await getEntries(adr.data.authors);
} catch (error) {
	logger.error(`Error fetching authors for ADR ${adr.id}`, error);
}

const formatDate = (date: Date): string => {
	return new Intl.DateTimeFormat("en-US", {
		year: "numeric",
		month: "long",
		day: "numeric",
	}).format(date);
};

const adrNumber = adr.id.match(/^(\d{4})-/)?.[1] || "0000";
const adoptedLabel = adr.data.adoptedAt ? formatDate(adr.data.adoptedAt) : "Not adopted";
const validAuthors = authors.filter((author) => author && author.data);
---

<Page
	title={`ADR-${adrNumber}: ${adr.data.title}`}
	description={`Architecture Decision Record: ${adr.data.title}`}
>
	<AdrJsonLd slot="extra-head" adr={adr} authors={authors} />
	<EditorialShell
		eyebrow={`ADR-${adrNumber}`}
		title={adr.data.title}
		lede={`Architecture decision record adopted on ${adoptedLabel}.`}
		compact
	>
		<div class="editorial-actions" slot="actions">
			<a class="editorial-button editorial-button--secondary" href="/adrs">All ADRs</a>
		</div>

		<section class="editorial-section adr-detail-meta">
			<div class="editorial-grid editorial-grid--3">
				<div class="editorial-card">
					<p class="editorial-meta">Status</p>
					<h2 class="editorial-card__title">Adopted</h2>
				</div>
				<div class="editorial-card">
					<p class="editorial-meta">Date</p>
					<h2 class="editorial-card__title">{adoptedLabel}</h2>
				</div>
				<div class="editorial-card">
					<p class="editorial-meta">Authors</p>
					<h2 class="editorial-card__title">
						{validAuthors.length > 0 ? validAuthors.map((author) => author.data.name).join(", ") : "Unknown"}
					</h2>
				</div>
			</div>
		</section>

		<section class="editorial-section">
			<article class="editorial-prose adr-content">
				<Content />
			</article>
		</section>
	</EditorialShell>
</Page>

<style>
	.adr-detail-meta {
		padding-bottom: 1.5rem;
	}

	.adr-content {
		max-width: 52rem;
	}

	.adr-content :global(h1:first-child) {
		display: none;
	}

	.adr-content :global(table) {
		display: block;
		overflow-x: auto;
		border-collapse: collapse;
		width: 100%;
	}

	.adr-content :global(th),
	.adr-content :global(td) {
		border: 1px solid var(--editorial-hairline);
		padding: 0.6rem;
	}
</style>
