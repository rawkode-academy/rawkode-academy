---
import { css, cx } from "../../../../styled-system/css";
import { getCollection, getEntries, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import Page from "@/wrappers/page.astro";
import type { GetStaticPaths, GetStaticPathsResult } from "astro";
import { createLogger } from "@/lib/logger";

export const prerender = true;

const logger = createLogger("adrs");

type Props = {
	adr: CollectionEntry<"adrs">;
};

export const getStaticPaths: GetStaticPaths =
	async (): Promise<GetStaticPathsResult> => {
		const adrs = await getCollection("adrs");

		return adrs.map((adr) => {
			return {
				params: {
					slug: adr.id,
				},
				props: {
					adr,
				},
			};
		});
	};

const { adr } = Astro.props;
const { Content } = await render(adr);

let authors: CollectionEntry<"people">[] = [];
try {
	authors = await getEntries(adr.data.authors);
} catch (error) {
	logger.error(`Error fetching authors for ADR ${adr.id}`, error);
}

const formatDate = (date: Date): string => {
	return new Intl.DateTimeFormat("en-US", {
		year: "numeric",
		month: "long",
		day: "numeric",
	}).format(date);
};

// Extract the ADR number from the ID using a regex to ensure it's 4 digits
const adrNumber = adr.id.match(/^(\d{4})-/)?.[1] || "0000";
---

<Page title={`ADR-${adrNumber}: ${adr.data.title}`} description={`Architecture Decision Record: ${adr.data.title}`}>
  <h1 class={css({
	fontSize: '5xl',
	fontWeight: 'extrabold',
	_dark: { color: 'white' },
})}>
    <span class={css({ color: 'secondary', _dark: { color: 'secondary' } })}>ADR-{adrNumber}:</span> {adr.data.title}
  </h1>

  <div class={css({
	pos: 'relative',
	maxW: 'full',
	overflowX: 'hidden',
})}>
    <article class={cx('prose', css({
	w: 'full',
	maxW: 'full',
	_dark: { '& *': {} },
}))}>
      <header class={css({
	mb: '8',
	lg: { mb: '10' },
})}>
        <!-- Metadata card with glass morphism effect -->
        <div
          class={css({
	pos: 'relative',
	backdropBlur: 'sm',
	bg: 'white/30',
	rounded: 'xl',
	p: '6',
	borderWidth: '1px',
	borderColor: 'gray.200',
	shadow: 'lg',
	_dark: { bg: 'gray.800/30', borderColor: 'gray.700' },
})}
        >
          <div class={css({
	display: 'flex',
	flexDir: 'column',
	gap: '4',
})}>
            <!-- Author section -->
            {authors.length > 0 && (
              <div class={css({
	display: 'flex',
	flexDir: 'column',
})}>
                <div class={css({
	display: 'flex',
	flexWrap: 'wrap',
	gap: '2',
	mb: '2',
})}>
                  <div class={css({
	display: 'flex',
	gap: '-4',
})}>
                    {authors.filter(author => author && author.data).slice(0, 4).map((author, index) => (
                      <div class={css({
	pos: 'relative',
})} style={`z-index: ${10 - index}`}>
                        <img
                          class={css({
	w: '16',
	h: '16',
	minW: '16',
	rounded: 'full',
	objectFit: 'cover',
	borderWidth: '2px',
	borderColor: 'secondary',
	bg: 'white',
	_dark: { bg: 'gray.800' },
})}
                          src={author.data.avatarUrl}
                          alt={`Profile picture of ${author.data.name}`}
                        />
                        {index === 0 && (
                          <span class={css({
	pos: 'absolute',
	bottom: '0',
	right: '0',
	h: '4',
	w: '4',
	bg: 'green.400',
	rounded: 'full',
	borderWidth: '2px',
	borderColor: 'white',
	_dark: { borderColor: 'gray.800' },
})}></span>
                        )}
                      </div>
                    ))}
                    {authors.filter(author => author && author.data).length > 4 && (
                      <div class={css({
	pos: 'relative',
	zIndex: '0',
})}>
                        <div class={css({
	w: '16',
	h: '16',
	rounded: 'full',
	bg: 'white',
	borderWidth: '2px',
	borderColor: 'secondary',
	display: 'flex',
	alignItems: 'center',
	justifyContent: 'center',
	fontSize: 'sm',
	fontWeight: 'medium',
	color: 'secondary',
	_dark: { bg: 'gray.800', color: 'secondary' },
})}>
                          +{authors.filter(author => author && author.data).length - 4}
                        </div>
                      </div>
                    )}
                  </div>
                </div>
                <div class={css({
	display: 'flex',
	flexWrap: 'wrap',
	gap: '2',
	mt: '2',
})}>
                  {authors.filter(author => author && author.data).map((author) => (
                    <div class={css({
	display: 'inline-flex',
	alignItems: 'center',
	bg: 'primary/10',
	rounded: 'full',
	px: '3',
	py: '1',
	_dark: { bg: 'primary/20' },
})}>
                      <a
                        href={author.data.github}
                        target="_blank"
                        rel="author noopener noreferrer"
                        class={css({
	fontSize: 'sm',
	fontWeight: 'medium',
	color: 'secondary',
	_hover: { color: 'secondary/90' },
	_dark: { color: 'secondary', _hover: { color: 'secondary/90' } },
	transition: 'colors',
})}
                      >
                        {author.data.name}
                      </a>
                      <span class={css({
	mx: '1',
	color: 'secondary',
	_dark: { color: 'secondary' },
})}>&#8226;</span>
                      <span class={css({
	fontSize: 'xs',
	color: 'secondary',
	_dark: { color: 'secondary' },
})}>@{author.id}</span>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {authors.length > 0 && <div class={css({
	w: 'full',
	h: 'px',
	bg: 'gray.200',
	my: '2',
	_dark: { bg: 'gray.700' },
})}></div>}

            <!-- Status section -->
            <div class={css({
	display: 'flex',
	flexDir: 'column',
	md: {
		flexDir: 'row',
		alignItems: 'center',
		justifyContent: 'space-between',
	},
})}>
              <div class={css({
	mt: '2',
	md: { mt: '0' },
})}>
                {adr.data.adoptedAt ? (
                  <div class={css({
	display: 'flex',
	alignItems: 'center',
})}>
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class={css({
	h: '5',
	w: '5',
	color: 'green.500',
})}
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                      />
                    </svg>
                    <span class={css({
	ml: '2',
	fontSize: 'sm',
	fontWeight: 'medium',
	color: 'green.700',
	_dark: { color: 'green.400' },
})}>
                      Adopted on {formatDate(adr.data.adoptedAt)}
                    </span>
                  </div>
                ) : (
                  <div class={css({
	display: 'flex',
	alignItems: 'center',
})}>
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class={css({
	h: '5',
	w: '5',
	color: 'yellow.500',
})}
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
                      />
                    </svg>

                    <span class={css({
	ml: '2',
	fontSize: 'sm',
	fontWeight: 'medium',
	color: 'yellow.700',
	_dark: { color: 'yellow.400' },
})}>
                      Adopted on {formatDate(adr.data.adoptedAt)}
                    </span>
                  </div>
                )}
              </div>
            </div>
          </div>
        </div>
      </header>

      <div class={cx('prose', css({
	maxW: 'none',
}))}>
        <Content />
      </div>
    </article>
  </div>
</Page>
