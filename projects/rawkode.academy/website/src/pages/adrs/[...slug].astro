---
import { getCollection, getEntries, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import AdrJsonLd from "@/components/html/adr-jsonld.astro";
import Page from "@/wrappers/page.astro";
import type { GetStaticPaths, GetStaticPathsResult } from "astro";
import { createLogger } from "@/lib/logger";
import { css } from "../../../styled-system/css";

export const prerender = true;

const logger = createLogger("adrs");

type Props = { adr: CollectionEntry<"adrs"> };

export const getStaticPaths: GetStaticPaths = async (): Promise<GetStaticPathsResult> => {
	const adrs = await getCollection("adrs");
	const sorted = [...adrs].sort((a, b) => {
		const an = a.id.match(/^(\d{4})-/)?.[1] || "0000";
		const bn = b.id.match(/^(\d{4})-/)?.[1] || "0000";
		return Number.parseInt(an) - Number.parseInt(bn);
	});
	return sorted.map((adr, idx) => ({
		params: { slug: adr.id },
		props: {
			adr,
			prev: idx > 0 ? sorted[idx - 1] : null,
			next: idx < sorted.length - 1 ? sorted[idx + 1] : null,
		},
	}));
};

const { adr, prev, next } = Astro.props as Props & {
	prev: CollectionEntry<"adrs"> | null;
	next: CollectionEntry<"adrs"> | null;
};
const { Content } = await render(adr);

let authors: CollectionEntry<"people">[] = [];
try {
	authors = await getEntries(adr.data.authors);
} catch (error) {
	logger.error(`Error fetching authors for ADR ${adr.id}`, error);
}

const formatDate = (date: Date) =>
	new Intl.DateTimeFormat("en-US", { year: "numeric", month: "long", day: "numeric" }).format(date);

const adrNumber = adr.id.match(/^(\d{4})-/)?.[1] || "0000";

const shell = css({ maxWidth: "56rem", mx: "auto", px: { base: "4", md: "6" }, py: "12" });

const backLink = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	fontSize: "sm",
	color: "fg.muted",
	fontWeight: "medium",
	textDecoration: "none",
	mb: "8",
	transition: "color 150ms ease",
	_hover: { color: "fg.brand" },
});

const sigilLarge = css({
	display: "inline-flex",
	px: "3.5",
	py: "1",
	mb: "4",
	borderRadius: "full",
	bg: "bg.brand-subtle",
	color: "fg.brand",
	fontFamily: "mono",
	fontSize: "sm",
	fontWeight: "bold",
	letterSpacing: "wider",
});

const titleClass = css({
	fontFamily: "display",
	fontSize: { base: "3xl", md: "4xl", lg: "5xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	lineHeight: "1.1",
	color: "fg.primary",
	mb: "8",
});

const numberClass = css({ color: "fg.brand", display: "none" });

const navRow = css({
	mt: "16",
	pt: "8",
	borderTopWidth: "1px",
	borderTopColor: "border.muted",
	display: "grid",
	gridTemplateColumns: { base: "1fr", md: "1fr 1fr" },
	gap: "4",
});

const navCard = css({
	display: "flex",
	flexDirection: "column",
	gap: "1",
	p: "5",
	borderRadius: "xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textDecoration: "none",
	color: "fg.primary",
	transition: "all 150ms ease",
	_hover: { borderColor: "border.default", transform: "translateY(-2px)" },
});

const navLabel = css({ fontSize: "xs", fontWeight: "semibold", color: "fg.muted", textTransform: "uppercase", letterSpacing: "wider" });
const navTitle = css({ fontSize: "md", fontWeight: "semibold", color: "fg.primary" });

const metaCard = css({
	p: "6",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	mb: "10",
	display: "flex",
	flexDirection: "column",
	gap: "4",
});

const authorList = css({ display: "flex", flexWrap: "wrap", gap: "3" });

const authorChip = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "3",
	py: "1.5",
	borderRadius: "full",
	bg: "bg.brand-subtle",
	color: "fg.brand",
	fontSize: "sm",
	fontWeight: "medium",
	textDecoration: "none",
});

const authorAvatar = css({
	width: "6",
	height: "6",
	borderRadius: "full",
	objectFit: "cover",
});

const status = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	fontSize: "sm",
	fontWeight: "medium",
	color: "fg.brand",
});

const proseClass = css({
	color: "fg.secondary",
	fontSize: "md",
	lineHeight: "1.7",
	"& h2": {
		fontFamily: "display",
		fontSize: "2xl",
		fontWeight: "bold",
		color: "fg.primary",
		mt: "10",
		mb: "4",
	},
	"& h3": {
		fontFamily: "display",
		fontSize: "xl",
		fontWeight: "semibold",
		color: "fg.primary",
		mt: "8",
		mb: "3",
	},
	"& p": { my: "4" },
	"& ul, & ol": { pl: "6", my: "4" },
	"& ul": { listStyle: "disc" },
	"& ol": { listStyle: "decimal" },
	"& li": { my: "1" },
	"& a": { color: "fg.brand", textDecoration: "underline" },
	"& code": { fontFamily: "mono", bg: "bg.sunken", px: "1.5", py: "0.5", borderRadius: "sm", fontSize: "0.9em" },
	"& pre": {
		fontFamily: "mono",
		bg: "bg.sunken",
		p: "4",
		borderRadius: "md",
		overflow: "auto",
		my: "4",
		borderWidth: "1px",
		borderColor: "border.muted",
	},
	"& pre code": { bg: "transparent", p: "0" },
	"& blockquote": {
		borderLeftWidth: "3px",
		borderLeftColor: "fg.brand",
		pl: "4",
		my: "4",
		fontStyle: "italic",
		color: "fg.muted",
	},
});
---

<Page title={`ADR-${adrNumber}: ${adr.data.title}`} description={`Architecture Decision Record: ${adr.data.title}`}>
	<AdrJsonLd slot="extra-head" adr={adr} authors={authors} />

	<div class={shell}>
		<a href="/adrs" class={backLink}>
			<svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
				<path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
			</svg>
			All decisions
		</a>
		<span class={sigilLarge}>ADR-{adrNumber}</span>
		<h1 class={titleClass}>{adr.data.title}</h1>

		<div class={metaCard}>
			{authors.length > 0 && (
				<div class={authorList}>
					{authors.filter((a) => a && a.data).map((author) => (
						<a href={author.data.github} target="_blank" rel="author noopener noreferrer" class={authorChip}>
							<img class={authorAvatar} src={author.data.avatarUrl} alt={author.data.name} />
							{author.data.name}
						</a>
					))}
				</div>
			)}
			<span class={status}>
				<svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
				</svg>
				Adopted on {formatDate(adr.data.adoptedAt)}
			</span>
		</div>

		<article class={proseClass}>
			<Content />
		</article>

		{(prev || next) && (
			<nav class={navRow} aria-label="ADR navigation">
				{prev ? (
					<a href={`/adrs/${prev.id}`} class={navCard}>
						<span class={navLabel}>← Previous</span>
						<span class={navTitle}>ADR-{prev.id.match(/^(\d{4})-/)?.[1] || "0000"}: {prev.data.title}</span>
					</a>
				) : <span />}
				{next ? (
					<a href={`/adrs/${next.id}`} class={navCard} style="text-align: right;">
						<span class={navLabel}>Next →</span>
						<span class={navTitle}>ADR-{next.id.match(/^(\d{4})-/)?.[1] || "0000"}: {next.data.title}</span>
					</a>
				) : <span />}
			</nav>
		)}
	</div>
</Page>
