---
import FAQJsonLD from "@/components/html/faq-jsonld.astro";
import EditorialShell from "@/components/ui/EditorialShell.astro";
import Page from "@/wrappers/page.astro";

export const prerender = true;

const trainingFAQs = [
	{
		question: "How many people can attend a training session?",
		answer:
			"For in-person workshops, we usually recommend up to 20 participants per instructor. For live remote training, 12-15 participants keeps the session interactive and gives everyone time for support.",
	},
	{
		question: "Do you provide training materials to participants?",
		answer:
			"Yes. Participants receive digital materials, lab instructions, example code, and follow-up resources. For custom workshops, the materials are adapted to your stack and goals.",
	},
	{
		question: "How far in advance should we book training?",
		answer:
			"Four to six weeks is ideal for standard workshops. Custom programs, on-site delivery, or multi-session plans benefit from eight to twelve weeks of planning.",
	},
	{
		question: "What prerequisites should participants have?",
		answer:
			"Prerequisites depend on the topic. We usually ask for basic command-line fluency and familiarity with containers, CI/CD, or cloud concepts. We can provide prep notes when needed.",
	},
	{
		question: "I have additional questions about training programs.",
		answer:
			"Book a conversation with us and we will help shape the right program, audience level, and delivery format.",
	},
];

const programs = [
	{
		title: "Kubernetes for developers and operators",
		body: "A practical path from application deployment to production operations, tuned for the way your team uses Kubernetes.",
		items: ["Workloads and networking", "Production operations", "Debugging patterns"],
	},
	{
		title: "Infrastructure as Code",
		body: "Terraform and Pulumi training focused on reviewable modules, testing, state, environments, and migration patterns.",
		items: ["Module design", "Testing and policy", "Team workflows"],
	},
	{
		title: "GitOps delivery",
		body: "Build confidence with declarative delivery using Flux or Argo CD, including promotion, rollback, and environment design.",
		items: ["Repository structure", "Reconciliation model", "Release workflows"],
	},
	{
		title: "SRE and observability",
		body: "Teach teams how to define useful signals, design alerts, run incidents, and learn from production behavior.",
		items: ["SLIs and SLOs", "Metrics and tracing", "Incident practice"],
	},
	{
		title: "Platform engineering",
		body: "Help platform teams define golden paths, service interfaces, and developer workflows that reduce friction.",
		items: ["Internal platforms", "Self-service design", "Developer experience"],
	},
	{
		title: "Rust and Go for infrastructure",
		body: "Hands-on software training for teams building operators, CLIs, APIs, and infrastructure services.",
		items: ["Project structure", "Testing discipline", "Production patterns"],
	},
];

const deliveryModes = [
	{
		title: "Live remote",
		body: "Interactive sessions with screen sharing, lab support, and short feedback loops.",
	},
	{
		title: "On-site workshop",
		body: "Focused team training when the context, pace, or collaboration style benefits from being in the same room.",
	},
	{
		title: "Custom program",
		body: "A multi-session path built around your stack, maturity, and the outcomes your leaders need to see.",
	},
];

const outcomes = [
	"Shared vocabulary across engineering, platform, and operations teams",
	"Hands-on labs that mirror real work instead of toy examples",
	"Clear next steps for applying the material after the workshop",
	"Optional pairing and consulting follow-through when teams want help shipping the change",
];
---

<Page
	title="Technical Training"
	description="Hands-on cloud native, platform engineering, Kubernetes, GitOps, and infrastructure training for engineering teams."
>
	<FAQJsonLD questions={trainingFAQs} slot="extra-head" />
	<EditorialShell
		eyebrow="Organizations"
		title="Training"
		lede="Practical technical training for teams that need to understand the tools, operate them with confidence, and apply the lessons immediately."
	>
		<div class="editorial-actions" slot="actions">
			<a class="editorial-button" href="/organizations/lets-chat">Plan training</a>
			<a class="editorial-button editorial-button--secondary" href="#programs">View programs</a>
		</div>

		<section class="editorial-section">
			<div class="editorial-stat-grid">
				<div class="editorial-stat">
					<span class="editorial-stat__value">Live</span>
					<span class="editorial-stat__label">Instructor-led sessions</span>
				</div>
				<div class="editorial-stat">
					<span class="editorial-stat__value">Labs</span>
					<span class="editorial-stat__label">Hands-on delivery</span>
				</div>
				<div class="editorial-stat">
					<span class="editorial-stat__value">Custom</span>
					<span class="editorial-stat__label">Built around your stack</span>
				</div>
			</div>
		</section>

		<section id="programs" class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">Programs</p>
				<h2 class="editorial-section__title">Training that maps to real engineering work</h2>
				<p class="editorial-section__lede">
					Each program can run as a focused workshop or become part of a longer enablement plan.
				</p>
			</div>
			<div class="editorial-grid editorial-grid--2">
				{programs.map((program) => (
					<article class="editorial-card">
						<h3 class="editorial-card__title">{program.title}</h3>
						<p class="editorial-card__body">{program.body}</p>
						<ul class="editorial-list">
							{program.items.map((item) => <li>{item}</li>)}
						</ul>
					</article>
				))}
			</div>
		</section>

		<section class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">Delivery</p>
				<h2 class="editorial-section__title">Formats that fit the team</h2>
				<p class="editorial-section__lede">
					Training works best when it respects the team size, skill level, and working context.
				</p>
			</div>
			<div class="editorial-grid editorial-grid--3">
				{deliveryModes.map((mode) => (
					<article class="editorial-card editorial-card--paper">
						<h3 class="editorial-card__title">{mode.title}</h3>
						<p class="editorial-card__body">{mode.body}</p>
					</article>
				))}
			</div>
		</section>

		<section class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">Outcomes</p>
				<h2 class="editorial-section__title">What participants leave with</h2>
			</div>
			<div class="editorial-card">
				<ul class="editorial-list">
					{outcomes.map((outcome) => <li>{outcome}</li>)}
				</ul>
			</div>
		</section>

		<section class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">Questions</p>
				<h2 class="editorial-section__title">Training FAQ</h2>
			</div>
			<div class="editorial-faq">
				{trainingFAQs.map((item, index) => (
					<details open={index === 0}>
						<summary>{item.question}</summary>
						<p>{item.answer}</p>
					</details>
				))}
			</div>
		</section>

		<section class="editorial-section">
			<div class="editorial-callout">
				<div>
					<h2 class="editorial-section__title">Need training tied to a migration or platform rollout?</h2>
					<p class="editorial-card__body">
						We can pair training with consulting so the learning lands inside the work your team already has to ship.
					</p>
				</div>
				<a class="editorial-button" href="/organizations/lets-chat">Discuss a program</a>
			</div>
		</section>
	</EditorialShell>
</Page>
