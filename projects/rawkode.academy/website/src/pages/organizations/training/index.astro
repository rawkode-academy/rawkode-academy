---
import PageHero from "@/components/layout/PageHero.astro";
import Page from "@/wrappers/page.astro";
import { css } from "../../../../styled-system/css";

export const prerender = true;

const programmes = [
	{ title: "Cloud Native Fundamentals", description: "From containers to orchestration — a hands-on introduction to the cloud native stack for engineers new to Kubernetes.", duration: "2 days" },
	{ title: "Kubernetes Production Readiness", description: "What it actually takes to run Kubernetes in production — observability, security, multi-tenancy, and reliability practices.", duration: "3 days" },
	{ title: "Platform Engineering Workshop", description: "Designing an internal developer platform — golden paths, IDPs, team topologies, and the build/buy/borrow decisions in between.", duration: "2 days" },
	{ title: "Custom curriculum", description: "Tailored programmes built around your team's tech stack, goals, and existing skill levels.", duration: "Custom" },
];

const features = [
	"Custom curriculum design",
	"Hands-on labs with real cluster access",
	"Real-world scenarios drawn from production incidents",
	"Ongoing learning support after the workshop",
];

const shell = css({ maxWidth: "80rem", mx: "auto", px: { base: "4", md: "6" }, py: "12" });

const grid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", md: "repeat(2, minmax(0, 1fr))" },
	gap: "5",
});

const card = css({
	p: "6",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	display: "flex",
	flexDirection: "column",
	gap: "3",
});

const programmeMeta = css({
	display: "inline-flex",
	px: "2.5",
	py: "0.5",
	borderRadius: "full",
	bg: "bg.brand-subtle",
	color: "fg.brand",
	fontSize: "xs",
	fontWeight: "semibold",
	letterSpacing: "wider",
	textTransform: "uppercase",
	alignSelf: "flex-start",
});

const cardTitle = css({ fontFamily: "display", fontSize: "lg", fontWeight: "bold", color: "fg.primary" });
const cardBody = css({ color: "fg.secondary", lineHeight: "1.6" });

const sectionBlock = css({ mt: "16" });

const sectionTitle = css({
	fontFamily: "display",
	fontSize: { base: "2xl", md: "3xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	color: "fg.primary",
	mb: "8",
	textAlign: "center",
});

const featureGrid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", sm: "repeat(2, minmax(0, 1fr))" },
	gap: "4",
	maxWidth: "48rem",
	mx: "auto",
});

const featureItem = css({
	display: "flex",
	alignItems: "flex-start",
	gap: "3",
	p: "4",
	borderRadius: "xl",
	bg: "bg.raised",
	borderWidth: "1px",
	borderColor: "border.muted",
});

const checkIcon = css({ flexShrink: 0, color: "fg.brand", mt: "0.5" });

const ctaCard = css({
	mt: "16",
	mx: "auto",
	maxWidth: "60rem",
	p: { base: "8", md: "12" },
	borderRadius: "3xl",
	textAlign: "center",
	color: "white",
	backgroundImage: "linear-gradient(135deg, token(colors.brand.500), token(colors.cyan.500))",
	boxShadow: "xl",
});

const ctaTitle = css({ fontFamily: "display", fontSize: { base: "2xl", md: "3xl" }, fontWeight: "bold" });
const ctaBody = css({ mt: "3", fontSize: { base: "md", md: "lg" }, opacity: "0.92" });

const ctaBtn = css({
	mt: "8",
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "6",
	py: "3",
	borderRadius: "lg",
	fontWeight: "semibold",
	color: "fg.primary",
	bg: "white",
	textDecoration: "none",
	_hover: { transform: "translateY(-1px)" },
});
---

<Page title="Team Training | Rawkode Academy" description="Empower your teams with hands-on cloud native training programmes tailored to your needs.">
	<PageHero eyebrow="Training" title="Hands-On Team Training" subtitle="Cloud native training programmes for engineering teams — real clusters, real production scenarios, real outcomes." />

	<div class={shell}>
		<div class={grid}>
			{programmes.map((p) => (
				<div class={card}>
					<span class={programmeMeta}>{p.duration}</span>
					<h2 class={cardTitle}>{p.title}</h2>
					<p class={cardBody}>{p.description}</p>
				</div>
			))}
		</div>

		<section class={sectionBlock}>
			<h2 class={sectionTitle}>What every programme includes</h2>
			<div class={featureGrid}>
				{features.map((f) => (
					<div class={featureItem}>
						<svg class={checkIcon} width="20" height="20" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
						<span>{f}</span>
					</div>
				))}
			</div>
		</section>

		<section class={ctaCard}>
			<h2 class={ctaTitle}>Train your team</h2>
			<p class={ctaBody}>Tell us about your team's goals — we'll design a programme that fits.</p>
			<a href="/organizations/lets-chat" class={ctaBtn}>
				Get in touch
				<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 5l7 7-7 7" /></svg>
			</a>
		</section>
	</div>
</Page>
