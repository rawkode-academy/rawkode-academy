---
import PageHero from "@/components/layout/PageHero.astro";
import Page from "@/wrappers/page.astro";
import { css } from "../../../styled-system/css";

const benefits = [
	"Your product's unique value proposition and how to effectively communicate it to developers",
	"Your current developer marketing challenges and opportunities",
	"Which partnership tier would best align with your business objectives",
	"Potential content strategies and formats to showcase your technology",
	"How we measure success and provide ongoing value throughout our partnership",
];

const shell = css({ maxWidth: "56rem", mx: "auto", px: { base: "4", md: "6" }, py: "12" });

const card = css({
	p: { base: "6", md: "8" },
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	mb: "8",
});

const intro = css({ fontSize: "lg", color: "fg.secondary", lineHeight: "1.7", mb: "6" });

const link = css({ color: "fg.brand", textDecoration: "underline" });

const sectionTitle = css({
	fontFamily: "display",
	fontSize: "xl",
	fontWeight: "bold",
	color: "fg.primary",
	mb: "4",
});

const benefitList = css({ display: "flex", flexDirection: "column", gap: "3", listStyle: "none", p: "0", m: "0" });

const benefitItem = css({ display: "flex", alignItems: "flex-start", gap: "3", fontSize: "md", color: "fg.secondary", lineHeight: "1.6" });

const checkIcon = css({ flexShrink: 0, color: "fg.brand", mt: "1" });

const bookingWrap = css({
	p: "6",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.surface",
});

const bookingTitle = css({
	fontFamily: "display",
	fontSize: "xl",
	fontWeight: "bold",
	color: "fg.primary",
	textAlign: "center",
	mb: "6",
});

const bookingFrame = css({ width: "full", minHeight: "600px", overflow: "hidden" });
---

<Page title="Schedule a Partnership Consultation" description="Discuss how Rawkode Academy can help accelerate your developer marketing strategy and product adoption.">
	<PageHero eyebrow="Let's Chat" title="Schedule a Consultation" subtitle="Tell us about your goals and we'll outline how a partnership, consulting engagement, or training plan can help." />

	<div class={shell}>
		<div class={card}>
			<p class={intro}>
				Ready to explore how a <a href="/organizations/partnerships" class={link}>Rawkode Academy partnership</a> can accelerate your developer marketing strategy and product adoption? Schedule a consultation with our team to discuss your specific goals and how we can help you achieve them.
			</p>
			<h2 class={sectionTitle}>During our consultation, we'll discuss</h2>
			<ul class={benefitList}>
				{benefits.map((benefit) => (
					<li class={benefitItem}>
						<svg class={checkIcon} width="20" height="20" fill="currentColor" viewBox="0 0 20 20">
							<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
						</svg>
						<span>{benefit}</span>
					</li>
				))}
			</ul>
		</div>

		<div class={bookingWrap}>
			<h2 class={bookingTitle}>Select a time that works for you</h2>
			<div id="booking-page" class={bookingFrame}></div>
			<script is:inline>
				window.SavvyCal = window.SavvyCal || function () {
					(SavvyCal.q = SavvyCal.q || []).push(arguments);
				};
			</script>
			<script is:inline async src="https://embed.savvycal.com/v1/embed.js"></script>
			<script is:inline>
				SavvyCal("init", { origin: "https://meet.rawkode.academy" });
				SavvyCal("inline", { link: "collaborate", selector: "#booking-page", theme: "os" });
			</script>
		</div>
	</div>
</Page>
