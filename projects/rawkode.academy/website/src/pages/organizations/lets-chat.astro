---
import EditorialShell from "@/components/ui/EditorialShell.astro";
import Page from "@/wrappers/page.astro";

export const prerender = true;

const contactHref =
	"mailto:david@rawkode.academy?subject=Partnership%20fit%20check&body=Company%2Fcategory%3A%0D%0APreferred%20partnership%20path%3A%0D%0ATarget%20technical%20evaluator%3A%0D%0ATeam%20stakeholders%3A%0D%0ADeadline%20or%20launch%20window%3A%0D%0ADocs%2C%20demos%2C%20architecture%20notes%2C%20or%20enablement%20material%3A%0D%0AInfrastructure%20artifacts%20available%3A%0D%0AAdoption%20risk%20or%20decision%20to%20review%3A%0D%0ALinks%2C%20if%20useful%3A";

const requiredContext = [
	"Company or product category",
	"Preferred partnership path",
	"Target technical evaluator",
	"Team stakeholders",
	"The adoption risk or decision to review",
	"Deadline or launch window",
	"Docs, demos, architecture notes, or enablement material",
];

const optionalContext = [
	"Helm charts, CRDs, RBAC/IAM notes, Terraform, architecture notes, telemetry, tenancy, runbooks, demo environment, or docs paths",
	"Current blockers from sales, product, marketing, DevRel, sales engineering, platform, or security",
	"What happens next if the review is useful",
];
---

<Page
	title="Partnership Fit Check"
	description="Email a partnership brief for a Rawkode technical adoption fit check."
>
	<EditorialShell
		eyebrow="Partnerships"
		title="Email a partnership brief"
		lede="Send rough context on the technical product, the evaluator you need to help, and the decision in front of your marketing, product, DevRel, sales engineering, and technical owners. If there is a fit, David will reply with the right next step and a call option."
	>
		<div class="editorial-actions" slot="actions">
			<a class="editorial-button" href={contactHref}>Email partnership brief</a>
			<a class="editorial-button editorial-button--secondary" href="/organizations/partnerships">Compare packages</a>
		</div>

		<section class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">What to send</p>
				<h2 class="editorial-section__title">Rough context is enough.</h2>
				<p class="editorial-section__lede">
					This is not a procurement form. The first email should make the adoption problem clear enough to judge fit.
				</p>
			</div>
			<div class="fit-check-grid">
				<article class="editorial-card">
					<h3 class="editorial-card__title">Useful first email</h3>
					<ul class="editorial-list">
						{requiredContext.map((item) => <li>{item}</li>)}
					</ul>
				</article>
				<article class="editorial-card editorial-card--paper">
					<h3 class="editorial-card__title">Optional links</h3>
					<ul class="editorial-list">
						{optionalContext.map((item) => <li>{item}</li>)}
					</ul>
				</article>
			</div>
		</section>

		<section class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">What happens next</p>
				<h2 class="editorial-section__title">The reply should make the next move obvious.</h2>
			</div>
			<div class="editorial-card editorial-card--paper">
				<p class="editorial-card__body">
					David will tell you whether the problem looks like an Adoption Risk Audit, Monthly Partnership, Launch Review Sprint, or a poor fit. If a call is useful, it can be arranged from there.
				</p>
			</div>
		</section>
	</EditorialShell>
</Page>

<style>
	.fit-check-grid {
		display: grid;
		gap: 1rem;
	}

	@media (min-width: 760px) {
		.fit-check-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}
</style>
