---
import PageHero from "@/components/layout/PageHero.astro";
import Page from "@/wrappers/page.astro";
import FAQJsonLD from "@/components/html/faq-jsonld.astro";
import { css } from "../../../../styled-system/css";

export const prerender = true;

const valueProps = [
	{ title: "Authentic technical content", description: "Expert-led tutorials, walkthroughs, and reviews that show your technology in real engineering work — not marketing fluff." },
	{ title: "Developer community engagement", description: "Direct conversations with engineers through live streams, AMAs, and community programmes." },
	{ title: "Flexible partnership tiers", description: "Engagement levels designed to match different budgets and content needs — from project-based to long-term annual programmes." },
	{ title: "Measurable outcomes", description: "Comprehensive analytics tailored to your goals — engagement, sentiment, community growth, and product adoption indicators." },
];

const pillars = [
	{ name: "Developer Marketing", tagline: "We inspire developers", description: "Authentic technical content that puts your product in the hands of engineers." },
	{ name: "Developer Education", tagline: "We level up developers", description: "Tutorials, learning paths, and workshops that turn curiosity into adoption." },
	{ name: "Developer Experience", tagline: "We support developers", description: "DX audits, docs reviews, and onboarding optimisation rooted in real feedback." },
];

const tiers = [
	{ name: "Nip", scope: "Essential visibility", highlights: ["Featured content placement", "Quarterly check-ins", "Annual programme"] },
	{ name: "Dram", scope: "Most popular", featured: true, highlights: ["Everything in Nip", "Co-produced video series", "Community AMA & launch support"] },
	{ name: "Blend", scope: "Extensive collaboration", highlights: ["Everything in Dram", "Dedicated DevRel hours", "Strategic content calendar"] },
	{ name: "Malt", scope: "Premier engagement", highlights: ["Everything in Blend", "Hands-on consulting hours", "Co-branded campaigns"] },
];

const partnershipFAQs = [
	{
		question: "What is the minimum partnership duration?",
		answer: "Our partnerships are structured as annual engagements to ensure we can deliver meaningful results. Developer marketing and education require a strategic, long-term approach to build awareness, trust, and adoption.",
	},
	{
		question: "What are the payment terms for partnerships?",
		answer: "For our entry tiers we typically require annual payment upfront. For larger engagements we offer flexible payment options including quarterly or semi-annual installments.",
	},
	{
		question: "How do you measure partnership success?",
		answer: "We provide comprehensive analytics tailored to your goals. Metrics include content engagement, developer sentiment, community growth, and product adoption indicators. All partnerships include regular performance reviews.",
	},
	{
		question: "How do you qualify potential partners?",
		answer: "We partner with companies that offer genuine value to developers and align with our mission of advancing developer education. We evaluate potential partners based on innovation, relevance, and community impact.",
	},
];

const shell = css({ maxWidth: "72rem", mx: "auto", px: { base: "4", md: "6" }, py: "12" });

const sectionLabel = css({ fontSize: "xs", fontWeight: "bold", letterSpacing: "wider", textTransform: "uppercase", color: "fg.brand", textAlign: "center", mb: "3" });

const grid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", md: "repeat(2, minmax(0, 1fr))" },
	gap: "5",
});

const pillarsGrid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", md: "repeat(3, minmax(0, 1fr))" },
	gap: "5",
	mb: "16",
});

const pillarCard = css({
	p: "6",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textAlign: "center",
});

const pillarName = css({ fontFamily: "display", fontSize: "lg", fontWeight: "bold", color: "fg.primary", mb: "1" });
const pillarTagline = css({ fontSize: "sm", color: "fg.brand", fontWeight: "semibold", mb: "3" });
const pillarBody = css({ fontSize: "sm", color: "fg.secondary", lineHeight: "1.6" });

const tierGrid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", sm: "repeat(2, minmax(0, 1fr))", lg: "repeat(4, minmax(0, 1fr))" },
	gap: "4",
	mb: "16",
});

const tierCard = css({
	position: "relative",
	display: "flex",
	flexDirection: "column",
	gap: "3",
	p: "6",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
});

const tierCardFeatured = css({
	borderColor: "fg.brand",
	boxShadow: "0 0 0 1px var(--colors-fg-brand)",
});

const tierBadge = css({
	position: "absolute",
	top: "-3",
	right: "5",
	px: "2.5",
	py: "0.5",
	borderRadius: "full",
	bg: "bg.brand",
	color: "fg.on-brand",
	fontSize: "2xs",
	fontWeight: "bold",
	letterSpacing: "wider",
	textTransform: "uppercase",
});

const tierName = css({
	fontFamily: "display",
	fontSize: "2xl",
	fontWeight: "bold",
	letterSpacing: "tight",
	backgroundImage: "linear-gradient(135deg, token(colors.brand.500), token(colors.cyan.500))",
	backgroundClip: "text",
	color: "transparent",
});

const tierScope = css({ fontSize: "sm", color: "fg.muted", fontWeight: "medium" });

const tierList = css({ display: "flex", flexDirection: "column", gap: "2", mt: "2", listStyle: "none", p: "0" });
const tierItem = css({
	display: "flex",
	alignItems: "flex-start",
	gap: "2",
	fontSize: "sm",
	color: "fg.secondary",
	lineHeight: "1.5",
});
const tierCheck = css({ color: "fg.brand", flexShrink: 0, mt: "0.5" });

const card = css({
	p: "6",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
});

const cardTitle = css({
	fontFamily: "display",
	fontSize: "lg",
	fontWeight: "bold",
	color: "fg.primary",
	mb: "3",
});

const cardBody = css({ color: "fg.secondary", lineHeight: "1.6" });

const sectionBlock = css({ mt: "16" });

const sectionTitle = css({
	fontFamily: "display",
	fontSize: { base: "2xl", md: "3xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	color: "fg.primary",
	mb: "8",
	textAlign: "center",
});

const faqList = css({ display: "flex", flexDirection: "column", gap: "3", maxWidth: "48rem", mx: "auto" });

const faqItem = css({
	p: "5",
	borderRadius: "xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
});

const faqQ = css({
	fontWeight: "semibold",
	color: "fg.primary",
	fontSize: "md",
	mb: "2",
	cursor: "pointer",
	listStyle: "none",
});

const faqA = css({ color: "fg.secondary", lineHeight: "1.6", fontSize: "sm" });

const ctaCard = css({
	mt: "16",
	mx: "auto",
	maxWidth: "60rem",
	p: { base: "8", md: "12" },
	borderRadius: "3xl",
	textAlign: "center",
	color: "white",
	backgroundImage: "linear-gradient(135deg, token(colors.brand.500), token(colors.cyan.500))",
	boxShadow: "xl",
});

const ctaTitle = css({ fontFamily: "display", fontSize: { base: "2xl", md: "3xl" }, fontWeight: "bold" });
const ctaBody = css({ mt: "3", fontSize: { base: "md", md: "lg" }, opacity: "0.92", maxWidth: "40rem", mx: "auto" });

const ctaBtn = css({
	mt: "8",
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "6",
	py: "3",
	borderRadius: "lg",
	fontWeight: "semibold",
	color: "fg.primary",
	bg: "white",
	textDecoration: "none",
	_hover: { transform: "translateY(-1px)" },
});
---

<Page title="Strategic Technology Partnerships | Rawkode Academy" description="Partner with Rawkode Academy to accelerate developer adoption, improve product experience, and drive growth.">
	<FAQJsonLD questions={partnershipFAQs} slot="head" />

	<PageHero eyebrow="Partner With Us" title="Strategic Technology Partnerships" subtitle="Accelerate developer adoption and product growth through authentic technical content and strategic guidance." />

	<div class={shell}>
		<p class={sectionLabel}>Three-pillar approach</p>
		<h2 class={sectionTitle}>How we accelerate developer adoption</h2>
		<div class={pillarsGrid}>
			{pillars.map((p) => (
				<div class={pillarCard}>
					<h3 class={pillarName}>{p.name}</h3>
					<p class={pillarTagline}>{p.tagline}</p>
					<p class={pillarBody}>{p.description}</p>
				</div>
			))}
		</div>

		<p class={sectionLabel}>Partnership tiers</p>
		<h2 class={sectionTitle}>Engagement levels named after Scottish whisky measures</h2>
		<div class={tierGrid}>
			{tiers.map((tier) => (
				<div class={`${tierCard} ${tier.featured ? tierCardFeatured : ""}`}>
					{tier.featured && <span class={tierBadge}>Most popular</span>}
					<span class={tierName}>{tier.name}</span>
					<span class={tierScope}>{tier.scope}</span>
					<ul class={tierList}>
						{tier.highlights.map((h) => (
							<li class={tierItem}>
								<svg class={tierCheck} width="16" height="16" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
								<span>{h}</span>
							</li>
						))}
					</ul>
				</div>
			))}
		</div>

		<p class={sectionLabel}>What you get</p>
		<h2 class={sectionTitle}>Every partnership delivers</h2>
		<div class={grid}>
			{valueProps.map((vp) => (
				<div class={card}>
					<h2 class={cardTitle}>{vp.title}</h2>
					<p class={cardBody}>{vp.description}</p>
				</div>
			))}
		</div>

		<section class={sectionBlock}>
			<h2 class={sectionTitle}>Frequently asked questions</h2>
			<div class={faqList}>
				{partnershipFAQs.map((faq) => (
					<details class={faqItem}>
						<summary class={faqQ}>{faq.question}</summary>
						<p class={faqA}>{faq.answer}</p>
					</details>
				))}
			</div>
		</section>

		<section class={ctaCard}>
			<h2 class={ctaTitle}>Let's build something together</h2>
			<p class={ctaBody}>Schedule a consultation with our team to discuss your goals and how a partnership can help.</p>
			<a href="/organizations/lets-chat" class={ctaBtn}>
				Schedule a chat
				<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 5l7 7-7 7" /></svg>
			</a>
		</section>
	</div>
</Page>
