---
import FAQJsonLD from "@/components/html/faq-jsonld.astro";
import Page from "@/wrappers/page.astro";

export const prerender = true;

const contactHref =
	"mailto:david@rawkode.academy?subject=Partnership%20fit%20check&body=Company%2Fcategory%3A%0D%0APreferred%20partnership%20path%3A%0D%0ATarget%20technical%20evaluator%3A%0D%0ATeam%20stakeholders%3A%0D%0ADeadline%20or%20launch%20window%3A%0D%0ASurfaces%20to%20review%3A%0D%0AInfrastructure%20artifacts%20available%3A%0D%0AAdoption%20risk%20or%20decision%20to%20review%3A%0D%0ALinks%2C%20if%20useful%3A";

const faqs = [
	{
		question: "Is this paid media?",
		answer:
			"No. A partnership does not buy coverage, endorsement, paid mentions, guaranteed leads, or editorial placement. It is a focused commercial engagement around developer adoption.",
	},
	{
		question: "Do you replace our marketing, product, or DevRel team?",
		answer:
			"No. Rawkode works with marketing, product, DevRel, sales engineering, and technical owners so they can make better decisions. Your team keeps execution ownership; the partnership exposes where technical evaluators are likely to stall, distrust the claim, or miss the value.",
	},
	{
		question: "What should we bring first?",
		answer:
			"Send the company or product, the target technical evaluator, the decision you need to make, the team stakeholders, the review deadline, the surfaces or infrastructure artifacts available, and useful links. Rough context is enough.",
	},
	{
		question: "Why pay for this before budget moves?",
		answer:
			"The point is to avoid a larger wasted bet: a launch story practitioners do not believe, a docs or demo rebuild that still misses evaluation risk, a DevRel hire without a clear remit, or sales-engineering confusion that slows technical buyers. The output tells your team what to keep, change, prove, or kill before more spend is committed.",
	},
	{
		question: "How fast can this start?",
		answer:
			"The diagnostic is the fastest route when the problem is narrow. A monthly Adoption Partnership is better when several surfaces need to align before launch, repositioning, sales enablement, or DevRel spend. Three monthly cycles are often enough to move from risk map to corrected story to launch-ready proof.",
	},
	{
		question: "Do you plan campaigns or run DevRel for us?",
		answer:
			"No. The partnership reviews named adoption decisions, technical proof, docs paths, demos, launch narratives, and enablement surfaces. It does not include full campaign planning, outsourced DevRel execution, custom content production, or open-ended access.",
	},
	{
		question: "Is confidential material safe to share?",
		answer:
			"Start with public or shareable material. If a fit check shows private context is needed, we can agree the right confidentiality boundary before reviewing it.",
	},
];

const packages = [
	{
		name: "Adoption Diagnostic",
		price: "From £1,000",
		label: "Fixed scope",
		bestFor:
			"A launch claim, docs path, demo flow, homepage, comparison page, sales narrative, or named DevRel surface has practitioner-risk before budget moves.",
		outcome:
			"A proof-gap table, evaluator objection map, P0/P1 change list, and 60-minute readout showing what to change before a launch campaign, docs rebuild, demo reset, or enablement rollout.",
		included: [
			"Review of one adoption decision and the supporting material",
			"Evaluator objections, technical proof gaps, and infrastructure evidence gaps called out directly",
			"One 60-minute readout with marketing, product, DevRel, sales engineering, and technical stakeholders",
			"Written action summary within five business days of the review",
		],
		boundaries: ["No implementation", "No rewrites", "One focused decision"],
		cta: "Start a diagnostic",
		href: "mailto:david@rawkode.academy?subject=Adoption%20Diagnostic&body=Company%2Fcategory%3A%0D%0APreferred%20partnership%20path%3A%20Adoption%20Diagnostic%0D%0ATarget%20technical%20evaluator%3A%0D%0ATeam%20stakeholders%3A%0D%0ADeadline%20or%20launch%20window%3A%0D%0ASurfaces%20to%20review%3A%0D%0AInfrastructure%20artifacts%20available%3A%0D%0AThe%20one%20adoption%20decision%20to%20review%3A%0D%0ALinks%2C%20if%20useful%3A",
	},
	{
		name: "Adoption Partnership",
		price: "From £2,000 / month",
		label: "Default",
		bestFor:
			"Your team is preparing a launch, repositioning, docs reset, demo reset, named DevRel narrative, or sales enablement motion and several pieces need to tell the same technical story.",
		outcome:
			"An evaluator map, redlined notes on reviewed surfaces, proof-gap table, P0/P1 change list, and 30-day action plan each month.",
		included: [
			"Kickoff to map the target evaluator, buying trigger, technical artifacts, and risk points",
			"Monthly review of up to three named surfaces such as launch page, docs path, demo script, enablement deck, architecture notes, or operator workflow",
			"One working session per month with marketing, product, DevRel, sales engineering, and technical owners",
			"Monthly decision memo: what to keep, change, prove, or kill before more budget moves",
		],
		boundaries: [
			"Month-to-month",
			"Three-month plan available",
			"No campaign execution",
		],
		cta: "Send adoption context",
		href: contactHref,
		featured: true,
	},
	{
		name: "Partnership Review Sprint",
		price: "From £3,000 / month",
		label: "Escalation",
		bestFor:
			"A team already has an active Adoption Partnership or urgent launch window and needs bounded scrutiny across two adoption decisions before or after release.",
		outcome:
			"Two working sessions, 72-hour triage on P0 adoption risks, executive-ready adoption-risk memo, and pre/post-launch synthesis across product story, proof, docs, demos, and enablement.",
		included: [
			"Two 60-minute working sessions per month",
			"Review of up to six named surfaces across two active adoption decisions",
			"72-hour written triage for P0 adoption risks",
			"Executive-ready adoption-risk memo for marketing, product, DevRel, sales engineering, technical owners, and leadership",
		],
		boundaries: [
			"Bounded sprint",
			"Your team executes",
			"No standing retainer",
		],
		cta: "Send sprint context",
		href: "mailto:david@rawkode.academy?subject=Partnership%20Review%20Sprint&body=Company%2Fcategory%3A%0D%0APreferred%20partnership%20path%3A%20Partnership%20Review%20Sprint%0D%0ATarget%20technical%20evaluator%3A%0D%0ATeam%20stakeholders%3A%0D%0ADeadline%20or%20launch%20window%3A%0D%0AThe%20two%20adoption%20decisions%20to%20review%3A%0D%0ASurfaces%20to%20review%3A%0D%0AInfrastructure%20artifacts%20available%3A%0D%0ALinks%2C%20if%20useful%3A",
	},
];

const inspectAreas = [
	{
		title: "Quickstart truth",
		body: "Does the first install prove something useful, or hide Helm charts, CRDs, RBAC/IAM, state, egress, tenancy, and failure modes?",
	},
	{
		title: "Architecture and trust boundary",
		body: "Can a platform engineer see control-plane/data-plane boundaries, credential ownership, telemetry, SaaS versus self-hosted trust boundaries, and data retention?",
	},
	{
		title: "Demo reproducibility",
		body: "Does the demo show a believable operating path with Terraform, operators, rollback, upgrade, cost/resource profile, and runbook implications?",
	},
	{
		title: "Migration story",
		body: "What does a team replace, what breaks, how long migration takes, what data or model movement is required, and what success looks like after day one?",
	},
	{
		title: "Operational proof",
		body: "Are RBAC, auth, observability, upgrade, rollback, PII/log retention, GPU scheduling, scale, and failure handling explained well enough for evaluation?",
	},
	{
		title: "Sales engineer handoff",
		body: "Can sales, DevRel, sales engineering, security, and product experts answer the same technical objections without inventing different stories?",
	},
];

const triggers = [
	"A launch budget is about to move and the claim still feels thin.",
	"Docs explain installation but not evaluation, migration, or operation.",
	"The demo is impressive to insiders but does not change buyer confidence.",
	"DevRel activity is growing but adoption behavior is not changing.",
	"Sales needs a sharper technical story than the homepage gives them.",
	"A category or repositioning claim needs to survive practitioner scrutiny.",
];

const workExamples = [
	{
		title: "Launch readiness",
		body: "Turn a release narrative from feature inventory into a practitioner-facing argument: what changed, why it matters, who should care, and what proof backs it up.",
	},
	{
		title: "Docs path",
		body: "Separate tutorial, evaluation, migration, and operations content so technical buyers are not forced to infer production readiness from a quickstart.",
	},
	{
		title: "Demo and enablement",
		body: "Reshape a demo flow and sales narrative around the objections platform, security, SRE, and AI infrastructure teams are likely to raise first.",
	},
];

const markets = [
	"Cloud infrastructure",
	"Kubernetes",
	"Observability",
	"Platform engineering",
	"Security",
	"Data infrastructure",
	"AI infrastructure",
	"Commercial open source",
	"DevTool SaaS",
];
---

<Page
	title="Developer Adoption Partnerships"
	description="Cloud-native and DevTool SaaS adoption partnerships for teams improving positioning, launches, docs, demos, DevRel, and developer trust."
>
	<FAQJsonLD questions={faqs} slot="extra-head" />

	<main class="partnerships-page">
		<section class="partnerships-hero" aria-labelledby="partnerships-title">
			<p class="partnerships-kicker">Cloud-native and DevTool SaaS adoption partnerships</p>
			<div class="partnerships-hero__grid">
				<div class="partnerships-hero__copy">
					<h1 id="partnerships-title">Find the proof gaps blocking technical adoption.</h1>
					<p>
						Rawkode works with your marketing, product, DevRel, sales engineering, and technical owners to find the proof, story, docs, and demo gaps blocking technical trust.
						We do not replace those teams or run the work for them.
					</p>
					<div class="partnerships-actions">
						<a class="partnerships-button" href={contactHref}>Send your adoption context</a>
						<a class="partnerships-button partnerships-button--secondary" href="#inspect">See what gets reviewed</a>
					</div>
				</div>
				<aside class="partnerships-trigger" aria-label="Common buying trigger">
					<p class="partnerships-trigger__label">Use this before</p>
					<p>
						You fund a launch, rewrite docs, rebuild a demo, hire DevRel, or push sales enablement around a story practitioners may not believe yet.
					</p>
				</aside>
			</div>
		</section>

		<section id="inspect" class="partnerships-section partnerships-section--split" aria-labelledby="inspect-title">
			<div class="partnerships-section__header">
				<p class="partnerships-kicker">What we inspect</p>
				<h2 id="inspect-title">Practitioner-risk areas we review.</h2>
				<p>
					This is not generic brand feedback. Useful review needs product experts, architecture notes, demo environments, docs, and operational constraints because platform engineers, SREs, security teams, AI infrastructure teams, and technical founders evaluate risk.
				</p>
			</div>
			<div class="partnerships-card-grid">
				{inspectAreas.map((area) => (
					<article class="partnerships-card">
						<h3>{area.title}</h3>
						<p>{area.body}</p>
					</article>
				))}
			</div>
		</section>

		<section class="partnerships-section partnerships-section--split partnerships-section--markets" aria-labelledby="markets-title">
			<div class="partnerships-section__header">
				<p class="partnerships-kicker">Markets</p>
				<h2 id="markets-title">Built for technical products with real evaluation risk.</h2>
			</div>
			<ul class="partnerships-markets" aria-label="Relevant markets">
				{markets.map((market) => <li>{market}</li>)}
			</ul>
		</section>

		<section id="packages" class="partnerships-section partnerships-section--tight" aria-labelledby="packages-title">
			<div class="partnerships-section__header">
				<p class="partnerships-kicker">Partnership paths</p>
				<h2 id="packages-title">Pick the amount of scrutiny the decision needs.</h2>
				<p>
					Start with a diagnostic for one narrow decision. Use the monthly partnership when several surfaces need to align. Use a sprint when launch timing or two active adoption decisions need tighter scrutiny.
				</p>
			</div>
			<div class="partnerships-package-grid">
				{packages.map((pkg) => (
					<article class:list={["partnerships-package", { "partnerships-package--featured": pkg.featured }]}>
						<div class="partnerships-package__top">
							<p class="partnerships-package__label">{pkg.label}</p>
							<h3>{pkg.name}</h3>
							<p class="partnerships-package__price">{pkg.price}</p>
							<a class="partnerships-button" href={pkg.href}>{pkg.cta}</a>
						</div>
						<div>
							<h4>Choose this when</h4>
							<p>{pkg.bestFor}</p>
						</div>
						<div>
							<h4>What your team gets</h4>
							<p>{pkg.outcome}</p>
						</div>
						<div>
							<h4>Included</h4>
							<ul>
								{pkg.included.map((item) => <li>{item}</li>)}
							</ul>
						</div>
						<div>
							<h4>Boundaries</h4>
							<ul>
								{pkg.boundaries.map((item) => <li>{item}</li>)}
							</ul>
						</div>
					</article>
				))}
			</div>
		</section>

		<section class="partnerships-section partnerships-section--split" aria-labelledby="company-maintainer-title">
			<div class="partnerships-section__header">
				<p class="partnerships-kicker">Maintainers vs companies</p>
				<h2 id="company-maintainer-title">This page is the paid company route.</h2>
			</div>
			<div class="partnerships-work-grid">
				<article class="partnerships-work">
					<h3>Companies</h3>
					<p>Use partnerships for hosted products, enterprise features, launches, positioning, docs, demos, sales enablement, and adoption decisions that need commercial follow-through.</p>
				</article>
				<article class="partnerships-work">
					<h3>Maintainers</h3>
					<p>Free project sharing for maintainers lives at <a href="/maintainers/share-your-project">Share Your Project</a>. That route is for showing useful open source work, not buying adoption review.</p>
				</article>
			</div>
		</section>

		<section class="partnerships-section partnerships-section--split" aria-labelledby="triggers-title">
			<div class="partnerships-section__header">
				<p class="partnerships-kicker">Good fit</p>
				<h2 id="triggers-title">Bring the work when the next move is expensive.</h2>
			</div>
			<ul class="partnerships-trigger-list">
				{triggers.map((trigger) => <li>{trigger}</li>)}
			</ul>
		</section>

		<section class="partnerships-section partnerships-section--split" aria-labelledby="proof-title">
			<div class="partnerships-section__header">
				<p class="partnerships-kicker">Why Rawkode</p>
				<h2 id="proof-title">The review comes from years of explaining infrastructure in public.</h2>
			</div>
			<div class="partnerships-work-grid">
				<article class="partnerships-work">
					<h3>90+ technologies covered</h3>
					<p>Kubernetes, observability, identity, platform engineering, WebAssembly, security, data, AI infrastructure, and developer tooling.</p>
				</article>
				<article class="partnerships-work">
					<h3>Public technical judgement</h3>
					<p>Rawkode has spent years making technical trade-offs visible through live builds, maintainer sessions, articles, courses, and hands-on demos.</p>
				</article>
				<article class="partnerships-work">
					<h3>Useful to operators</h3>
					<p>The output helps the teams shipping the change and the technical owners who have to defend adoption: marketing, product, DevRel, sales engineering, platform, security, and leadership.</p>
				</article>
			</div>
		</section>

		<section class="partnerships-section partnerships-section--split" aria-labelledby="examples-title">
			<div class="partnerships-section__header">
				<p class="partnerships-kicker">Representative work</p>
				<h2 id="examples-title">The output has to be useful to the teams shipping the change.</h2>
				<p>
					The partnership turns review into decisions your team can reuse, not a slide deck that sits in a folder.
				</p>
			</div>
			<div class="partnerships-work-grid">
				{workExamples.map((item) => (
					<article class="partnerships-work">
						<h3>{item.title}</h3>
						<p>{item.body}</p>
					</article>
				))}
			</div>
		</section>

		<section class="partnerships-section partnerships-section--split" aria-labelledby="process-title">
			<div class="partnerships-section__header">
				<p class="partnerships-kicker">Process</p>
				<h2 id="process-title">Email context first. Call only when there is a fit.</h2>
			</div>
			<div class="partnerships-process">
				<article>
					<span>01</span>
					<h3>Send rough context</h3>
					<p>Company, category, target technical evaluator, team stakeholders, deadline, surfaces, available infrastructure artifacts, and links if they help.</p>
				</article>
				<article>
					<span>02</span>
					<h3>Get a fit reply</h3>
					<p>David will say whether this fits an Adoption Partnership, Adoption Diagnostic, Partnership Review Sprint, or no fit.</p>
				</article>
				<article>
					<span>03</span>
					<h3>Review the decision</h3>
					<p>Rawkode works with your team on the proof, story, docs, demo, and next actions.</p>
				</article>
			</div>
		</section>

		<section class="partnerships-section partnerships-section--split" aria-labelledby="faq-title">
			<div class="partnerships-section__header">
				<p class="partnerships-kicker">Questions</p>
				<h2 id="faq-title">Clear boundaries before we start.</h2>
			</div>
			<div class="partnerships-faq-list">
				{faqs.map((faq) => (
					<details>
						<summary>{faq.question}</summary>
						<p>{faq.answer}</p>
					</details>
				))}
			</div>
		</section>

		<section class="partnerships-final" aria-labelledby="final-title">
			<p class="partnerships-kicker">Start here</p>
			<h2 id="final-title">Send the adoption problem before the spend is committed.</h2>
			<p>
				Rough context is enough: product, target technical evaluator, decision to review, timing, surfaces, available artifacts, and links if useful.
			</p>
			<a class="partnerships-button" href={contactHref}>Send your adoption context</a>
		</section>
	</main>
</Page>

<style>
	.partnerships-page {
		--partnerships-ink: var(--editorial-ink, oklch(0.18 0.02 260));
		--partnerships-muted: var(--editorial-ink-soft, oklch(0.42 0.025 260));
		--partnerships-paper: var(--editorial-paper, oklch(0.985 0.006 95));
		--partnerships-paper-deep: var(--editorial-paper-deep, oklch(0.955 0.012 95));
		--partnerships-line: var(--editorial-hairline, oklch(0.82 0.018 95));
		--partnerships-accent: var(--editorial-spruce, oklch(0.36 0.08 170));
		background: var(--partnerships-paper);
		color: var(--partnerships-ink);
		font-family: var(--font-inter-tight), system-ui, sans-serif;
	}

	.partnerships-hero,
	.partnerships-section,
	.partnerships-final {
		max-width: 72rem;
		margin: 0 auto;
		padding-left: clamp(1rem, 4vw, 2rem);
		padding-right: clamp(1rem, 4vw, 2rem);
	}

	.partnerships-hero {
		padding-top: clamp(2rem, 6vw, 5rem);
		padding-bottom: 2rem;
		border-bottom: 1px solid var(--partnerships-line);
	}

	.partnerships-kicker,
	.partnerships-package__label,
	.partnerships-trigger__label {
		font-family: var(--font-jetbrains-mono), ui-monospace, monospace;
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		line-height: 1.35;
		margin: 0;
		text-transform: uppercase;
		color: var(--partnerships-accent);
	}

	.partnerships-hero__grid {
		display: grid;
		gap: 1.5rem;
		margin-top: 0.9rem;
	}

	.partnerships-hero h1 {
		font-size: clamp(2.1rem, 10vw, 4.7rem);
		font-weight: 780;
		letter-spacing: 0;
		line-height: 0.92;
		margin: 0;
		max-width: 12ch;
		overflow-wrap: anywhere;
	}

	.partnerships-hero__copy > p,
	.partnerships-trigger p,
	.partnerships-section__header p,
	.partnerships-package p,
	.partnerships-card p,
	.partnerships-work p,
	.partnerships-process p,
	.partnerships-faq-list p,
	.partnerships-final p {
		color: var(--partnerships-muted);
		font-size: 1rem;
		line-height: 1.55;
		margin: 0;
	}

	.partnerships-hero__copy > p {
		font-size: clamp(1.05rem, 3.5vw, 1.35rem);
		margin-top: 1rem;
		max-width: 44rem;
	}

	.partnerships-actions {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin-top: 1.3rem;
	}

	.partnerships-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.85rem;
		border: 1px solid var(--partnerships-ink);
		border-radius: 4px;
		padding: 0.85rem 1rem;
		background: var(--partnerships-ink);
		color: var(--partnerships-paper);
		font-family: var(--font-jetbrains-mono), ui-monospace, monospace;
		font-size: 0.72rem;
		font-weight: 750;
		letter-spacing: 0.08em;
		line-height: 1.1;
		text-align: center;
		text-decoration: none;
		text-transform: uppercase;
	}

	.partnerships-button:hover {
		background: var(--partnerships-accent);
		border-color: var(--partnerships-accent);
	}

	.partnerships-button--secondary {
		background: transparent;
		color: var(--partnerships-ink);
		border-color: var(--partnerships-line);
	}

	.partnerships-trigger,
	.partnerships-card,
	.partnerships-work,
	.partnerships-process article,
	.partnerships-package,
	.partnerships-faq-list details {
		border: 1px solid var(--partnerships-line);
		border-radius: 6px;
		background: var(--partnerships-paper-deep);
	}

	.partnerships-trigger {
		padding: 1rem;
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
	}

	.partnerships-markets {
		list-style: none;
		padding: 0;
		margin: 1.5rem 0 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.partnerships-markets li {
		border: 1px solid var(--partnerships-line);
		border-radius: 999px;
		padding: 0.45rem 0.7rem;
		background: color-mix(in oklch, var(--partnerships-paper) 75%, white);
		font-size: 0.82rem;
		line-height: 1;
		color: var(--partnerships-muted);
	}

	.partnerships-section {
		padding-top: 2.5rem;
		padding-bottom: 2.5rem;
		border-bottom: 1px solid var(--partnerships-line);
	}

	.partnerships-section--tight {
		padding-top: 2rem;
	}

	.partnerships-section__header {
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
		margin-bottom: 1.25rem;
	}

	.partnerships-section h2,
	.partnerships-final h2 {
		font-size: clamp(1.65rem, 7vw, 3.1rem);
		font-weight: 760;
		letter-spacing: 0;
		line-height: 0.98;
		margin: 0;
		max-width: 14ch;
	}

	.partnerships-section__header p {
		max-width: 40rem;
	}

	.partnerships-package-grid,
	.partnerships-card-grid,
	.partnerships-work-grid,
	.partnerships-process {
		display: grid;
		gap: 1rem;
	}

	.partnerships-package {
		padding: 1rem;
		display: flex;
		flex-direction: column;
