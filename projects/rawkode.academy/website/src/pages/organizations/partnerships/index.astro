---
import FAQJsonLD from "@/components/html/faq-jsonld.astro";
import Page from "@/wrappers/page.astro";

export const prerender = true;

const decisionBriefFields = [
	"Company/category:",
	"Preferred partnership path:",
	"Target technical evaluator:",
	"Team stakeholders:",
	"Deadline or launch window:",
	"Docs, demos, architecture notes, or enablement material:",
	"Infrastructure artifacts available:",
	"Adoption risk or decision to review:",
	"Links, if useful:",
];

const briefHref = (path?: string) => {
	const fields = [...decisionBriefFields];
	if (path) {
		fields[1] = `Preferred partnership path: ${path}`;
	} else {
		fields[1] = "Preferred partnership path: Not sure yet";
	}

	return `mailto:david@rawkode.academy?subject=${encodeURIComponent(
		path ? `${path} decision brief` : "Decision brief request",
	)}&body=${encodeURIComponent(fields.join("\r\n"))}`;
};

const contactHref = briefHref();

const faqs = [
	{
		question: "Is this paid media?",
		answer:
			"No. A partnership does not buy coverage, endorsement, paid mentions, guaranteed leads, or editorial placement. It is a focused commercial engagement around technical adoption.",
	},
	{
		question: "Do you replace our marketing, product, or DevRel team?",
		answer:
			"No. Your team keeps execution ownership. Rawkode brings practitioner signal, technical critique, and a clearer decision path for the people already doing the work.",
	},
	{
		question: "What should we bring first?",
		answer:
			"Send rough context: the product, the target technical evaluator, stakeholders, the current adoption risk, any deadline, and the docs, demos, architecture notes, or enablement material already in play.",
	},
	{
		question: "Why do this before budget moves?",
		answer:
			"The useful moment is before the bigger bet hardens: a launch story practitioners ignore, a docs rebuild that does not change evaluation, a DevRel hire without a clear remit, or a sales push that cannot answer technical objections.",
	},
	{
		question: "How fast can this start?",
		answer:
			"Start by email. If the problem fits, David will reply with the right path and a call option. Monthly partnerships are month-to-month. Audit and sprint paths are bounded by the decision being reviewed.",
	},
	{
		question: "Do you plan campaigns or run DevRel for us?",
		answer:
			"No. The work shapes adoption strategy, technical narrative, developer education, launch proof, and internal alignment. It does not include campaign ownership, outsourced DevRel execution, custom content production, lead generation, or open-ended access.",
	},
	{
		question: "Is confidential material safe to share?",
		answer:
			"Start with public or shareable context. If private context is needed after the fit check, agree the confidentiality boundary before using it in the partnership.",
	},
];

const decisionLedger = [
	{
		label: "Claim",
		value: "What developers are being asked to believe",
	},
	{
		label: "Proof",
		value: "Docs, demos, architecture, runbooks, and operational evidence",
	},
	{
		label: "Friction",
		value: "The objection, missing step, or trust boundary blocking adoption",
	},
	{
		label: "Owner",
		value: "Product, marketing, DevRel, sales engineering, or technical lead",
	},
];

const partnershipPaths = [
	{
		name: "Signal Partnership",
		role: "Lightweight",
		price: "£1,000 / month",
		summary:
			"Outside practitioner signal before your team commits more budget to messaging, launches, docs, demos, DevRel, or sales enablement.",
		useWhen: [
			"Your team needs a lightweight outside read",
			"A launch, docs path, demo, or sales push is still movable",
			"You need signal before more budget is committed",
		],
		deliverables: [
			"Monthly partnership session",
			"Question submission before the session",
			"Monthly memo with themes, recommendations, and next decisions",
		],
		boundaries: [
			"No private delivery team",
			"No custom content production",
			"Your team owns execution",
		],
		cta: "Email signal brief",
		href: briefHref("Signal Partnership"),
	},
	{
		name: "Adoption Partnership",
		role: "Default",
		price: "£2,000 / month",
		summary:
			"Month-to-month help for teams shaping developer adoption across product, marketing, DevRel, sales engineering, and engineering.",
		useWhen: [
			"Adoption work spans several teams",
			"The story, docs, demos, and sales handoff need to line up",
			"You need critique while the work is still movable",
		],
		deliverables: [
			"Monthly working session with the core team",
			"Developer adoption map: audience, trigger, friction, proof, and next action",
			"Shared memo with recommendations, tradeoffs, and owner suggestions",
		],
		boundaries: [
			"Scoped monthly rhythm",
			"No outsourced GTM or DevRel",
			"Your team owns delivery",
		],
		featured: true,
		cta: "Email partnership brief",
		href: briefHref("Adoption Partnership"),
	},
	{
		name: "Launch Partnership",
		role: "High focus",
		price: "£3,000 / month",
		summary:
			"Tighter cross-functional direction while a launch, repositioning, category push, DevRel program, or sales motion is live.",
		useWhen: [
			"A deadline or launch window exists",
			"Multiple teams are telling different stories",
			"Technical buyers need proof before they can recommend",
		],
		deliverables: [
			"Priority review of launch story, demo path, technical objections, and education flow",
			"Cross-functional alignment session for the people carrying adoption",
			"Leadership-ready recommendations for the next market move",
		],
		boundaries: [
			"Bounded monthly scope",
			"No campaign ownership",
			"No fractional team replacement",
		],
		cta: "Email launch brief",
		href: briefHref("Launch Partnership"),
	},
];

const proofAreas = [
	{
		title: "Technical narrative",
		body: "Does the story explain the architecture, tradeoffs, and reason to change in a way a practitioner can repeat?",
	},
	{
		title: "Docs and demos",
		body: "Do the learning materials help someone evaluate, recommend, and adopt, or do they only list features?",
	},
	{
		title: "Operational trust",
		body: "Are migration, tenancy, RBAC/IAM, telemetry, egress, reliability, and failure modes addressed before objections appear?",
	},
	{
		title: "Sales handoff",
		body: "Can sales engineering answer the technical buyer without flattening the product into claims that practitioners reject?",
	},
	{
		title: "DevRel direction",
		body: "Does DevRel know which developer behavior it is trying to change, and how that signal flows back to product?",
	},
	{
		title: "Team alignment",
		body: "Are product, marketing, DevRel, sales engineering, and engineering working from the same adoption reality?",
	},
];

const publicWork = [
	{
		title: "Rawkode Live",
		href: "/shows/rawkode-live",
		body: "Maintainer-led live builds and product walkthroughs across Kubernetes, observability, identity, platform engineering, security, data, AI infrastructure, and developer tooling.",
	},
	{
		title: "Klustered",
		href: "/shows/klustered",
		body: "Public Kubernetes failure-mode triage under pressure, with teams working through broken clusters, operational constraints, and real debugging paths.",
	},
	{
		title: "Courses and education",
		href: "/courses/teleport-for-kubernetes",
		body: "Runnable technical education that shows how developers learn infrastructure, where they get stuck, and what proof they need before a tool becomes part of their workflow.",
	},
];

const goodFits = [
	"Your team needs to decide what claim deserves to lead.",
	"Developers understand the feature but not why it matters now.",
	"Docs or demos are busy but do not help evaluation.",
	"Sales conversations stall on technical proof, migration path, or operational risk.",
	"DevRel activity exists, but the team cannot say what it should change.",
];

const badFits = [
	"You want paid coverage, guaranteed mentions, media inventory, or leads.",
	"You need someone to run DevRel, campaigns, or content production for you.",
	"You want a generic workshop disconnected from adoption strategy.",
	"You need open-ended access without a decision or scope boundary.",
];

const processSteps = [
	{
		number: "01",
		title: "Email the decision brief",
		body: "Send the product, evaluator, stakeholders, decision, deadline, and existing artifacts. Rough context is enough.",
	},
	{
		number: "02",
		title: "Get a fit reply",
		body: "David will say whether it fits an audit, monthly partnership, launch sprint, or no-fit reply.",
	},
	{
		number: "03",
		title: "Work on the adoption proof",
		body: "The engagement focuses on strategy, narrative, education, technical proof, objections, alignment, and next actions your team can own.",
	},
];
---

<Page
	title="Developer Adoption Partnerships"
	description="Decision-focused partnerships for DevTool and cloud-native companies that need sharper technical proof, launch clarity, developer education, and adoption strategy."
>
	<FAQJsonLD questions={faqs} slot="extra-head" />

	<main class="partnerships-page">
		<section class="partnerships-hero" aria-labelledby="partnerships-title">
			<div class="partnerships-hero__copy">
				<p class="partnerships-label">Developer adoption partnerships</p>
				<h1 id="partnerships-title">Find the technical proof your buyers need before the next spend hardens.</h1>
				<p class="partnerships-hero__lede">
					Rawkode works with DevTool and cloud-native teams when developer adoption is stuck between product depth and market understanding. Your team keeps execution. The partnership sharpens the claim, proof, education path, and handoff that make adoption easier to decide.
				</p>
				<div class="partnerships-actions" aria-label="Partnership actions">
					<a class="partnerships-button partnerships-button--primary" href={contactHref}>Email decision brief</a>
					<a class="partnerships-button partnerships-button--secondary" href="#paths">Compare paths</a>
				</div>
			</div>

			<aside class="partnerships-ledger" aria-label="Decision brief fields">
				<div class="partnerships-ledger__head">
					<span>Decision brief</span>
					<strong>What gets tested</strong>
				</div>
				<dl class="partnerships-ledger__list">
					{decisionLedger.map((item) => (
						<div>
							<dt>{item.label}</dt>
							<dd>{item.value}</dd>
						</div>
					))}
				</dl>
			</aside>
		</section>

		<section class="partnerships-signal" aria-label="Partnership operating model">
			<div>
				<strong>Bounded input</strong>
				<span>No open-ended retainer. Each path has a decision boundary.</span>
			</div>
			<div>
				<strong>Practitioner signal</strong>
				<span>Advice comes from public technical work, maintainer sessions, and real evaluation paths.</span>
			</div>
			<div>
				<strong>Your team ships</strong>
				<span>Rawkode sharpens direction. Product, marketing, DevRel, sales engineering, and engineering own delivery.</span>
			</div>
		</section>

		<section id="paths" class="partnerships-section partnerships-section--paths" aria-labelledby="paths-title">
			<div class="partnerships-section__intro">
				<h2 id="paths-title">Pick the shape of the decision.</h2>
				<p>
					Use the lightest path that answers the adoption question in front of the team. Each option is designed to reduce wasted spend before bigger execution begins.
				</p>
			</div>

			<div class="partnerships-path-list">
				{partnershipPaths.map((path) => (
					<article class:list={["partnerships-path", { "partnerships-path--featured": path.featured }]}>
						<header class="partnerships-path__head">
							<div>
								<p class="partnerships-path__role">{path.role}</p>
								<h3>{path.name}</h3>
							</div>
							<div class="partnerships-path__price">
								<strong>{path.price}</strong>
								<a class="partnerships-button partnerships-button--compact" href={path.href}>{path.cta}</a>
							</div>
						</header>
						<p class="partnerships-path__summary">{path.summary}</p>
						<div class="partnerships-path__details">
							<div>
								<h4>Use when</h4>
								<ul>
									{path.useWhen.map((item) => <li>{item}</li>)}
								</ul>
							</div>
							<div>
								<h4>You get</h4>
								<ul>
									{path.deliverables.map((item) => <li>{item}</li>)}
								</ul>
							</div>
							<div>
								<h4>Not included</h4>
								<ul>
									{path.boundaries.map((item) => <li>{item}</li>)}
								</ul>
							</div>
						</div>
					</article>
				))}
			</div>
		</section>

		<section class="partnerships-section partnerships-section--proof" aria-labelledby="proof-title">
			<div class="partnerships-section__intro">
				<h2 id="proof-title">The work is technical proof, not output volume.</h2>
				<p>
					Most adoption problems are not solved by publishing more assets. They are solved by making the right claim easier to verify, repeat, and defend inside a technical team.
				</p>
			</div>

			<div class="partnerships-proof-grid">
				{proofAreas.map((area) => (
					<article class="partnerships-proof-item">
						<h3>{area.title}</h3>
						<p>{area.body}</p>
					</article>
				))}
			</div>
		</section>

		<section class="partnerships-section partnerships-section--split" aria-labelledby="public-work-title">
			<div class="partnerships-section__intro">
				<h2 id="public-work-title">Built from public practitioner work.</h2>
				<p>
					The advice comes from years of watching tools meet real developer skepticism in public: live builds, broken systems, maintainer walkthroughs, and technical education.
				</p>
			</div>
			<div class="partnerships-public-list">
				{publicWork.map((item) => (
					<a class="partnerships-public-item" href={item.href}>
						<strong>{item.title}</strong>
						<span>{item.body}</span>
					</a>
				))}
			</div>
		</section>

		<section class="partnerships-fit" aria-labelledby="fit-title">
			<div class="partnerships-fit__intro">
				<h2 id="fit-title">Useful when adoption is the unclear part.</h2>
				<p>
					This should be bought because the team needs sharper judgement, not because it needs another generic content lane.
				</p>
			</div>
			<div class="partnerships-fit__lists">
				<div>
					<h3>Good fit</h3>
					<ul>
						{goodFits.map((item) => <li>{item}</li>)}
					</ul>
				</div>
				<div>
					<h3>Bad fit</h3>
					<ul>
						{badFits.map((item) => <li>{item}</li>)}
					</ul>
				</div>
			</div>
		</section>

		<section class="partnerships-section partnerships-section--process" aria-labelledby="process-title">
			<div class="partnerships-section__intro">
				<h2 id="process-title">Email first. Call only when there is a fit.</h2>
				<p>
					The first step is deliberately small. A useful email gives enough context to avoid wasting a call on the wrong problem.
				</p>
			</div>
			<ol class="partnerships-process">
				{processSteps.map((step) => (
					<li>
						<span>{step.number}</span>
						<div>
							<h3>{step.title}</h3>
							<p>{step.body}</p>
						</div>
					</li>
				))}
			</ol>
		</section>

		<section class="partnerships-section partnerships-section--faq" aria-labelledby="faq-title">
			<div class="partnerships-section__intro">
				<h2 id="faq-title">Boundaries before we start.</h2>
			</div>
			<div class="partnerships-faq-list">
				{faqs.map((faq) => (
					<details>
						<summary>{faq.question}</summary>
						<p>{faq.answer}</p>
					</details>
				))}
			</div>
		</section>

		<section class="partnerships-final" aria-labelledby="final-title">
			<div>
				<h2 id="final-title">Send the decision before the spend is committed.</h2>
				<p>
					Rough context is enough: product, target technical evaluator, stakeholders, adoption risk, deadline, and useful links. If the path is unclear, say that.
				</p>
			</div>
			<a class="partnerships-button partnerships-button--primary" href={contactHref}>Email decision brief</a>
		</section>
	</main>
</Page>

<style>
	.partnerships-page {
		--partnerships-ink: var(--editorial-ink);
		--partnerships-muted: var(--editorial-ink-soft);
		--partnerships-subtle: var(--editorial-ink-mute);
		--partnerships-paper: var(--editorial-paper);
		--partnerships-paper-deep: var(--editorial-paper-deep);
		--partnerships-line: var(--editorial-hairline);
		--partnerships-line-strong: var(--editorial-hairline-strong);
		--partnerships-spruce: var(--editorial-spruce);
		--partnerships-amber: var(--editorial-amber);
		--partnerships-rust: var(--editorial-rust);
		background: var(--partnerships-paper);
		color: var(--partnerships-ink);
		font-family: var(--font-inter-tight), system-ui, sans-serif;
	}

	.partnerships-page * {
		box-sizing: border-box;
	}

	.partnerships-hero,
	.partnerships-signal,
	.partnerships-section,
	.partnerships-fit,
	.partnerships-final {
		max-width: 118rem;
		margin: 0 auto;
		padding-inline: clamp(1rem, 3vw, 3rem);
	}

	.partnerships-hero {
		display: grid;
		gap: clamp(1.5rem, 4vw, 4rem);
		grid-template-columns: minmax(0, 1fr);
		padding-block: clamp(2rem, 6vw, 5rem);
		border-bottom: 1px solid var(--partnerships-line);
	}

	.partnerships-hero__copy {
		display: flex;
		flex-direction: column;
		gap: 1.3rem;
		max-width: 76rem;
	}

	.partnerships-label,
	.partnerships-path__role,
	.partnerships-ledger__head span {
		margin: 0;
		color: var(--partnerships-spruce);
		font-family: var(--font-jetbrains-mono), ui-monospace, monospace;
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		line-height: 1.2;
		text-transform: uppercase;
	}

	.partnerships-hero h1,
	.partnerships-section h2,
	.partnerships-fit h2,
	.partnerships-final h2 {
		margin: 0;
		color: var(--partnerships-ink);
		font-family: var(--font-inter-tight), system-ui, sans-serif;
		font-style: normal;
		font-weight: 780;
		letter-spacing: 0;
		text-wrap: balance;
	}

	.partnerships-hero h1 {
		max-width: 16ch;
		font-size: clamp(2.75rem, 7vw, 5.8rem);
		line-height: 0.95;
	}

	.partnerships-hero__lede,
	.partnerships-section__intro p,
	.partnerships-fit__intro p,
	.partnerships-final p {
		max-width: 66ch;
		margin: 0;
		color: var(--partnerships-muted);
		font-size: clamp(1.02rem, 1.4vw, 1.2rem);
		line-height: 1.55;
		text-wrap: pretty;
	}

	.partnerships-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		align-items: center;
	}

	.partnerships-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.85rem;
		border: 1px solid var(--partnerships-ink);
		border-radius: 4px;
		padding: 0.85rem 1rem;
		font-family: var(--font-jetbrains-mono), ui-monospace, monospace;
		font-size: 0.72rem;
		font-weight: 750;
		letter-spacing: 0.08em;
		line-height: 1.1;
		text-align: center;
		text-decoration: none;
		text-transform: uppercase;
		transition:
			background-color var(--duration-base) var(--ease-standard),
			border-color var(--duration-base) var(--ease-standard),
			color var(--duration-base) var(--ease-standard),
			transform var(--duration-base) var(--ease-standard);
	}

	.partnerships-button:hover {
		transform: translateY(-1px);
	}

	.partnerships-button:focus-visible,
	.partnerships-public-item:focus-visible,
	.partnerships-faq-list summary:focus-visible {
		outline: 2px solid var(--partnerships-spruce);
		outline-offset: 3px;
	}

	.partnerships-button--primary,
	.partnerships-button--compact {
		background: var(--partnerships-ink);
		color: var(--partnerships-paper);
	}

	.partnerships-button--primary:hover,
	.partnerships-button--compact:hover {
		background: var(--partnerships-spruce);
		border-color: var(--partnerships-spruce);
	}

	.partnerships-button--secondary {
		background: transparent;
		color: var(--partnerships-ink);
		border-color: var(--partnerships-line-strong);
	}

	.partnerships-button--secondary:hover {
		background: var(--partnerships-paper-deep);
		border-color: var(--partnerships-ink);
	}

	.partnerships-button--compact {
		width: 100%;
		min-height: 2.5rem;
		padding: 0.72rem 0.85rem;
		font-size: 0.68rem;
	}

	.partnerships-ledger {
		align-self: start;
		border: 1px solid var(--partnerships-line-strong);
		border-radius: 6px;
		background: var(--partnerships-paper-deep);
	}

	.partnerships-ledger__head {
		display: flex;
		align-items: start;
		justify-content: space-between;
		gap: 1rem;
		padding: 1rem;
		border-bottom: 1px solid var(--partnerships-line);
	}

	.partnerships-ledger__head strong {
		max-width: 12rem;
		color: var(--partnerships-ink);
		font-size: 1.05rem;
		line-height: 1.1;
		text-align: right;
		text-wrap: balance;
	}

	.partnerships-ledger__list {
		margin: 0;
	}

	.partnerships-ledger__list div {
		display: grid;
		gap: 0.25rem;
		grid-template-columns: 6.5rem minmax(0, 1fr);
		padding: 0.95rem 1rem;
		border-bottom: 1px solid var(--partnerships-line);
	}

	.partnerships-ledger__list div:last-child {
		border-bottom: 0;
	}

	.partnerships-ledger dt {
		color: var(--partnerships-rust);
		font-family: var(--font-jetbrains-mono), ui-monospace, monospace;
		font-size: 0.72rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.partnerships-ledger dd {
		margin: 0;
		color: var(--partnerships-muted);
		font-size: 0.95rem;
		line-height: 1.45;
	}

	.partnerships-signal {
		display: grid;
		gap: 0;
		border-bottom: 1px solid var(--partnerships-line);
	}

	.partnerships-signal div {
		display: grid;
		gap: 0.3rem;
		padding-block: 1rem;
		border-bottom: 1px solid var(--partnerships-line);
	}

	.partnerships-signal div:last-child {
		border-bottom: 0;
	}

	.partnerships-signal strong {
		color: var(--partnerships-ink);
		font-size: 1rem;
		line-height: 1.2;
	}

	.partnerships-signal span {
		color: var(--partnerships-muted);
		font-size: 0.95rem;
		line-height: 1.45;
	}

	.partnerships-section,
	.partnerships-fit {
		padding-block: clamp(2.75rem, 6vw, 5.5rem);
		border-bottom: 1px solid var(--partnerships-line);
		scroll-margin-top: 5rem;
	}

	.partnerships-section__intro,
	.partnerships-fit__intro {
		display: grid;
		gap: 0.8rem;
		margin-bottom: clamp(1.25rem, 3vw, 2.5rem);
	}

	.partnerships-section--split {
		display: grid;
		gap: 1.5rem;
	}

