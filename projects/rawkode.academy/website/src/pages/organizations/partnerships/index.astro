---
import FAQJsonLD from "@/components/html/faq-jsonld.astro";
import Page from "@/wrappers/page.astro";

export const prerender = true;

const contactHref =
	"mailto:david@rawkode.academy?subject=Partnership%20fit&body=Company%2Fcategory%3A%0D%0AProduct%20or%20platform%3A%0D%0ATarget%20developers%20or%20platform%20teams%3A%0D%0ATeam%20stakeholders%3A%0D%0ACurrent%20adoption%20challenge%3A%0D%0ACurrent%20GTM%2C%20DevRel%2C%20or%20product%20rhythm%3A%0D%0AWhat%20your%20team%20wants%20to%20learn%20or%20improve%20next%3A%0D%0AUseful%20links%3A";

const faqs = [
	{
		question: "Is this paid media?",
		answer:
			"No. A partnership does not buy coverage, endorsement, paid mentions, guaranteed leads, audience access, or editorial placement. Public outputs are sponsor-disclosed and editorially independent. Partners get practitioner signal, collaboration, and learning they can use, not control over conclusions.",
	},
	{
		question: "Do you replace our marketing, product, or DevRel team?",
		answer:
			"No. We work with marketing, product, DevRel, sales engineering, and technical owners so they can make better adoption decisions. Your team keeps execution ownership; the partnership brings practitioner signal, strategic critique, and sharper direction.",
	},
	{
		question: "What should we bring first?",
		answer:
			"Send the company or product, the target developer or platform team, the adoption challenge, the team stakeholders, the current GTM, DevRel, or product rhythm, and useful links. Rough context is enough.",
	},
	{
		question: "Why pay for this month after month?",
		answer:
			"Developer adoption changes as the product, category, competitors, and buyer questions move. The partnership keeps a running signal history, friction backlog, experiment record, and outside pattern recognition your team can use every month.",
	},
	{
		question: "How fast can this start?",
		answer:
			"Partnerships are month-to-month with no annual lock-in. Companies can join when they need outside signal, use the partnership while it is valuable, and stop before the next billing cycle.",
	},
	{
		question: "Do you plan campaigns or run DevRel for us?",
		answer:
			"No. The partnership helps shape adoption strategy, technical narrative, developer education, community learning, and internal alignment. It can produce Rawkode-owned field notes or shared learning artifacts when the work belongs in public, but it does not include full campaign planning, outsourced DevRel execution, custom content production on demand, lead generation, audience access, or open-ended access.",
	},
	{
		question: "Is confidential material safe to share?",
		answer:
			"Start with public or shareable context. If a fit check shows private context is needed, we can agree the right confidentiality boundary before using it in the partnership.",
	},
];

const packages = [
	{
		name: "Signal",
		price: "£1,000 / month",
		label: "Entry",
		bestFor:
			"Founders and small GTM teams that want a recurring read on whether developers understand, trust, and act on the story they are putting into market.",
		outcome:
			"Each month surfaces the clearest adoption friction, the proof developers still need, and the next bet your team should make.",
		included: [
			"Evidence base from public developer discussion and feedback, product surface review, category monitoring, and Rawkode field notes",
			"Monthly adoption signal brief covering objections, proof gaps, confusing language, and market narrative shifts",
			"Living adoption signal register across positioning, docs, demos, onboarding, launch story, and team narrative alignment",
			"Sponsor-disclosed public field note or open takeaway when the learning belongs in the community",
			"Decision readout: what to keep, change, prove, pause, or escalate next month",
		],
		cta: "Get in Touch",
		href: "mailto:david@rawkode.academy?subject=Signal%20path&body=Company%2Fcategory%3A%0D%0APreferred%20partnership%20path%3A%20Signal%0D%0ATarget%20developers%20or%20platform%20teams%3A%0D%0ATeam%20stakeholders%3A%0D%0ACurrent%20adoption%20challenge%3A%0D%0ACurrent%20GTM%2C%20DevRel%2C%20or%20product%20rhythm%3A%0D%0AUseful%20links%3A",
	},
	{
		name: "Adoption",
		price: "£2,000 / month",
		label: "Default",
		bestFor:
			"Product, marketing, DevRel, sales engineering, and founder teams ready to turn developer signal into a monthly adoption improvement loop.",
		outcome:
			"Run a focused adoption experiment each month, review what changed, and keep the adoption map moving with your team.",
		included: [
			"Everything in Signal",
			"Monthly experiment design session tied to one adoption blocker",
			"Evidence plan for what to observe, compare, or test in developer-facing work",
			"Shared learning artifact: teardown notes, docs-friction pattern, demo-path findings, or onboarding rubric",
			"Living adoption map showing blockers, proof gaps, learning, and next experiments",
		],
		cta: "Get in Touch",
		href: contactHref,
		featured: true,
	},
	{
		name: "Council",
		price: "£3,000 / month",
		label: "Cohort",
		bestFor:
			"Teams that want a curated peer room, expert perspective, and serious practitioner comparison while they shape developer adoption.",
		outcome:
			"Join the same recurring cohort as other Council members, learn from an industry expert, and compare the adoption blockers shaping your next bets.",
		included: [
			"Everything in Adoption",
			"Shared monthly cohort room where Council members compare adoption problems and collaborate",
			"Member case reviews around live docs, demos, narratives, onboarding, or launch motions",
			"Monthly industry expert presentation with working Q&A",
			"Council pattern notes with risks, experiments, expert takeaways, and reusable decision language",
		],
		cta: "Get in Touch",
		href: "mailto:david@rawkode.academy?subject=Council%20path&body=Company%2Fcategory%3A%0D%0APreferred%20partnership%20path%3A%20Council%0D%0ATarget%20developers%20or%20platform%20teams%3A%0D%0ATeam%20stakeholders%3A%0D%0ACurrent%20adoption%20challenge%3A%0D%0ACohort%20or%20expert%20themes%20that%20would%20help%3A%0D%0AUseful%20links%3A",
	},
];

const compoundPoints = [
	{
		title: "Signal explains what blocks trust.",
		body: "The evidence base stays visible: public developer discussion and feedback, category monitoring, product surface review, Rawkode field notes, and disclosed community learning.",
	},
	{
		title: "Adoption tests a focused change.",
		body: "The record gets stronger over time: proof gaps, friction patterns, experiments, outcomes, and sharper next-month decisions.",
	},
	{
		title: "Council adds peer and expert pattern recognition.",
		body: "Members compare live adoption problems in a shared cohort and leave with reusable patterns from the room.",
	},
];

const inspectAreas = [
	{
		title: "Adoption strategy",
		body: "Who needs to care, what belief needs to change, what friction blocks adoption, and what your team should do next.",
	},
	{
		title: "Technical narrative",
		body: "Turn architecture, tradeoffs, and product depth into a story that developers, platform teams, and technical buyers can follow.",
	},
	{
		title: "Developer education",
		body: "Shape docs, demos, tutorials, learning paths, and examples around the real journey from curiosity to evaluation to internal recommendation.",
	},
	{
		title: "Sales enablement",
		body: "Help sales engineering and GTM teams explain technical value without flattening the product into claims practitioners will reject.",
	},
	{
		title: "DevRel direction",
		body: "Decide what DevRel should own, which developer behaviors matter, and how community, education, and product feedback should connect.",
	},
	{
		title: "Cross-team alignment",
		body: "Get product, marketing, DevRel, sales engineering, and engineering working from the same adoption story and the same technical reality.",
	},
];

const triggers = [
	"You are launching and the story is not turning technical interest into adoption.",
	"Your team knows the product is strong, but developers are not seeing why it matters.",
	"Docs and demos explain features but do not help teams evaluate, recommend, or adopt.",
	"DevRel or community activity is busy, but nobody agrees what it should change.",
	"Sales conversations stall because technical buyers cannot see fit, migration path, or operational reality.",
	"Product, marketing, DevRel, and sales engineering are telling different versions of the story.",
];

const workExamples = [
	{
		title: "Positioning and category",
		body: "Clarify who the product is for, what adoption moment matters, and which claim deserves to lead.",
	},
	{
		title: "Developer journey",
		body: "Map the path from first interest to hands-on evaluation, internal recommendation, and repeated use.",
	},
	{
		title: "Team handoff",
		body: "Make sure product, marketing, DevRel, sales engineering, and engineering can explain the same value without pretending to be the same function.",
	},
];

const heroProofPoints = [
	{
		label: "Keep",
		body: "Your team owns execution.",
	},
	{
		label: "Bring",
		body: "Practitioner signal and strategic critique.",
	},
	{
		label: "Decide",
		body: "What to prove, change, or stop before the next investment.",
	},
];
---

<Page
	title="Partnerships"
	description="Cloud-native and DevTool partnerships for teams improving developer adoption across product, marketing, DevRel, sales engineering, and engineering."
>
	<FAQJsonLD questions={faqs} slot="extra-head" />

	<main class="partnerships-page">
		<section class="partnerships-hero" aria-labelledby="partnerships-title">
			<p class="partnerships-kicker">Partnerships for DevTools and infrastructure teams</p>
			<div class="partnerships-hero__grid">
				<div class="partnerships-hero__copy">
					<h1 id="partnerships-title">We help your team turn technical depth into developer adoption.</h1>
					<p class="partnerships-hero__lead">
						Rawkode works alongside marketing, product, DevRel, sales engineering, and engineering teams to shape the strategy, narrative, education, and proof that help developers understand why your product matters and how to adopt it.
					</p>
					<div class="partnerships-actions">
						<a class="partnerships-button" href={contactHref}>Get in Touch</a>
						<a class="partnerships-link" href="#packages">View options</a>
					</div>
				</div>
				<aside class="partnerships-hero__rail" aria-label="How the partnership helps">
					<p class="partnerships-hero__rail-label">Developer growth grounded in technical reality</p>
					<ul>
						{heroProofPoints.map((point) => (
							<li>
								<span>{point.label}</span>
								<p>{point.body}</p>
							</li>
						))}
					</ul>
				</aside>
			</div>
		</section>

		<section id="inspect" class="partnerships-section partnerships-section--inspect" aria-labelledby="inspect-title">
			<div class="partnerships-section__header">
				<p class="partnerships-kicker">Where we help</p>
				<h2 id="inspect-title">Make adoption clearer across the teams already doing the work.</h2>
				<p>
					The work is strategy, signal, and cross-team clarity: what developers need to understand, believe, try, and repeat before adoption moves.
				</p>
			</div>
			<div class="partnerships-inspection-list">
				{inspectAreas.map((area, index) => (
					<article class="partnerships-inspection-item">
						<span class="partnerships-inspection-item__number">{String(index + 1).padStart(2, "0")}</span>
						<div>
							<h3>{area.title}</h3>
							<p>{area.body}</p>
						</div>
					</article>
				))}
			</div>
		</section>

		<section id="packages" class="partnerships-section partnerships-section--tight" aria-labelledby="packages-title">
			<div class="partnerships-section__header">
				<p class="partnerships-kicker">Partnership paths</p>
				<h2 id="packages-title">Build a monthly adoption loop your team can keep using.</h2>
				<p>
					Start with recurring practitioner signal, move into monthly adoption experiments, then join the Council when shared cohort learning and expert perspective are worth bringing into the room.
				</p>
			</div>
			<ul class="partnerships-compound-list" aria-label="What compounds each month">
				{compoundPoints.map((point) => (
					<li>
						<h3>{point.title}</h3>
						<p>{point.body}</p>
					</li>
				))}
			</ul>
			<div class="partnerships-package-grid">
				{packages.map((pkg) => (
					<article class:list={["partnerships-package", { "partnerships-package--featured": pkg.featured }]}>
						<div class="partnerships-package__top">
							<p class="partnerships-package__label">{pkg.label}</p>
							<h3>{pkg.name}</h3>
							<p class="partnerships-package__price">{pkg.price}</p>
							<a class="partnerships-button" href={pkg.href}>{pkg.cta}</a>
						</div>
						<div class="partnerships-package__summary">
							<p>{pkg.bestFor}</p>
							<p class="partnerships-package__outcome">{pkg.outcome}</p>
						</div>
						<div>
							<ul class="partnerships-package__included">
								{pkg.included.map((item) => <li>{item}</li>)}
							</ul>
						</div>
					</article>
				))}
			</div>
		</section>

		<section class="partnerships-section partnerships-section--split" aria-labelledby="triggers-title">
			<div class="partnerships-section__header">
				<p class="partnerships-kicker">Good fit</p>
				<h2 id="triggers-title">Use this when adoption is the problem, not output volume.</h2>
			</div>
			<ul class="partnerships-trigger-list">
				{triggers.map((trigger) => <li>{trigger}</li>)}
			</ul>
		</section>

		<section class="partnerships-section partnerships-section--split partnerships-section--proof" aria-labelledby="proof-title">
			<div class="partnerships-section__header">
				<p class="partnerships-kicker">Why Rawkode</p>
				<h2 id="proof-title">Built from years of public practitioner work.</h2>
			</div>
			<div class="partnerships-work-grid">
				<article class="partnerships-work">
					<h3>Rawkode Live</h3>
					<p><a href="/shows/rawkode-live">Maintainer-led live builds and product walkthroughs</a> across Kubernetes, observability, identity, platform engineering, security, data, AI infrastructure, and developer tooling.</p>
				</article>
				<article class="partnerships-work">
					<h3>Klustered</h3>
					<p><a href="/shows/klustered">Public Kubernetes failure-mode triage under pressure</a>, with teams working through broken clusters, operational constraints, and real debugging paths.</p>
				</article>
				<article class="partnerships-work">
					<h3>Courses and education</h3>
					<p><a href="/courses/teleport-for-kubernetes">Runnable technical education</a> that shows how developers learn infrastructure, where they get stuck, and what they need before a tool becomes part of their workflow.</p>
				</article>
			</div>
		</section>

		<section class="partnerships-section partnerships-section--split" aria-labelledby="examples-title">
			<div class="partnerships-section__header">
				<p class="partnerships-kicker">Adoption work</p>
				<h2 id="examples-title">What gets clearer.</h2>
				<p>
					The partnership should make the next move easier for the people already responsible for product, marketing, DevRel, sales engineering, and engineering.
				</p>
			</div>
			<div class="partnerships-work-grid">
				{workExamples.map((item) => (
					<article class="partnerships-work">
						<h3>{item.title}</h3>
						<p>{item.body}</p>
					</article>
				))}
			</div>
		</section>

		<section class="partnerships-section partnerships-section--split" aria-labelledby="process-title">
			<div class="partnerships-section__header">
				<p class="partnerships-kicker">Process</p>
				<h2 id="process-title">Email context first. Call only when there is a fit.</h2>
			</div>
			<div class="partnerships-process">
				<article>
					<span>01</span>
					<h3>Email context</h3>
					<p>Company, category, product, target developers, team stakeholders, current adoption challenge, current team rhythm, and links if they help.</p>
				</article>
				<article>
					<span>02</span>
					<h3>Get a fit reply</h3>
					<p>David will say whether this fits Signal, Adoption, or Council, or whether it is not a good fit.</p>
				</article>
				<article>
					<span>03</span>
					<h3>Work with your team</h3>
					<p>Each month produces signal, experiment decisions, or cohort synthesis your team can reuse in strategy, narrative, education, proof, objections, and alignment.</p>
				</article>
			</div>
		</section>

		<section class="partnerships-section partnerships-section--split" aria-labelledby="faq-title">
			<div class="partnerships-section__header">
				<p class="partnerships-kicker">Questions</p>
				<h2 id="faq-title">Clear boundaries before we start.</h2>
			</div>
			<div class="partnerships-faq-list">
				{faqs.map((faq) => (
					<details>
						<summary>{faq.question}</summary>
						<p>{faq.answer}</p>
					</details>
				))}
			</div>
		</section>

		<section class="partnerships-final" aria-labelledby="final-title">
			<p class="partnerships-kicker">Start here</p>
			<h2 id="final-title">Start with the next adoption problem.</h2>
			<p>
				Rough context is enough: product, target developers, team stakeholders, adoption challenge, current team rhythm, and links if useful.
			</p>
			<a class="partnerships-button" href={contactHref}>Get in Touch</a>
		</section>
	</main>
</Page>

<style>
	.partnerships-page {
		--partnerships-ink: var(--editorial-ink, oklch(0.18 0.02 260));
		--partnerships-muted: var(--editorial-ink-soft, oklch(0.42 0.025 260));
		--partnerships-paper: var(--editorial-paper, oklch(0.985 0.006 95));
		--partnerships-paper-deep: var(--editorial-paper-deep, oklch(0.955 0.012 95));
		--partnerships-line: var(--editorial-hairline, oklch(0.82 0.018 95));
		--partnerships-accent: var(--editorial-spruce, oklch(0.36 0.08 170));
		background: var(--partnerships-paper);
		color: var(--partnerships-ink);
		font-family: var(--font-inter-tight), system-ui, sans-serif;
	}

	.partnerships-hero,
	.partnerships-section,
	.partnerships-final {
		max-width: 118rem;
		margin: 0 auto;
		padding-left: clamp(1rem, 3vw, 3rem);
		padding-right: clamp(1rem, 3vw, 3rem);
	}

	.partnerships-hero {
		padding-top: clamp(1.5rem, 3vw, 3rem);
		padding-bottom: clamp(1.75rem, 3vw, 2.75rem);
		border-bottom: 1px solid var(--partnerships-line);
	}

	.partnerships-kicker,
	.partnerships-package__label {
		font-family: var(--font-jetbrains-mono), ui-monospace, monospace;
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		line-height: 1.35;
		margin: 0;
		text-transform: uppercase;
		color: var(--partnerships-accent);
	}

	.partnerships-hero__grid {
		display: grid;
		gap: clamp(1.75rem, 4vw, 4rem);
		margin-top: 1rem;
	}

	.partnerships-hero h1 {
		font-family: var(--font-inter-tight), system-ui, sans-serif;
		font-size: clamp(2.2rem, 4.4vw, 4.55rem);
		font-style: normal;
		font-weight: 780;
		letter-spacing: 0;
		line-height: 1;
		margin: 0;
		max-width: 17ch;
	}

	.partnerships-hero__lead,
	.partnerships-section__header p,
	.partnerships-package p,
	.partnerships-inspection-item p,
	.partnerships-work p,
	.partnerships-process p,
	.partnerships-faq-list p,
	.partnerships-final p {
		color: var(--partnerships-muted);
		font-size: 1rem;
		line-height: 1.55;
		margin: 0;
	}

	.partnerships-hero__lead {
		font-size: clamp(1rem, 2.2vw, 1.18rem);
		line-height: 1.6;
		margin-top: clamp(0.9rem, 1.8vw, 1.15rem);
		max-width: 44rem;
	}

	.partnerships-hero__rail {
		border-top: 1px solid var(--partnerships-line);
		display: grid;
		gap: 0.9rem;
		padding-top: 1rem;
	}

	.partnerships-hero__rail-label {
		color: var(--partnerships-ink);
		font-size: 0.95rem;
		font-weight: 760;
		line-height: 1.25;
		margin: 0;
	}

	.partnerships-hero__rail ul {
		display: grid;
		gap: 0;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.partnerships-hero__rail li {
		border-top: 1px solid var(--partnerships-line);
		display: grid;
		gap: 0.5rem;
		grid-template-columns: 4.5rem minmax(0, 1fr);
		padding: 0.85rem 0;
	}

	.partnerships-hero__rail li:first-child {
		border-top: 0;
		padding-top: 0;
	}

	.partnerships-hero__rail span {
		color: var(--partnerships-accent);
		font-family: var(--font-jetbrains-mono), ui-monospace, monospace;
		font-size: 0.7rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		line-height: 1.25;
		text-transform: uppercase;
	}

	.partnerships-hero__rail p {
		color: var(--partnerships-ink);
		font-size: 1rem;
		font-weight: 680;
		line-height: 1.35;
		margin: 0;
	}

	.partnerships-actions {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin-top: 1.5rem;
		width: fit-content;
	}

	.partnerships-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.85rem;
		border: 1px solid var(--partnerships-ink);
		border-radius: 4px;
		padding: 0.85rem 1rem;
		background: var(--partnerships-ink);
		color: var(--partnerships-paper);
		font-family: var(--font-jetbrains-mono), ui-monospace, monospace;
		font-size: 0.72rem;
		font-weight: 750;
		letter-spacing: 0.08em;
		line-height: 1.1;
		text-align: center;
		text-decoration: none;
		text-transform: uppercase;
	}

	.partnerships-button:hover {
		background: var(--partnerships-accent);
		border-color: var(--partnerships-accent);
	}

	.partnerships-link {
		align-self: flex-start;
		display: inline-flex;
		align-items: center;
		color: var(--partnerships-ink);
		font-family: var(--font-jetbrains-mono), ui-monospace, monospace;
		font-size: 0.72rem;
		font-weight: 750;
		letter-spacing: 0.08em;
		line-height: 1.2;
		min-height: 2.85rem;
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 0.22em;
		text-transform: uppercase;
	}

	.partnerships-link:hover {
		color: var(--partnerships-accent);
	}

	.partnerships-work,
	.partnerships-process article,
	.partnerships-package,
	.partnerships-faq-list details {
		border: 1px solid var(--partnerships-line);
		border-radius: 6px;
		background: var(--partnerships-paper-deep);
	}

	.partnerships-section {
		padding-top: 2.5rem;
		padding-bottom: 2.5rem;
		border-bottom: 1px solid var(--partnerships-line);
		scroll-margin-top: 5rem;
	}

	.partnerships-section--tight {
		padding-top: 2rem;
	}

	.partnerships-section__header {
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
		margin-bottom: 1.25rem;
		max-width: none;
	}

	.partnerships-section h2,
	.partnerships-final h2 {
		font-family: var(--font-inter-tight), system-ui, sans-serif;
		font-size: clamp(1.65rem, 6vw, 4rem);
		font-style: normal;
		font-weight: 760;
		letter-spacing: 0;
		line-height: 0.98;
		margin: 0;
		max-width: 20ch;
