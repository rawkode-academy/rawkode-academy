---
import FAQJsonLD from "@/components/html/faq-jsonld.astro";
import CollectionMasthead from "@/components/ui/CollectionMasthead.astro";
import Page from "@/wrappers/page.astro";

export const prerender = true;

const partnershipFAQs = [
	{
		question: "Is this a consulting retainer?",
		answer:
			"No. The monthly format gives your marketing, product, and DevRel teams cohort discussion, practitioner signal, and outside perspective. Your team owns execution. It does not include implementation support, bespoke strategy documents, custom content, training, or unlimited access.",
	},
	{
		question: "What is the minimum commitment?",
		answer:
			"The monthly format is designed to be useful immediately. It renews month-to-month with no annual lock-in and no minimum commitment. Unused asset reviews, questions, and private calls expire at the end of the active billing cycle and do not roll over.",
	},
	{
		question: "What happens in an async asset review?",
		answer:
			"Asset reviews are one-pass reviews of one existing URL or artifact, such as a landing page, launch narrative, demo outline, docs page, messaging draft, or developer education asset. Each review is bounded and does not include rewriting, follow-up review, campaign planning, production, implementation, or a slide/doc deliverable.",
	},
	{
		question: "Can a partnership influence Rawkode Academy coverage?",
		answer:
			"No. Partnerships do not include endorsements, guaranteed coverage, product reviews, rankings, sponsored content, or publication timing. Editorial coverage remains independent.",
	},
	{
		question: "Who should join?",
		answer:
			"The best fit is a founder, product, DevRel, developer marketing, or technical leadership team with existing execution capacity that wants sharper developer adoption judgment before committing more budget.",
	},
	{
		question: "Do we need to share confidential material?",
		answer:
			"No. Bring public materials, sanitized examples, or bounded questions. The partnership works best when teams bring real constraints without turning the cohort into a private strategy room.",
	},
	{
		question: "What if we need custom content, training, or launch support?",
		answer:
			"This format is not designed for custom production or hands-on delivery. If you need custom content, training, implementation support, or launch execution, it is not the right fit.",
	},
];

const proofStats = [
	{ value: "Avoid one wasted bet", label: "Launch, docs, demo, event, campaign, or DevRel spend" },
	{ value: "Find proof gaps", label: "Before budget moves" },
	{ value: "Align owners", label: "Marketing, product, and DevRel before execution" },
	{ value: "Cancel monthly", label: "If the signal stops paying for itself" },
];

const audienceSegments = [
	"Platform engineering",
	"DevOps and SRE",
	"Kubernetes",
	"Cloud native",
	"AI infrastructure",
	"Open source",
	"Developer tooling",
	"Technical founders",
];

const avoidWaste = [
	{
		title: "Before a launch",
		body: "Will practitioners believe the claim? What technical proof is missing? What objection will slow adoption?",
	},
	{
		title: "Before docs or demos",
		body: "Where will the evaluator stall, distrust the path, or ask for evidence before they are willing to try?",
	},
	{
		title: "Before DevRel spend",
		body: "What should education, community, advocacy, or events actually own before you add more activity?",
	},
];

const signalSources = [
	{
		title: "Practitioner evaluation",
		body: "How platform, SRE, DevOps, Kubernetes, AI infrastructure, and developer tooling practitioners decide whether a product is credible enough to try.",
	},
	{
		title: "Cohort comparison",
		body: "Member teams hear how adjacent infrastructure companies frame similar adoption problems, constraints, and tradeoffs.",
	},
	{
		title: "Artifact review",
		body: "Docs, demos, launch narratives, onboarding paths, and positioning are challenged against how engineers actually evaluate technical products.",
	},
];

const partnershipTiers = [
	{
		slug: "signal",
		name: "Signal",
		price: "£1,000",
		term: "per month / 1 seat",
		summary:
			"For teams deciding whether the audience, category, or adoption problem is worth further GTM spend.",
		buyWhen:
			"Buy this when you need recurring practitioner judgment before committing budget.",
		recommendedReason: "",
		bestFor:
			"Best for budget-ready teams with an execution owner who need recurring signal before committing GTM spend.",
		featured: false,
		features: [
			"1 seat",
			"90-minute monthly cohort session",
			"1 pre-submitted question per month",
			"Shared post-session notes",
			"Access to shared notes and resources",
			"Suggest future cohort themes",
		],
		boundaries: [
			"No private calls",
			"No asset reviews",
			"No custom resources",
		],
	},
	{
		slug: "review",
		name: "Review",
		price: "£2,000",
		term: "per month / up to 2 seats",
		summary:
			"For teams with a live page, demo, docs path, or launch narrative that needs one hard pass before budget moves.",
		buyWhen:
			"Buy this when you have an artifact or GTM bet that needs outside review this month.",
		recommendedReason:
			"Recommended for most teams because this is the first tier with a guaranteed artifact review.",
		bestFor:
			"Best for seed to Series B infrastructure companies preparing launches, improving docs, or sharpening developer positioning.",
		featured: true,
		features: [
			"Up to 2 seats",
			"90-minute monthly cohort session",
			"2 pre-submitted questions per month",
			"Shared post-session notes",
			"1 guaranteed one-pass async asset review per month",
			"Review-only asset feedback, no rewrite",
		],
		boundaries: ["Review only", "No rewrites", "No private calls"],
	},
	{
		slug: "direction",
		name: "Direction",
		price: "£3,000",
		term: "per month / up to 3 seats",
		summary:
			"For teams with an active adoption bet that needs one bounded private decision review before execution continues.",
		buyWhen:
			"Buy this when one bounded private review call would change an active adoption decision.",
		recommendedReason: "",
		bestFor:
			"Best for companies with a launch, repositioning, docs, demo, or DevRel decision that needs a monthly hard stop before spend moves.",
		featured: false,
		features: [
			"Up to 3 seats",
			"90-minute monthly cohort session",
			"3 pre-submitted questions per month",
			"Shared post-session notes",
			"1 private 45-minute office-hours call per month",
			"2 one-pass async asset reviews per month",
		],
		boundaries: [
			"One question or artifact in the private call",
			"No strategy doc or follow-up thread",
			"Your team executes",
		],
	},
];

const tierMatrixRows = [
	{
		label: "Choose this if",
		values: [
			"You have a budget-ready execution owner and need signal before an artifact is ready.",
			"One live artifact needs a hard pass before budget moves.",
			"One bounded private decision review would change what your team does before spend moves.",
		],
	},
	{
		label: "Monthly price",
		values: ["£1,000", "£2,000", "£3,000"],
	},
	{
		label: "Seats",
		values: ["1", "Up to 2", "Up to 3"],
	},
	{
		label: "Cohort",
		values: ["90 minutes", "90 minutes", "90 minutes"],
	},
	{
		label: "Questions",
		values: [
			"1 capped question answered in cohort or shared notes",
			"2 capped questions answered in cohort or shared notes",
			"3 capped questions answered in cohort or shared notes",
		],
	},
	{
		label: "Asset reviews",
		values: [
			"None",
			"1 guaranteed one-pass async asset review",
			"2 guaranteed one-pass async asset reviews",
		],
	},
	{
		label: "Private call",
		values: [
			"None",
			"None",
			"1 capped 45-minute call for one question or artifact",
		],
	},
	{
		label: "What this prevents",
		values: [
			"Committing GTM spend before the adoption risk is clear",
			"Shipping a weak page, docs path, demo, or launch story",
			"Letting an active GTM or product-adoption bet drift across teams",
		],
	},
	{
		label: "Expiry",
		values: ["Monthly, no rollover", "Monthly, no rollover", "Monthly, no rollover"],
	},
	{
		label: "Hard exclusions",
		values: [
			"No private calls, asset reviews, or custom resources",
			"No rewrites, private calls, or implementation",
			"No strategy doc, follow-up thread, or implementation",
		],
	},
];

const notIncluded = [
	{
		title: "Works with your teams",
		body: "Your marketing, product, and DevRel owners get practitioner signal and outside review. They keep execution ownership.",
	},
	{
		title: "No production",
		body: "Partnerships do not include custom content, training, implementation, launch campaigns, lead generation, or full rewrites.",
	},
	{
		title: "No editorial influence or always-on access",
		body: "Payment does not buy coverage, endorsement, review timing, or unlimited access. Access is capped by tier and expires monthly.",
	},
];

const monthlyRhythm = [
	{
		title: "Intake deadline",
		timing: "3 business days before",
		body: "Questions are capped at 300 words, tied to a real adoption decision, and submitted before the monthly cohort.",
	},
	{
		title: "Monthly cohort",
		timing: "90 minutes",
		body: "One cohort session covers a developer adoption theme, guaranteed capped question responses, and shared review.",
	},
	{
		title: "Notes delivery",
		timing: "After the session",
		body: "Shared notes are capped to 10 bullets and derived from the cohort session, not original research or bespoke analysis.",
	},
	{
		title: "Monthly expiry",
		timing: "Billing cycle",
		body: "Unused questions, reviews, calls, and cohort access expire monthly and do not roll over.",
	},
];

const roiExamples = [
	"One misdirected launch sprint",
	"One weak conference push",
	"One off-target video series",
	"One docs rewrite aimed at the wrong evaluator",
	"One campaign built on a claim practitioners reject",
];

const goodFit = [
	"Developer infrastructure company with existing execution capacity",
	"Founder, product, DevRel, developer marketing, or technical leadership owner",
	"Marketing, product, and DevRel teams that want sharper practitioner signal before they execute",
	"Ready to test assumptions before spending more on content, launches, docs, events, or campaigns",
	"Building for platform engineers, SREs, Kubernetes users, AI infrastructure teams, or developer tooling users",
	"Comfortable joining a cohort where shared examples improve the signal for everyone",
];

const poorFit = [
	"Teams seeking custom videos, sponsored coverage, or guaranteed mentions",
	"Companies expecting fractional DevRel, weekly calls, or unlimited Slack access",
	"Teams trying to replace marketing, product, DevRel, or community ownership",
	"Campaigns that need lead generation, sales intros, or paid endorsement",
	"Teams looking for implementation support, full rewrites, workshops, or bespoke strategy documents",
	"Teams that need confidential private consulting as the main value",
];
---

<Page
	title="Developer Adoption Partnerships"
	description="Monthly developer adoption partnerships for cloud-native, infrastructure, AI, and developer tooling companies that need sharper practitioner signal and outside review."
>
	<FAQJsonLD questions={partnershipFAQs} slot="extra-head" />

	<div class="advisory-page">
		<CollectionMasthead
			title="Developer Adoption Partnerships"
			dek="Practitioner review before GTM spend."
		/>

		<section class="advisory-hero">
			<div class="advisory-hero__copy">
				<h2>Stop guessing what practitioners will believe.</h2>
				<p>
					Before the next launch, docs rewrite, demo, campaign, or DevRel push,
					test the story against practitioner judgment. Find the weak claim,
					the missing proof, and the change your internal owners should make
					before budget moves.
				</p>
				<div class="advisory-actions">
					<a class="advisory-button advisory-button--primary" href="/organizations/lets-chat">
						Email your adoption decision
					</a>
					<a class="advisory-button advisory-button--secondary" href="#tiers">
						See plans from £1k/month
					</a>
				</div>
				<p class="advisory-fit-line">
					For developer infrastructure teams building for platform engineers,
					SREs, Kubernetes users, AI infrastructure teams, and developer tooling
					buyers. One monthly cohort session, capped intake, shared notes, and
					tiered review from £1k/month. Your team executes.
				</p>
			</div>

			<dl class="advisory-proof" aria-label="Offer summary">
				{proofStats.map((stat) => (
					<div>
						<dt>{stat.value}</dt>
						<dd>{stat.label}</dd>
					</div>
				))}
			</dl>
		</section>

		<section class="advisory-section">
			<header class="advisory-section__head advisory-section__head--inline">
				<div>
					<p class="advisory-kicker">Signal source</p>
					<h2>Grounded in how practitioners evaluate technical products.</h2>
				</div>
				<p>
					This is not abstract advice or outsourced strategy. The signal comes
					from practitioner evaluation patterns, cohort comparison, and direct
					review of the artifacts developers use to decide whether to try,
					trust, or ignore a product.
				</p>
			</header>

			<div class="advisory-card-grid advisory-card-grid--3">
				{signalSources.map((source) => (
					<article class="advisory-card">
						<h3>{source.title}</h3>
						<p>{source.body}</p>
					</article>
				))}
			</div>
		</section>

		<section class="advisory-section advisory-section--deep">
			<header class="advisory-section__head advisory-section__head--inline">
				<div>
					<p class="advisory-kicker">When to use this</p>
					<h2>Use this before the spend is committed.</h2>
				</div>
				<p>
					Choose partnerships when the cost of being wrong is higher than the
					monthly fee.
				</p>
			</header>

			<div class="advisory-card-grid advisory-card-grid--3">
				{avoidWaste.map((item) => (
					<article class="advisory-card">
						<h3>{item.title}</h3>
						<p>{item.body}</p>
					</article>
				))}
			</div>

			<ul class="advisory-audience">
				{audienceSegments.map((segment) => (
					<li>{segment}</li>
				))}
			</ul>
		</section>

		<section id="tiers" class="advisory-section">
			<header class="advisory-section__head advisory-section__head--inline">
				<div>
					<p class="advisory-kicker">Tiers</p>
					<h2>Choose the level of outside review you need.</h2>
				</div>
				<p>
					No minimum commitment. Partnerships renew monthly and can be
					cancelled before the next billing cycle.
				</p>
			</header>

			<div class="advisory-tier-matrix" role="table" aria-label="Tier comparison">
				<div class="advisory-tier-matrix__header" role="row">
					<div role="columnheader">Plan</div>
					{partnershipTiers.map((tier) => (
						<div class:list={["advisory-tier-matrix__plan", tier.featured && "advisory-tier-matrix__plan--featured"]} role="columnheader">
							{tier.featured && <span>Recommended</span>}
							<h3>{tier.name}</h3>
							<p>{tier.price} / month</p>
							<p class="advisory-tier-matrix__summary">{tier.summary}</p>
							<ul class="advisory-tier-matrix__mobile-features">
								{tier.features.slice(0, 3).map((feature) => <li>{feature}</li>)}
							</ul>
							{tier.recommendedReason && <small>{tier.recommendedReason}</small>}
							<a href={`/organizations/lets-chat?tier=${tier.slug}`}>
								Email your adoption decision
							</a>
						</div>
					))}
				</div>
				{tierMatrixRows.map((row) => (
					<div class="advisory-tier-matrix__row" role="row">
						<div class="advisory-tier-matrix__label" role="rowheader">{row.label}</div>
						{row.values.map((value, index) => (
							<div role="cell" data-tier={partnershipTiers[index]?.name}>{value}</div>
						))}
					</div>
				))}
			</div>
		</section>

		<section class="advisory-cta advisory-cta--compact">
			<div>
				<p class="advisory-kicker">Next step</p>
				<h2>Email your adoption decision.</h2>
				<p>
					Send the tier, company context, adoption constraint, internal owner,
					decision window, and optional artifact URL. You will get a direct
					reply if the partnership can create useful practitioner signal this
					month.
				</p>
			</div>
			<a class="advisory-button advisory-button--primary" href="/organizations/lets-chat">
				Email your adoption decision
			</a>
		</section>

		<section class="advisory-section advisory-section--deep">
			<header class="advisory-section__head">
				<p class="advisory-kicker">Why the fee makes sense</p>
				<h2>Cheaper than one expensive wrong turn.</h2>
				<p>
					If one month prevents a misdirected launch sprint, off-target
					campaign, unnecessary docs rewrite, weak event push, or DevRel hire
					aimed at the wrong problem, the partnership has paid for itself.
				</p>
			</header>

			<ul class="advisory-roi-list">
				{roiExamples.map((item) => <li>{item}</li>)}
			</ul>
		</section>

		<section class="advisory-section">
			<header class="advisory-section__head">
				<p class="advisory-kicker">Operating rules</p>
				<h2>Clear rules keep the partnership useful.</h2>
			</header>

			<div class="advisory-workflow">
				{monthlyRhythm.map((step, index) => (
					<article>
						<span>{String(index + 1).padStart(2, "0")} / {step.timing}</span>
						<h3>{step.title}</h3>
						<p>{step.body}</p>
					</article>
				))}
			</div>
		</section>

		<section class="advisory-section advisory-section--compare">
			<div class="advisory-compare__copy">
				<p class="advisory-kicker">Boundaries</p>
				<h2>Outside signal before your team executes.</h2>
				<p>
					The value is senior practitioner judgment before execution, not more
					execution capacity. You buy sharper decisions, earlier objections,
					and fewer wasted cycles. The cohort notes capture the objections
					marketing, product, and DevRel owners should consider: what to stop
					claiming, what to prove, and what to explain before the next spend
					decision. That is why access is capped, editorial remains independent,
					and your team owns implementation.
				</p>
			</div>
			<div class="advisory-compare__points">
				{notIncluded.map((point) => (
					<article>
						<h3>{point.title}</h3>
						<p>{point.body}</p>
					</article>
				))}
			</div>
		</section>

		<section class="advisory-section">
			<header class="advisory-section__head">
				<p class="advisory-kicker">Fit</p>
				<h2>Designed for teams that want sharper decisions, not another delivery team.</h2>
			</header>

			<div class="advisory-fit-grid">
				<article class="advisory-fit-card">
					<h3>Good fit</h3>
					<ul>
						{goodFit.map((item) => (
							<li>{item}</li>
						))}
					</ul>
				</article>
				<article class="advisory-fit-card">
					<h3>Not a fit</h3>
					<ul>
						{poorFit.map((item) => (
							<li>{item}</li>
						))}
					</ul>
				</article>
			</div>
		</section>

		<section class="advisory-cta">
			<div>
				<p class="advisory-kicker">Next step</p>
				<h2>Email your adoption decision.</h2>
				<p>
					Send the tier you are considering, company context, adoption
					constraint, internal owner, decision window, and optional artifact
					URL. You will get a direct reply if there is a useful fit. The email
					is not a product audit, positioning review, or strategy session.
				</p>
			</div>
			<a class="advisory-button advisory-button--primary" href="/organizations/lets-chat">
				Email your adoption decision
			</a>
		</section>

		<section class="advisory-section advisory-section--faq">
			<header class="advisory-section__head">
				<p class="advisory-kicker">FAQ</p>
				<h2>Common questions.</h2>
			</header>

			<div class="advisory-faq">
				{partnershipFAQs.map((item) => (
					<details>
						<summary>{item.question}</summary>
						<p>{item.answer}</p>
					</details>
				))}
			</div>
		</section>
	</div>
</Page>

<style>
	.advisory-page {
		background: var(--editorial-paper);
		color: var(--editorial-ink);
	}

	.advisory-hero {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(16rem, 22rem);
		gap: 1.5rem;
		align-items: start;
		padding: 1.75rem var(--space-section-pad-x);
		border-bottom: 1px solid var(--editorial-hairline);
	}

	.advisory-hero__copy {
		max-width: 58rem;
	}

	.advisory-kicker,
	.advisory-tier__label {
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 0.6875rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--editorial-spruce);
		margin: 0 0 0.75rem;
	}

	.advisory-hero h2,
	.advisory-section h2,
	.advisory-cta h2 {
		font-family: var(--font-inter-tight), sans-serif;
		font-size: clamp(2rem, 4vw, 3.5rem);
		font-weight: 700;
		line-height: 1;
		letter-spacing: 0;
		color: var(--editorial-ink);
		margin: 0;
		text-wrap: balance;
	}

	.advisory-section:not(#tiers) h2,
	.advisory-cta h2 {
		font-size: clamp(1.75rem, 3vw, 2.5rem);
		line-height: 1.05;
	}

	.advisory-hero p:not(.advisory-kicker),
	.advisory-section__head > p:not(.advisory-kicker),
	.advisory-compare__copy p:not(.advisory-kicker),
	.advisory-cta p:not(.advisory-kicker) {
		font-family: var(--font-inter-tight), sans-serif;
		font-size: 1.05rem;
		line-height: 1.5;
		color: var(--editorial-ink-soft);
		margin: 1rem 0 0;
		max-width: 44rem;
	}

	.advisory-fit-line {
		max-width: 40rem !important;
		margin-top: 1.25rem !important;
		padding-left: 1rem;
		border-left: 3px solid var(--editorial-spruce);
	}

	.advisory-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 1.25rem;
	}

	.advisory-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.75rem;
		padding: 0.625rem 1rem;
		border: 1px solid var(--editorial-ink);
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		text-align: center;
		text-decoration: none;
		transition:
			background-color var(--duration-base) var(--ease-standard),
			color var(--duration-base) var(--ease-standard);
	}

	.advisory-button--primary {
		background: var(--editorial-ink);
		color: var(--editorial-paper);
	}

	.advisory-button--primary:hover {
		background: var(--editorial-spruce);
		border-color: var(--editorial-spruce);
	}

	.advisory-button--secondary {
		background: transparent;
		color: var(--editorial-ink);
	}

	.advisory-button--secondary:hover {
		background: var(--editorial-paper-deep);
	}

	.advisory-proof {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0;
		margin: 0;
		border-top: 1px solid var(--editorial-hairline);
		border-bottom: 1px solid var(--editorial-hairline);
	}

	.advisory-proof div {
		display: grid;
		align-items: start;
		gap: 0.5rem;
		padding: 0.875rem 0.875rem 0.875rem 0;
	}

	.advisory-proof div + div {
		border-left: 1px solid var(--editorial-hairline);
		padding-left: 0.875rem;
	}

	.advisory-proof div:nth-child(2n + 1) {
		border-left: 0;
		padding-left: 0;
	}

	.advisory-proof div:nth-child(n + 3) {
		border-top: 1px solid var(--editorial-hairline);
	}

