---
import { css } from "../../../../styled-system/css";
import Button from "@/components/common/Button.vue";
import { Hero } from "@/components/ui";
import FAQ from "@/components/faq/list.vue";
import FeatureListIcons from "@/components/feature/list-icons.vue";
import FAQJsonLD from "@/components/html/faq-jsonld.astro";
import PartnerLogos from "@/components/partner/logos.astro";
import Pricing from "@/components/partner/pricing/cards.vue";
import Featured from "@/components/partner/pricing/featured.vue";
import VsConference from "@/components/partner/vs-conference.astro";
import Stats from "@/components/stats/simple.vue";
import TestimonialSlider from "@/components/testimonial/slider.astro";
import Page from "@/wrappers/page.astro";
import {
	sectionSep, sectionHighlight,
	heading as sectionHeading, headingXl as sectionHeadingXl,
	subText, mutedText, iconBubble, svgIcon6, ctaLink, ctaArrow,
} from "../_styles";

export const prerender = true;

const partnershipFAQs = [
	{
		question: "What is the minimum partnership duration?",
		answer:
			"Our partnerships are structured as annual engagements to ensure we can deliver meaningful results. Developer marketing and education require a strategic, long-term approach to build awareness, trust, and adoption. Our experience shows that sustained engagement over time yields significantly better outcomes than short-term campaigns.",
	},
	{
		question: "What are the payment terms for partnerships?",
		answer:
			"For Nip and Dram partnerships, we typically require annual payment upfront. For Blend and Malt partnerships, we offer flexible payment options including quarterly or semi-annual installments. We're happy to discuss payment structures that align with your budgeting cycles during our consultation.",
	},
	{
		question: "How do you measure partnership success?",
		answer:
			"We provide comprehensive analytics and reporting tailored to your specific goals. Metrics typically include content engagement (views, watch time, interactions), developer sentiment, community growth, and when possible, product adoption indicators. All partnerships include regular performance reviews to ensure we're delivering value and to refine our approach as needed. For partners at the Blend and Malt tiers, we also provide deeper insights into developer behavior and preferences, helping you refine your product and go-to-market strategy.",
	},
	{
		question: "How do you qualify potential partners?",
		answer:
			"We partner with companies that offer genuine value to developers and align with our mission of advancing developer education. We evaluate potential partners based on their technology's innovation, market relevance, and potential impact on the developer community. We're selective in our partnerships to ensure we can authentically advocate for your products.",
	},
	{
		question: "I have additional questions about partnerships",
		answer:
			"We'd be happy to discuss your specific needs and answer any questions you may have. Schedule a consultation with our partnership team to explore how we can work together to achieve your developer marketing and education goals.",
	},
];

const sectionWhiteWithPy = css({ bg: { base: 'white', _dark: 'gray.800' }, py: '16' });

const infoCard = css({
	bg: { base: 'white', _dark: 'gray.800' },
	p: '6',
	rounded: 'lg',
	shadow: 'sm',
	border: '1px solid',
	borderColor: { base: 'gray.100', _dark: 'gray.700' },
});

const cardTitle = css({ fontSize: 'lg', fontWeight: 'bold' });
const subTextXl = css({ color: { base: 'gray.600', _dark: 'gray.400' }, fontSize: { sm: 'xl' }, maxW: '3xl', mx: 'auto' });
---

<Page
	title="Strategic Technology Partnerships | Rawkode Academy"
	description="Partner with Rawkode Academy to accelerate developer adoption, improve product experience, and drive growth through expert technical content and strategic guidance."
>
	<FAQJsonLD questions={partnershipFAQs} slot="head" />
	<!-- Hero Section -->
	<Hero
		title="Strategic Technology Partnerships"
		subtitle="Accelerate developer adoption and product growth through authentic technical content and strategic guidance."
		badge="Partner With Us"
		background="blobs"
		pattern="grid"
		wave={true}
		stats={[
			{ label: '100K+ Developers' },
			{ label: 'Global Reach' },
			{ label: 'Proven Results' }
		]}
		client:load
	>
		<Fragment slot="actions">
			<Button href="#benefits" variant="primary" size="lg">Explore Benefits</Button>
			<Button href="/organizations/lets-chat" variant="secondary" size="lg">Become a Partner</Button>
		</Fragment>
	</Hero>

	<div class={css({ maxW: '5xl', mx: 'auto', mb: '16', textAlign: 'center', pt: '16' })}>
		<p class={css({ fontSize: 'xl', color: { base: 'gray.700', _dark: 'gray.300' }, mb: '8', lineHeight: 'relaxed' })}>
			At Rawkode Academy, we connect cutting-edge technologies with the
			developers who bring them to life. Our expertise bridges the critical gap
			between technical innovation and developer understanding.
		</p>

		<div class={css({ display: 'grid', gridTemplateColumns: { md: '3' }, gap: '6', textAlign: 'left', mt: '12' })}>
			<div class={infoCard}>
				<div class={css({ display: 'flex', alignItems: 'center', mb: '4' })}>
					<div class={`${iconBubble} ${css({ bg: 'colorPalette.default/10' })}`}>
						<svg
							class={`${svgIcon6} ${css({ color: 'colorPalette.default' })}`}
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
							xmlns="http://www.w3.org/2000/svg"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M13 10V3L4 14h7v7l9-11h-7z"></path>
						</svg>
					</div>
					<h3 class={cardTitle}>Amplify Your Reach</h3>
				</div>
				<p class={mutedText}>
					Extend your message to our engaged community of developers and
					technical decision-makers through authentic, expert-led content.
				</p>
			</div>

			<div class={infoCard}>
				<div class={css({ display: 'flex', alignItems: 'center', mb: '4' })}>
					<div class={`${iconBubble} ${css({ bg: 'colorPalette.default/10' })}`}>
						<svg
							class={`${svgIcon6} ${css({ color: 'colorPalette.default' })}`}
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
							xmlns="http://www.w3.org/2000/svg"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"
							></path>
						</svg>
					</div>
					<h3 class={cardTitle}>Accelerate Adoption</h3>
				</div>
				<p class={mutedText}>
					Remove barriers to entry through strategic educational content that
					showcases your product's unique value and practical applications.
				</p>
			</div>

			<div class={infoCard}>
				<div class={css({ display: 'flex', alignItems: 'center', mb: '4' })}>
					<div class={`${iconBubble} ${css({ bg: 'colorPalette.default/10' })}`}>
						<svg
							class={`${svgIcon6} ${css({ color: 'colorPalette.default' })}`}
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
							xmlns="http://www.w3.org/2000/svg"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
							></path>
						</svg>
					</div>
					<h3 class={cardTitle}>Strategic Growth</h3>
				</div>
				<p class={mutedText}>
					Refine your developer experience and go-to-market approach with expert
					guidance that drives measurable business outcomes.
				</p>
			</div>
		</div>
	</div>

	<section id="benefits" class={sectionWhiteWithPy}>
		<FeatureListIcons />
	</section>

	<section class={`${sectionHighlight} ${sectionSep}`}>
		<div class={css({ py: '12', px: '4', mx: 'auto', maxW: 'breakpoint-xl', lg: { py: '16', px: '6' } })}>
			<div class={css({ textAlign: 'center', mb: '10' })}>
				<h2 class={sectionHeading}>
					Proven Developer Engagement
				</h2>
				<p class={subText}>
					Our strategic partnerships deliver measurable results for technology
					companies worldwide
				</p>
			</div>
			<Stats
				title=""
				stats={[
					{
						label: "Technologies Covered",
						value: "90+",
					},
					{
						label: "Hours of Content Produced",
						value: "500+",
					},
					{
						label: "Developer Views",
						value: "1M+",
					},
				]}
			/>

			<TestimonialSlider
				type="partner"
				blurb="Hear directly from the companies that have partnered with us"
			/>
		</div>
	</section>

	<section class={`${sectionHighlight} ${sectionSep} ${css({ backgroundImage: { base: 'linear-gradient(to bottom, white, var(--colors-gray-50))', _dark: 'linear-gradient(to bottom, var(--colors-gray-900), black)' } })}`}>
		<div class={css({ py: '2', px: '4', mx: 'auto', maxW: '7xl', lg: { px: '6' } })}>
			<div class={css({ mb: { base: '12', lg: '16' }, textAlign: 'center' })}>
				<h2 class={sectionHeading}>
					Our <span class={css({ color: 'colorPalette.default' })}>Trusted</span> Partners
				</h2>
				<p class={subTextXl}>
					Join these innovative companies who trust Rawkode Academy to connect
					their technologies with developers worldwide.
				</p>
			</div>

			<div class={css({ position: 'relative' })}>
				<div class={css({ position: 'absolute', inset: '0', backgroundImage: 'linear-gradient(to right, token(colors.colorPalette.default/5), transparent, token(colors.colorPalette.default/5))', rounded: 'xl' })}>
				</div>
				<div class={css({ position: 'relative' })}>
					<PartnerLogos />
				</div>
			</div>
		</div>
	</section>

	<section class={sectionWhiteWithPy}>
		<div class={css({ containerType: 'inline-size', mx: 'auto', px: '4' })}>
			<VsConference />
		</div>
	</section>

	<section class={`${sectionHighlight} ${sectionSep}`}>
		<div class={css({ py: '12', px: '4', mx: 'auto', maxW: 'breakpoint-xl', lg: { py: '16', px: '6' } })}>
			<div class={css({ mx: 'auto', maxW: 'breakpoint-md', textAlign: 'center', mb: '12' })}>
				<h2 class={sectionHeadingXl}>
					Partnership Tiers
				</h2>
				<p class={css({ mb: '5', color: { base: 'gray.600', _dark: 'gray.300' }, fontSize: { sm: 'xl' } })}>
					Whether you're looking to increase brand awareness, educate developers
					about your technology, or develop a comprehensive go-to-market
					strategy, we offer flexible partnership options to meet your specific
					goals.
				</p>
			</div>

			<div class={css({ mx: 'auto', maxW: 'breakpoint-md', textAlign: 'center', mb: '10' })}>
				<p class={css({ mb: '5', color: { base: 'gray.600', _dark: 'gray.300' }, fontSize: { sm: 'xl' } })}>
					The Rawkode Academy is proudly brought to you from Glasgow, Scotland.
					Our partnership tiers are named after traditional Scottish whisky
					measurements, reflecting our heritage of quality, craftsmanship, and
					attention to detail.
				</p>
			</div>

			<div class={css({ mx: 'auto', maxW: '6xl' })}>
				<Featured />
				<Pricing />
			</div>
		</div>
	</section>

	<section class={`${css({ bg: { base: 'white', _dark: 'gray.800' } })} ${sectionSep}`}>
		<div class={css({ px: '4', mx: 'auto', maxW: 'breakpoint-xl', lg: { px: '6' } })}>
			<div class={css({ mx: 'auto', maxW: 'breakpoint-md', textAlign: 'center' })}>
				<div class={css({ display: 'inline-block', p: '2', mb: '6', bg: 'colorPalette.default/10', rounded: 'full' })}>
					<svg
						class={css({ w: '8', h: '8', color: 'colorPalette.default' })}
						fill="none"
						stroke="currentColor"
						viewBox="0 0 24 24"
						xmlns="http://www.w3.org/2000/svg"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122"
						></path>
					</svg>
				</div>

				<h2 class={sectionHeadingXl}>
					Ready to Transform Your <span class={css({ color: 'colorPalette.default' })}>Developer Strategy</span>?
				</h2>
				<p class={css({ mb: '10', fontSize: 'xl', color: { base: 'gray.600', _dark: 'gray.400' }, maxW: '3xl', mx: 'auto' })}>
					Schedule a consultation to explore how a strategic partnership can
					align with your specific business objectives and connect your
					technology with our passionate developer community.
				</p>
				<div class={css({ display: 'flex', flexDir: { base: 'column', sm: 'row' }, justifyContent: 'center', gap: '4' })}>
					<a
						href="/organizations/lets-chat"
						class={ctaLink}
					>
						Schedule Your Consultation
						<svg
							class={ctaArrow}
							fill="currentColor"
							viewBox="0 0 20 20"
							xmlns="http://www.w3.org/2000/svg"
						>
							<path
								fill-rule="evenodd"
								d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
								clip-rule="evenodd"></path>
						</svg>
					</a>
				</div>
			</div>
		</div>
	</section>

	<section class={`${css({ bg: { base: 'white', _dark: 'gray.800' } })} ${sectionSep}`}>
		<div class={css({ px: '4', py: '12', mx: 'auto', maxW: 'breakpoint-xl', lg: { py: '16' } })}>
			<div class={css({ mx: 'auto', maxW: 'breakpoint-md', textAlign: 'center', mb: '8' })}>
				<h2 class={css({ mb: '4', fontSize: '3xl', letterSpacing: 'tight', fontWeight: 'extrabold', color: { base: 'gray.900', _dark: 'white' } })}>
					Frequently Asked Questions
				</h2>
				<p class={subText}>
					Learn more about partnering with Rawkode Academy
				</p>
			</div>
			<FAQ client:load items={partnershipFAQs} title="Partnership FAQ" />
		</div>
	</section>
</Page>
