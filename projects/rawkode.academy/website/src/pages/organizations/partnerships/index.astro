---
import FAQJsonLD from "@/components/html/faq-jsonld.astro";
import CollectionMasthead from "@/components/ui/CollectionMasthead.astro";
import Page from "@/wrappers/page.astro";
import controlplaneLogo from "../../../components/partner/logos/controlplane.svg?raw";
import fermyonLogo from "../../../components/partner/logos/fermyon.svg?raw";
import guidepadLogo from "../../../components/partner/logos/guidepad.svg?raw";
import herokuLogo from "../../../components/partner/logos/heroku.svg?raw";
import microsoftLogo from "../../../components/partner/logos/microsoft.svg?raw";
import ngrokLogo from "../../../components/partner/logos/ngrok.svg?raw";
import spectrocloudLogo from "../../../components/partner/logos/spectrocloud.svg?raw";
import teleportLogo from "../../../components/partner/logos/teleport.svg?raw";
import wundergraphLogo from "../../../components/partner/logos/wundergraph.svg?raw";
import zitadelLogo from "../../../components/partner/logos/zitadel.svg?raw";

export const prerender = true;

const partnershipFAQs = [
	{
		question: "What is the minimum partnership duration?",
		answer:
			"Partnerships are structured as annual engagements because developer trust compounds through repeated technical proof, not one campaign burst. We still plan the work in quarterly cycles so each quarter has clear deliverables and reporting.",
	},
	{
		question: "What are the payment terms for partnerships?",
		answer:
			"Nip and Dram are typically paid annually upfront. Blend and Malt can be paid annually, semi-annually, or quarterly depending on procurement needs. We confirm the commercial structure during the fit call.",
	},
	{
		question: "Do you replace our internal DevRel team?",
		answer:
			"No. We assist and extend internal DevRel, marketing, product, and engineering teams. Partners use Rawkode Academy for external practitioner credibility, content production capacity, technical feedback, and distribution into a relevant developer audience.",
	},
	{
		question: "How do you measure partnership success?",
		answer:
			"We align on success measures before work starts. Reporting can include views, watch time, retention, referral traffic with UTM links, developer questions, docs friction, product feedback, content reuse, and partner-defined adoption indicators.",
	},
	{
		question: "Can our team reuse the content?",
		answer:
			"Yes. Partnership planning includes the assets your sales, marketing, DevRel, and product teams can reuse, such as clips, tutorials, demo paths, workshop material, launch recaps, and technical feedback summaries.",
	},
	{
		question: "How do you qualify potential partners?",
		answer:
			"We look for developer tools and cloud native companies with useful technology, technical access for review, and a willingness to teach through real usage. We are not a fit for scripted praise, paid mentions with no technical review, or guaranteed pipeline claims from a single asset.",
	},
	{
		question: "I have additional questions about partnerships",
		answer:
			"Book a fit call and we can talk through your product, audience, timing, internal team shape, and the smallest useful partnership tier.",
	},
];

const proofStats = [
	{ value: "90+", label: "Technologies covered" },
	{ value: "400+", label: "Videos, articles, and lessons" },
	{ value: "1M+", label: "Developer views" },
];

const partnerProofs = [
	{
		company: "Fermyon",
		label: "Developer education",
		headline: "Hands-on challenges moved developers from awareness to use.",
		body: "Rawkode Academy introduced developers to server-side WebAssembly, promoted Spin and Fermyon Cloud, and created Advent of Spin challenges that gave developers a practical way to try the technology.",
		quote:
			"We saw notable results in developers joining our community and using our services.",
		source: "Head of DevRel at Fermyon",
	},
	{
		company: "Guidepad",
		label: "Product positioning",
		headline: "Strategy, demo videos, and market guidance for an early-stage platform.",
		body: "Guidepad used the partnership for cloud native positioning, product strategy, and demo assets while the company was still sharpening its market story.",
		quote:
			"The guidance and insights consistently elevate our product and strategy.",
		source: "Reggie Wilkerson, Co-Founder and CEO at Guidepad",
	},
];

const capabilities = [
	{
		title: "Technical proof",
		body: "Tutorials, livestreams, workshops, and product walkthroughs built around real developer workflows instead of abstract positioning.",
		items: ["Tutorials", "Live builds", "Workshops"],
	},
	{
		title: "DevRel assistance",
		body: "Extra content capacity, launch support, practitioner feedback, and campaign execution that supports your internal team without replacing it.",
		items: ["Content support", "Launch coverage", "Team enablement"],
	},
	{
		title: "Product signal",
		body: "Developer experience feedback, docs friction, demo path review, and market context from people who build with cloud native tools in public.",
		items: ["DX review", "Docs feedback", "Positioning"],
	},
];

const first90Days = [
	{
		title: "Fit and focus",
		timing: "Days 1-14",
		body: "Confirm the developer audience, product moments, internal owners, technical access, and success measures.",
	},
	{
		title: "Technical proof",
		timing: "Days 15-45",
		body: "Shape the demo path, plan the first tutorial or live build, and capture product or documentation feedback.",
	},
	{
		title: "Distribution and signal",
		timing: "Days 46-90",
		body: "Publish, package reusable assets, report what developers responded to, and choose the next quarter's focus.",
	},
];

const measurementSignals = [
	{
		title: "Content performance",
		body: "Views, watch time, retention, engagement, and the topics developers keep returning to.",
	},
	{
		title: "Qualified traffic",
		body: "Referral traffic, UTM-tagged links, campaign landing pages, and partner-owned conversion points where available.",
	},
	{
		title: "Developer signal",
		body: "Questions, objections, docs gaps, product friction, and feedback that can help DevRel, product, and engineering teams.",
	},
	{
		title: "Reusable assets",
		body: "Clips, tutorials, demos, recaps, workshop material, and internal enablement notes your team can keep using.",
	},
];

const partnershipTiers = [
	{
		label: "Visibility Partner",
		name: "Nip",
		price: "12,000",
		cadence: "Quarterly rhythm",
		summary:
			"A focused visibility layer for teams that want steady awareness with a relevant developer audience.",
		bestFor: "Best for staying present without a heavy program.",
		featured: false,
		features: [
			"Partner placement across the academy",
			"One technical livestream per quarter",
			"Quarterly short-form clip pack",
			"Social distribution for each release",
			"Quarterly performance report",
		],
	},
	{
		label: "Launch Partner",
		name: "Dram",
		price: "24,000",
		cadence: "1 video per quarter",
		summary:
			"Launch and tutorial support for teams that need repeatable product stories developers can inspect.",
		bestFor: "Best for feature launches and repeatable demo paths.",
		featured: true,
		features: [
			"Everything in Nip",
			"One produced technical video per quarter",
			"Launch or tutorial plan",
			"One technical article or tutorial per quarter",
			"Quarterly strategy session",
		],
	},
	{
		label: "Adoption Partner",
		name: "Blend",
		price: "48,000",
		cadence: "1 video every 2 months",
		summary:
			"Deeper collaboration for teams turning awareness into education, adoption, and internal learning.",
		bestFor: "Best for multi-format adoption campaigns.",
		featured: false,
		features: [
			"Everything in Dram",
			"One produced technical video every two months",
			"Workshop or live build program",
			"Priority calendar placement",
			"Monthly working session",
		],
	},
	{
		label: "Strategic Partner",
		name: "Malt",
		price: "96,000",
		cadence: "1 video per month",
		summary:
			"Category-level partnership for teams that want annual planning, executive context, and deeper market signal.",
		bestFor: "Best for teams shaping a category or major roadmap.",
		featured: false,
		features: [
			"Everything in Blend",
			"One produced technical video per month",
			"Annual category narrative and content roadmap",
			"Executive advisory sessions",
			"Custom reporting and co-marketing plan",
		],
	},
];

const comparisonPoints = [
	{
		title: "Conference sponsorship",
		body: "Useful for presence, but the value fades quickly. A partnership creates technical assets and feedback loops that keep working after launch week.",
	},
	{
		title: "Podcast or newsletter buys",
		body: "Good reach, limited proof. Rawkode Academy turns attention into demos, tutorials, workshops, and product questions your team can use.",
	},
	{
		title: "Paid ads",
		body: "Fast distribution, low trust. Technical education gives developers a reason to inspect, try, and discuss the product.",
	},
	{
		title: "Internal DevRel",
		body: "We do not replace your team. We extend it with external practitioner credibility, production capacity, and market feedback.",
	},
];

const goodFit = [
	"Cloud native, infrastructure, platform, security, or developer tooling product",
	"DevRel, marketing, product, or engineering owner who can collaborate",
	"Access to technical review, demos, docs, or roadmap context",
	"Interest in annual education, not a one-off paid mention",
];

const poorFit = [
	"Scripted praise with no technical inspection",
	"Guaranteed pipeline attribution from one asset",
	"No access to product, docs, or a technical reviewer",
	"Campaigns that only need broad consumer awareness",
];

const currentPartnerLogos = [
	{
		name: "Spectro Cloud",
		url: "https://spectrocloud.com",
		logo: spectrocloudLogo,
	},
	{
		name: "Teleport",
		url: "https://goteleport.com",
		logo: teleportLogo,
	},
];

const previousPartnerLogos = [
	{
		name: "ControlPlane",
		url: "https://controlplane.io",
		logo: controlplaneLogo,
	},
	{
		name: "Fermyon",
		url: "https://www.fermyon.com",
		logo: fermyonLogo,
	},
	{
		name: "Guidepad",
		url: "https://guidepad.io",
		logo: guidepadLogo,
	},
	{
		name: "Heroku",
		url: "https://heroku.com",
		logo: herokuLogo,
	},
	{
		name: "Microsoft Azure",
		url: "https://azure.com",
		logo: microsoftLogo,
	},
	{
		name: "ngrok",
		url: "https://ngrok.com",
		logo: ngrokLogo,
	},
	{
		name: "WunderGraph",
		url: "https://wundergraph.com",
		logo: wundergraphLogo,
	},
	{
		name: "Zitadel",
		url: "https://zitadel.com",
		logo: zitadelLogo,
	},
];

function withPartnerUtm(url: string): string {
	const u = new URL(url);
	u.searchParams.set("utm_source", "rawkode-academy");
	u.searchParams.set("utm_medium", "partner-logo");
	u.searchParams.set("utm_campaign", "partnerships-page");
	return u.toString();
}
---

<Page
	title="Strategic Technology Partnerships"
	description="Partner with Rawkode Academy to accelerate developer adoption through technical content, DevRel assistance, and developer experience feedback."
>
	<FAQJsonLD questions={partnershipFAQs} slot="extra-head" />

	<div class="partnerships-page">
		<CollectionMasthead
			title="Partnerships"
			dek="DevRel support programs."
		/>

		<section class="partnerships-hero">
			<div class="partnerships-hero__copy">
				<p class="partnerships-kicker">
					For DevRel, marketing, and developer tools teams
				</p>
				<h2>Turn developer attention into product adoption.</h2>
				<p>
					Rawkode Academy helps cloud native and developer tools teams create
					hands-on tutorials, livestreams, workshops, and technical feedback
					loops that make products easier to understand, trust, and adopt.
				</p>
				<p class="partnerships-fit-line">
					We assist internal DevRel teams with external credibility, production
					capacity, and audience access.
				</p>
				<div class="partnerships-actions">
					<a class="partnerships-button partnerships-button--primary" href="/organizations/lets-chat">
						Book a 30-minute fit call
					</a>
					<a class="partnerships-button partnerships-button--secondary" href="#tiers">
						Compare tiers
					</a>
				</div>
			</div>

			<dl class="partnerships-proof" aria-label="Partnership proof">
				{proofStats.map((stat) => (
					<div>
						<dt>{stat.value}</dt>
						<dd>{stat.label}</dd>
					</div>
				))}
			</dl>
		</section>

		<section class="partnerships-section partnerships-section--proof">
			<header class="partnerships-section__head partnerships-section__head--inline">
				<div>
					<p class="partnerships-kicker">Partner proof</p>
					<h2>Proof that lives beyond launch week.</h2>
				</div>
				<p>
					The work is designed to become reusable education, product signal, and
					market context, not a single sponsored impression.
				</p>
			</header>

			<div class="partnerships-case-grid">
				{partnerProofs.map((proof) => (
					<article class="partnerships-case">
						<p class="partnerships-case__label">
							{proof.company} / {proof.label}
						</p>
						<h3>{proof.headline}</h3>
						<p>{proof.body}</p>
						<blockquote>
							<p>{proof.quote}</p>
							<cite>{proof.source}</cite>
						</blockquote>
					</article>
				))}
			</div>
		</section>

		<section id="benefits" class="partnerships-section">
			<header class="partnerships-section__head">
				<p class="partnerships-kicker">What we do</p>
				<h2>Ship technical proof developers believe.</h2>
			</header>

			<div class="partnerships-capabilities">
				{capabilities.map((capability, index) => (
					<article class="partnerships-capability">
						<span class="partnerships-capability__number">
							{String(index + 1).padStart(2, "0")}
						</span>
						<h3>{capability.title}</h3>
						<p>{capability.body}</p>
						<ul>
							{capability.items.map((item) => (
								<li>{item}</li>
							))}
						</ul>
					</article>
				))}
			</div>
		</section>

		<section id="tiers" class="partnerships-section partnerships-section--deep">
			<header class="partnerships-section__head partnerships-section__head--inline">
				<div>
					<p class="partnerships-kicker">Partnership tiers</p>
					<h2>Choose the video cadence and support level.</h2>
				</div>
				<p>
					All tiers are annual and can mix content creation, strategy,
					developer education, and developer experience feedback.
				</p>
			</header>

			<div class="partnerships-tiers">
				{partnershipTiers.map((tier) => (
					<article class:list={["partnerships-tier", tier.featured && "partnerships-tier--featured"]}>
						{tier.featured && <span class="partnerships-tier__flag">Recommended</span>}
						<p class="partnerships-tier__label">{tier.label}</p>
						<h3>{tier.name}</h3>
						<p class="partnerships-tier__price">{tier.price}</p>
						<p class="partnerships-tier__term">USD annually / {tier.cadence}</p>
						<p class="partnerships-tier__summary">{tier.summary}</p>
						<p class="partnerships-tier__best">{tier.bestFor}</p>
						<ul>
							{tier.features.map((feature) => (
								<li>{feature}</li>
							))}
						</ul>
						<a href="/organizations/lets-chat">Discuss {tier.label}</a>
					</article>
				))}
			</div>
		</section>

		<section class="partnerships-section partnerships-section--deep">
			<header class="partnerships-section__head">
				<p class="partnerships-kicker">First 90 days</p>
				<h2>Start with focus, then publish and learn.</h2>
			</header>

			<div class="partnerships-workflow">
				{first90Days.map((step, index) => (
					<article>
						<span>{String(index + 1).padStart(2, "0")} / {step.timing}</span>
						<h3>{step.title}</h3>
						<p>{step.body}</p>
					</article>
				))}
			</div>
		</section>

		<section class="partnerships-section">
			<header class="partnerships-section__head partnerships-section__head--inline">
				<div>
					<p class="partnerships-kicker">Measurement</p>
					<h2>Make success visible to every team involved.</h2>
				</div>
				<p>
					Reporting connects awareness, education, reusable assets, and product
					feedback so DevRel, marketing, sales, and product can all use the
					work.
				</p>
			</header>

			<div class="partnerships-measurement">
				{measurementSignals.map((signal) => (
					<article>
						<h3>{signal.title}</h3>
						<p>{signal.body}</p>
					</article>
				))}
			</div>
		</section>

		<section class="partnerships-section partnerships-section--compare">
			<div class="partnerships-compare__copy">
				<p class="partnerships-kicker">Why this format</p>
				<h2>More useful than one-off visibility.</h2>
				<p>
					Sponsorship can create a moment. Technical education creates proof,
					reuse, and feedback your team can keep compounding.
				</p>
			</div>
			<div class="partnerships-compare__points">
				{comparisonPoints.map((point) => (
					<article>
						<h3>{point.title}</h3>
						<p>{point.body}</p>
					</article>
				))}
			</div>
		</section>

		<section class="partnerships-section">
			<header class="partnerships-section__head">
				<p class="partnerships-kicker">Fit</p>
				<h2>Designed for teams that want technical trust.</h2>
			</header>

			<div class="partnerships-fit-grid">
				<article class="partnerships-fit-card">
					<h3>Good fit</h3>
					<ul>
						{goodFit.map((item) => (
							<li>{item}</li>
						))}
					</ul>
				</article>
				<article class="partnerships-fit-card">
					<h3>Not a fit</h3>
					<ul>
						{poorFit.map((item) => (
							<li>{item}</li>
						))}
					</ul>
				</article>
			</div>
		</section>

		<section class="partnerships-section partnerships-section--credibility">
			<div class="partnerships-credibility__copy">
				<p class="partnerships-kicker">Partner history</p>
				<h2>Companies we have worked with.</h2>
				<p>
					Current and past partners span platform engineering, identity,
					WebAssembly, cloud security, and developer experience.
				</p>
			</div>

			<div class="partnerships-logo-groups">
				<article class="partnerships-logo-group">
					<h3>Current partners</h3>
					<div class="partnerships-logo-grid partnerships-logo-grid--current">
						{currentPartnerLogos.map((partner) => (
							<a
								class="partnerships-logo-card partnerships-logo-card--current"
								href={withPartnerUtm(partner.url)}
								target="_blank"
								rel="noopener noreferrer"
								aria-label={`Visit ${partner.name}`}
							>
								<span class="partnerships-logo-mark">
									<Fragment set:html={partner.logo} />
								</span>
								<span class="partnerships-logo-name">{partner.name}</span>
							</a>
						))}
					</div>
				</article>

				<article class="partnerships-logo-group">
					<h3>Previously supported by</h3>
					<div class="partnerships-logo-grid partnerships-logo-grid--previous">
						{previousPartnerLogos.map((partner) => (
							<a
								class="partnerships-logo-card partnerships-logo-card--previous"
								href={withPartnerUtm(partner.url)}
								target="_blank"
								rel="noopener noreferrer"
								aria-label={`Visit ${partner.name}`}
							>
								<span class="partnerships-logo-mark">
									<Fragment set:html={partner.logo} />
								</span>
								<span class="partnerships-logo-name">{partner.name}</span>
							</a>
						))}
					</div>
				</article>
			</div>
		</section>

		<section class="partnerships-cta">
			<div>
				<p class="partnerships-kicker">Next step</p>
				<h2>Book a 30-minute fit call.</h2>
				<p>
					We will look at your product, audience, internal team shape, and goals,
					then recommend the smallest useful partnership tier.
				</p>
			</div>
			<a class="partnerships-button partnerships-button--primary" href="/organizations/lets-chat">
				Book a 30-minute fit call
			</a>
		</section>

		<section class="partnerships-section partnerships-section--faq">
			<header class="partnerships-section__head">
				<p class="partnerships-kicker">FAQ</p>
				<h2>Partnership questions.</h2>
			</header>

			<div class="partnerships-faq">
				{partnershipFAQs.map((item) => (
					<details>
						<summary>{item.question}</summary>
						<p>{item.answer}</p>
					</details>
				))}
			</div>
		</section>
	</div>
</Page>

<style>
	.partnerships-page {
		background: var(--editorial-paper);
		color: var(--editorial-ink);
	}

	.partnerships-hero {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(18rem, 28rem);
		gap: 2rem;
		align-items: end;
		padding: 3rem var(--space-section-pad-x);
		border-bottom: 1px solid var(--editorial-hairline);
	}

	.partnerships-hero__copy {
		max-width: 52rem;
	}

	.partnerships-kicker,
	.partnerships-case__label,
	.partnerships-tier__label {
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 0.6875rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--editorial-spruce);
		margin: 0 0 0.75rem;
	}

	.partnerships-hero h2,
	.partnerships-section h2,
	.partnerships-cta h2 {
		font-family: var(--font-inter-tight), sans-serif;
		font-size: clamp(2rem, 4vw, 3.5rem);
		font-weight: 700;
		line-height: 1;
		letter-spacing: 0;
		color: var(--editorial-ink);
		margin: 0;
		text-wrap: balance;
	}

	.partnerships-hero p:not(.partnerships-kicker),
	.partnerships-section__head > p:not(.partnerships-kicker),
	.partnerships-compare__copy p:not(.partnerships-kicker),
	.partnerships-cta p:not(.partnerships-kicker) {
		font-family: var(--font-inter-tight), sans-serif;
		font-size: 1.05rem;
		line-height: 1.5;
		color: var(--editorial-ink-soft);
		margin: 1rem 0 0;
		max-width: 44rem;
	}

	.partnerships-fit-line {
		max-width: 38rem !important;
		padding-left: 1rem;
		border-left: 3px solid var(--editorial-spruce);
	}

	.partnerships-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 1.5rem;
	}

	.partnerships-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.75rem;
		padding: 0.625rem 1rem;
		border: 1px solid var(--editorial-ink);
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		text-align: center;
		text-decoration: none;
		transition: background-color var(--duration-base) var(--ease-standard),
			color var(--duration-base) var(--ease-standard);
	}

	.partnerships-button--primary {
		background: var(--editorial-ink);
		color: var(--editorial-paper);
	}

	.partnerships-button--primary:hover {
		background: var(--editorial-spruce);
		border-color: var(--editorial-spruce);
	}

	.partnerships-button--secondary {
		background: transparent;
		color: var(--editorial-ink);
	}

	.partnerships-button--secondary:hover {
