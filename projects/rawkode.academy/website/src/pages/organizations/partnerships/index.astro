---
import FAQJsonLD from "@/components/html/faq-jsonld.astro";
import Page from "@/wrappers/page.astro";

export const prerender = true;

const contactHref =
	"mailto:david@rawkode.academy?subject=Partnership%20fit&body=Company%2Fcategory%3A%0D%0AProduct%20or%20platform%3A%0D%0ATarget%20developers%20or%20platform%20teams%3A%0D%0ATeam%20stakeholders%3A%0D%0ACurrent%20adoption%20challenge%3A%0D%0AUpcoming%20launch%2C%20sales%20push%2C%20DevRel%20motion%2C%20or%20budget%20decision%3A%0D%0AWhat%20your%20team%20needs%20to%20decide%20next%3A%0D%0AUseful%20links%3A";

const faqs = [
	{
		question: "Is this paid media?",
		answer:
			"No. A partnership does not buy coverage, endorsement, paid mentions, guaranteed leads, or editorial placement. It is a focused commercial engagement around technical adoption.",
	},
	{
		question: "Do you replace our marketing, product, or DevRel team?",
		answer:
			"No. We work with marketing, product, DevRel, sales engineering, and technical owners so they can make better adoption decisions. Your team keeps execution ownership; the partnership brings practitioner signal, strategic critique, and sharper direction.",
	},
	{
		question: "What should we bring first?",
		answer:
			"Send the company or product, the target developer or platform team, the adoption challenge, the team stakeholders, the next budget or launch decision, and useful links. Rough context is enough.",
	},
	{
		question: "Why pay for this before budget moves?",
		answer:
			"The point is to avoid a larger wasted bet: a launch story practitioners ignore, a docs or demo rebuild that does not change adoption, a DevRel hire without a clear remit, or a sales push that cannot answer technical objections. The partnership helps your team decide what to keep, change, prove, or stop before more spend is committed.",
	},
	{
		question: "How fast can this start?",
		answer:
			"Partnerships are month-to-month with no annual lock-in. Companies can join when they need outside signal, use the partnership while it is valuable, and stop before the next billing cycle.",
	},
	{
		question: "Do you plan campaigns or run DevRel for us?",
		answer:
			"No. The partnership helps shape adoption strategy, technical narrative, developer education, launch direction, and internal alignment. It does not include full campaign planning, outsourced DevRel execution, custom content production, lead generation, or open-ended access.",
	},
	{
		question: "Is confidential material safe to share?",
		answer:
			"Start with public or shareable context. If a fit check shows private context is needed, we can agree the right confidentiality boundary before using it in the partnership.",
	},
];

const packages = [
	{
		name: "Signal Partnership",
		price: "£1,000 / month",
		label: "Lightweight",
		bestFor:
			"Founders and small teams that need outside practitioner signal before they commit more budget to messaging, launches, docs, demos, DevRel, or sales enablement.",
		outcome:
			"Know what developers are likely to understand, question, ignore, or need next before your team spends more.",
		included: [
			"Monthly partnership session",
			"Question submission before the session",
			"Practitioner signal on developer adoption, DevRel, docs, demos, positioning, or launch direction",
			"Monthly memo with themes, recommendations, and next decisions",
		],
		boundaries: ["No private delivery team", "No custom content production", "Your team owns execution"],
		cta: "Email David",
		href: "mailto:david@rawkode.academy?subject=Signal%20Partnership&body=Company%2Fcategory%3A%0D%0APreferred%20partnership%20path%3A%20Signal%20Partnership%0D%0ATarget%20developers%20or%20platform%20teams%3A%0D%0ATeam%20stakeholders%3A%0D%0ACurrent%20adoption%20challenge%3A%0D%0AUpcoming%20launch%2C%20sales%20push%2C%20DevRel%20motion%2C%20or%20budget%20decision%3A%0D%0AUseful%20links%3A",
	},
	{
		name: "Adoption Partnership",
		price: "£2,000 / month",
		label: "Default",
		bestFor:
			"Marketing, product, DevRel, sales engineering, and engineering teams that need recurring outside judgement while shaping developer adoption.",
		outcome:
			"Leave each month with clearer adoption priorities, stronger technical narrative, and practical next moves your team can own.",
		included: [
			"Monthly working session with your core team",
			"Developer adoption map: audience, trigger, friction, proof, and next action",
			"Async input on active adoption decisions during the month",
			"Shared memo with recommendations, tradeoffs, and owner suggestions",
		],
		boundaries: [
			"Scoped monthly rhythm",
			"No outsourced GTM or DevRel",
			"Your team owns delivery",
		],
		cta: "Email David",
		href: contactHref,
		featured: true,
	},
	{
		name: "Launch Partnership",
		price: "£3,000 / month",
		label: "High focus",
		bestFor:
			"A launch, repositioning, category push, DevRel program, or sales motion needs tighter cross-functional direction while the market window is live.",
		outcome:
			"Keep the adoption strategy, technical narrative, education path, and sales or DevRel handoff aligned while the work is still movable.",
		included: [
			"Monthly private strategy session",
			"Priority async input on active adoption questions",
			"Cross-functional alignment session for product, marketing, DevRel, sales engineering, or engineering",
			"Leadership-ready adoption recommendations",
		],
		boundaries: [
			"Bounded monthly scope",
			"No campaign ownership",
			"No fractional team replacement",
		],
		cta: "Email David",
		href: "mailto:david@rawkode.academy?subject=Launch%20Partnership&body=Company%2Fcategory%3A%0D%0APreferred%20partnership%20path%3A%20Launch%20Partnership%0D%0ATarget%20developers%20or%20platform%20teams%3A%0D%0ATeam%20stakeholders%3A%0D%0AUpcoming%20launch%2C%20repositioning%2C%20sales%20push%2C%20or%20DevRel%20motion%3A%0D%0ACurrent%20adoption%20challenge%3A%0D%0AWhat%20your%20team%20needs%20to%20decide%20next%3A%0D%0AUseful%20links%3A",
	},
];

const inspectAreas = [
	{
		title: "Adoption strategy",
		body: "Who needs to care, what belief needs to change, what friction blocks adoption, and what your team should do next.",
	},
	{
		title: "Technical narrative",
		body: "Turn architecture, tradeoffs, and product depth into a story that developers, platform teams, and technical buyers can follow.",
	},
	{
		title: "Developer education",
		body: "Shape docs, demos, tutorials, learning paths, and examples around the real journey from curiosity to evaluation to internal recommendation.",
	},
	{
		title: "Sales enablement",
		body: "Help sales engineering and GTM teams explain technical value without flattening the product into claims practitioners will reject.",
	},
	{
		title: "DevRel direction",
		body: "Decide what DevRel should own, which developer behaviors matter, and how community, education, and product feedback should connect.",
	},
	{
		title: "Cross-team alignment",
		body: "Get product, marketing, DevRel, sales engineering, and engineering working from the same adoption story and the same technical reality.",
	},
];

const triggers = [
	"You are launching and the story is not turning technical interest into adoption.",
	"Your team knows the product is strong, but developers are not seeing why it matters.",
	"Docs and demos explain features but do not help teams evaluate, recommend, or adopt.",
	"DevRel or community activity is busy, but nobody agrees what it should change.",
	"Sales conversations stall because technical buyers cannot see fit, migration path, or operational reality.",
	"Product, marketing, DevRel, and sales engineering are telling different versions of the story.",
];

const workExamples = [
	{
		title: "Positioning and category",
		body: "Clarify who the product is for, what adoption moment matters, and which claim deserves to lead.",
	},
	{
		title: "Developer journey",
		body: "Map the path from first interest to hands-on evaluation, internal recommendation, and repeated use.",
	},
	{
		title: "Team handoff",
		body: "Make sure product, marketing, DevRel, sales engineering, and engineering can explain the same value without pretending to be the same function.",
	},
];
---

<Page
	title="Partnerships"
	description="Cloud-native and DevTool partnerships for teams improving developer adoption across product, marketing, DevRel, sales engineering, and engineering."
>
	<FAQJsonLD questions={faqs} slot="extra-head" />

	<main class="partnerships-page">
		<section class="partnerships-hero" aria-labelledby="partnerships-title">
			<p class="partnerships-kicker">Partnerships for DevTools and infrastructure teams</p>
			<div class="partnerships-hero__grid">
				<div class="partnerships-hero__copy">
					<h1 id="partnerships-title">We help your team turn technical depth into developer adoption.</h1>
					<div class="partnerships-hero__body">
						<p>
							Rawkode works alongside your marketing, product, DevRel, sales engineering, and engineering teams to shape the strategy, narrative, education, and proof that help developers understand why your product matters and how to adopt it.
						</p>
						<div class="partnerships-hero__next">
							<p class="partnerships-hero__trigger">
								Your team keeps execution. We bring practitioner signal, strategic critique, and cloud-native judgement before the spend hardens.
							</p>
							<div class="partnerships-actions">
								<a class="partnerships-button" href={contactHref}>Email David</a>
								<a class="partnerships-link" href="#packages">View options</a>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section id="inspect" class="partnerships-section partnerships-section--inspect" aria-labelledby="inspect-title">
			<div class="partnerships-section__header">
				<p class="partnerships-kicker">Where we help</p>
				<h2 id="inspect-title">Make adoption clearer across the teams already doing the work.</h2>
				<p>
					The work is strategy, signal, and cross-team clarity: what developers need to understand, believe, try, and repeat before adoption moves.
				</p>
			</div>
			<div class="partnerships-inspection-list">
				{inspectAreas.map((area, index) => (
					<article class="partnerships-inspection-item">
						<span class="partnerships-inspection-item__number">{String(index + 1).padStart(2, "0")}</span>
						<div>
							<h3>{area.title}</h3>
							<p>{area.body}</p>
						</div>
					</article>
				))}
			</div>
		</section>

		<section id="packages" class="partnerships-section partnerships-section--tight" aria-labelledby="packages-title">
			<div class="partnerships-section__header">
				<p class="partnerships-kicker">Partnership paths</p>
				<h2 id="packages-title">Pick the partnership your team needs now.</h2>
				<p>
					Month-to-month help for adoption strategy, technical narrative, developer education, DevRel direction, launch readiness, and sales handoff. No annual lock-in, no fractional DevRel role, no content treadmill.
				</p>
			</div>
			<div class="partnerships-package-grid">
				{packages.map((pkg) => (
					<article class:list={["partnerships-package", { "partnerships-package--featured": pkg.featured }]}>
						<div class="partnerships-package__top">
							<p class="partnerships-package__label">{pkg.label}</p>
							<h3>{pkg.name}</h3>
							<p class="partnerships-package__price">{pkg.price}</p>
							<a class="partnerships-button" href={pkg.href}>{pkg.cta}</a>
						</div>
						<div class="partnerships-package__summary">
							<p>{pkg.bestFor}</p>
							<p class="partnerships-package__outcome">{pkg.outcome}</p>
						</div>
						<div>
							<ul class="partnerships-package__included">
								{pkg.included.map((item) => <li>{item}</li>)}
							</ul>
						</div>
						<div class="partnerships-package__boundary-group" aria-label={`${pkg.name} boundaries`}>
							<ul class="partnerships-package__boundaries">
								{pkg.boundaries.map((item) => <li>{item}</li>)}
							</ul>
						</div>
					</article>
				))}
			</div>
		</section>

		<section class="partnerships-section partnerships-section--split" aria-labelledby="triggers-title">
			<div class="partnerships-section__header">
				<p class="partnerships-kicker">Good fit</p>
				<h2 id="triggers-title">Use this when adoption is the problem, not output volume.</h2>
			</div>
			<ul class="partnerships-trigger-list">
				{triggers.map((trigger) => <li>{trigger}</li>)}
			</ul>
		</section>

		<section class="partnerships-section partnerships-section--split partnerships-section--proof" aria-labelledby="proof-title">
			<div class="partnerships-section__header">
				<p class="partnerships-kicker">Why Rawkode</p>
				<h2 id="proof-title">Built from years of public practitioner work.</h2>
			</div>
			<div class="partnerships-work-grid">
				<article class="partnerships-work">
					<h3>Rawkode Live</h3>
					<p><a href="/shows/rawkode-live">Maintainer-led live builds and product walkthroughs</a> across Kubernetes, observability, identity, platform engineering, security, data, AI infrastructure, and developer tooling.</p>
				</article>
				<article class="partnerships-work">
					<h3>Klustered</h3>
					<p><a href="/shows/klustered">Public Kubernetes failure-mode triage under pressure</a>, with teams working through broken clusters, operational constraints, and real debugging paths.</p>
				</article>
				<article class="partnerships-work">
					<h3>Courses and education</h3>
					<p><a href="/courses/teleport-for-kubernetes">Runnable technical education</a> that shows how developers learn infrastructure, where they get stuck, and what they need before a tool becomes part of their workflow.</p>
				</article>
			</div>
		</section>

		<section class="partnerships-section partnerships-section--split" aria-labelledby="examples-title">
			<div class="partnerships-section__header">
				<p class="partnerships-kicker">Adoption work</p>
				<h2 id="examples-title">What gets clearer.</h2>
				<p>
					The partnership should make the next move easier for the people already responsible for product, marketing, DevRel, sales engineering, and engineering.
				</p>
			</div>
			<div class="partnerships-work-grid">
				{workExamples.map((item) => (
					<article class="partnerships-work">
						<h3>{item.title}</h3>
						<p>{item.body}</p>
					</article>
				))}
			</div>
		</section>

		<section class="partnerships-section partnerships-section--split" aria-labelledby="process-title">
			<div class="partnerships-section__header">
				<p class="partnerships-kicker">Process</p>
				<h2 id="process-title">Email context first. Call only when there is a fit.</h2>
			</div>
			<div class="partnerships-process">
				<article>
					<span>01</span>
					<h3>Email context</h3>
					<p>Company, category, product, target developers, team stakeholders, current adoption challenge, upcoming budget decision, and links if they help.</p>
				</article>
				<article>
					<span>02</span>
					<h3>Get a fit reply</h3>
					<p>David will say whether this fits a signal, adoption, or launch partnership, or whether it is not a good fit.</p>
				</article>
				<article>
					<span>03</span>
					<h3>Work with your team</h3>
					<p>We work with your team on strategy, narrative, education, proof, objections, team alignment, and next actions.</p>
				</article>
			</div>
		</section>

		<section class="partnerships-section partnerships-section--split" aria-labelledby="faq-title">
			<div class="partnerships-section__header">
				<p class="partnerships-kicker">Questions</p>
				<h2 id="faq-title">Clear boundaries before we start.</h2>
			</div>
			<div class="partnerships-faq-list">
				{faqs.map((faq) => (
					<details>
						<summary>{faq.question}</summary>
						<p>{faq.answer}</p>
					</details>
				))}
			</div>
		</section>

		<section class="partnerships-final" aria-labelledby="final-title">
			<p class="partnerships-kicker">Start here</p>
			<h2 id="final-title">Start before the spend is committed.</h2>
			<p>
				Rough context is enough: product, target developers, team stakeholders, adoption challenge, upcoming launch or budget decision, and links if useful.
			</p>
			<a class="partnerships-button" href={contactHref}>Email David</a>
		</section>
	</main>
</Page>

<style>
	.partnerships-page {
		--partnerships-ink: var(--editorial-ink, oklch(0.18 0.02 260));
		--partnerships-muted: var(--editorial-ink-soft, oklch(0.42 0.025 260));
		--partnerships-paper: var(--editorial-paper, oklch(0.985 0.006 95));
		--partnerships-paper-deep: var(--editorial-paper-deep, oklch(0.955 0.012 95));
		--partnerships-line: var(--editorial-hairline, oklch(0.82 0.018 95));
		--partnerships-accent: var(--editorial-spruce, oklch(0.36 0.08 170));
		background: var(--partnerships-paper);
		color: var(--partnerships-ink);
		font-family: var(--font-inter-tight), system-ui, sans-serif;
	}

	.partnerships-hero,
	.partnerships-section,
	.partnerships-final {
		max-width: 118rem;
		margin: 0 auto;
		padding-left: clamp(1rem, 3vw, 3rem);
		padding-right: clamp(1rem, 3vw, 3rem);
	}

	.partnerships-hero {
		padding-top: clamp(1.5rem, 4vw, 3.5rem);
		padding-bottom: clamp(1.5rem, 4vw, 2.5rem);
		border-bottom: 1px solid var(--partnerships-line);
	}

	.partnerships-kicker,
	.partnerships-package__label {
		font-family: var(--font-jetbrains-mono), ui-monospace, monospace;
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		line-height: 1.35;
		margin: 0;
		text-transform: uppercase;
		color: var(--partnerships-accent);
	}

	.partnerships-hero__grid {
		display: grid;
		gap: 1.25rem;
		margin-top: 0.9rem;
	}

	.partnerships-hero h1 {
		font-family: var(--font-inter-tight), system-ui, sans-serif;
		font-size: clamp(2.15rem, 5.5vw, 6rem);
		font-style: normal;
		font-weight: 780;
		letter-spacing: 0;
		line-height: 0.96;
		margin: 0;
		max-width: 100%;
	}

	.partnerships-hero__body p,
	.partnerships-section__header p,
	.partnerships-package p,
	.partnerships-inspection-item p,
	.partnerships-work p,
	.partnerships-process p,
	.partnerships-faq-list p,
	.partnerships-final p {
		color: var(--partnerships-muted);
		font-size: 1rem;
		line-height: 1.55;
		margin: 0;
	}

	.partnerships-hero__body {
		display: grid;
		gap: 0.85rem;
		margin-top: 0.9rem;
	}

	.partnerships-hero__body > p {
		font-size: clamp(1rem, 2.2vw, 1.18rem);
		max-width: 66rem;
	}

	.partnerships-hero__trigger {
		color: var(--partnerships-ink) !important;
		font-weight: 680;
	}

	.partnerships-actions {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin-top: 1.3rem;
		width: fit-content;
	}

	.partnerships-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.85rem;
		border: 1px solid var(--partnerships-ink);
		border-radius: 4px;
		padding: 0.85rem 1rem;
		background: var(--partnerships-ink);
		color: var(--partnerships-paper);
		font-family: var(--font-jetbrains-mono), ui-monospace, monospace;
		font-size: 0.72rem;
		font-weight: 750;
		letter-spacing: 0.08em;
		line-height: 1.1;
		text-align: center;
		text-decoration: none;
		text-transform: uppercase;
	}

	.partnerships-button:hover {
		background: var(--partnerships-accent);
		border-color: var(--partnerships-accent);
	}

	.partnerships-link {
		align-self: flex-start;
		display: inline-flex;
		align-items: center;
		color: var(--partnerships-ink);
		font-family: var(--font-jetbrains-mono), ui-monospace, monospace;
		font-size: 0.72rem;
		font-weight: 750;
		letter-spacing: 0.08em;
		line-height: 1.2;
		min-height: 2.85rem;
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 0.22em;
		text-transform: uppercase;
	}

	.partnerships-link:hover {
		color: var(--partnerships-accent);
	}

	.partnerships-work,
	.partnerships-process article,
	.partnerships-package,
	.partnerships-faq-list details {
		border: 1px solid var(--partnerships-line);
		border-radius: 6px;
		background: var(--partnerships-paper-deep);
	}

	.partnerships-section {
		padding-top: 2.5rem;
		padding-bottom: 2.5rem;
		border-bottom: 1px solid var(--partnerships-line);
		scroll-margin-top: 5rem;
	}

	.partnerships-section--tight {
		padding-top: 2rem;
	}

	.partnerships-section__header {
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
		margin-bottom: 1.25rem;
		max-width: none;
	}

	.partnerships-section h2,
	.partnerships-final h2 {
		font-family: var(--font-inter-tight), system-ui, sans-serif;
		font-size: clamp(1.65rem, 6vw, 4rem);
		font-style: normal;
		font-weight: 760;
		letter-spacing: 0;
		line-height: 0.98;
		margin: 0;
		max-width: 20ch;
	}

	.partnerships-section__header p {
		max-width: 58rem;
	}

	.partnerships-package-grid,
	.partnerships-work-grid,
	.partnerships-process {
		display: grid;
		gap: 1rem;
	}

	.partnerships-package {
		padding: 0.9rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.partnerships-package--featured {
		border-color: var(--partnerships-accent);
		box-shadow: inset 0 0 0 1px var(--partnerships-accent);
	}

	.partnerships-package__top {
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
	}

	.partnerships-package__top .partnerships-button {
		margin-top: 0.35rem;
	}

	.partnerships-package h3,
	.partnerships-inspection-item h3,
	.partnerships-work h3,
	.partnerships-process h3 {
		font-size: 1.25rem;
		font-weight: 730;
		line-height: 1.1;
		letter-spacing: 0;
		margin: 0;
	}

	.partnerships-package__price {
		font-family: var(--font-jetbrains-mono), ui-monospace, monospace;
		font-size: 0.95rem;
		font-weight: 700;
		color: var(--partnerships-ink) !important;
	}

	.partnerships-package__summary {
		display: grid;
		gap: 0.5rem;
	}

	.partnerships-package__outcome {
		color: var(--partnerships-ink) !important;
	}

	.partnerships-package__included,
	.partnerships-trigger-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 0.45rem;
	}

	.partnerships-package__included li,
	.partnerships-trigger-list li {
		position: relative;
		padding-left: 1rem;
		color: var(--partnerships-muted);
		font-size: 0.92rem;
		line-height: 1.4;
	}

	.partnerships-package__included li::before,
	.partnerships-trigger-list li::before {
		content: "";
		position: absolute;
		left: 0;
