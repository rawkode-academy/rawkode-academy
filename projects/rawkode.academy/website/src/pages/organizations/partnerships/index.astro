---
import PageHero from "@/components/layout/PageHero.astro";
import Page from "@/wrappers/page.astro";
import FAQJsonLD from "@/components/html/faq-jsonld.astro";
import { css } from "../../../../styled-system/css";

export const prerender = true;

const valueProps = [
	{ title: "Authentic technical content", description: "Expert-led tutorials, walkthroughs, and reviews that show your technology in real engineering work — not marketing fluff." },
	{ title: "Developer community engagement", description: "Direct conversations with engineers through live streams, AMAs, and community programmes." },
	{ title: "Flexible partnership tiers", description: "Engagement levels designed to match different budgets and content needs — from project-based to long-term annual programmes." },
	{ title: "Measurable outcomes", description: "Comprehensive analytics tailored to your goals — engagement, sentiment, community growth, and product adoption indicators." },
];

const partnershipFAQs = [
	{
		question: "What is the minimum partnership duration?",
		answer: "Our partnerships are structured as annual engagements to ensure we can deliver meaningful results. Developer marketing and education require a strategic, long-term approach to build awareness, trust, and adoption.",
	},
	{
		question: "What are the payment terms for partnerships?",
		answer: "For our entry tiers we typically require annual payment upfront. For larger engagements we offer flexible payment options including quarterly or semi-annual installments.",
	},
	{
		question: "How do you measure partnership success?",
		answer: "We provide comprehensive analytics tailored to your goals. Metrics include content engagement, developer sentiment, community growth, and product adoption indicators. All partnerships include regular performance reviews.",
	},
	{
		question: "How do you qualify potential partners?",
		answer: "We partner with companies that offer genuine value to developers and align with our mission of advancing developer education. We evaluate potential partners based on innovation, relevance, and community impact.",
	},
];

const shell = css({ maxWidth: "72rem", mx: "auto", px: { base: "4", md: "6" }, py: "12" });

const grid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", md: "repeat(2, minmax(0, 1fr))" },
	gap: "5",
});

const card = css({
	p: "6",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
});

const cardTitle = css({
	fontFamily: "display",
	fontSize: "lg",
	fontWeight: "bold",
	color: "fg.primary",
	mb: "3",
});

const cardBody = css({ color: "fg.secondary", lineHeight: "1.6" });

const sectionBlock = css({ mt: "16" });

const sectionTitle = css({
	fontFamily: "display",
	fontSize: { base: "2xl", md: "3xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	color: "fg.primary",
	mb: "8",
	textAlign: "center",
});

const faqList = css({ display: "flex", flexDirection: "column", gap: "3", maxWidth: "48rem", mx: "auto" });

const faqItem = css({
	p: "5",
	borderRadius: "xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
});

const faqQ = css({
	fontWeight: "semibold",
	color: "fg.primary",
	fontSize: "md",
	mb: "2",
	cursor: "pointer",
	listStyle: "none",
});

const faqA = css({ color: "fg.secondary", lineHeight: "1.6", fontSize: "sm" });

const ctaCard = css({
	mt: "16",
	mx: "auto",
	maxWidth: "60rem",
	p: { base: "8", md: "12" },
	borderRadius: "3xl",
	textAlign: "center",
	color: "white",
	backgroundImage: "linear-gradient(135deg, token(colors.brand.500), token(colors.cyan.500))",
	boxShadow: "xl",
});

const ctaTitle = css({ fontFamily: "display", fontSize: { base: "2xl", md: "3xl" }, fontWeight: "bold" });
const ctaBody = css({ mt: "3", fontSize: { base: "md", md: "lg" }, opacity: "0.92", maxWidth: "40rem", mx: "auto" });

const ctaBtn = css({
	mt: "8",
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "6",
	py: "3",
	borderRadius: "lg",
	fontWeight: "semibold",
	color: "fg.primary",
	bg: "white",
	textDecoration: "none",
	_hover: { transform: "translateY(-1px)" },
});
---

<Page title="Strategic Technology Partnerships | Rawkode Academy" description="Partner with Rawkode Academy to accelerate developer adoption, improve product experience, and drive growth.">
	<FAQJsonLD questions={partnershipFAQs} slot="head" />

	<PageHero eyebrow="Partner With Us" title="Strategic Technology Partnerships" subtitle="Accelerate developer adoption and product growth through authentic technical content and strategic guidance." />

	<div class={shell}>
		<div class={grid}>
			{valueProps.map((vp) => (
				<div class={card}>
					<h2 class={cardTitle}>{vp.title}</h2>
					<p class={cardBody}>{vp.description}</p>
				</div>
			))}
		</div>

		<section class={sectionBlock}>
			<h2 class={sectionTitle}>Frequently asked questions</h2>
			<div class={faqList}>
				{partnershipFAQs.map((faq) => (
					<details class={faqItem}>
						<summary class={faqQ}>{faq.question}</summary>
						<p class={faqA}>{faq.answer}</p>
					</details>
				))}
			</div>
		</section>

		<section class={ctaCard}>
			<h2 class={ctaTitle}>Let's build something together</h2>
			<p class={ctaBody}>Schedule a consultation with our team to discuss your goals and how a partnership can help.</p>
			<a href="/organizations/lets-chat" class={ctaBtn}>
				Schedule a chat
				<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 5l7 7-7 7" /></svg>
			</a>
		</section>
	</div>
</Page>
