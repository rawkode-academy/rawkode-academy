---
import FAQJsonLD from "@/components/html/faq-jsonld.astro";
import Page from "@/wrappers/page.astro";

export const prerender = true;

const contactHref =
	"mailto:david@rawkode.academy?subject=Partnership%20fit%20check&body=Company%2Fcategory%3A%0D%0APreferred%20partnership%20path%3A%0D%0ATarget%20technical%20evaluator%3A%0D%0ATeam%20stakeholders%3A%0D%0ADeadline%20or%20launch%20window%3A%0D%0ADocs%2C%20demos%2C%20architecture%20notes%2C%20or%20enablement%20material%3A%0D%0AInfrastructure%20artifacts%20available%3A%0D%0AAdoption%20risk%20or%20decision%20to%20review%3A%0D%0ALinks%2C%20if%20useful%3A";

const faqs = [
	{
		question: "Is this paid media?",
		answer:
			"No. A partnership does not buy coverage, endorsement, paid mentions, guaranteed leads, or editorial placement. It is a focused commercial engagement around technical adoption.",
	},
	{
		question: "Do you replace our marketing, product, or DevRel team?",
		answer:
			"No. We work with marketing, product, DevRel, sales engineering, and technical owners so they can make better decisions. Your team keeps execution ownership; the partnership exposes where technical evaluators are likely to stall, distrust the claim, or miss the value.",
	},
	{
		question: "What should we bring first?",
		answer:
			"Send the company or product, the target technical evaluator, the decision you need to make, the team stakeholders, the review deadline, the surfaces or infrastructure artifacts available, and useful links. Rough context is enough.",
	},
	{
		question: "Why pay for this before budget moves?",
		answer:
			"The point is to avoid a larger wasted bet: a launch story practitioners do not believe, a docs or demo rebuild that still misses evaluation risk, a DevRel hire without a clear remit, or sales-engineering confusion that slows technical buyers. The output tells your team what to keep, change, prove, or stop before more spend is committed.",
	},
	{
		question: "How fast can this start?",
		answer:
			"The diagnostic is the fastest route when the problem is narrow. A monthly partnership is better when several pieces need to align before launch, repositioning, sales enablement, or DevRel spend. Three monthly cycles are often enough to move from risk map to corrected story to launch-ready proof.",
	},
	{
		question: "Do you plan campaigns or run DevRel for us?",
		answer:
			"No. The partnership reviews named adoption decisions, technical proof, docs paths, demos, launch narratives, and enablement surfaces. It does not include full campaign planning, outsourced DevRel execution, custom content production, or open-ended access.",
	},
	{
		question: "Is confidential material safe to share?",
		answer:
			"Start with public or shareable material. If a fit check shows private context is needed, we can agree the right confidentiality boundary before reviewing it.",
	},
];

const packages = [
	{
		name: "Adoption Risk Audit",
		price: "From £1,000",
		label: "One decision",
		bestFor:
			"A launch claim, docs journey, demo flow, sales narrative, or DevRel bet needs a hard technical read before budget moves.",
		outcome:
			"Know what buyers will question, what proof is missing, and what to keep, change, prove, or stop.",
		included: [
			"One adoption decision",
			"Technical objections and missing evidence",
			"60-minute readout plus written P0/P1 actions",
		],
		boundaries: ["Fixed scope", "No implementation", "No rewrites"],
		cta: "Email audit brief",
		href: "mailto:david@rawkode.academy?subject=Adoption%20Risk%20Audit&body=Company%2Fcategory%3A%0D%0APreferred%20partnership%20path%3A%20Adoption%20Risk%20Audit%0D%0ATarget%20technical%20evaluator%3A%0D%0ATeam%20stakeholders%3A%0D%0ADeadline%20or%20launch%20window%3A%0D%0ADocs%2C%20demos%2C%20architecture%20notes%2C%20or%20enablement%20material%3A%0D%0AInfrastructure%20artifacts%20available%3A%0D%0AThe%20one%20adoption%20decision%20to%20review%3A%0D%0ALinks%2C%20if%20useful%3A",
	},
	{
		name: "Monthly Partnership",
		price: "From £2,000 / month",
		label: "Default",
		bestFor:
			"Marketing, product, DevRel, sales engineering, and technical owners need a monthly outside read across launch, docs, demo, enablement, or positioning work.",
		outcome:
			"Find adoption risk early, align the story across teams, and leave each month with practical decisions to ship.",
		included: [
			"Evaluator, buying trigger, and risk map",
			"Review across active launch, docs, demo, or enablement work",
			"Monthly working session plus decision memo",
		],
		boundaries: [
			"Month-to-month",
			"No campaign execution",
			"Your team owns delivery",
		],
		cta: "Email partnership brief",
		href: contactHref,
		featured: true,
	},
	{
		name: "Launch Review Sprint",
		price: "From £3,000",
		label: "High urgency",
		bestFor:
			"A launch, repositioning, sales push, or major product update is already in motion and needs tighter scrutiny before the story reaches the market.",
		outcome:
			"Fast feedback while the launch, repositioning, or sales push is still movable.",
		included: [
			"Two 60-minute working sessions",
			"Risk triage across the critical material",
			"Priority written feedback and leadership-ready summary",
		],
		boundaries: [
			"Bounded sprint",
			"Your team executes",
			"No standing retainer",
		],
		cta: "Email sprint brief",
		href: "mailto:david@rawkode.academy?subject=Launch%20Review%20Sprint&body=Company%2Fcategory%3A%0D%0APreferred%20partnership%20path%3A%20Launch%20Review%20Sprint%0D%0ATarget%20technical%20evaluator%3A%0D%0ATeam%20stakeholders%3A%0D%0ADeadline%20or%20launch%20window%3A%0D%0AThe%20adoption%20risk%20to%20review%3A%0D%0ADocs%2C%20demos%2C%20architecture%20notes%2C%20or%20enablement%20material%3A%0D%0AInfrastructure%20artifacts%20available%3A%0D%0ALinks%2C%20if%20useful%3A",
	},
];

const inspectAreas = [
	{
		title: "Quickstart truth",
		body: "Does the first install prove something useful, or hide Helm charts, CRDs, RBAC/IAM, state, egress, tenancy, and failure modes?",
	},
	{
		title: "Architecture and trust boundary",
		body: "Can a platform engineer see control-plane/data-plane boundaries, credential ownership, telemetry, SaaS versus self-hosted trust boundaries, and data retention?",
	},
	{
		title: "Demo reproducibility",
		body: "Does the demo show a believable operating path with Terraform, operators, rollback, upgrade, cost/resource profile, and runbook implications?",
	},
	{
		title: "Migration story",
		body: "What does a team replace, what breaks, how long migration takes, what data or model movement is required, and what success looks like after day one?",
	},
	{
		title: "Operational proof",
		body: "Are RBAC, auth, observability, upgrade, rollback, PII/log retention, GPU scheduling, scale, and failure handling explained well enough for evaluation?",
	},
	{
		title: "Sales engineer handoff",
		body: "Can sales, DevRel, sales engineering, security, and product experts answer the same technical objections without inventing different stories?",
	},
];

const triggers = [
	"A launch budget is about to move and the technical claim still feels thin.",
	"Docs explain installation but not evaluation, migration, or operation.",
	"The demo is impressive to insiders but does not change buyer confidence.",
	"DevRel activity is growing but adoption behavior is not changing.",
	"Sales needs a sharper technical story than the homepage gives them.",
	"A category or repositioning claim needs to survive a skeptical evaluator.",
];

const workExamples = [
	{
		title: "Launch claims",
		body: "Claims that sound impressive but do not prove operational value, migration value, or a clear reason to change the current stack.",
	},
	{
		title: "Docs paths",
		body: "Docs that install the product but fail the evaluation, migration, security, tenancy, upgrade, and day-two ownership questions.",
	},
	{
		title: "Demos and enablement",
		body: "Demos and sales narratives that work on stage but collapse under platform, security, SRE, or AI infrastructure objections.",
	},
];
---

<Page
	title="Partnerships"
	description="Cloud-native and DevTool SaaS partnerships for teams improving positioning, launches, docs, demos, DevRel, and technical trust."
>
	<FAQJsonLD questions={faqs} slot="extra-head" />

	<main class="partnerships-page">
		<section class="partnerships-hero" aria-labelledby="partnerships-title">
			<p class="partnerships-kicker">Partnerships for cloud-native and DevTool SaaS teams</p>
			<div class="partnerships-hero__grid">
				<div class="partnerships-hero__copy">
					<h1 id="partnerships-title">Stop technical buyers stalling on claims you cannot prove yet.</h1>
					<p>
						We work with your marketing, product, DevRel, sales engineering, and technical teams to pressure-test the claims, docs, demos, and proof buyers use to decide. Your team keeps execution; we make the adoption risks obvious before budget moves.
					</p>
					<div class="partnerships-actions">
						<a class="partnerships-button" href={contactHref}>Email partnership brief</a>
						<a class="partnerships-button partnerships-button--secondary" href="#packages">Compare packages</a>
					</div>
				</div>
				<aside class="partnerships-trigger" aria-label="Common buying trigger">
					<p class="partnerships-trigger__label">Use this before you</p>
					<p>
						Fund a launch, rewrite docs, rebuild a demo, hire DevRel, or arm sales with a story practitioners may not believe yet.
					</p>
				</aside>
			</div>
		</section>

		<section id="inspect" class="partnerships-section partnerships-section--split" aria-labelledby="inspect-title">
			<div class="partnerships-section__header">
				<p class="partnerships-kicker">What we inspect</p>
				<h2 id="inspect-title">Where technical evaluators lose confidence.</h2>
				<p>
					This is not generic brand feedback. Bring the same evidence your evaluator needs: architecture notes, docs, demo paths, operational constraints, and the claims your team is already making.
				</p>
			</div>
			<div class="partnerships-card-grid">
				{inspectAreas.map((area) => (
					<article class="partnerships-card">
						<h3>{area.title}</h3>
						<p>{area.body}</p>
					</article>
				))}
			</div>
		</section>

		<section id="packages" class="partnerships-section partnerships-section--tight" aria-labelledby="packages-title">
			<div class="partnerships-section__header">
				<p class="partnerships-kicker">Partnership paths</p>
				<h2 id="packages-title">Pick the review depth before the next expensive move.</h2>
				<p>
					Start with an audit for one narrow decision. Use the monthly partnership when several teams need to align. Use a sprint when launch timing needs tighter pressure.
				</p>
			</div>
			<div class="partnerships-package-grid">
				{packages.map((pkg) => (
					<article class:list={["partnerships-package", { "partnerships-package--featured": pkg.featured }]}>
						<div class="partnerships-package__top">
							<p class="partnerships-package__label">{pkg.label}</p>
							<h3>{pkg.name}</h3>
							<p class="partnerships-package__price">{pkg.price}</p>
							<a class="partnerships-button" href={pkg.href}>{pkg.cta}</a>
						</div>
						<div class="partnerships-package__summary">
							<p>{pkg.bestFor}</p>
							<p class="partnerships-package__outcome">{pkg.outcome}</p>
						</div>
						<div>
							<ul class="partnerships-package__included">
								{pkg.included.map((item) => <li>{item}</li>)}
							</ul>
						</div>
						<div class="partnerships-package__boundary-group" aria-label={`${pkg.name} boundaries`}>
							<ul class="partnerships-package__boundaries">
								{pkg.boundaries.map((item) => <li>{item}</li>)}
							</ul>
						</div>
					</article>
				))}
			</div>
		</section>

		<section class="partnerships-section partnerships-section--split" aria-labelledby="triggers-title">
			<div class="partnerships-section__header">
				<p class="partnerships-kicker">Good fit</p>
				<h2 id="triggers-title">Bring the work when the next move is expensive.</h2>
			</div>
			<ul class="partnerships-trigger-list">
				{triggers.map((trigger) => <li>{trigger}</li>)}
			</ul>
		</section>

		<section class="partnerships-section partnerships-section--split" aria-labelledby="proof-title">
			<div class="partnerships-section__header">
				<p class="partnerships-kicker">Why Rawkode</p>
				<h2 id="proof-title">Years of making infrastructure claims prove themselves in public.</h2>
			</div>
			<div class="partnerships-work-grid">
				<article class="partnerships-work">
					<h3>90+ technologies covered</h3>
					<p>Kubernetes, observability, identity, platform engineering, WebAssembly, security, data, AI infrastructure, and developer tooling.</p>
				</article>
				<article class="partnerships-work">
					<h3>Public technical judgement</h3>
					<p>Live builds, maintainer sessions, articles, courses, and hands-on demos make technical trade-offs visible before they become sales objections.</p>
				</article>
				<article class="partnerships-work">
					<h3>Useful to operators</h3>
					<p>The output helps the teams shipping the change and the technical owners who have to defend adoption: marketing, product, DevRel, sales engineering, platform, security, and leadership.</p>
				</article>
			</div>
		</section>

		<section class="partnerships-section partnerships-section--split" aria-labelledby="examples-title">
			<div class="partnerships-section__header">
				<p class="partnerships-kicker">Failure points</p>
				<h2 id="examples-title">What gets torn apart.</h2>
				<p>
					The output is not a slide deck that sits in a folder. It is a set of decisions your team can use before launch, docs, demos, sales enablement, or DevRel spend.
				</p>
			</div>
			<div class="partnerships-work-grid">
				{workExamples.map((item) => (
					<article class="partnerships-work">
						<h3>{item.title}</h3>
						<p>{item.body}</p>
					</article>
				))}
			</div>
		</section>

		<section class="partnerships-section partnerships-section--split" aria-labelledby="process-title">
			<div class="partnerships-section__header">
				<p class="partnerships-kicker">Process</p>
				<h2 id="process-title">Email context first. Call only when there is a fit.</h2>
			</div>
			<div class="partnerships-process">
				<article>
					<span>01</span>
					<h3>Email the brief</h3>
					<p>Company, category, target technical evaluator, team stakeholders, deadline, docs, demos, architecture notes, enablement material, and links if they help.</p>
				</article>
				<article>
					<span>02</span>
					<h3>Get a fit reply</h3>
					<p>David will say whether this fits an audit, monthly partnership, sprint, or no fit.</p>
				</article>
				<article>
					<span>03</span>
					<h3>Review the decision</h3>
					<p>We work with your team on the proof, story, docs, demo, objections, and next actions.</p>
				</article>
			</div>
		</section>

		<section class="partnerships-section partnerships-section--split" aria-labelledby="faq-title">
			<div class="partnerships-section__header">
				<p class="partnerships-kicker">Questions</p>
				<h2 id="faq-title">Clear boundaries before we start.</h2>
			</div>
			<div class="partnerships-faq-list">
				{faqs.map((faq) => (
					<details>
						<summary>{faq.question}</summary>
						<p>{faq.answer}</p>
					</details>
				))}
			</div>
		</section>

		<section class="partnerships-final" aria-labelledby="final-title">
			<p class="partnerships-kicker">Start here</p>
			<h2 id="final-title">Email the adoption problem before the spend is committed.</h2>
			<p>
				Rough context is enough: product, target technical evaluator, decision to review, timing, docs, demos, architecture notes, enablement material, and links if useful.
			</p>
			<a class="partnerships-button" href={contactHref}>Email partnership brief</a>
		</section>
	</main>
</Page>

<style>
	.partnerships-page {
		--partnerships-ink: var(--editorial-ink, oklch(0.18 0.02 260));
		--partnerships-muted: var(--editorial-ink-soft, oklch(0.42 0.025 260));
		--partnerships-paper: var(--editorial-paper, oklch(0.985 0.006 95));
		--partnerships-paper-deep: var(--editorial-paper-deep, oklch(0.955 0.012 95));
		--partnerships-line: var(--editorial-hairline, oklch(0.82 0.018 95));
		--partnerships-accent: var(--editorial-spruce, oklch(0.36 0.08 170));
		background: var(--partnerships-paper);
		color: var(--partnerships-ink);
		font-family: var(--font-inter-tight), system-ui, sans-serif;
	}

	.partnerships-hero,
	.partnerships-section,
	.partnerships-final {
		max-width: 72rem;
		margin: 0 auto;
		padding-left: clamp(1rem, 4vw, 2rem);
		padding-right: clamp(1rem, 4vw, 2rem);
	}

	.partnerships-hero {
		padding-top: clamp(1.5rem, 4vw, 3.5rem);
		padding-bottom: clamp(1.5rem, 4vw, 2.5rem);
		border-bottom: 1px solid var(--partnerships-line);
	}

	.partnerships-kicker,
	.partnerships-package__label,
	.partnerships-trigger__label {
		font-family: var(--font-jetbrains-mono), ui-monospace, monospace;
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		line-height: 1.35;
		margin: 0;
		text-transform: uppercase;
		color: var(--partnerships-accent);
	}

	.partnerships-hero__grid {
		display: grid;
		gap: 1.25rem;
		margin-top: 0.9rem;
	}

	.partnerships-hero h1 {
		font-family: var(--font-inter-tight), system-ui, sans-serif;
		font-size: clamp(2.15rem, 6vw, 4.75rem);
		font-style: normal;
		font-weight: 780;
		letter-spacing: 0;
		line-height: 0.96;
		margin: 0;
		max-width: 15ch;
		overflow-wrap: anywhere;
	}

	.partnerships-hero__copy > p,
	.partnerships-trigger p,
	.partnerships-section__header p,
	.partnerships-package p,
	.partnerships-card p,
	.partnerships-work p,
	.partnerships-process p,
	.partnerships-faq-list p,
	.partnerships-final p {
		color: var(--partnerships-muted);
		font-size: 1rem;
		line-height: 1.55;
		margin: 0;
	}

	.partnerships-hero__copy > p {
		font-size: clamp(1rem, 2.2vw, 1.18rem);
		margin-top: 0.9rem;
		max-width: 41rem;
	}

	.partnerships-actions {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin-top: 1.3rem;
	}

	.partnerships-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.85rem;
		border: 1px solid var(--partnerships-ink);
		border-radius: 4px;
		padding: 0.85rem 1rem;
		background: var(--partnerships-ink);
		color: var(--partnerships-paper);
		font-family: var(--font-jetbrains-mono), ui-monospace, monospace;
		font-size: 0.72rem;
		font-weight: 750;
		letter-spacing: 0.08em;
		line-height: 1.1;
		text-align: center;
		text-decoration: none;
		text-transform: uppercase;
	}

	.partnerships-button:hover {
		background: var(--partnerships-accent);
		border-color: var(--partnerships-accent);
	}

	.partnerships-button--secondary {
		background: transparent;
		color: var(--partnerships-ink);
		border-color: var(--partnerships-line);
	}

	.partnerships-trigger,
	.partnerships-card,
	.partnerships-work,
	.partnerships-process article,
	.partnerships-package,
	.partnerships-faq-list details {
		border: 1px solid var(--partnerships-line);
		border-radius: 6px;
		background: var(--partnerships-paper-deep);
	}

	.partnerships-trigger {
		padding: 1rem;
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
	}

	.partnerships-section {
		padding-top: 2.5rem;
		padding-bottom: 2.5rem;
		border-bottom: 1px solid var(--partnerships-line);
		scroll-margin-top: 5rem;
	}

	.partnerships-section--tight {
		padding-top: 2rem;
	}

	.partnerships-section__header {
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
		margin-bottom: 1.25rem;
	}

	.partnerships-section h2,
	.partnerships-final h2 {
		font-family: var(--font-inter-tight), system-ui, sans-serif;
		font-size: clamp(1.65rem, 7vw, 3.1rem);
		font-style: normal;
		font-weight: 760;
		letter-spacing: 0;
		line-height: 0.98;
		margin: 0;
		max-width: 14ch;
	}

	.partnerships-section__header p {
		max-width: 40rem;
	}

	.partnerships-package-grid,
	.partnerships-card-grid,
	.partnerships-work-grid,
	.partnerships-process {
		display: grid;
		gap: 1rem;
	}

	.partnerships-package {
		padding: 0.9rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.partnerships-package--featured {
		border-color: var(--partnerships-accent);
		box-shadow: inset 0 0 0 1px var(--partnerships-accent);
	}

	.partnerships-package__top {
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
	}

	.partnerships-package h3,
	.partnerships-card h3,
	.partnerships-work h3,
	.partnerships-process h3 {
		font-size: 1.25rem;
		font-weight: 730;
		line-height: 1.1;
		letter-spacing: 0;
		margin: 0;
	}

	.partnerships-package__price {
		font-family: var(--font-jetbrains-mono), ui-monospace, monospace;
		font-size: 0.95rem;
		font-weight: 700;
		color: var(--partnerships-ink) !important;
	}

	.partnerships-package__summary {
		display: grid;
		gap: 0.5rem;
	}

	.partnerships-package__outcome {
		color: var(--partnerships-ink) !important;
	}

	.partnerships-package__included,
	.partnerships-trigger-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 0.45rem;
	}

	.partnerships-package__included li,
	.partnerships-trigger-list li {
		position: relative;
		padding-left: 1rem;
		color: var(--partnerships-muted);
		font-size: 0.92rem;
		line-height: 1.4;
	}

	.partnerships-package__included li::before,
	.partnerships-trigger-list li::before {
		content: "";
		position: absolute;
		left: 0;
		top: 0.62em;
		width: 0.35rem;
		height: 0.35rem;
		border-radius: 999px;
		background: var(--partnerships-accent);
	}

	.partnerships-package__boundaries {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.partnerships-package__boundaries li {
		border: 1px solid var(--partnerships-line);
		border-radius: 999px;
