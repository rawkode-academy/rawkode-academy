---
import { css } from "../../../../styled-system/css";
import Badge from "@/components/common/Badge.vue";
import Button from "@/components/common/Button.vue";
import FeatureCard from "@/components/common/FeatureCard.vue";
import GridLayout from "@/components/common/GridLayout.vue";
import { Hero } from "@/components/ui";
import FAQ from "@/components/faq/consulting-list.vue";
import FAQJsonLD from "@/components/html/faq-jsonld.astro";
import Page from "@/wrappers/page.astro";
import {
	sectionSep, sectionHighlight, sectionWhite,
	heading, headingXl, subText, mutedText, secondaryContent,
	serviceCard, serviceCardPopular, priceCard, stepCard,
	iconBubble, svgIcon6, serviceTitle,
	featureList, featureItem, checkIcon5, greenCheck,
	stepNum, stepTitle,
	priceValue, priceUnit, bookLink, popularTag,
	ctaLink, ctaArrow,
} from "../_styles";

export const prerender = true;

const consultingFAQs = [
	{
		question: "What technologies and platforms do you specialize in?",
		answer:
			"We specialize in cloud native infrastructure and software development technologies, with particular expertise in: Infrastructure as Code using Terraform and Pulumi, Kubernetes for both developers and operators, Site Reliability Engineering (SRE) practices, Observability with modern monitoring stacks, Platform Engineering and internal developer platforms, GitOps workflows and continuous delivery, and Software development in Rust and Go with DDD, BDD, and TDD practices.",
	},
	{
		question: "Do you offer remote consulting services?",
		answer:
			"Yes, we provide fully remote consulting services to clients worldwide. We use collaborative tools and structured processes that have proven effective for distributed teams. For certain engagements, we can also arrange for on-site work if required, though this may involve additional travel expenses.",
	},
	{
		question:
			"Can you help with migrating our infrastructure to Infrastructure as Code?",
		answer:
			"Absolutely! We specialize in helping organizations migrate their existing infrastructure to Infrastructure as Code using Terraform or Pulumi. Our process involves a careful assessment of your current environment, creating a migration strategy, implementing the IaC solution with proper testing, and training your team on best practices. We handle everything from basic VM deployments to complex multi-cloud architectures.",
	},
	{
		question: "How quickly can you start a consulting engagement?",
		answer:
			"Our typical lead time is 2-4 weeks from contract signing to project kickoff, depending on the scope of work and our current commitments. For urgent needs, we may be able to accommodate faster timelines – please discuss your timeframe during our initial consultation. We maintain a limited number of active engagements to ensure high-quality delivery for all clients.",
	},
	{
		question: "I have additional questions about consulting services",
		answer:
			"We'd be happy to discuss your specific technical challenges and answer any questions you may have. Schedule a consultation with our team to explore how we can help with your infrastructure, platform engineering, or software development needs.",
	},
];

---

<Page
	title="Technical Consulting Services | Rawkode Academy"
	description="Expert technical consulting for developer experience, cloud native technologies, and software architecture to accelerate your technical initiatives and upskill your teams."
>
	<FAQJsonLD questions={consultingFAQs} slot="head" />
	<!-- Hero Section -->
	<Hero
		title="Expert Technical Consulting"
		subtitle="Accelerate your technical initiatives with expert guidance and hands-on implementation."
		badge="Consulting Services"
		background="blobs"
		pattern="grid"
		wave={true}
		stats={[
			{ label: '20+ Years Experience' },
			{ label: 'Cloud Native Focus' },
			{ label: 'Hands-on Approach' }
		]}
		client:load
	>
		<Fragment slot="actions">
			<Button href="#services" variant="primary" size="lg">Our Services</Button>
			<Button href="/organizations/lets-chat" variant="secondary" size="lg">Schedule Consultation</Button>
		</Fragment>
	</Hero>

	<div class={css({ maxW: '5xl', mx: 'auto', mb: '16', textAlign: 'center', pt: '16' })}>
		<p class={css({ fontSize: 'xl', color: { base: 'gray.700', _dark: 'gray.200' }, mb: '8', lineHeight: 'relaxed' })}>
			Rawkode Academy offers specialized technical consulting services focused
			on cloud infrastructure, Kubernetes, platform engineering, and cloud
			engineering. We help you implement Infrastructure as Code with Terraform
			and Pulumi, optimize Kubernetes environments, establish GitOps workflows,
			implement SRE practices, and build comprehensive observability solutions.
		</p>

		<GridLayout cols={{ default: 1, md: 3 }} gap={6} class="text-left mt-12">
			<FeatureCard
				title="Cloud Native Expertise"
				description="Deep experience with Kubernetes, Terraform, Pulumi, and GitOps workflows to help you build robust, scalable infrastructure and delivery pipelines."
			>
				<svg
					slot="icon"
					class={`${svgIcon6} ${css({ color: 'colorPalette.default' })}`}
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
					xmlns="http://www.w3.org/2000/svg"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"
					></path>
				</svg>
			</FeatureCard>

			<FeatureCard
				title="GitOps & Continuous Delivery"
				description="Implement GitOps practices and continuous delivery pipelines using tools like Flux and ArgoCD to enable declarative, git-based infrastructure and application deployments."
				iconBgColor="bg-secondary/10"
			>
				<svg
					slot="icon"
					class={`${svgIcon6} ${css({ color: 'colorPalette.default' })}`}
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
					xmlns="http://www.w3.org/2000/svg"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
					></path>
				</svg>
			</FeatureCard>

			<FeatureCard
				title="Reliability & Observability"
				description="Establish SRE practices and comprehensive observability solutions that improve system reliability, incident response, and operational visibility."
				iconBgColor="bg-tertiary/10"
			>
				<svg
					slot="icon"
					class={`${svgIcon6} ${css({ color: 'colorPalette.default' })}`}
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
					xmlns="http://www.w3.org/2000/svg"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
					></path>
				</svg>
			</FeatureCard>
		</GridLayout>
	</div>

	<section id="services" class={`${sectionWhite} ${css({ py: '16' })}`}>
		<div class={css({ maxW: 'container', mx: 'auto', px: '4' })}>
			<div class={css({ maxW: 'breakpoint-md', mx: 'auto', mb: '12', textAlign: 'center' })}>
				<h2 class={heading}>Our Consulting Services</h2>
				<p class={subText}>Tailored expertise to address your specific technical challenges</p>
			</div>

			<div class={css({ display: 'grid', gridTemplateColumns: { md: '2' }, gap: '8', maxW: '5xl', mx: 'auto' })}>
				{/* Service 1 */}
				<div class={serviceCard}>
					<div class={css({ display: 'flex', alignItems: 'center', mb: '4' })}>
						<div class={`${iconBubble} ${css({ bg: 'colorPalette.default/10' })}`}>
							<svg class={`${svgIcon6} ${css({ color: 'colorPalette.default' })}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
							</svg>
						</div>
						<h3 class={serviceTitle}>Developer Experience Optimization</h3>
					</div>
					<p class={`${mutedText} ${css({ mb: '4' })}`}>
						Improve your development workflows, tooling, and environments to boost developer productivity and satisfaction.
					</p>
					<ul class={featureList}>
						<li class={featureItem}><svg class={`${checkIcon5} ${css({ color: 'colorPalette.default' })}`} fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg><span class={secondaryContent}>CI/CD pipeline optimization</span></li>
						<li class={featureItem}><svg class={`${checkIcon5} ${css({ color: 'colorPalette.default' })}`} fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg><span class={secondaryContent}>Development environment setup</span></li>
						<li class={featureItem}><svg class={`${checkIcon5} ${css({ color: 'colorPalette.default' })}`} fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg><span class={secondaryContent}>Docker and containerization strategies</span></li>
					</ul>
				</div>

				{/* Service 2 */}
				<div class={serviceCard}>
					<div class={css({ display: 'flex', alignItems: 'center', mb: '4' })}>
						<div class={`${iconBubble} ${css({ bg: 'colorPalette.default/10' })}`}>
							<svg class={`${svgIcon6} ${css({ color: 'colorPalette.default' })}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"></path>
							</svg>
						</div>
						<h3 class={serviceTitle}>Cloud Native Architecture</h3>
					</div>
					<p class={`${mutedText} ${css({ mb: '4' })}`}>
						Design, implement, and optimize cloud-native architectures that leverage Kubernetes and modern infrastructure patterns.
					</p>
					<ul class={featureList}>
						<li class={featureItem}><svg class={`${checkIcon5} ${css({ color: 'colorPalette.default' })}`} fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg><span class={secondaryContent}>Kubernetes deployment strategies</span></li>
						<li class={featureItem}><svg class={`${checkIcon5} ${css({ color: 'colorPalette.default' })}`} fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg><span class={secondaryContent}>Microservices architecture design</span></li>
						<li class={featureItem}><svg class={`${checkIcon5} ${css({ color: 'colorPalette.default' })}`} fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg><span class={secondaryContent}>Service mesh implementation</span></li>
					</ul>
				</div>

				{/* Service 3 */}
				<div class={serviceCard}>
					<div class={css({ display: 'flex', alignItems: 'center', mb: '4' })}>
						<div class={`${iconBubble} ${css({ bg: 'colorPalette.default/10' })}`}>
							<svg class={`${svgIcon6} ${css({ color: 'colorPalette.default' })}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
							</svg>
						</div>
						<h3 class={serviceTitle}>Platform Engineering</h3>
					</div>
					<p class={`${mutedText} ${css({ mb: '4' })}`}>
						Build internal developer platforms that streamline operations and empower engineering teams to focus on value delivery.
					</p>
					<ul class={featureList}>
						<li class={featureItem}><svg class={`${checkIcon5} ${css({ color: 'colorPalette.default' })}`} fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg><span class={secondaryContent}>Self-service infrastructure portals</span></li>
						<li class={featureItem}><svg class={`${checkIcon5} ${css({ color: 'colorPalette.default' })}`} fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg><span class={secondaryContent}>GitOps and Infrastructure as Code</span></li>
						<li class={featureItem}><svg class={`${checkIcon5} ${css({ color: 'colorPalette.default' })}`} fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg><span class={secondaryContent}>Developer tooling standardization</span></li>
					</ul>
				</div>

				{/* Service 4 */}
				<div class={serviceCard}>
					<div class={css({ display: 'flex', alignItems: 'center', mb: '4' })}>
						<div class={`${iconBubble} ${css({ bg: 'colorPalette.default/10' })}`}>
							<svg class={`${svgIcon6} ${css({ color: 'colorPalette.default' })}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
							</svg>
						</div>
						<h3 class={serviceTitle}>Technical Team Development</h3>
					</div>
					<p class={`${mutedText} ${css({ mb: '4' })}`}>
						Upskill your engineering teams with targeted workshops, pair programming, and knowledge transfer sessions.
					</p>
					<ul class={featureList}>
						<li class={featureItem}><svg class={`${checkIcon5} ${css({ color: 'colorPalette.default' })}`} fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg><span class={secondaryContent}>Custom technical workshops</span></li>
						<li class={featureItem}><svg class={`${checkIcon5} ${css({ color: 'colorPalette.default' })}`} fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg><span class={secondaryContent}>Mentoring and technical guidance</span></li>
						<li class={featureItem}><svg class={`${checkIcon5} ${css({ color: 'colorPalette.default' })}`} fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg><span class={secondaryContent}>Technology architecture reviews</span></li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<section class={`${sectionHighlight} ${sectionSep}`}>
		<div class={css({ py: '12', px: '4', mx: 'auto', maxW: 'breakpoint-xl', lg: { py: '16', px: '6' } })}>
			<div class={css({ textAlign: 'center', mb: '10' })}>
				<h2 class={heading}>Engagement Models</h2>
				<p class={subText}>Flexible consulting arrangements designed to meet your specific needs and timeline</p>
			</div>

			<div class={css({ display: 'grid', gridTemplateColumns: { md: '3' }, gap: '8', maxW: '6xl', mx: 'auto' })}>
				{/* Engagement 1 */}
				<div class={priceCard}>
					<div class={css({ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start', mb: '4' })}>
						<h3 class={serviceTitle}>Technology Assessment</h3>
						<Badge variant="primary" size="sm">1-2 weeks</Badge>
					</div>
					<p class={`${mutedText} ${css({ mb: '4' })}`}>
						Comprehensive analysis of your current technology stack, architecture, and development workflows with actionable recommendations.
					</p>
					<div class={css({ mt: '6', mb: '4' })}>
						<span class={priceValue}>$10,000</span>
						<span class={priceUnit}> fixed price</span>
					</div>
					<ul class={`${featureList} ${css({ mb: '6' })}`}>
						<li class={featureItem}><svg class={greenCheck} fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg><span class={secondaryContent}>Deep-dive technical discovery</span></li>
						<li class={featureItem}><svg class={greenCheck} fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg><span class={secondaryContent}>Prioritized recommendations</span></li>
						<li class={featureItem}><svg class={greenCheck} fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg><span class={secondaryContent}>Detailed documentation</span></li>
						<li class={featureItem}><svg class={greenCheck} fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg><span class={secondaryContent}>Executive presentation</span></li>
					</ul>
					<a href="/organizations/lets-chat" class={bookLink}>Book Assessment</a>
				</div>

				{/* Engagement 2 */}
				<div class={serviceCardPopular}>
					<div class={popularTag}>Popular Choice</div>
					<div class={css({ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start', mb: '4' })}>
						<h3 class={serviceTitle}>Implementation Sprint</h3>
						<Badge variant="secondary" size="sm">2-4 weeks</Badge>
					</div>
					<p class={`${mutedText} ${css({ mb: '4' })}`}>
						Hands-on implementation of specific technical initiatives with your team, delivering immediate improvement to your systems.
					</p>
					<div class={css({ mt: '6', mb: '4' })}>
						<span class={priceValue}>$25,000</span>
						<span class={priceUnit}> fixed price</span>
					</div>
					<ul class={`${featureList} ${css({ mb: '6' })}`}>
						<li class={featureItem}><svg class={greenCheck} fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg><span class={secondaryContent}>Focused technical project</span></li>
						<li class={featureItem}><svg class={greenCheck} fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg><span class={secondaryContent}>Direct hands-on coding</span></li>
						<li class={featureItem}><svg class={greenCheck} fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg><span class={secondaryContent}>Knowledge transfer sessions</span></li>
