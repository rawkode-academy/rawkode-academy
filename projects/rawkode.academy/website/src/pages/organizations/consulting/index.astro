---
import FAQJsonLD from "@/components/html/faq-jsonld.astro";
import EditorialShell from "@/components/ui/EditorialShell.astro";
import Page from "@/wrappers/page.astro";

export const prerender = true;

const consultingFAQs = [
	{
		question: "What technologies and platforms do you specialize in?",
		answer:
			"We specialize in cloud native infrastructure, Kubernetes, Infrastructure as Code with Terraform and Pulumi, GitOps with Flux and Argo CD, observability, SRE practices, platform engineering, and software development in Rust and Go.",
	},
	{
		question: "Do you offer remote consulting services?",
		answer:
			"Yes. Most consulting is remote-first. We use structured discovery, shared working sessions, and written handover notes so distributed teams can keep momentum between calls.",
	},
	{
		question: "Can you help with migrating our infrastructure to Infrastructure as Code?",
		answer:
			"Yes. We can assess your existing estate, define a migration path, implement Terraform or Pulumi modules with your team, and leave you with reviewable workflows and operating guidance.",
	},
	{
		question: "How quickly can you start a consulting engagement?",
		answer:
			"Typical lead time is 2-4 weeks after scope is agreed. Short advisory sessions may start sooner when availability allows.",
	},
	{
		question: "I have additional questions about consulting services.",
		answer:
			"Book a conversation with us and we will map the problem, constraints, and likely engagement shape before proposing a scope.",
	},
];

const focusAreas = [
	{
		title: "Platform engineering",
		body: "Design the internal platform, workflows, and team interfaces that let developers ship without waiting on bespoke operations work.",
		items: ["Golden paths", "Self-service infrastructure", "Developer experience reviews"],
	},
	{
		title: "Kubernetes and GitOps",
		body: "Get clusters, delivery pipelines, and operational practices into a repeatable state with practical Flux, Argo CD, and Kubernetes guidance.",
		items: ["Cluster architecture", "Delivery workflows", "Production readiness"],
	},
	{
		title: "Infrastructure as Code",
		body: "Move infrastructure changes into a tested, reviewable system your team can maintain after the engagement ends.",
		items: ["Terraform and Pulumi", "Module design", "Migration planning"],
	},
	{
		title: "Reliability and observability",
		body: "Create the feedback loops needed to operate services confidently, from useful signals to incident learning.",
		items: ["SLOs and alerting", "Tracing and metrics", "Runbooks and reviews"],
	},
	{
		title: "Software architecture",
		body: "Review services, boundaries, and delivery practices with a bias toward code that is easier to change.",
		items: ["Rust and Go", "DDD and testing", "Architecture reviews"],
	},
	{
		title: "Developer tooling",
		body: "Remove workflow drag from local setup, CI, environments, and release processes.",
		items: ["CI/CD cleanup", "Local environments", "Automation strategy"],
	},
];

const engagementSteps = [
	{
		title: "Diagnose",
		body: "We start with your current system, constraints, team shape, and business pressure. The first output is a clear problem map, not a generic roadmap.",
	},
	{
		title: "Build together",
		body: "We work alongside your team on the highest-leverage changes: design sessions, pairing, implementation, reviews, and operational proof.",
	},
	{
		title: "Leave capability",
		body: "Every engagement ends with documented decisions, working examples, and transfer sessions so the team can keep improving without us.",
	},
];

const outcomes = [
	"Sharper platform and infrastructure strategy",
	"Working implementation, not just recommendations",
	"Cleaner delivery and GitOps workflows",
	"Better observability and incident response",
	"Team enablement through pairing and handover",
];
---

<Page
	title="Technical Consulting"
	description="Hands-on cloud native, platform engineering, reliability, and software architecture consulting for engineering teams."
>
	<FAQJsonLD questions={consultingFAQs} slot="extra-head" />
	<EditorialShell
		eyebrow="Organizations"
		title="Consulting"
		lede="Hands-on cloud native and platform engineering help for teams who need working systems, sharper decisions, and durable team capability."
	>
		<div class="editorial-actions" slot="actions">
			<a class="editorial-button" href="/organizations/lets-chat">Talk to us</a>
			<a class="editorial-button editorial-button--secondary" href="#services">See focus areas</a>
		</div>

		<section class="editorial-section">
			<div class="editorial-stat-grid">
				<div class="editorial-stat">
					<span class="editorial-stat__value">2-4w</span>
					<span class="editorial-stat__label">Typical start window</span>
				</div>
				<div class="editorial-stat">
					<span class="editorial-stat__value">Remote</span>
					<span class="editorial-stat__label">Default delivery mode</span>
				</div>
				<div class="editorial-stat">
					<span class="editorial-stat__value">Build</span>
					<span class="editorial-stat__label">Advice plus implementation</span>
				</div>
			</div>
		</section>

		<section id="services" class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">Focus areas</p>
				<h2 class="editorial-section__title">Where we can help</h2>
				<p class="editorial-section__lede">
					We fit around your team instead of replacing it. Engagements can be advisory, implementation-heavy, or a focused blend of both.
				</p>
			</div>
			<div class="editorial-grid editorial-grid--2">
				{focusAreas.map((area) => (
					<article class="editorial-card">
						<h3 class="editorial-card__title">{area.title}</h3>
						<p class="editorial-card__body">{area.body}</p>
						<ul class="editorial-list">
							{area.items.map((item) => <li>{item}</li>)}
						</ul>
					</article>
				))}
			</div>
		</section>

		<section class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">Method</p>
				<h2 class="editorial-section__title">Practical by default</h2>
				<p class="editorial-section__lede">
					The work should improve the system and the team at the same time.
				</p>
			</div>
			<div class="editorial-grid editorial-grid--3">
				{engagementSteps.map((step, index) => (
					<article class="editorial-card editorial-card--paper">
						<p class="editorial-meta">Step {String(index + 1).padStart(2, "0")}</p>
						<h3 class="editorial-card__title">{step.title}</h3>
						<p class="editorial-card__body">{step.body}</p>
					</article>
				))}
			</div>
		</section>

		<section class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">Outcomes</p>
				<h2 class="editorial-section__title">What good looks like</h2>
			</div>
			<div class="editorial-card">
				<ul class="editorial-list">
					{outcomes.map((outcome) => <li>{outcome}</li>)}
				</ul>
			</div>
		</section>

		<section class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">Questions</p>
				<h2 class="editorial-section__title">Consulting FAQ</h2>
			</div>
			<div class="editorial-faq">
				{consultingFAQs.map((item, index) => (
					<details open={index === 0}>
						<summary>{item.question}</summary>
						<p>{item.answer}</p>
					</details>
				))}
			</div>
		</section>

		<section class="editorial-section">
			<div class="editorial-callout">
				<div>
					<h2 class="editorial-section__title">Have a specific technical problem?</h2>
					<p class="editorial-card__body">
						Send us the context. We will tell you whether a short advisory session, a focused implementation sprint, or training would be the right fit.
					</p>
				</div>
				<a class="editorial-button" href="/organizations/lets-chat">Start a conversation</a>
			</div>
		</section>
	</EditorialShell>
</Page>
