---
import PageHero from "@/components/layout/PageHero.astro";
import Page from "@/wrappers/page.astro";
import monogramSvgRaw from "@/components/branding/logos/monogram.svg?raw";
import monogramSvgFile from "@/components/branding/logos/monogram.svg?url";
import wordmarkSvgRaw from "@/components/branding/logos/wordmark.svg?raw";
import wordmarkSvgFile from "@/components/branding/logos/wordmark.svg?url";
import iconSvgRaw from "@/components/branding/logos/logo.svg?raw";
import iconSvgFile from "@/components/branding/logos/logo.svg?url";
import { css } from "../../../../styled-system/css";

export const prerender = true;

const greenPalette = [
	{ label: "Teal", hex: "#04B59C", usage: "Primary actions and hero gradients" },
	{ label: "Green", hex: "#85FF95", usage: "Glow accents and CTA outlines" },
	{ label: "Black", hex: "#23282D", usage: "Typography and surfaces" },
];

const bluePalette = [
	{ label: "Purple", hex: "#5F5ED7", usage: "Primary headlines and hero sweeps" },
	{ label: "Blue", hex: "#00CEFF", usage: "Buttons, inputs, and status indicators" },
	{ label: "Black", hex: "#23282D", usage: "Depth, borders, and typography" },
];

const themingCss = `/* Define colors as variables */
:root {
  --brand-primary: #5F5ED7;
  --brand-on-surface: #23282D; /* base black */
}

/* Inline svg -- set svg children to currentColor */
.brand-logo svg * {
  fill: currentColor !important;
  stroke: currentColor !important;
}

/* Usage: tint the svg by setting color */
.brand-logo--primary { color: var(--brand-primary); }
.brand-logo--dark { color: var(--brand-on-surface); }`;

const gradients = [
	{ name: "Rawkode Core Gradient", angle: "45°", stops: [{ label: "Purple", hex: "#5F5ED7" }, { label: "Cyan", hex: "#00CEFF" }], usage: "Primary brand surfaces, hero backdrops, CTAs, button fills.", background: "linear-gradient(45deg, #5F5ED7 0%, #00CEFF 100%)" },
	{ name: "Rawkode Academy Gradient", angle: "45°", stops: [{ label: "Teal", hex: "#04B59C" }, { label: "Green", hex: "#85FF95" }], usage: "Educational and event surfaces, co-brand with green-leaning partners.", background: "linear-gradient(45deg, #04B59C 0%, #85FF95 100%)" },
];

const guidelines = [
	{ title: "Clearspace", description: "Reserve clearspace equal to the height of the monogram on all sides. Don't let other marks crowd ours.", icon: "M4 6h16M4 12h16M4 18h16" },
	{ title: "Use currentColor", description: "Our SVGs use currentColor so they inherit the parent's color. Set a CSS color and the logo follows.", icon: "M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" },
	{ title: "Don't rotate or distort", description: "Keep the logos upright and proportional. Never stretch, skew, or recolour the lockups outside of the official palette.", icon: "M12 9v3.75m-9.303 3.376C1.83 17.626 2.914 19.5 4.645 19.5h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" },
	{ title: "Light & dark", description: "The brand colours work on both light and dark canvases. Avoid mid-grey backgrounds that flatten the gradient.", icon: "M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" },
];

const logos = [
	{ label: "Icon", svg: iconSvgRaw, file: iconSvgFile },
	{ label: "Monogram", svg: monogramSvgRaw, file: monogramSvgFile },
	{ label: "Wordmark", svg: wordmarkSvgRaw, file: wordmarkSvgFile },
];

const shell = css({ maxWidth: "80rem", mx: "auto", px: { base: "4", md: "6" }, py: "12" });

const section = css({ mb: "16" });

const sectionTitle = css({
	fontFamily: "display",
	fontSize: { base: "2xl", md: "3xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	color: "fg.primary",
	mb: "6",
});

const grid3 = css({ display: "grid", gridTemplateColumns: { base: "1fr", md: "repeat(3, minmax(0, 1fr))" }, gap: "5" });

const colorCard = css({
	overflow: "hidden",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
});

const colorSwatch = css({ height: "32" });

const colorMeta = css({ p: "5", display: "flex", flexDirection: "column", gap: "2" });

const colorLabel = css({ fontFamily: "display", fontSize: "lg", fontWeight: "bold", color: "fg.primary" });
const colorHex = css({ fontFamily: "mono", fontSize: "sm", color: "fg.brand", fontWeight: "semibold" });
const colorUsage = css({ fontSize: "sm", color: "fg.muted" });

const logoCard = css({
	display: "flex",
	flexDirection: "column",
	gap: "4",
	p: "6",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
});

const logoFrame = css({
	display: "flex",
	alignItems: "center",
	justifyContent: "center",
	minHeight: "8rem",
	p: "8",
	borderRadius: "xl",
	bg: "bg.canvas",
	"& svg": { maxWidth: "12rem", maxHeight: "5rem" },
});

const downloadBtn = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "4",
	py: "2",
	borderRadius: "lg",
	bg: "bg.brand-subtle",
	color: "fg.brand",
	fontSize: "sm",
	fontWeight: "semibold",
	textDecoration: "none",
	alignSelf: "flex-start",
	_hover: { bg: "bg.brand", color: "fg.on-brand" },
});

const gradientCard = css({
	overflow: "hidden",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
});

const gradientSwatch = css({ height: "32" });

const gradientMeta = css({ p: "5" });

const gradientTitle = css({ fontFamily: "display", fontSize: "lg", fontWeight: "bold", color: "fg.primary", mb: "2" });
const gradientDesc = css({ fontSize: "sm", color: "fg.muted", mb: "3" });
const gradientStops = css({ display: "flex", gap: "3", fontSize: "xs", fontFamily: "mono", color: "fg.secondary" });

const guidelineGrid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", md: "repeat(2, minmax(0, 1fr))" },
	gap: "4",
});

const guidelineCard = css({
	display: "flex",
	gap: "4",
	p: "5",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
});

const guidelineIcon = css({
	display: "inline-flex",
	alignItems: "center",
	justifyContent: "center",
	w: "10",
	h: "10",
	borderRadius: "lg",
	bg: "bg.brand-subtle",
	color: "fg.brand",
	flexShrink: 0,
});

const guidelineBody = css({ display: "flex", flexDirection: "column", gap: "1" });
const guidelineTitle = css({ fontFamily: "display", fontSize: "md", fontWeight: "bold", color: "fg.primary" });
const guidelineDesc = css({ fontSize: "sm", color: "fg.muted", lineHeight: "1.6" });

const themeBlock = css({ mb: "10" });
const themeLabel = css({ fontSize: "xs", fontWeight: "bold", letterSpacing: "wider", textTransform: "uppercase", color: "fg.brand", mb: "3" });
const themeTitle = css({ fontFamily: "display", fontSize: { base: "xl", md: "2xl" }, fontWeight: "bold", color: "fg.primary", mb: "5" });

const codeBlock = css({
	p: { base: "5", md: "6" },
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	overflow: "auto",
	fontFamily: "mono",
	fontSize: "sm",
	color: "fg.secondary",
	lineHeight: "1.7",
	whiteSpace: "pre",
});

const themingIntro = css({ fontSize: "md", color: "fg.secondary", lineHeight: "1.7", mb: "6", maxWidth: "60ch" });
---

<Page title="Brand Assets | Rawkode Academy" description="Official Rawkode Academy brand assets, palette, and gradients for partners and contributors.">
	<PageHero eyebrow="Brand" title="Brand Assets" subtitle="Official logos, palette, and gradients for co-branding, partnerships, and contributor projects." />

	<div class={shell}>
		<section class={section}>
			<h2 class={sectionTitle}>Logos</h2>
			<div class={grid3}>
				{logos.map((logo) => (
					<div class={logoCard}>
						<div class={logoFrame} set:html={logo.svg}></div>
						<h3 style="font-weight: 600; color: var(--colors-fg-primary);">{logo.label}</h3>
						<a href={logo.file} download class={downloadBtn}>
							<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
							Download SVG
						</a>
					</div>
				))}
			</div>
		</section>

		<section class={section}>
			<h2 class={sectionTitle}>Core color palettes</h2>

			<div class={themeBlock}>
				<p class={themeLabel}>Default</p>
				<h3 class={themeTitle}>Rawkode Green Theme</h3>
				<div class={grid3}>
					{greenPalette.map((c) => (
						<div class={colorCard}>
							<div class={colorSwatch} style={`background: ${c.hex};`}></div>
							<div class={colorMeta}>
								<span class={colorLabel}>{c.label}</span>
								<span class={colorHex}>{c.hex}</span>
								<span class={colorUsage}>{c.usage}</span>
							</div>
						</div>
					))}
				</div>
			</div>

			<div class={themeBlock}>
				<p class={themeLabel}>Co-brand</p>
				<h3 class={themeTitle}>Rawkode Blue Theme</h3>
				<div class={grid3}>
					{bluePalette.map((c) => (
						<div class={colorCard}>
							<div class={colorSwatch} style={`background: ${c.hex};`}></div>
							<div class={colorMeta}>
								<span class={colorLabel}>{c.label}</span>
								<span class={colorHex}>{c.hex}</span>
								<span class={colorUsage}>{c.usage}</span>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class={section}>
			<h2 class={sectionTitle}>How to theme black SVGs</h2>
			<p class={themingIntro}>Only a black source file lives in the repository — theming is applied through CSS. Inline the SVG when possible; for <code>&lt;img/&gt;</code> tags, use CSS filters or masking.</p>
			<pre class={codeBlock}><code>{themingCss}</code></pre>
		</section>

		<section class={section}>
			<h2 class={sectionTitle}>Gradients</h2>
			<div class={grid3} style="grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr));">
				{gradients.map((g) => (
					<div class={gradientCard}>
						<div class={gradientSwatch} style={`background: ${g.background};`}></div>
						<div class={gradientMeta}>
							<h3 class={gradientTitle}>{g.name} · {g.angle}</h3>
							<p class={gradientDesc}>{g.usage}</p>
							<div class={gradientStops}>
								{g.stops.map((s) => <span>{s.label}: {s.hex}</span>)}
							</div>
						</div>
					</div>
				))}
			</div>
		</section>

		<section class={section}>
			<h2 class={sectionTitle}>Usage guidelines</h2>
			<div class={guidelineGrid}>
				{guidelines.map((g) => (
					<div class={guidelineCard}>
						<span class={guidelineIcon}>
							<svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d={g.icon} /></svg>
						</span>
						<div class={guidelineBody}>
							<h3 class={guidelineTitle}>{g.title}</h3>
							<p class={guidelineDesc}>{g.description}</p>
						</div>
					</div>
				))}
			</div>
		</section>
	</div>
</Page>
