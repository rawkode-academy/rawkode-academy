---
import PageHero from "@/components/layout/PageHero.astro";
import Page from "@/wrappers/page.astro";
import controlplaneSvg from "@/components/partner/logos/controlplane.svg?raw";
import fermyonSvg from "@/components/partner/logos/fermyon.svg?raw";
import guidepadSvg from "@/components/partner/logos/guidepad.svg?raw";
import herokuSvg from "@/components/partner/logos/heroku.svg?raw";
import microsoftSvg from "@/components/partner/logos/microsoft.svg?raw";
import ngrokSvg from "@/components/partner/logos/ngrok.svg?raw";
import spectrocloudSvg from "@/components/partner/logos/spectrocloud.svg?raw";
import teleportSvg from "@/components/partner/logos/teleport.svg?raw";
import wundergraphSvg from "@/components/partner/logos/wundergraph.svg?raw";
import zitadelSvg from "@/components/partner/logos/zitadel.svg?raw";
import { css } from "../../../styled-system/css";

export const prerender = true;

function withUtm(url: string): string {
	const u = new URL(url);
	u.searchParams.set("utm_source", "rawkode-academy");
	u.searchParams.set("utm_medium", "partner-logo");
	u.searchParams.set("utm_campaign", "website");
	return u.toString();
}

const currentPartners = [
	{
		name: "Spectro Cloud",
		industry: "Kubernetes",
		since: "2025",
		description: "Kubernetes management platform for deploying, operating, and securing clusters across environments.",
		url: "https://spectrocloud.com",
		logo: spectrocloudSvg,
	},
	{
		name: "Teleport",
		industry: "Identity & Access",
		since: "2026",
		description: "Secure access platform for servers, Kubernetes clusters, databases, and internal applications.",
		url: "https://goteleport.com",
		logo: teleportSvg,
	},
];

const pastPartners = [
	{ name: "ControlPlane", url: "https://controlplane.io", logo: controlplaneSvg },
	{ name: "Fermyon", url: "https://www.fermyon.com", logo: fermyonSvg },
	{ name: "Guidepad", url: "https://guidepad.io", logo: guidepadSvg },
	{ name: "Heroku", url: "https://heroku.com", logo: herokuSvg },
	{ name: "Microsoft Azure", url: "https://azure.com", logo: microsoftSvg },
	{ name: "ngrok", url: "https://ngrok.com", logo: ngrokSvg },
	{ name: "WunderGraph", url: "https://wundergraph.com", logo: wundergraphSvg },
	{ name: "Zitadel", url: "https://zitadel.com", logo: zitadelSvg },
];

const reachStats = [
	{ value: "100K+", label: "Developers reached" },
	{ value: "90+", label: "Technologies covered" },
	{ value: "500+", label: "Hours of content" },
	{ value: "1M+", label: "Developer views" },
];

const pillars = [
	{ title: "Authentic expertise", description: "Two decades of building, breaking, and operating production cloud native systems — not surface-level marketing fluff." },
	{ title: "Engaged community", description: "Direct access to engineers who tune in for the hard problems, the live coding, and the unfiltered conversations." },
	{ title: "Measurable results", description: "Comprehensive analytics tailored to your goals — engagement, sentiment, community growth, and adoption signals." },
];

const services = [
	{
		title: "Strategic Partnerships",
		description: "Accelerate developer adoption through authentic technical content and strategic guidance.",
		link: "/organizations/partnerships",
		features: ["Expert-led technical content", "Developer community engagement", "Flexible partnership tiers", "Measurable outcomes"],
	},
	{
		title: "Expert Consulting",
		description: "Transform your developer experience and go-to-market strategy with battle-tested expertise.",
		link: "/organizations/consulting",
		features: ["Developer experience audits", "Technical strategy workshops", "Developer tools optimization", "Platform engineering guidance"],
	},
	{
		title: "Team Training",
		description: "Empower your teams with hands-on cloud native training programs tailored to your needs.",
		link: "/organizations/training",
		features: ["Custom curriculum design", "Hands-on workshops", "Real-world scenarios", "Ongoing learning support"],
	},
	{
		title: "Branding",
		description: "Access our official brand assets — logos, palette, and usage guidelines.",
		link: "/organizations/branding",
		features: ["Logo and monogram assets", "Color palettes and CSS variables", "Downloadable brand kit"],
	},
];

const shell = css({ maxWidth: "80rem", mx: "auto", px: { base: "4", md: "6" }, py: "12" });

const statsGrid = css({
	display: "grid",
	gridTemplateColumns: { base: "repeat(2, minmax(0, 1fr))", md: "repeat(4, minmax(0, 1fr))" },
	gap: "4",
	mb: "16",
});

const statBox = css({
	textAlign: "center",
	p: { base: "5", md: "7" },
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
});

const statValue = css({
	fontFamily: "display",
	fontSize: { base: "3xl", md: "4xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	backgroundImage: "linear-gradient(135deg, #5f5ed7, #00ceff)",
	backgroundClip: "text",
	color: "transparent",
});

const statLabel = css({ mt: "2", fontSize: "sm", color: "fg.muted", fontWeight: "medium" });

const sectionLabel = css({ fontSize: "xs", fontWeight: "bold", letterSpacing: "wider", textTransform: "uppercase", color: "fg.brand", textAlign: "center", mb: "3" });

const sectionTitle = css({
	fontFamily: "display",
	fontSize: { base: "2xl", md: "3xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	color: "fg.primary",
	textAlign: "center",
	mb: "10",
});

const pillarsGrid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", md: "repeat(3, minmax(0, 1fr))" },
	gap: "5",
	mb: "16",
});

const pillarCard = css({
	p: "6",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
});

const pillarIcon = css({
	display: "inline-flex",
	alignItems: "center",
	justifyContent: "center",
	w: "10",
	h: "10",
	mb: "4",
	borderRadius: "lg",
	bg: "bg.brand-subtle",
	color: "fg.brand",
	fontFamily: "display",
	fontWeight: "bold",
});

const pillarTitle = css({
	fontFamily: "display",
	fontSize: "lg",
	fontWeight: "bold",
	color: "fg.primary",
	mb: "3",
});

const pillarBody = css({ color: "fg.secondary", lineHeight: "1.6" });

const grid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", md: "repeat(2, minmax(0, 1fr))" },
	gap: "6",
});

const card = css({
	display: "flex",
	flexDirection: "column",
	gap: "4",
	p: { base: "6", md: "8" },
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textDecoration: "none",
	color: "fg.primary",
	transition: "transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease",
	_hover: { transform: "translateY(-2px)", boxShadow: "lg", borderColor: "border.default" },
});

const cardTitle = css({
	fontFamily: "display",
	fontSize: "xl",
	fontWeight: "bold",
	color: "fg.primary",
});

const cardDesc = css({ fontSize: "md", color: "fg.secondary", lineHeight: "1.6" });

const featureList = css({
	display: "flex",
	flexDirection: "column",
	gap: "2",
	mt: "2",
	listStyle: "none",
	p: "0",
});

const featureItem = css({
	display: "flex",
	alignItems: "flex-start",
	gap: "2",
	fontSize: "sm",
	color: "fg.secondary",
});

const featureCheck = css({ color: "fg.brand", flexShrink: 0, mt: "0.5" });

const cardLink = css({
	mt: "auto",
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	fontSize: "sm",
	fontWeight: "semibold",
	color: "fg.brand",
});

const ctaCard = css({
	mt: "16",
	mx: "auto",
	maxWidth: "60rem",
	p: { base: "8", md: "12" },
	borderRadius: "3xl",
	textAlign: "center",
	color: "white",
	backgroundImage: "linear-gradient(135deg, #5f5ed7, #00ceff)",
	boxShadow: "xl",
});

const ctaTitle = css({
	fontFamily: "display",
	fontSize: { base: "2xl", md: "3xl" },
	fontWeight: "bold",
});

const ctaBody = css({ mt: "3", fontSize: { base: "md", md: "lg" }, opacity: "0.92", maxWidth: "40rem", mx: "auto" });

const ctaBtn = css({
	mt: "8",
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "6",
	py: "3",
	borderRadius: "lg",
	fontWeight: "semibold",
	color: "fg.primary",
	bg: "white",
	textDecoration: "none",
	transition: "transform 150ms ease",
	_hover: { transform: "translateY(-1px)" },
});

const partnersIntro = css({ maxWidth: "44rem", mx: "auto", color: "fg.secondary", fontSize: { base: "md", md: "lg" }, lineHeight: "1.7", textAlign: "center", mb: "10" });

const partnersHeader = css({ display: "flex", flexWrap: "wrap", alignItems: "center", justifyContent: "space-between", gap: "3", mt: "16", mb: "4" });
const partnersHeaderCol = css({ display: "flex", flexDirection: "column", gap: "1" });
const partnersEyebrow = css({ fontSize: "xs", fontWeight: "bold", letterSpacing: "wider", textTransform: "uppercase", color: "fg.brand" });
const partnersSubTitle = css({ fontFamily: "display", fontSize: "2xl", fontWeight: "bold", letterSpacing: "tight", color: "fg.primary" });
const partnersChip = css({ display: "inline-flex", alignItems: "center", px: "4", py: "1.5", borderRadius: "full", borderWidth: "1px", borderColor: "border.muted", bg: "bg.raised", color: "fg.muted", fontSize: "sm", fontWeight: "semibold" });
const partnersLede = css({ maxWidth: "60ch", color: "fg.secondary", fontSize: { base: "sm", md: "md" }, lineHeight: "1.7", mb: "8" });

const currentList = css({ display: "flex", flexDirection: "column", borderTopWidth: "1px", borderColor: "border.muted" });
const currentEntry = css({
	display: "grid",
	gap: "5",
	py: "6",
	borderBottomWidth: "1px",
	borderColor: "border.muted",
	gridTemplateColumns: { base: "1fr", md: "minmax(0, 18rem) minmax(0, 1fr)" },
	alignItems: "center",
});
const currentMeta = css({ display: "flex", flexWrap: "wrap", alignItems: "center", gap: "3", gridColumn: { base: "1", md: "1 / -1" } });
const currentIndustry = css({ fontSize: "xs", fontWeight: "bold", letterSpacing: "wider", textTransform: "uppercase", color: "fg.brand" });
const currentDot = css({ width: "1", height: "1", borderRadius: "full", bg: "border.default" });
const currentSince = css({ fontSize: "xs", fontWeight: "bold", letterSpacing: "wider", textTransform: "uppercase", color: "fg.muted" });
const currentLogoStage = css({
	display: "grid",
	placeItems: "center",
	minHeight: "7rem",
	px: "5",
	py: "4",
	borderRadius: "xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	"& svg": { width: "100%", height: "4rem", maxWidth: "12rem", display: "block" },
	"& svg path, & svg circle, & svg polygon, & svg rect:not([fill='none'])": { fill: "currentColor !important" },
	color: "fg.primary",
});
const currentBody = css({ display: "flex", flexDirection: "column", gap: "3" });
const currentName = css({ fontFamily: "display", fontSize: "2xl", fontWeight: "bold", letterSpacing: "tight", color: "fg.primary" });
const currentDesc = css({ fontSize: "sm", color: "fg.secondary", lineHeight: "1.7" });
const currentLink = css({ display: "inline-flex", alignItems: "center", gap: "2", fontSize: "sm", fontWeight: "semibold", color: "fg.brand", textDecoration: "none", _hover: { textDecoration: "underline" } });

const pastGrid = css({
	display: "grid",
	gridTemplateColumns: { base: "repeat(2, minmax(0, 1fr))", sm: "repeat(4, minmax(0, 1fr))" },
	columnGap: "5",
	rowGap: "0",
});
const pastMark = css({
	display: "flex",
	alignItems: "center",
	justifyContent: "center",
	py: "4",
	minHeight: "4.5rem",
	borderBottomWidth: "1px",
	borderColor: "border.muted",
	opacity: "0.8",
	transition: "opacity 200ms ease, transform 200ms ease",
	color: "fg.secondary",
	_hover: { opacity: "1", transform: "translateX(2px)" },
	"& svg": { width: "100%", height: "2.3rem", maxWidth: "100%", display: "block" },
	"& svg path, & svg circle, & svg polygon, & svg rect:not([fill='none']), & svg ellipse": { fill: "currentColor !important" },
	"& svg [stroke]:not([stroke='none'])": { stroke: "currentColor !important" },
});
---

<Page title="For Organizations — Rawkode Academy" description="Partner with Rawkode Academy for strategic partnerships, expert consulting, team training, and brand collaboration.">
	<PageHero eyebrow="For Organizations" title="Partner with the Academy" subtitle="Strategic partnerships, hands-on consulting, and team training rooted in real cloud native experience." />

	<div class={shell}>
		<div class={statsGrid}>
			{reachStats.map((stat) => (
				<div class={statBox}>
					<p class={statValue}>{stat.value}</p>
					<p class={statLabel}>{stat.label}</p>
				</div>
			))}
		</div>

		<p class={sectionLabel}>Why teams choose us</p>
		<h2 class={sectionTitle}>Trusted by maintainers and platform teams</h2>
		<div class={pillarsGrid}>
			{pillars.map((p, i) => (
				<div class={pillarCard}>
					<span class={pillarIcon}>{(i + 1).toString().padStart(2, "0")}</span>
					<h3 class={pillarTitle}>{p.title}</h3>
					<p class={pillarBody}>{p.description}</p>
				</div>
			))}
		</div>

		<p class={sectionLabel}>Engagement options</p>
		<h2 class={sectionTitle}>Pick the engagement that fits</h2>
		<div class={grid}>
			{services.map((service) => (
				<a href={service.link} class={card}>
					<h2 class={cardTitle}>{service.title}</h2>
					<p class={cardDesc}>{service.description}</p>
					<ul class={featureList}>
						{service.features.map((f) => (
							<li class={featureItem}>
								<svg class={featureCheck} width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
								<span>{f}</span>
							</li>
						))}
					</ul>
					<span class={cardLink}>
						Learn more
						<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
					</span>
				</a>
			))}
		</div>

		<section>
			<p class={sectionLabel} style="margin-top: 4rem;">Partner showcase</p>
			<h2 class={sectionTitle}>Trusted by Innovative Companies</h2>
			<p class={partnersIntro}>Join these organizations who have partnered with us to accelerate their cloud native journey.</p>

			<div class={partnersHeader}>
				<div class={partnersHeaderCol}>
					<span class={partnersEyebrow}>Current partners</span>
					<h3 class={partnersSubTitle}>Supporting the academy right now</h3>
				</div>
				<span class={partnersChip}>{currentPartners.length} current</span>
			</div>
			<p class={partnersLede}>These teams currently fund the academy. We still evaluate their tools with the same candid, hands-on standard as everything else on Rawkode.</p>

			<div class={currentList}>
				{currentPartners.map((p) => (
					<article class={currentEntry}>
						<div class={currentMeta}>
							<span class={currentIndustry}>{p.industry}</span>
							<span class={currentDot} aria-hidden="true"></span>
							<span class={currentSince}>Since {p.since}</span>
						</div>
						<div class={currentLogoStage} set:html={p.logo}></div>
						<div class={currentBody}>
							<h4 class={currentName}>{p.name}</h4>
							<p class={currentDesc}>{p.description}</p>
							<a href={withUtm(p.url)} target="_blank" rel="noopener noreferrer" class={currentLink}>
								Visit {p.name}
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
							</a>
						</div>
					</article>
				))}
			</div>

			<div class={partnersHeader}>
				<div class={partnersHeaderCol}>
					<span class={partnersEyebrow} style="color: var(--colors-fg-muted);">Past partners</span>
					<h3 class={partnersSubTitle}>Teams we've partnered with before</h3>
				</div>
				<span class={partnersChip}>{pastPartners.length} past</span>
			</div>
			<p class={partnersLede}>Companies we've worked with on earlier sponsorships and educational projects.</p>

			<div class={pastGrid}>
				{pastPartners.map((p) => (
					<a href={withUtm(p.url)} target="_blank" rel="noopener noreferrer" aria-label={`Visit ${p.name}`} title={p.name} class={pastMark} set:html={p.logo}></a>
				))}
			</div>
		</section>

		<section class={ctaCard}>
			<h2 class={ctaTitle}>Ready to talk?</h2>
			<p class={ctaBody}>Tell us what you're building and we'll point you to the engagement that fits — partnership, consulting, training, or something custom.</p>
			<a href="/organizations/lets-chat" class={ctaBtn}>
				Start the conversation
				<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 5l7 7-7 7" /></svg>
			</a>
		</section>
	</div>
</Page>
