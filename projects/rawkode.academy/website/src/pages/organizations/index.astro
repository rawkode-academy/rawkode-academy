---
import EditorialShell from "@/components/ui/EditorialShell.astro";
import Page from "@/wrappers/page.astro";

export const prerender = true;

const contactHref =
	"mailto:david@rawkode.academy?subject=Partnership%20fit%20check&body=Company%2Fcategory%3A%0D%0APreferred%20partnership%20path%3A%0D%0ATarget%20technical%20evaluator%3A%0D%0ATeam%20stakeholders%3A%0D%0ADeadline%20or%20launch%20window%3A%0D%0ASurfaces%20to%20review%3A%0D%0AInfrastructure%20artifacts%20available%3A%0D%0AAdoption%20risk%20or%20decision%20to%20review%3A%0D%0ALinks%2C%20if%20useful%3A";

const practitionerSignals = [
	{
		value: "Proof",
		label: "Docs, demos, architecture, and operational claims",
	},
	{
		value: "Risk",
		label: "Trust boundaries, migration, RBAC/IAM, egress, and tenancy",
	},
	{
		value: "Owners",
		label: "Marketing, product, DevRel, sales engineering, and technical teams",
	},
];

const adoptionSignals = [
	{
		value: "£1k",
		label: "Adoption Diagnostic from",
	},
	{
		value: "£2k/mo",
		label: "Adoption Partnership from",
	},
	{
		value: "£3k/mo",
		label: "Review Sprint from",
	},
];

const fitAreas = [
	{
		title: "Developer adoption partnerships",
		body: "Work with marketing, product, DevRel, sales engineering, and technical owners to expose the proof, docs, demo, and operational gaps blocking adoption.",
		items: [
			"Adoption Diagnostic",
			"Adoption Partnership",
			"Partnership Review Sprint",
			"Adoption context",
		],
		href: "/organizations/partnerships",
		cta: "Compare partnership paths",
	},
];

const utilityLinks = [
	{
		title: "Brand assets",
		body: "Use the official Rawkode Academy marks, palette, and usage guidance when an approved collaboration needs co-branding.",
		href: "/organizations/branding",
		cta: "View brand kit",
	},
];

const badFits = [
	"You need outsourced DevRel execution or someone to run the function for you.",
	"You want paid coverage, guaranteed mentions, media inventory, or leads.",
	"You want a generic workshop disconnected from adoption strategy.",
];
---

<Page
	title="For Organizations"
	description="Developer adoption partnerships for cloud-native and DevTool companies that need sharper practitioner proof, launch, docs, demo, and DevRel strategy."
>
	<EditorialShell
		eyebrow="For Organizations"
		title="Developer Adoption Partnerships"
		lede="Rawkode works with your marketing, product, DevRel, sales engineering, and technical owners to find the proof gaps practitioners hit before they trust a DevTool, cloud-native platform, or infrastructure product. Your team keeps execution ownership; Rawkode sharpens the path."
	>
		<div class="editorial-actions" slot="actions">
			<a class="editorial-button" href="/organizations/partnerships">Compare partnership paths</a>
			<a class="editorial-button editorial-button--secondary" href={contactHref}>Send adoption context</a>
		</div>

		<section class="editorial-section">
			<div class="editorial-stat-grid">
				{practitionerSignals.map((signal) => (
					<div class="editorial-stat">
						<span class="editorial-stat__value">{signal.value}</span>
						<span class="editorial-stat__label">{signal.label}</span>
					</div>
				))}
			</div>
		</section>

		<section class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">What is active now</p>
				<h2 class="editorial-section__title">The company route is Developer Adoption Partnerships</h2>
				<p class="editorial-section__lede">
					For companies, the active route is an Adoption Diagnostic from £1,000, an Adoption Partnership from £2,000/month, or a Partnership Review Sprint from £3,000/month focused on practitioner proof, launch clarity, and technical trust.
				</p>
			</div>
			<div class="editorial-grid editorial-grid--2">
				{fitAreas.map((area) => (
					<article class="editorial-card organizations-card">
						<h3 class="editorial-card__title">{area.title}</h3>
						<p class="editorial-card__body">{area.body}</p>
						<ul class="editorial-list">
							{area.items.map((item) => <li>{item}</li>)}
						</ul>
						<a class="organizations-card__link" href={area.href}>{area.cta}</a>
					</article>
				))}
			</div>
		</section>

		<section class="editorial-section">
			<div class="editorial-stat-grid">
				{adoptionSignals.map((signal) => (
					<div class="editorial-stat">
						<span class="editorial-stat__value">{signal.value}</span>
						<span class="editorial-stat__label">{signal.label}</span>
					</div>
				))}
			</div>
		</section>

		<section class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">Utility</p>
				<h2 class="editorial-section__title">Brand assets are not the commercial offer</h2>
			</div>
			<div class="editorial-grid editorial-grid--2">
				{utilityLinks.map((link) => (
					<article class="editorial-card organizations-card">
						<h3 class="editorial-card__title">{link.title}</h3>
						<p class="editorial-card__body">{link.body}</p>
						<a class="organizations-card__link" href={link.href}>{link.cta}</a>
					</article>
				))}
			</div>
		</section>

		<section class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">Fit check</p>
				<h2 class="editorial-section__title">This is useful when the adoption path is unclear</h2>
			</div>
			<div class="editorial-card editorial-card--paper">
				<p class="editorial-card__body">
					Bring the product, the evaluator, the current adoption risk, the surfaces to review, and any useful infrastructure artifacts: Helm charts, CRDs, RBAC/IAM notes, Terraform, architecture notes, telemetry, tenancy, runbooks, demo environment, or docs paths. We will tell you whether it fits an Adoption Diagnostic, Adoption Partnership, Partnership Review Sprint, or no fit.
				</p>
			</div>
		</section>

		<section class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">Bad fit</p>
				<h2 class="editorial-section__title">What this does not solve</h2>
			</div>
			<ul class="organizations-list">
				{badFits.map((item) => <li>{item}</li>)}
			</ul>
		</section>
	</EditorialShell>
</Page>

<style>
	.organizations-card {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.organizations-card__link {
		align-self: flex-start;
		margin-top: auto;
		font-family: var(--font-jetbrains-mono), ui-monospace, monospace;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--editorial-spruce);
		text-decoration: none;
	}

	.organizations-card__link:hover {
		text-decoration: underline;
		text-underline-offset: 0.2em;
	}

	.organizations-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 0.75rem;
	}

	.organizations-list li {
		border-left: 3px solid var(--editorial-red, #b42318);
		padding: 0.8rem 1rem;
		background: var(--editorial-paper-deep);
		color: var(--editorial-ink-soft);
		font-family: var(--font-inter-tight), system-ui, sans-serif;
		font-size: 0.95rem;
		line-height: 1.5;
	}

	@media (max-width: 760px) {
		.organizations-card__link {
			width: 100%;
		}
	}
</style>
