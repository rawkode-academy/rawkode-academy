---
import PageHero from "@/components/layout/PageHero.astro";
import Page from "@/wrappers/page.astro";
import { css } from "../../../styled-system/css";

export const prerender = true;

const reachStats = [
	{ value: "100K+", label: "Developers reached" },
	{ value: "90+", label: "Technologies covered" },
	{ value: "500+", label: "Hours of content" },
	{ value: "1M+", label: "Developer views" },
];

const pillars = [
	{ title: "Authentic expertise", description: "Two decades of building, breaking, and operating production cloud native systems — not surface-level marketing fluff." },
	{ title: "Engaged community", description: "Direct access to engineers who tune in for the hard problems, the live coding, and the unfiltered conversations." },
	{ title: "Measurable results", description: "Comprehensive analytics tailored to your goals — engagement, sentiment, community growth, and adoption signals." },
];

const services = [
	{
		title: "Strategic Partnerships",
		description: "Accelerate developer adoption through authentic technical content and strategic guidance.",
		link: "/organizations/partnerships",
		features: ["Expert-led technical content", "Developer community engagement", "Flexible partnership tiers", "Measurable outcomes"],
	},
	{
		title: "Expert Consulting",
		description: "Transform your developer experience and go-to-market strategy with battle-tested expertise.",
		link: "/organizations/consulting",
		features: ["Developer experience audits", "Technical strategy workshops", "Developer tools optimization", "Platform engineering guidance"],
	},
	{
		title: "Team Training",
		description: "Empower your teams with hands-on cloud native training programs tailored to your needs.",
		link: "/organizations/training",
		features: ["Custom curriculum design", "Hands-on workshops", "Real-world scenarios", "Ongoing learning support"],
	},
	{
		title: "Branding",
		description: "Access our official brand assets — logos, palette, and usage guidelines.",
		link: "/organizations/branding",
		features: ["Logo and monogram assets", "Color palettes and CSS variables", "Downloadable brand kit"],
	},
];

const shell = css({ maxWidth: "80rem", mx: "auto", px: { base: "4", md: "6" }, py: "12" });

const statsGrid = css({
	display: "grid",
	gridTemplateColumns: { base: "repeat(2, minmax(0, 1fr))", md: "repeat(4, minmax(0, 1fr))" },
	gap: "4",
	mb: "16",
});

const statBox = css({
	textAlign: "center",
	p: { base: "5", md: "7" },
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
});

const statValue = css({
	fontFamily: "display",
	fontSize: { base: "3xl", md: "4xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	backgroundImage: "linear-gradient(135deg, token(colors.brand.500), token(colors.cyan.500))",
	backgroundClip: "text",
	color: "transparent",
});

const statLabel = css({ mt: "2", fontSize: "sm", color: "fg.muted", fontWeight: "medium" });

const sectionLabel = css({ fontSize: "xs", fontWeight: "bold", letterSpacing: "wider", textTransform: "uppercase", color: "fg.brand", textAlign: "center", mb: "3" });

const sectionTitle = css({
	fontFamily: "display",
	fontSize: { base: "2xl", md: "3xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	color: "fg.primary",
	textAlign: "center",
	mb: "10",
});

const pillarsGrid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", md: "repeat(3, minmax(0, 1fr))" },
	gap: "5",
	mb: "16",
});

const pillarCard = css({
	p: "6",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
});

const pillarIcon = css({
	display: "inline-flex",
	alignItems: "center",
	justifyContent: "center",
	w: "10",
	h: "10",
	mb: "4",
	borderRadius: "lg",
	bg: "bg.brand-subtle",
	color: "fg.brand",
	fontFamily: "display",
	fontWeight: "bold",
});

const pillarTitle = css({
	fontFamily: "display",
	fontSize: "lg",
	fontWeight: "bold",
	color: "fg.primary",
	mb: "3",
});

const pillarBody = css({ color: "fg.secondary", lineHeight: "1.6" });

const grid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", md: "repeat(2, minmax(0, 1fr))" },
	gap: "6",
});

const card = css({
	display: "flex",
	flexDirection: "column",
	gap: "4",
	p: { base: "6", md: "8" },
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textDecoration: "none",
	color: "fg.primary",
	transition: "transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease",
	_hover: { transform: "translateY(-2px)", boxShadow: "lg", borderColor: "border.default" },
});

const cardTitle = css({
	fontFamily: "display",
	fontSize: "xl",
	fontWeight: "bold",
	color: "fg.primary",
});

const cardDesc = css({ fontSize: "md", color: "fg.secondary", lineHeight: "1.6" });

const featureList = css({
	display: "flex",
	flexDirection: "column",
	gap: "2",
	mt: "2",
	listStyle: "none",
	p: "0",
});

const featureItem = css({
	display: "flex",
	alignItems: "flex-start",
	gap: "2",
	fontSize: "sm",
	color: "fg.secondary",
});

const featureCheck = css({ color: "fg.brand", flexShrink: 0, mt: "0.5" });

const cardLink = css({
	mt: "auto",
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	fontSize: "sm",
	fontWeight: "semibold",
	color: "fg.brand",
});

const ctaCard = css({
	mt: "16",
	mx: "auto",
	maxWidth: "60rem",
	p: { base: "8", md: "12" },
	borderRadius: "3xl",
	textAlign: "center",
	color: "white",
	backgroundImage: "linear-gradient(135deg, token(colors.brand.500), token(colors.cyan.500))",
	boxShadow: "xl",
});

const ctaTitle = css({
	fontFamily: "display",
	fontSize: { base: "2xl", md: "3xl" },
	fontWeight: "bold",
});

const ctaBody = css({ mt: "3", fontSize: { base: "md", md: "lg" }, opacity: "0.92", maxWidth: "40rem", mx: "auto" });

const ctaBtn = css({
	mt: "8",
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "6",
	py: "3",
	borderRadius: "lg",
	fontWeight: "semibold",
	color: "fg.primary",
	bg: "white",
	textDecoration: "none",
	transition: "transform 150ms ease",
	_hover: { transform: "translateY(-1px)" },
});
---

<Page title="For Organizations — Rawkode Academy" description="Partner with Rawkode Academy for strategic partnerships, expert consulting, team training, and brand collaboration.">
	<PageHero eyebrow="For Organizations" title="Partner with the Academy" subtitle="Strategic partnerships, hands-on consulting, and team training rooted in real cloud native experience." />

	<div class={shell}>
		<div class={statsGrid}>
			{reachStats.map((stat) => (
				<div class={statBox}>
					<p class={statValue}>{stat.value}</p>
					<p class={statLabel}>{stat.label}</p>
				</div>
			))}
		</div>

		<p class={sectionLabel}>Why teams choose us</p>
		<h2 class={sectionTitle}>Trusted by maintainers and platform teams</h2>
		<div class={pillarsGrid}>
			{pillars.map((p, i) => (
				<div class={pillarCard}>
					<span class={pillarIcon}>{(i + 1).toString().padStart(2, "0")}</span>
					<h3 class={pillarTitle}>{p.title}</h3>
					<p class={pillarBody}>{p.description}</p>
				</div>
			))}
		</div>

		<p class={sectionLabel}>Engagement options</p>
		<h2 class={sectionTitle}>Pick the engagement that fits</h2>
		<div class={grid}>
			{services.map((service) => (
				<a href={service.link} class={card}>
					<h2 class={cardTitle}>{service.title}</h2>
					<p class={cardDesc}>{service.description}</p>
					<ul class={featureList}>
						{service.features.map((f) => (
							<li class={featureItem}>
								<svg class={featureCheck} width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
								<span>{f}</span>
							</li>
						))}
					</ul>
					<span class={cardLink}>
						Learn more
						<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
					</span>
				</a>
			))}
		</div>

		<section class={ctaCard}>
			<h2 class={ctaTitle}>Ready to talk?</h2>
			<p class={ctaBody}>Tell us what you're building and we'll point you to the engagement that fits — partnership, consulting, training, or something custom.</p>
			<a href="/organizations/lets-chat" class={ctaBtn}>
				Start the conversation
				<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 5l7 7-7 7" /></svg>
			</a>
		</section>
	</div>
</Page>
