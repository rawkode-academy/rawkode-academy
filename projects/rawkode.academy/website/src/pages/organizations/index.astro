---
import EditorialShell from "@/components/ui/EditorialShell.astro";
import Page from "@/wrappers/page.astro";

export const prerender = true;

const summaryStats = [
	{ value: "£1k-£3k", label: "Monthly range" },
	{ value: "90 min", label: "Monthly cohort session" },
	{ value: "Bounded", label: "Review, not execution" },
];

const organizationPaths = [
	{
		title: "Developer Adoption Partnerships",
		body: "Monthly outside review for infrastructure teams that want marketing, product, and DevRel to make sharper adoption decisions.",
		href: "/organizations/partnerships",
		items: [
			"Cohort review",
			"Question submission",
			"Shared post-session notes",
			"Bounded asset review by tier",
		],
	},
	{
		title: "Branding",
		body: "Official Rawkode Academy logos, marks, colors, and usage guidance for approved co-branding contexts.",
		href: "/organizations/branding",
		items: ["Logo assets", "Usage guidelines", "Color system"],
	},
];

const partnershipBoundaries = [
	"Not a consulting retainer",
	"Not outsourced DevRel",
	"Does not replace marketing, product, or DevRel teams",
	"Not a custom content package",
	"Not sponsored editorial coverage",
	"Not unlimited access",
];
---

<Page
	title="For Organizations"
	description="Monthly partnerships help developer infrastructure companies sharpen adoption direction through practitioner-led review and cohort learning."
>
	<EditorialShell
		eyebrow="Organizations"
		title="Avoid expensive developer adoption mistakes before GTM budget moves"
		lede="Monthly partnerships work with marketing, product, and DevRel teams to pressure-test developer adoption decisions before GTM budget moves."
	>
		<div class="editorial-actions" slot="actions">
			<a class="editorial-button" href="/organizations/partnerships">View partnership tiers</a>
			<a class="editorial-button editorial-button--secondary" href="/organizations/lets-chat">Email your adoption decision</a>
		</div>

		<section class="editorial-section">
			<div class="editorial-stat-grid">
				{summaryStats.map((stat) => (
					<div class="editorial-stat">
						<span class="editorial-stat__value">{stat.value}</span>
						<span class="editorial-stat__label">{stat.label}</span>
					</div>
				))}
			</div>
		</section>

		<section class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">Developer adoption</p>
				<h2 class="editorial-section__title">Pressure-test adoption before spend commits</h2>
				<p class="editorial-section__lede">
					Choose partnerships when the cost of being wrong is higher than the
					monthly fee. Use them before committing budget to launch messaging,
					docs, demos, campaigns, events, community, or DevRel hiring decisions.
				</p>
			</div>
			<div class="editorial-grid editorial-grid--2">
				{organizationPaths.map((path) => (
					<article class="editorial-card">
						<h3 class="editorial-card__title">{path.title}</h3>
						<p class="editorial-card__body">{path.body}</p>
						<ul class="editorial-list">
							{path.items.map((item) => <li>{item}</li>)}
						</ul>
						<a class="editorial-card-link" href={path.href}>Open {path.title}</a>
					</article>
				))}
			</div>
		</section>

		<section class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">Boundary</p>
				<h2 class="editorial-section__title">Designed to stay lightweight</h2>
				<p class="editorial-section__lede">
					The value is clarity and direction for internal teams without turning
					the relationship into an execution-heavy agency, replacement product
					marketer, or fractional DevRel function.
				</p>
			</div>
			<div class="editorial-card">
				<ul class="editorial-list">
					{partnershipBoundaries.map((boundary) => <li>{boundary}</li>)}
				</ul>
			</div>
		</section>

		<section class="editorial-section">
			<div class="editorial-callout">
				<div>
					<h2 class="editorial-section__title">Need practitioner signal before committing budget?</h2>
					<p class="editorial-card__body">
						Email the current GTM decision. We will reply if a monthly
						partnership can create useful practitioner signal before you spend.
					</p>
				</div>
				<a class="editorial-button" href="/organizations/lets-chat">Email your adoption decision</a>
			</div>
		</section>
	</EditorialShell>
</Page>

<style>
	.editorial-card-link {
		display: inline-flex;
		align-items: center;
		width: fit-content;
		margin-top: 1rem;
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--editorial-ink);
		text-decoration-thickness: 1px;
		text-underline-offset: 0.35em;
	}

	.editorial-card-link:hover {
		color: var(--editorial-spruce);
	}
</style>
