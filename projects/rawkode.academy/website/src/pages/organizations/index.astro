---
import { css } from "../../../styled-system/css";
import Button from "@/components/common/Button.vue";
import { Hero } from "@/components/ui";
import PartnerLogos from "@/components/partner/logos.astro";
import Page from "@/wrappers/page.astro";

export const prerender = true;

const services = [
	{
		icon: "rocket",
		title: "Strategic Partnerships",
		description:
			"Accelerate developer adoption through authentic technical content and strategic guidance.",
		link: "/organizations/partnerships",
		features: [
			"Expert-led technical content",
			"Developer community engagement",
			"Flexible partnership tiers",
			"Measurable outcomes",
		],
	},
	{
		icon: "wrench",
		title: "Expert Consulting",
		description:
			"Transform your developer experience and go-to-market strategy with battle-tested expertise.",
		link: "/organizations/consulting",
		features: [
			"Developer experience audits",
			"Technical strategy workshops",
			"Developer tools optimization",
			"Platform engineering guidance",
		],
	},
	{
		icon: "academic",
		title: "Team Training",
		description:
			"Empower your teams with hands-on cloud native training programs tailored to your needs.",
		link: "/organizations/training",
		features: [
			"Custom curriculum design",
			"Hands-on workshops",
			"Real-world scenarios",
			"Ongoing learning support",
		],
	},
	{
		icon: "information",
		title: "Branding",
		description:
			"Access our official brand assets — logos, palette, and usage guidelines for co-branding and partnerships.",
		link: "/organizations/branding",
		features: [
			"Logo and monogram assets",
			"Color palettes and CSS variables",
			"Downloadable brand kit",
		],
	},
];

const sectionLight = css({ py: '16', bg: { base: 'gray.50', _dark: 'gray.900' } });
const sectionWhite = css({ py: '16', bg: { base: 'white', _dark: 'gray.800' } });
const container6xl = css({ maxW: '6xl', mx: 'auto', px: '4' });
const container7xl = css({ maxW: '7xl', mx: 'auto', px: '4' });
const container4xl = css({ maxW: '4xl', mx: 'auto', px: '4', textAlign: 'center' });
const textCenter = css({ textAlign: 'center', mb: '12' });
const heading = css({ fontSize: { base: '3xl', md: '4xl' }, fontWeight: 'bold', color: { base: 'gray.900', _dark: 'white' }, mb: '4' });
const subheading = css({ fontSize: 'xl', color: { base: 'gray.600', _dark: 'gray.400' }, maxW: '3xl', mx: 'auto' });
const grid4 = css({ display: 'grid', gridTemplateColumns: { base: '1', md: '4' }, gap: '8' });
const grid3 = css({ display: 'grid', gridTemplateColumns: { md: '3' }, gap: '8' });

const statCard = css({ textAlign: 'center', p: '6' });
const statValue = css({ fontSize: { base: '4xl', md: '5xl' }, fontWeight: 'bold', color: 'colorPalette.default', mb: '2' });
const statLabel = css({ color: { base: 'gray.600', _dark: 'gray.400' }, fontSize: 'sm', textTransform: 'uppercase', letterSpacing: 'wide' });

const serviceCard = css({
	bg: { base: 'white', _dark: 'gray.800' },
	rounded: 'xl',
	border: '1px solid',
	borderColor: { base: 'gray.200', _dark: 'gray.700' },
	p: '8',
	transition: 'all',
	transitionDuration: '300ms',
	_hover: { shadow: 'xl', borderColor: 'colorPalette.default/50' },
});

const iconStyle = css({ w: '12', h: '12', mb: '6', color: 'colorPalette.default' });

const whyCard = css({ textAlign: 'center' });
const whyIconWrap = css({ display: 'inline-flex', alignItems: 'center', justifyContent: 'center', w: '16', h: '16', rounded: 'full', mb: '4' });
const whyIconPrimary = css({ bg: 'colorPalette.default/10' });
const whyIconSecondary = css({ bg: 'colorPalette.default/10' });
const whyIconTertiary = css({ bg: 'colorPalette.default/10' });
const whyIconSvg = css({ w: '8', h: '8' });
const whyTitle = css({ fontSize: 'xl', fontWeight: 'bold', color: { base: 'gray.900', _dark: 'white' }, mb: '3' });
const whyText = css({ color: { base: 'gray.600', _dark: 'gray.400' } });

const featureItem = css({ display: 'flex', alignItems: 'center', color: { base: 'gray.700', _dark: 'gray.200' } });
const checkIcon = css({ w: '5', h: '5', color: 'green.500', flexShrink: '0', mr: '2' });
const serviceTitle = css({ fontSize: '2xl', fontWeight: 'bold', color: { base: 'gray.900', _dark: 'white' }, mb: '3' });
const serviceDesc = css({ color: { base: 'gray.600', _dark: 'gray.400' }, mb: '6' });
const featureList = css({ display: 'flex', flexDir: 'column', gap: '3', mb: '8' });
const learnMore = css({ display: 'inline-flex', alignItems: 'center', color: 'colorPalette.default', fontWeight: 'semibold', transition: 'colors', transitionDuration: '200ms', _hover: { color: 'colorPalette.default' } });
const learnMoreIcon = css({ w: '5', h: '5', ml: '1' });

const ctaSection = css({ py: '20', backgroundImage: 'linear-gradient(to right, var(--colors-color-palette-default), var(--colors-color-palette-default))', color: 'white' });
const ctaHeading = css({ fontSize: { base: '3xl', md: '4xl' }, fontWeight: 'bold', mb: '6' });
const ctaText = css({ fontSize: 'xl', mb: '8', opacity: '0.9' });
const ctaButtons = css({ display: 'flex', flexDir: { base: 'column', sm: 'row' }, justifyContent: 'center', gap: '4' });
const ctaPrimary = css({
	display: 'inline-flex', alignItems: 'center', justifyContent: 'center',
	px: '8', py: '4', fontSize: 'lg', fontWeight: 'semibold',
	bg: 'white', color: 'colorPalette.default', rounded: 'lg',
	transition: 'all', transitionDuration: '200ms',
	shadow: 'lg', _hover: { bg: 'gray.100', shadow: 'xl' },
});
const ctaSecondary = css({
	display: 'inline-flex', alignItems: 'center', justifyContent: 'center',
	px: '8', py: '4', fontSize: 'lg', fontWeight: 'semibold',
	bg: 'transparent', border: '2px solid white', color: 'white', rounded: 'lg',
	transition: 'all', transitionDuration: '200ms',
	_hover: { bg: 'white/10' },
});
const ctaArrow = css({ w: '5', h: '5', ml: '2' });
---

<Page
	title="Enterprise Solutions | Rawkode Academy"
	description="Partner with Rawkode Academy for strategic partnerships, expert consulting, and team training to accelerate your cloud native journey."
>
	<!-- Hero Section -->
	<Hero
		title="Enterprise Solutions for Modern Teams"
		subtitle="Accelerate your cloud native journey with strategic partnerships, expert consulting, and hands-on training programs designed to drive measurable results."
		badge="For Organizations"
		background="blobs"
		pattern="grid"
		wave={true}
		stats={[
			{ label: 'Global Reach' },
			{ label: 'Proven Expertise' },
			{ label: 'Measurable Impact' }
		]}
		client:load
	>
		<Fragment slot="actions">
			<Button href="#services" variant="primary" size="lg">Explore Services</Button>
			<Button href="/organizations/lets-chat" variant="secondary" size="lg">Schedule a Call</Button>
		</Fragment>
	</Hero>

	<!-- Stats Section -->
	<section class={sectionLight}>
		<div class={container6xl}>
			<div class={grid4}>
				<div class={statCard}>
					<div class={statValue}>100K+</div>
					<div class={statLabel}>Developers Reached</div>
				</div>
				<div class={statCard}>
					<div class={statValue}>90+</div>
					<div class={statLabel}>Technologies Covered</div>
				</div>
				<div class={statCard}>
					<div class={statValue}>500+</div>
					<div class={statLabel}>Hours of Content</div>
				</div>
				<div class={statCard}>
					<div class={statValue}>1M+</div>
					<div class={statLabel}>Developer Views</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Why Choose Us Section -->
	<section class={sectionWhite}>
		<div class={container6xl}>
			<div class={textCenter}>
				<h2 class={heading}>
					Why Choose Rawkode Academy?
				</h2>
				<p class={subheading}>
					We bridge the critical gap between technical innovation and developer understanding
				</p>
			</div>

			<div class={grid3}>
				<div class={whyCard}>
					<div class={`${whyIconWrap} ${whyIconPrimary}`}>
						<svg class={`${whyIconSvg} ${css({ color: 'colorPalette.default' })}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
						</svg>
					</div>
					<h3 class={whyTitle}>Authentic Expertise</h3>
					<p class={whyText}>
						Deep technical knowledge combined with real-world experience building and deploying cloud native applications
					</p>
				</div>

				<div class={whyCard}>
					<div class={`${whyIconWrap} ${whyIconSecondary}`}>
						<svg class={`${whyIconSvg} ${css({ color: 'colorPalette.default' })}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
						</svg>
					</div>
					<h3 class={whyTitle}>Engaged Community</h3>
					<p class={whyText}>
						Access to a passionate, global community of developers actively seeking to learn and adopt new technologies
					</p>
				</div>

				<div class={whyCard}>
					<div class={`${whyIconWrap} ${whyIconTertiary}`}>
						<svg class={`${whyIconSvg} ${css({ color: 'colorPalette.default' })}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
						</svg>
					</div>
					<h3 class={whyTitle}>Measurable Results</h3>
					<p class={whyText}>
						Data-driven approach with comprehensive analytics and reporting to track engagement and adoption
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Services Section -->
	<section id="services" class={css({ py: '20', bg: { base: 'gray.50', _dark: 'gray.900' } })}>
		<div class={container7xl}>
			<div class={css({ textAlign: 'center', mb: '16' })}>
				<h2 class={heading}>
					Our Services
				</h2>
				<p class={subheading}>
					Tailored solutions to meet your organization's unique needs
				</p>
			</div>

			<div class={grid3}>
				{services.map((service) => (
					<div class={serviceCard}>
						<div class={css({ mb: '6' })}>
							{service.icon === 'rocket' && (
								<svg class={iconStyle} fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
								</svg>
							)}
							{service.icon === 'wrench' && (
								<svg class={iconStyle} fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
								</svg>
							)}
							{service.icon === 'information' && (
								<svg class={iconStyle} fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M12 20c4.418 0 8-3.582 8-8s-3.582-8-8-8-8 3.582-8 8 3.582 8 8 8z"></path>
								</svg>
							)}
							{service.icon === 'academic' && (
								<svg class={iconStyle} fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path d="M12 14l9-5-9-5-9 5 9 5z"></path>
									<path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"></path>
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222"></path>
								</svg>
							)}
						</div>

						<h3 class={serviceTitle}>
							{service.title}
						</h3>

						<p class={serviceDesc}>
							{service.description}
						</p>

						<ul class={featureList}>
							{service.features.map((feature) => (
								<li class={featureItem}>
									<svg class={checkIcon} fill="currentColor" viewBox="0 0 20 20">
										<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
									</svg>
									{feature}
								</li>
							))}
						</ul>

						<a
							href={service.link}
							class={learnMore}
						>
							Learn More
							<svg class={learnMoreIcon} fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
							</svg>
						</a>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Trusted Partners Section -->
	<section class={sectionWhite}>
		<div class={container6xl}>
			<div class={textCenter}>
				<h2 class={heading}>
					Trusted by Innovative Companies
				</h2>
				<p class={css({ fontSize: 'xl', color: { base: 'gray.600', _dark: 'gray.400' } })}>
					Join these organizations who have partnered with us to accelerate their cloud native journey
				</p>
			</div>

			<div class={css({ mt: '10' })}>
				<PartnerLogos />
			</div>
		</div>
	</section>

	<!-- CTA Section -->
	<section class={ctaSection}>
		<div class={container4xl}>
			<h2 class={ctaHeading}>
				Ready to Accelerate Your Cloud Native Journey?
			</h2>
			<p class={ctaText}>
				Schedule a consultation to explore how we can help you achieve your goals
			</p>
			<div class={ctaButtons}>
				<a
					href="/organizations/lets-chat"
					class={ctaPrimary}
				>
					Schedule a Call
					<svg class={ctaArrow} fill="currentColor" viewBox="0 0 20 20">
						<path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
					</svg>
				</a>
				<a
					href="#services"
					class={ctaSecondary}
				>
					View Services
				</a>
			</div>
		</div>
	</section>
</Page>
