---
import ContactFallback from "@/components/organizations/ContactFallback.astro";
import EditorialShell from "@/components/ui/EditorialShell.astro";
import {
	decisionBriefMailto,
	decisionBriefSubject,
	decisionBriefTemplate,
	partnershipBoundaries,
	partnershipTierNames,
	partnershipTiers,
} from "@/lib/partnerships";
import Page from "@/wrappers/page.astro";

export const prerender = true;

const contactHref = decisionBriefMailto;

const reviewScope = [
	{
		term: "What we review",
		detail: "Docs, demos, architecture, and operational claims.",
	},
	{
		term: "Risk we surface",
		detail: "Trust boundaries, migration, RBAC/IAM, egress, and tenancy.",
	},
	{
		term: "Who owns the work",
		detail:
			"Marketing, product, DevRel, sales engineering, and technical teams. Your team keeps execution.",
	},
];

const pricingStats = partnershipTiers.map((tier) => ({
	value: tier.priceShort,
	label: `${tier.name} from`,
}));

const tierSummary = partnershipTiers
	.map(
		(tier, index) =>
			`${index === partnershipTiers.length - 1 ? "or " : ""}${tier.name} from ${tier.price.replace(" / ", "/")}`,
	)
	.join(", ");

const fitAreas = [
	{
		title: "Partnerships",
		body: "Work with marketing, product, DevRel, sales engineering, and technical owners to expose the claims, docs, demos, and operational gaps that stall technical buyers.",
		items: [...partnershipTierNames, "Technical buyer proof"],
		href: "/organizations/partnerships",
		cta: "Compare partnership paths",
	},
];

const utilityLinks = [
	{
		title: "Brand assets",
		body: "Use the official Rawkode Academy marks, palette, and usage guidance when an approved collaboration needs co-branding.",
		href: "/organizations/branding",
		cta: "View brand kit",
	},
];

const badFits = partnershipBoundaries;
---

<Page
	title="For Organizations"
	description="Cloud-native and DevTool partnerships for companies that need sharper technical proof, launch, docs, demo, and DevRel strategy."
>
	<EditorialShell
		eyebrow="For Organizations"
		title="Partnerships"
		lede="We work with your marketing, product, DevRel, sales engineering, and technical owners to find the claims practitioners cannot verify before they trust a DevTool, cloud-native platform, or infrastructure product. Your team keeps execution ownership; the partnership sharpens the path."
	>
		<div class="editorial-actions" slot="actions">
			<a class="editorial-button" href="/organizations/partnerships">Compare packages</a>
			<a class="editorial-button editorial-button--secondary" href={contactHref}>Email decision brief</a>
		</div>

		<section class="editorial-section">
			<dl class="organizations-scope">
				{reviewScope.map((row) => (
					<div class="organizations-scope__row">
						<dt>{row.term}</dt>
						<dd>{row.detail}</dd>
					</div>
				))}
			</dl>
		</section>

		<section class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">What is active now</p>
				<h2 class="editorial-section__title">The company route is partnerships</h2>
				<p class="editorial-section__lede">
					For companies, the active paths are {tierSummary}, focused on practitioner signal, focused experiments, and peer perspective.
				</p>
			</div>
			<div class="editorial-grid editorial-grid--2">
				{fitAreas.map((area) => (
					<article class="editorial-card organizations-card">
						<h3 class="editorial-card__title">{area.title}</h3>
						<p class="editorial-card__body">{area.body}</p>
						<ul class="editorial-list">
							{area.items.map((item) => <li>{item}</li>)}
						</ul>
						<a class="organizations-card__link" href={area.href}>{area.cta}</a>
					</article>
				))}
			</div>
		</section>

		<section class="editorial-section">
			<div class="editorial-stat-grid">
				{pricingStats.map((signal) => (
					<div class="editorial-stat">
						<span class="editorial-stat__value">{signal.value}</span>
						<span class="editorial-stat__label">{signal.label}</span>
					</div>
				))}
			</div>
		</section>

		<section class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">Utility</p>
				<h2 class="editorial-section__title">Brand assets are not the commercial offer</h2>
			</div>
			<div class="editorial-grid editorial-grid--2">
				{utilityLinks.map((link) => (
					<article class="editorial-card organizations-card">
						<h3 class="editorial-card__title">{link.title}</h3>
						<p class="editorial-card__body">{link.body}</p>
						<a class="organizations-card__link" href={link.href}>{link.cta}</a>
					</article>
				))}
			</div>
		</section>

		<section class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">Fit check</p>
				<h2 class="editorial-section__title">This is useful when the adoption path is unclear</h2>
			</div>
			<div class="editorial-card editorial-card--paper">
				<p class="editorial-card__body">
					Bring the product, the evaluator, the current adoption risk, the docs, demos, architecture notes, enablement material, and any useful infrastructure artifacts: Helm charts, CRDs, RBAC/IAM notes, Terraform, telemetry, tenancy, runbooks, or demo environments. We will tell you whether it fits Signal, Adoption, Council, or is not a fit.
				</p>
			</div>
			<ContactFallback
				subject={decisionBriefSubject}
				template={decisionBriefTemplate}
			/>
		</section>

		<section class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">Bad fit</p>
				<h2 class="editorial-section__title">What this does not solve</h2>
			</div>
			<ul class="organizations-list">
				{badFits.map((item) => <li>{item}</li>)}
			</ul>
		</section>
	</EditorialShell>
</Page>

<style>
	.organizations-card {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.organizations-card__link {
		align-self: flex-start;
		margin-top: auto;
		font-family: var(--font-jetbrains-mono), ui-monospace, monospace;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--editorial-spruce);
		text-decoration: none;
	}

	.organizations-card__link:hover {
		text-decoration: underline;
		text-underline-offset: 0.2em;
	}

	.organizations-scope {
		margin: 0;
		border-top: 1px solid var(--editorial-hairline);
		border-bottom: 1px solid var(--editorial-hairline);
	}

	.organizations-scope__row {
		display: grid;
		gap: 0.35rem;
		padding: 0.9rem 0;
	}

	.organizations-scope__row + .organizations-scope__row {
		border-top: 1px solid var(--editorial-hairline);
	}

	.organizations-scope dt {
		font-family: var(--font-jetbrains-mono), ui-monospace, monospace;
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--editorial-spruce);
	}

	.organizations-scope dd {
		margin: 0;
		color: var(--editorial-ink-soft);
		font-family: var(--font-inter-tight), system-ui, sans-serif;
		font-size: 0.98rem;
		line-height: 1.55;
	}

	@media (min-width: 760px) {
		.organizations-scope__row {
			grid-template-columns: minmax(11rem, 0.28fr) minmax(0, 1fr);
			gap: 1.5rem;
			align-items: baseline;
		}
	}

	.organizations-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 0.75rem;
	}

	.organizations-list li {
		border: 1px solid var(--editorial-hairline);
		padding: 0.8rem 1rem;
		background: var(--editorial-paper-deep);
		color: var(--editorial-ink-soft);
		font-family: var(--font-inter-tight), system-ui, sans-serif;
		font-size: 0.95rem;
		line-height: 1.5;
	}

	@media (max-width: 760px) {
		.organizations-card__link {
			width: 100%;
		}
	}
</style>
