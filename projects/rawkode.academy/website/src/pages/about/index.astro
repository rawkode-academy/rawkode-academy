---
import EditorialShell from "@/components/ui/EditorialShell.astro";
import Page from "@/wrappers/page.astro";

export const prerender = true;

const stats = [
	{
		value: "60K+",
		label: "Developers reached",
	},
	{
		value: "500+",
		label: "Hours of content",
	},
	{
		value: "90+",
		label: "Projects featured",
	},
];

const missionPillars = [
	{
		title: "Hands-on and honest",
		body: "We show the work as it happens, including the mistakes, dead ends, and fixes that make technical learning real.",
	},
	{
		title: "Maintainer-first",
		body: "We bring creators and contributors into the room so learners hear the decisions, constraints, and trade-offs from the people closest to the project.",
	},
	{
		title: "Future-looking",
		body: "We track emerging runtimes, infrastructure patterns, and developer workflows before they become default practice.",
	},
];

const timeline = [
	{
		period: "2003-2014",
		title: "Full-stack builder and accidental SRE",
		body: "David worked across ticketing systems, custom kernels, QT point-of-sale apps, early mobile devices, and automation that shaped a long-running interest in reliable systems.",
	},
	{
		period: "2014-2016",
		title: "Scaling TeamRock",
		body: "As Director of Development, he helped move workloads from virtual machines to containers on AWS during a period of intense traffic growth.",
	},
	{
		period: "2016-2019",
		title: "Developer advocate at InfluxData",
		body: "Working with Kubernetes metrics, Telegraf, and operators made education, live demos, and direct technical support a daily practice.",
	},
	{
		period: "2019",
		title: "Rawkode Academy launches",
		body: "The first video set the tone for live, practical exploration of cloud native tools and the people behind them.",
	},
	{
		period: "Today",
		title: "Still experimenting in public",
		body: "The academy now mixes shows, articles, and developer adoption partnerships around the same core idea: learn by doing the real work.",
	},
];

const formats = [
	{
		title: "Rawkode Live",
		body: "Live sessions with maintainers and practitioners exploring releases, ideas, bugs, and production patterns.",
		items: ["Live coding", "Maintainer access", "Real troubleshooting"],
	},
	{
		title: "Klustered",
		body: "A Kubernetes troubleshooting format where experts repair deliberately broken clusters under pressure.",
		items: ["Kubernetes", "Incident response", "Operational intuition"],
	},
	{
		title: "Learning paths",
		body: "Curated sequences of articles, shows, and courses that turn broad topics into practical progression.",
		items: ["Self-paced", "Curated resources", "Actionable outcomes"],
	},
];
---

<Page
	title="About Rawkode Academy"
	description="The story, mission, and formats behind Rawkode Academy and its practical cloud native education."
	pageType="AboutPage"
>
	<EditorialShell
		eyebrow="About"
		title="Cloud native education built in public"
		lede="Rawkode Academy helps engineers understand modern infrastructure by watching real people build, break, debug, and explain real systems."
	>
		<div class="editorial-actions" slot="actions">
			<a class="editorial-button" href="/watch">Watch latest</a>
			<a class="editorial-button editorial-button--secondary" href="/organizations/partnerships">Work with us</a>
		</div>

		<section class="editorial-section">
			<div class="editorial-stat-grid">
				{stats.map((stat) => (
					<div class="editorial-stat">
						<span class="editorial-stat__value">{stat.value}</span>
						<span class="editorial-stat__label">{stat.label}</span>
					</div>
				))}
			</div>
		</section>

		<section class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">Mission</p>
				<h2 class="editorial-section__title">Make complex systems easier to learn without pretending they are simple</h2>
				<p class="editorial-section__lede">
					We care about the full path from curiosity to production confidence: context, trade-offs, tooling, mistakes, and repetition.
				</p>
			</div>
			<div class="editorial-grid editorial-grid--3">
				{missionPillars.map((pillar) => (
					<article class="editorial-card">
						<h3 class="editorial-card__title">{pillar.title}</h3>
						<p class="editorial-card__body">{pillar.body}</p>
					</article>
				))}
			</div>
		</section>

		<section class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">Story</p>
				<h2 class="editorial-section__title">A builder's path into teaching</h2>
			</div>
			<div class="about-timeline">
				{timeline.map((item) => (
					<article class="about-timeline__item">
						<p class="editorial-meta">{item.period}</p>
						<h3 class="editorial-card__title">{item.title}</h3>
						<p class="editorial-card__body">{item.body}</p>
					</article>
				))}
			</div>
		</section>

		<section class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">Formats</p>
				<h2 class="editorial-section__title">How we teach</h2>
				<p class="editorial-section__lede">
					Everything is built around practical exposure to tools, maintainers, and trade-offs.
				</p>
			</div>
			<div class="editorial-grid editorial-grid--3">
				{formats.map((format) => (
					<article class="editorial-card">
						<h3 class="editorial-card__title">{format.title}</h3>
						<p class="editorial-card__body">{format.body}</p>
						<div class="editorial-pill-row">
							{format.items.map((item) => <span class="editorial-pill">{item}</span>)}
						</div>
					</article>
				))}
			</div>
		</section>

		<section class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">Origin clips</p>
				<h2 class="editorial-section__title">Two moments that shaped the academy</h2>
			</div>
			<div class="editorial-grid editorial-grid--2">
				<article class="editorial-card about-video">
					<div class="about-video__frame">
						<iframe
							src="https://www.youtube-nocookie.com/embed/ebei2vbn2o8?si=f5-J_6DpjxW39xn7"
							title="Last Week in Kubernetes"
							allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
							allowfullscreen
						></iframe>
					</div>
					<h3 class="editorial-card__title">Last Week in Kubernetes</h3>
					<p class="editorial-card__body">The first format that proved live, curious exploration could work.</p>
				</article>
				<article class="editorial-card about-video">
					<div class="about-video__frame">
						<iframe
							src="https://www.youtube-nocookie.com/embed/teB22ZuV_z8"
							title="Klustered Episode One"
							allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
							allowfullscreen
						></iframe>
					</div>
					<h3 class="editorial-card__title">Klustered</h3>
					<p class="editorial-card__body">Kubernetes troubleshooting turned into shared, high-signal learning.</p>
				</article>
			</div>
		</section>

		<section class="editorial-section">
			<div class="editorial-callout">
				<div>
					<h2 class="editorial-section__title">Bring Rawkode Academy into your week</h2>
					<p class="editorial-card__body">
						Watch the latest episode, share an open-source project, or work with Rawkode on developer adoption proof for cloud-native and DevTool teams.
					</p>
				</div>
				<div class="editorial-button-row">
					<a class="editorial-button" href="/watch">Watch</a>
					<a class="editorial-button" href="/organizations/partnerships">Adoption Partnerships</a>
					<a class="editorial-button" href="/maintainers/share-your-project">Share a project</a>
				</div>
			</div>
		</section>
	</EditorialShell>
</Page>

<style>
	.about-timeline {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.about-timeline__item {
		border-left: 2px solid var(--editorial-spruce);
		padding-left: 1rem;
	}

	.about-video {
		padding: 0;
		overflow: hidden;
	}

	.about-video__frame {
		aspect-ratio: 16 / 9;
		background: var(--editorial-ink);
	}

	.about-video iframe {
		width: 100%;
		height: 100%;
		border: 0;
		display: block;
	}

	.about-video .editorial-card__title,
	.about-video .editorial-card__body {
		margin-left: 1rem;
		margin-right: 1rem;
	}

	.about-video .editorial-card__title {
		margin-top: 1rem;
	}

	.about-video .editorial-card__body {
		margin-bottom: 1rem;
	}
</style>
