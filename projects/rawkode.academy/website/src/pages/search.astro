---
import { getCollection } from "astro:content";
import { env } from "cloudflare:workers";
import PageHero from "@/components/layout/PageHero.astro";
import Page from "@/wrappers/page.astro";
import { captureServerEvent, getDistinctId } from "@/server/analytics";
import { css } from "../../styled-system/css";

const searchQuery = (Astro.url.searchParams.get("q") || "").trim();
const normalizedQuery = searchQuery.toLowerCase();

const results = normalizedQuery
	? await getCollection("videos", ({ data }) => {
			const haystack = `${data.title} ${data.description ?? ""}`.toLowerCase();
			return haystack.includes(normalizedQuery);
		})
	: [];

if (normalizedQuery) {
	const analytics = env.ANALYTICS as Fetcher | undefined;
	await captureServerEvent(
		{
			event: "search_performed",
			properties: { query: searchQuery, results_count: results.length, search_type: "video" },
			distinctId: getDistinctId(Astro),
		},
		analytics,
	);
}

const feedVideos = results
	.sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime())
	.slice(0, 24)
	.map((video) => ({
		id: video.data.id,
		title: video.data.title,
		description: video.data.description,
		slug: video.data.slug,
		thumbnailUrl: `https://content.rawkode.academy/videos/${video.data.id}/thumbnail.jpg`,
		duration: typeof video.data.duration === "number" ? video.data.duration : 0,
		publishedAt:
			video.data.publishedAt instanceof Date ? video.data.publishedAt.toISOString() : String(video.data.publishedAt),
	}));

const formatDate = (date: string) =>
	new Date(date).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });

const shell = css({ maxWidth: "80rem", mx: "auto", px: { base: "4", md: "6" }, py: "12" });

const searchForm = css({
	maxWidth: "44rem",
	mx: "auto",
	mt: "8",
	display: "flex",
	alignItems: "center",
	gap: "2",
	p: "2",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
});

const searchInput = css({
	flex: "1",
	bg: "transparent",
	color: "fg.primary",
	border: "none",
	px: "4",
	py: "2",
	fontSize: "md",
	_focus: { outline: "none" },
});

const searchBtn = css({
	display: "inline-flex",
	alignItems: "center",
	justifyContent: "center",
	w: "10",
	h: "10",
	borderRadius: "lg",
	color: "fg.on-brand",
	backgroundImage: "linear-gradient(135deg, token(colors.brand.500), token(colors.cyan.500))",
	border: "none",
	cursor: "pointer",
});

const emptyState = css({
	textAlign: "center",
	py: "16",
	color: "fg.secondary",
	maxWidth: "32rem",
	mx: "auto",
});

const resultsHeader = css({
	fontFamily: "display",
	fontSize: { base: "xl", md: "2xl" },
	fontWeight: "bold",
	color: "fg.primary",
	mb: "8",
});

const grid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", sm: "repeat(2, minmax(0, 1fr))", lg: "repeat(3, minmax(0, 1fr))" },
	gap: "5",
});

const card = css({
	display: "flex",
	flexDirection: "column",
	overflow: "hidden",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textDecoration: "none",
	color: "fg.primary",
	transition: "transform 200ms ease, box-shadow 200ms ease",
	_hover: { transform: "translateY(-2px)", boxShadow: "lg" },
});

const thumb = css({ aspectRatio: "16 / 9", overflow: "hidden", bg: "bg.sunken", "& img": { width: "full", height: "full", objectFit: "cover" } });
const cardBody = css({ p: "5", display: "flex", flexDirection: "column", gap: "2" });
const cardMeta = css({ fontSize: "xs", color: "fg.muted", fontWeight: "semibold", letterSpacing: "wider", textTransform: "uppercase" });
const cardTitle = css({ fontSize: "md", fontWeight: "semibold", color: "fg.primary", lineHeight: "tight", display: "-webkit-box", WebkitLineClamp: "2", WebkitBoxOrient: "vertical", overflow: "hidden" });
---

<Page title={searchQuery ? `${searchQuery} Search Results` : "Search"} description="Search Rawkode Academy videos, articles, and technologies.">
	<PageHero eyebrow="Search" title="Find Anything" subtitle="Search across our videos, articles, learning paths, and technologies.">
		<form action="/search" method="get" class={searchForm}>
			<input type="search" name="q" value={searchQuery} placeholder="What are you looking for?" class={searchInput} autofocus />
			<button type="submit" class={searchBtn} aria-label="Search">
				<svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
			</button>
		</form>
	</PageHero>

	<div class={shell}>
		{searchQuery.length === 0 ? (
			<p class={emptyState}>Enter a search term to find videos.</p>
		) : feedVideos.length === 0 ? (
			<p class={emptyState}>No videos matched "{searchQuery}".</p>
		) : (
			<>
				<h2 class={resultsHeader}>{feedVideos.length} result{feedVideos.length === 1 ? "" : "s"} for "{searchQuery}"</h2>
				<div class={grid}>
					{feedVideos.map((v) => (
						<a href={`/watch/${v.slug}`} class={card}>
							<div class={thumb}>
								<img src={v.thumbnailUrl} alt={v.title} loading="lazy" />
							</div>
							<div class={cardBody}>
								<div class={cardMeta}>{formatDate(v.publishedAt)}</div>
								<h3 class={cardTitle}>{v.title}</h3>
							</div>
						</a>
					))}
				</div>
			</>
		)}
	</div>
</Page>
