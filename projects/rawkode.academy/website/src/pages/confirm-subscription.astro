---
import { env } from "cloudflare:workers";
import Page from "@/wrappers/page.astro";
import { createLearnerId } from "@/actions/newsletter";
import { css } from "../../styled-system/css";

const user = Astro.locals.user;
if (!user) return Astro.redirect("/sign-in?returnTo=/confirm-subscription");

const prefixedUserId = createLearnerId(user.id);
await env.EMAIL_PREFERENCES.setPreference(prefixedUserId, {
	audience: "academy",
	channel: "newsletter",
	status: "subscribed",
	source: "registration-flow",
});

const wrap = css({
	minHeight: "60vh",
	display: "flex",
	flexDirection: "column",
	alignItems: "center",
	justifyContent: "center",
	textAlign: "center",
	px: "4",
	py: "16",
});

const iconWrap = css({
	width: "24",
	height: "24",
	borderRadius: "full",
	bg: "bg.brand-subtle",
	color: "fg.brand",
	display: "flex",
	alignItems: "center",
	justifyContent: "center",
	mb: "8",
});

const title = css({
	fontFamily: "display",
	fontSize: { base: "3xl", md: "4xl" },
	fontWeight: "bold",
	color: "fg.primary",
	mb: "4",
});

const subtitle = css({ fontSize: "lg", color: "fg.secondary", maxWidth: "32rem", lineHeight: "1.7", mb: "8" });

const btn = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "6",
	py: "3",
	borderRadius: "lg",
	fontWeight: "semibold",
	color: "fg.on-brand",
	backgroundImage: "linear-gradient(135deg, token(colors.brand.500), token(colors.cyan.500))",
	textDecoration: "none",
	boxShadow: "md",
	transition: "transform 150ms ease",
	_hover: { transform: "translateY(-1px)" },
});
---

<Page title="Subscription Confirmed" description="You are now subscribed to the Rawkode Academy newsletter.">
	<div class={wrap}>
		<div class={iconWrap}>
			<svg width="40" height="40" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
			</svg>
		</div>
		<h1 class={title}>Subscription Confirmed</h1>
		<p class={subtitle}>Thanks for joining the Rawkode Academy newsletter. You'll now receive updates about our latest courses, videos, and articles.</p>
		<a href="/" class={btn}>Back to home</a>
	</div>
</Page>
