---
import { getCollection } from "astro:content";
import Page from "@/wrappers/page.astro";
import { css } from "../../styled-system/css";

export const prerender = false;

const user = Astro.locals.user;

if (!user) {
	return Astro.redirect(`/sign-in?returnTo=${encodeURIComponent("/home")}`);
}

Astro.response.headers.set("Cache-Control", "private, no-store");

interface WatchPosition {
	videoId: string;
	positionSeconds: number;
	updatedAt: string;
}

let continueWatchingData: WatchPosition[] = [];
try {
	const response = await fetch("https://api.rawkode.academy/graphql", {
		method: "POST",
		headers: { "Content-Type": "application/json" },
		body: JSON.stringify({
			query: `
				query ContinueWatching($userId: String!, $limit: Int) {
					continueWatching(userId: $userId, limit: $limit) {
						videoId
						positionSeconds
						updatedAt
					}
				}
			`,
			variables: { userId: user.id, limit: 12 },
		}),
	});
	const result = (await response.json()) as {
		data?: { continueWatching?: WatchPosition[] };
	};
	continueWatchingData = result?.data?.continueWatching ?? [];
} catch {
	// silently fail
}

const allVideos = await getCollection("videos");
const continueWatching = continueWatchingData
	.map((w) => {
		const video = allVideos.find((v) => v.data.id === w.videoId);
		if (!video) return null;
		const duration = typeof video.data.duration === "number" ? video.data.duration : 0;
		return {
			id: video.data.id,
			title: video.data.title,
			slug: video.data.slug,
			thumbnailUrl: `https://content.rawkode.academy/videos/${video.data.id}/thumbnail.jpg`,
			duration,
			position: w.positionSeconds,
			progress: duration > 0 ? Math.min(100, (w.positionSeconds / duration) * 100) : 0,
		};
	})
	.filter((v): v is NonNullable<typeof v> => v !== null);

const shell = css({
	maxWidth: "80rem",
	mx: "auto",
	px: { base: "4", md: "6" },
	py: "8",
});

const welcomeBlock = css({ mb: "10" });
const welcomeTitle = css({
	fontFamily: "display",
	fontSize: { base: "3xl", md: "4xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	color: "fg.primary",
});
const welcomeSubtitle = css({ mt: "2", color: "fg.secondary", fontSize: "md" });

const sectionTitle = css({
	fontFamily: "display",
	fontSize: "2xl",
	fontWeight: "bold",
	color: "fg.primary",
	mb: "4",
});

const grid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", sm: "repeat(2, minmax(0, 1fr))", lg: "repeat(3, minmax(0, 1fr))" },
	gap: "4",
});

const videoCard = css({
	display: "flex",
	flexDirection: "column",
	borderRadius: "2xl",
	overflow: "hidden",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textDecoration: "none",
	color: "fg.primary",
	transition: "transform 200ms ease, box-shadow 200ms ease",
	_hover: { transform: "translateY(-2px)", boxShadow: "lg" },
});
const thumbWrap = css({
	position: "relative",
	aspectRatio: "16 / 9",
	bg: "bg.sunken",
	"& img": { width: "full", height: "full", objectFit: "cover" },
});
const progressTrack = css({
	position: "absolute",
	left: "0",
	right: "0",
	bottom: "0",
	h: "3px",
	bg: "bg.overlay",
});
const progressFill = css({
	h: "full",
	backgroundImage: "linear-gradient(to right, token(colors.brand.500), token(colors.cyan.500))",
});
const videoMeta = css({ p: "4", display: "flex", flexDirection: "column", gap: "1" });
const videoTitle = css({
	fontSize: "md",
	fontWeight: "semibold",
	color: "fg.primary",
	display: "-webkit-box",
	WebkitLineClamp: "2",
	overflow: "hidden",
});

const emptyState = css({
	textAlign: "center",
	py: "16",
	display: "flex",
	flexDirection: "column",
	alignItems: "center",
	gap: "4",
});
const emptyIcon = css({
	display: "inline-flex",
	alignItems: "center",
	justifyContent: "center",
	w: "16",
	h: "16",
	borderRadius: "full",
	bg: "bg.brand-subtle",
	color: "fg.brand",
});
const emptyTitle = css({
	fontSize: "xl",
	fontWeight: "semibold",
	color: "fg.primary",
});
const emptyBody = css({ color: "fg.secondary", maxWidth: "32rem" });
const emptyBtn = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "6",
	py: "3",
	borderRadius: "lg",
	fontWeight: "semibold",
	color: "fg.on-brand",
	backgroundImage: "linear-gradient(135deg, token(colors.brand.500), token(colors.cyan.500))",
	textDecoration: "none",
	boxShadow: "md",
	_hover: { transform: "translateY(-1px)", boxShadow: "lg" },
});
---

<Page title="Home" description="Your personalized dashboard">
	<div class={shell}>
		<div class={welcomeBlock}>
			<h1 class={welcomeTitle}>
				Welcome back{user.name ? `, ${user.name.split(" ")[0]}` : ""}
			</h1>
			<p class={welcomeSubtitle}>Pick up where you left off.</p>
		</div>

		{continueWatching.length > 0 ? (
			<section>
				<h2 class={sectionTitle}>Continue watching</h2>
				<div class={grid}>
					{continueWatching.map((video) => (
						<a href={`/watch/${video.slug}`} class={videoCard}>
							<div class={thumbWrap}>
								<img src={video.thumbnailUrl} alt={video.title} loading="lazy" />
								<div class={progressTrack}>
									<div class={progressFill} style={`width: ${video.progress}%`}></div>
								</div>
							</div>
							<div class={videoMeta}>
								<h3 class={videoTitle}>{video.title}</h3>
							</div>
						</a>
					))}
				</div>
			</section>
		) : (
			<div class={emptyState}>
				<div class={emptyIcon}>
					<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<circle cx="12" cy="12" r="9" />
						<path d="M10 8l5 4-5 4V8z" fill="currentColor" />
					</svg>
				</div>
				<h2 class={emptyTitle}>No watch history yet</h2>
				<p class={emptyBody}>Start watching videos and they'll appear here so you can easily continue where you left off.</p>
				<a href="/watch" class={emptyBtn}>
					Browse videos
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
				</a>
			</div>
		)}
	</div>
</Page>
