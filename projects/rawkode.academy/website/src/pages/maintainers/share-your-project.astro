---
import PageHero from "@/components/layout/PageHero.astro";
import Page from "@/wrappers/page.astro";
import { css } from "../../../styled-system/css";

export const prerender = true;

const stats = [
	{ value: "100+", label: "Projects Featured" },
	{ value: "1M+", label: "Views" },
	{ value: "100%", label: "Enjoyed the Experience" },
];

const benefits = [
	{ title: "Gain visibility", description: "Reach engineers who actively seek out new tooling — not surface-level marketing impressions.", icon: "M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" },
	{ title: "Get real feedback", description: "Live Q&A and pair-programming with a technical audience that asks the hard questions.", icon: "M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" },
	{ title: "Connect with the community", description: "Conversations continue after the stream ends — we introduce you to maintainers and contributors who care.", icon: "M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a3 3 0 015.356-1.857M17 10.5a4 4 0 100-8 4 4 0 000 8zm-7 0a4 4 0 110-8 4 4 0 010 8z" },
	{ title: "It's fun", description: "Relaxed, authentic conversation. No corporate talking points, no slideware. Just engineers talking shop.", icon: "M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" },
];

const processSteps = [
	{ title: "Apply", description: "Submit your project through our booking system. We'll review it to ensure it's a good fit for our audience." },
	{ title: "Prepare", description: "Once approved, we'll send you preparation guidelines to help you showcase your project effectively." },
	{ title: "Present", description: "Join David for a live session where we'll demo your project, discuss its features, and engage with the audience." },
	{ title: "Connect", description: "After the stream, we'll share the recording and help you connect with interested developers from our community." },
];

const expectations = [
	{ title: "Introduction", description: "We'll start with introductions and background on you and your project. What problem does it solve? What inspired you to create it?" },
	{ title: "Demo & Walkthrough", description: "Show your project in action with a live demonstration. Walk through key features, architecture decisions, and what makes your approach unique." },
	{ title: "Q&A & Discussion", description: "Engage with the audience through live Q&A. Discuss challenges, future plans, and how others can contribute to your project." },
	{ title: "Builder Feedback", description: "Receive real-time feedback from David and the community on your project's design, developer experience, and roadmap." },
];

const testimonials = [
	{
		quote: "Being a guest on David's Rawkode Academy channel was a very great experience. This was my first time being a guest in such a format and David made sure that it turned out being a great session.",
		name: "Alexander Block",
		role: "Maintainer of Kluctl",
	},
];

const faqItems = [
	{ question: "What types of projects are suitable for Rawkode Live?", answer: "We welcome open-source projects related to cloud-native technologies, developer tools, infrastructure, and automation. The key criteria are that your project solves a real problem for developers and has an open-source component." },
	{ question: "Do I need to be the project creator to present?", answer: "Not necessarily. We welcome core contributors or maintainers who are deeply familiar with the project and can speak authoritatively about its design, implementation, and roadmap." },
	{ question: "How technical should my presentation be?", answer: "Our audience is primarily developers and technical professionals, so we encourage in-depth technical discussions. The best presentations balance technical detail with clear explanations of the problem being solved." },
	{ question: "Is there a cost to participate?", answer: "No, featuring your open-source project on Rawkode Live is completely free. We're passionate about supporting the open-source community and helping great projects gain visibility." },
	{ question: "What's the format of the session?", answer: "Sessions typically run 60-90 minutes and include an introduction to you and your project, a demonstration or walkthrough, and audience Q&A. The format is conversational and flexible, allowing us to focus on the most interesting aspects of your project." },
];

const shell = css({ maxWidth: "80rem", mx: "auto", px: { base: "4", md: "6" }, py: "12" });

const section = css({ mb: "16" });

const sectionTitle = css({
	fontFamily: "display",
	fontSize: { base: "2xl", md: "3xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	color: "fg.primary",
	mb: "8",
	textAlign: "center",
});

const statsGrid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", md: "repeat(3, minmax(0, 1fr))" },
	gap: "5",
	maxWidth: "60rem",
	mx: "auto",
});

const statCard = css({
	textAlign: "center",
	p: "8",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
});

const statValue = css({
	fontFamily: "display",
	fontSize: "4xl",
	fontWeight: "bold",
	backgroundImage: "linear-gradient(135deg, token(colors.brand.500), token(colors.cyan.500))",
	backgroundClip: "text",
	color: "transparent",
});

const statLabel = css({ mt: "2", color: "fg.muted", fontSize: "sm" });

const benefitGrid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", sm: "repeat(2, minmax(0, 1fr))", lg: "repeat(4, minmax(0, 1fr))" },
	gap: "4",
});

const benefitCard = css({
	display: "flex",
	flexDirection: "column",
	gap: "3",
	p: "6",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
});

const benefitIcon = css({
	display: "inline-flex",
	alignItems: "center",
	justifyContent: "center",
	w: "11",
	h: "11",
	borderRadius: "xl",
	bg: "bg.brand-subtle",
	color: "fg.brand",
});

const benefitTitle = css({ fontFamily: "display", fontSize: "lg", fontWeight: "bold", color: "fg.primary" });
const benefitDesc = css({ fontSize: "sm", color: "fg.secondary", lineHeight: "1.6" });

const stepsGrid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", md: "repeat(2, minmax(0, 1fr))", lg: "repeat(4, minmax(0, 1fr))" },
	gap: "4",
});

const stepCard = css({
	p: "6",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	display: "flex",
	flexDirection: "column",
	gap: "3",
});

const stepNum = css({
	display: "inline-flex",
	alignItems: "center",
	justifyContent: "center",
	w: "10",
	h: "10",
	borderRadius: "full",
	bg: "bg.brand-subtle",
	color: "fg.brand",
	fontWeight: "bold",
});

const stepTitle = css({ fontFamily: "display", fontSize: "lg", fontWeight: "bold", color: "fg.primary" });
const stepBody = css({ fontSize: "sm", color: "fg.secondary", lineHeight: "1.6" });

const sectionLede = css({
	mt: "-6",
	mb: "8",
	maxWidth: "44rem",
	mx: "auto",
	fontSize: "md",
	color: "fg.secondary",
	lineHeight: "1.7",
	textAlign: "center",
});

const expectGrid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", sm: "repeat(2, minmax(0, 1fr))", lg: "repeat(4, minmax(0, 1fr))" },
	gap: "4",
});

const expectCard = css({
	p: "6",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	display: "flex",
	flexDirection: "column",
	gap: "3",
});

const expectTitle = css({ fontFamily: "display", fontSize: "lg", fontWeight: "bold", color: "fg.primary" });
const expectBody = css({ fontSize: "sm", color: "fg.secondary", lineHeight: "1.6" });

const testimonialGrid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr" },
	gap: "5",
	maxWidth: "48rem",
	mx: "auto",
});

const testimonialCard = css({
	p: { base: "6", md: "8" },
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	display: "flex",
	flexDirection: "column",
	gap: "4",
});

const testimonialQuote = css({
	fontSize: { base: "md", md: "lg" },
	color: "fg.primary",
	lineHeight: "1.7",
	fontStyle: "italic",
});

const testimonialAttr = css({
	display: "flex",
	flexDirection: "column",
	gap: "1",
});

const testimonialName = css({ fontWeight: "semibold", color: "fg.primary", fontSize: "sm" });
const testimonialRole = css({ fontSize: "sm", color: "fg.muted" });

const faqList = css({ display: "flex", flexDirection: "column", gap: "3", maxWidth: "48rem", mx: "auto" });

const faqItem = css({
	p: "5",
	borderRadius: "xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
});

const faqQ = css({ fontWeight: "semibold", color: "fg.primary", fontSize: "md", mb: "2", cursor: "pointer", listStyle: "none" });
const faqA = css({ color: "fg.secondary", lineHeight: "1.6", fontSize: "sm" });

const ctaCard = css({
	mt: "8",
	mx: "auto",
	maxWidth: "60rem",
	p: { base: "8", md: "12" },
	borderRadius: "3xl",
	textAlign: "center",
	color: "white",
	backgroundImage: "linear-gradient(135deg, token(colors.brand.500), token(colors.cyan.500))",
	boxShadow: "xl",
});

const ctaTitle = css({ fontFamily: "display", fontSize: { base: "2xl", md: "3xl" }, fontWeight: "bold" });
const ctaBody = css({ mt: "3", fontSize: { base: "md", md: "lg" }, opacity: "0.92", maxWidth: "40rem", mx: "auto" });

const ctaBtn = css({
	mt: "8",
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "6",
	py: "3",
	borderRadius: "lg",
	fontWeight: "semibold",
	color: "fg.primary",
	bg: "white",
	textDecoration: "none",
	_hover: { transform: "translateY(-1px)" },
});
---

<Page title="Share Your Project on Rawkode Live" description="Showcase your open-source project to a passionate community of developers and tech enthusiasts on Rawkode Live.">
	<PageHero eyebrow="Maintainers" title="Share Your Project on Rawkode Live" subtitle="Showcase your open-source project to a passionate community of developers and tech enthusiasts." />

	<div class={shell}>
		<section class={section}>
			<h2 class={sectionTitle}>Join our growing community</h2>
			<div class={statsGrid}>
				{stats.map((s) => (
					<div class={statCard}>
						<div class={statValue}>{s.value}</div>
						<div class={statLabel}>{s.label}</div>
					</div>
				))}
			</div>
		</section>

		<section class={section}>
			<h2 class={sectionTitle}>Why join</h2>
			<div class={benefitGrid}>
				{benefits.map((b) => (
					<div class={benefitCard}>
						<span class={benefitIcon}>
							<svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d={b.icon} /></svg>
						</span>
						<h3 class={benefitTitle}>{b.title}</h3>
						<p class={benefitDesc}>{b.description}</p>
					</div>
				))}
			</div>
		</section>

		<section class={section}>
			<h2 class={sectionTitle}>How it works</h2>
			<div class={stepsGrid}>
				{processSteps.map((step, i) => (
					<div class={stepCard}>
						<span class={stepNum}>{i + 1}</span>
						<h3 class={stepTitle}>{step.title}</h3>
						<p class={stepBody}>{step.description}</p>
					</div>
				))}
			</div>
		</section>

		<section class={section}>
			<h2 class={sectionTitle}>What to Expect</h2>
			<p class={sectionLede}>Our sessions are typically 60-90 minutes long and follow this format:</p>
			<div class={expectGrid}>
				{expectations.map((e) => (
					<div class={expectCard}>
						<h3 class={expectTitle}>{e.title}</h3>
						<p class={expectBody}>{e.description}</p>
					</div>
				))}
			</div>
		</section>

		<section class={section}>
			<h2 class={sectionTitle}>What Project Maintainers Say</h2>
			<p class={sectionLede}>Curious what it's like to join us?</p>
			<div class={testimonialGrid}>
				{testimonials.map((t) => (
					<figure class={testimonialCard}>
						<svg width="28" height="28" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true" style="color: var(--colors-fg-brand); opacity: 0.6;">
							<path d="M7.17 6.17A5 5 0 0 0 2 11v7h7v-7H5.5A3.5 3.5 0 0 1 9 7.5V6.17h-1.83zm10 0A5 5 0 0 0 12 11v7h7v-7h-3.5A3.5 3.5 0 0 1 19 7.5V6.17h-1.83z"/>
						</svg>
						<blockquote class={testimonialQuote}>{t.quote}</blockquote>
						<figcaption class={testimonialAttr}>
							<span class={testimonialName}>{t.name}</span>
							<span class={testimonialRole}>{t.role}</span>
						</figcaption>
					</figure>
				))}
			</div>
		</section>

		<section class={section}>
			<h2 class={sectionTitle}>Frequently asked questions</h2>
			<div class={faqList}>
				{faqItems.map((faq) => (
					<details class={faqItem}>
						<summary class={faqQ}>{faq.question}</summary>
						<p class={faqA}>{faq.answer}</p>
					</details>
				))}
			</div>
		</section>

		<section class={ctaCard}>
			<h2 class={ctaTitle}>Ready to share your project?</h2>
			<p class={ctaBody}>Book a slot on Rawkode Live and bring your open-source project to a community of engineers who care.</p>
			<a href="https://meet.rawkode.academy/share-your-project" target="_blank" rel="noopener noreferrer" class={ctaBtn}>
				Apply now
				<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 5l7 7-7 7" /></svg>
			</a>
		</section>
	</div>
</Page>
