---
import EditorialShell from "@/components/ui/EditorialShell.astro";
import Page from "@/wrappers/page.astro";

export const prerender = true;

const stats = [
	{ value: "100+", label: "Projects featured" },
	{ value: "60-90", label: "Minute session" },
	{ value: "Free", label: "For open source" },
];

const benefits = [
	{
		title: "Reach developers",
		body: "Introduce your project to an audience already interested in developer tools, infrastructure, automation, and open source.",
	},
	{
		title: "Get useful feedback",
		body: "Talk through trade-offs, roadmap decisions, and adoption questions with people who understand the technical context.",
	},
	{
		title: "Create a durable artifact",
		body: "The recording gives your project a clear walkthrough you can share with contributors, users, and sponsors.",
	},
];

const processSteps = [
	{
		title: "Apply",
		body: "Share the project, maintainers, and what you want to cover. We check fit before confirming a slot.",
	},
	{
		title: "Prepare",
		body: "We send prep notes and help shape a session that works for a live technical audience.",
	},
	{
		title: "Present",
		body: "Join David for a live walkthrough, demo, architecture discussion, and audience Q&A.",
	},
	{
		title: "Share",
		body: "After the session, you get a recording and links you can use in your own project channels.",
	},
];

const expectations = [
	"Open-source projects, maintainer tools, cloud native systems, developer infrastructure, and automation projects are the strongest fit.",
	"You do not need to be the original creator, but you should be able to speak deeply about the project.",
	"The session should be technical, practical, and honest about trade-offs.",
	"Preparation matters. A focused demo beats a broad marketing walkthrough.",
];

const faqItems = [
	{
		question: "What types of projects are suitable for Rawkode Live?",
		answer:
			"Open-source projects related to cloud native technology, developer tools, infrastructure, automation, observability, security, and software delivery are usually a strong fit.",
	},
	{
		question: "Do I need to be the project creator to present?",
		answer:
			"No. Core contributors and maintainers are welcome as long as they can explain the project, decisions, and roadmap clearly.",
	},
	{
		question: "How technical should the presentation be?",
		answer:
			"Technical enough for working developers. The best sessions balance the problem, architecture, demo, and trade-offs.",
	},
	{
		question: "Is there a cost to participate?",
		answer:
			"No. Featuring an open-source project on Rawkode Live is free.",
	},
	{
		question: "What is the format of the session?",
		answer:
			"Sessions usually run 60-90 minutes and include an introduction, demo or walkthrough, architecture discussion, and audience Q&A.",
	},
];
---

<Page
	title="Share Your Project on Rawkode Live"
	description="Showcase your open-source project to a technical audience on Rawkode Live."
>
	<EditorialShell
		eyebrow="Maintainers"
		title="Share your project"
		lede="Bring your open-source project onto Rawkode Live for a practical walkthrough, maintainer conversation, and live technical Q&A."
	>
		<div class="editorial-actions" slot="actions">
			<a class="editorial-button" href="#booking">Book a slot</a>
			<a class="editorial-button editorial-button--secondary" href="#process">How it works</a>
		</div>

		<section class="editorial-section">
			<div class="editorial-stat-grid">
				{stats.map((stat) => (
					<div class="editorial-stat">
						<span class="editorial-stat__value">{stat.value}</span>
						<span class="editorial-stat__label">{stat.label}</span>
					</div>
				))}
			</div>
		</section>

		<section class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">Why join</p>
				<h2 class="editorial-section__title">A useful technical stage, not a pitch deck</h2>
				<p class="editorial-section__lede">
					The goal is to help developers understand what your project does, why it exists, and how to get started.
				</p>
			</div>
			<div class="editorial-grid editorial-grid--3">
				{benefits.map((benefit) => (
					<article class="editorial-card">
						<h3 class="editorial-card__title">{benefit.title}</h3>
						<p class="editorial-card__body">{benefit.body}</p>
					</article>
				))}
			</div>
		</section>

		<section id="process" class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">Process</p>
				<h2 class="editorial-section__title">How it works</h2>
			</div>
			<div class="editorial-grid editorial-grid--4">
				{processSteps.map((step, index) => (
					<article class="editorial-card">
						<p class="editorial-meta">Step {String(index + 1).padStart(2, "0")}</p>
						<h3 class="editorial-card__title">{step.title}</h3>
						<p class="editorial-card__body">{step.body}</p>
					</article>
				))}
			</div>
		</section>

		<section class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">Fit</p>
				<h2 class="editorial-section__title">What makes a strong session</h2>
			</div>
			<div class="editorial-card">
				<ul class="editorial-list">
					{expectations.map((expectation) => <li>{expectation}</li>)}
				</ul>
				<p class="share-prep">
					Read the live prep notes before the session: <a href="https://rawkode.link/live-prep">rawkode.link/live-prep</a>
				</p>
			</div>
		</section>

		<section class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">Questions</p>
				<h2 class="editorial-section__title">Maintainer FAQ</h2>
			</div>
			<div class="editorial-faq">
				{faqItems.map((item, index) => (
					<details open={index === 0}>
						<summary>{item.question}</summary>
						<p>{item.answer}</p>
					</details>
				))}
			</div>
		</section>

		<section id="booking" class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">Booking</p>
				<h2 class="editorial-section__title">Pick a time</h2>
				<p class="editorial-section__lede">
					Choose an available slot and we will follow up with the details needed before the show.
				</p>
			</div>
			<div class="share-booking">
				<div id="booking-page" class="share-booking__embed" aria-label="Booking calendar"></div>
			</div>
		</section>
	</EditorialShell>

	<script is:inline>
		window.SavvyCal =
			window.SavvyCal ||
			function () {
				(SavvyCal.q = SavvyCal.q || []).push(arguments);
			};

		const script = document.createElement("script");
		script.async = true;
		script.src = "https://embed.savvycal.com/v1/embed.js";
		document.head.appendChild(script);

		script.onload = () => {
			SavvyCal("init", { origin: "https://meet.rawkode.academy" });
			SavvyCal("inline", {
				link: "share-your-project",
				selector: "#booking-page",
				theme: "os",
			});
		};
	</script>
</Page>

<style>
	.share-prep {
		margin: 1rem 0 0;
		font-family: var(--font-inter-tight), system-ui, sans-serif;
		color: var(--editorial-ink-soft);
		line-height: 1.55;
	}

	.share-prep a {
		color: var(--editorial-spruce);
		text-underline-offset: 0.2em;
	}

	.share-booking {
		border: 1px solid var(--editorial-hairline);
		border-radius: 6px;
		background: var(--editorial-paper-deep);
		padding: 0.75rem;
	}

	.share-booking__embed {
		min-height: 42rem;
		border-radius: 4px;
		overflow: hidden;
		background: var(--editorial-paper);
	}

	@media (max-width: 700px) {
		.share-booking {
			padding: 0.4rem;
		}

		.share-booking__embed {
			min-height: 36rem;
		}
	}
</style>
