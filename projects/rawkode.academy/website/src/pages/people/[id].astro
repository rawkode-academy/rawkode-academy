---
export const prerender = true;

import { getCollection, render } from "astro:content";
import PersonJsonLd from "@/components/html/person-jsonld.astro";
import Prose from "@/components/prose/Prose.astro";
import Page from "@/wrappers/page.astro";
import { normalizeTechnologyReferences } from "@/utils/normalize-technology-refs";
import { css } from "../../../styled-system/css";

export async function getStaticPaths() {
	const people = await getCollection("people");
	return people.map((person) => ({ params: { id: person.data.id }, props: { person } }));
}

const { person } = Astro.props;

const videos = await getCollection("videos");
const shows = await getCollection("shows");
const technologies = await getCollection("technologies");
const news = await getCollection("news");
const articles = await getCollection("articles", ({ data }) => !data.draft);
const techNameById = new Map(technologies.map((t) => [t.id.replace(/\/index$/, ""), t.data.name] as const));

const matchRef = (ref: { collection: string; id: string } | string, id: string) =>
	typeof ref === "string" ? ref === id : ref.id === id;

const hostedShows = shows.filter((show) => show.data.hosts.some((h) => matchRef(h, person.data.id)));
const guestVideos = videos.filter((video) => video.data.guests.some((g) => matchRef(g, person.data.id)));
const authoredNews = news
	.filter((s) => s.data.authors.some((a) => matchRef(a, person.data.id)))
	.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
const authoredArticles = articles
	.filter((a) => a.data.authors.some((au) => matchRef(au, person.data.id)))
	.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const formatPublishDate = (date: Date) =>
	new Intl.DateTimeFormat("en-US", { month: "short", day: "numeric", year: "numeric" }).format(date);

const guestVideoFeed = guestVideos
	.map((v) => ({
		id: v.data.id,
		title: v.data.title,
		thumbnailUrl: `https://content.rawkode.academy/videos/${v.data.id}/thumbnail.jpg`,
		duration: typeof v.data.duration === "number" ? v.data.duration : 0,
		slug: v.data.slug,
		publishedAt: v.data.publishedAt instanceof Date ? v.data.publishedAt.toISOString() : String(v.data.publishedAt),
	}))
	.sort((a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime());

const { Content: BiographyContent } = await render(person);
const hasBiography = Boolean(person.body && person.body.trim().length > 0);

const videoCount = guestVideos.length;
const showCount = hostedShows.length;
const techCounts = new Map<string, number>();
for (const v of guestVideos) {
	for (const techId of normalizeTechnologyReferences(v.data.technologies)) {
		const id = techId.replace(/\/index$/, "");
		techCounts.set(id, (techCounts.get(id) ?? 0) + 1);
	}
}
const topTechNames = [...techCounts.entries()]
	.sort((a, b) => b[1] - a[1])
	.slice(0, 5)
	.map(([id]) => techNameById.get(id) ?? id);

const showNames = hostedShows.map((s) => s.data.name);
const newsCount = authoredNews.length;
const articleCount = authoredArticles.length;
const noindex = videoCount === 0 && showCount === 0 && newsCount === 0 && articleCount === 0 && !hasBiography;

const pageTitle = (() => {
	if (showCount > 0) return `${person.data.name} — Host of ${showNames[0]} | Rawkode Academy`;
	if (topTechNames.length > 0) return `${person.data.name} — Talks on ${topTechNames.slice(0, 2).join(" & ")} | Rawkode Academy`;
	return `${person.data.name} | Rawkode Academy`;
})();

const pageDescription = (() => {
	const parts: string[] = [];
	if (showCount > 0) parts.push(`Host of ${showNames.slice(0, 2).join(" and ")}${showCount > 2 ? ` and ${showCount - 2} more shows` : ""}`);
	if (videoCount > 0) parts.push(`${videoCount} appearance${videoCount === 1 ? "" : "s"} on Rawkode Academy`);
	const writtenCount = newsCount + articleCount;
	if (writtenCount > 0) parts.push(`${writtenCount} published ${writtenCount === 1 ? "story" : "stories"}`);
	if (topTechNames.length > 0) parts.push(`covering ${topTechNames.slice(0, 4).join(", ")}`);
	if (parts.length === 0) return `${person.data.name} on Rawkode Academy — interviews, live coding, and conversations with leaders in Cloud Native and open source.`;
	return `${person.data.name}: ${parts.join(", ")}. Watch interviews, live coding, and deep dives on Rawkode Academy.`;
})();

const profileUrl = new URL(`/people/${person.data.id}`, Astro.site).href;

const socialLinks = [
	person.data.github && { name: "GitHub", url: person.data.github, icon: "M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" },
	person.data.twitter && { name: "Twitter", url: person.data.twitter, icon: "M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z" },
	person.data.linkedin && { name: "LinkedIn", url: person.data.linkedin, icon: "M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z M2 9h4v12H2z M2 4a2 2 0 1 1 4 0 2 2 0 0 1-4 0z" },
	person.data.website && { name: "Website", url: person.data.website, icon: "M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71 M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" },
].filter(Boolean) as Array<{ name: string; url: string; icon: string }>;

const relMeUrls = [person.data.mastodon, person.data.github, person.data.bluesky, person.data.twitter, person.data.linkedin, person.data.website, person.data.youtube].filter((u): u is string => typeof u === "string" && u.length > 0);

const shell = css({ maxWidth: "80rem", mx: "auto", px: { base: "4", md: "6" }, py: "10" });

const heroCard = css({
	display: "flex",
	flexDirection: { base: "column", md: "row" },
	alignItems: { base: "center", md: "flex-start" },
	gap: { base: "8", md: "12" },
	p: { base: "8", md: "12" },
	borderRadius: "3xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	backgroundImage:
		"radial-gradient(circle at 20% 20%, rgba(95, 94, 215, 0.10), transparent 50%), radial-gradient(circle at 80% 30%, rgba(0, 206, 255, 0.10), transparent 50%)",
});

const avatarWrap = css({
	width: { base: "40", md: "48" },
	height: { base: "40", md: "48" },
	borderRadius: "full",
	overflow: "hidden",
	borderWidth: "4px",
	borderColor: "bg.surface",
	boxShadow: "lg",
	flexShrink: 0,
	"& img": { width: "full", height: "full", objectFit: "cover" },
});

const heroBody = css({ flex: "1", textAlign: { base: "center", md: "left" } });

const nameClass = css({
	fontFamily: "display",
	fontSize: { base: "4xl", md: "5xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	color: "fg.primary",
	mb: "2",
});

const handle = css({ fontSize: "lg", color: "fg.brand", fontWeight: "medium" });

const statsRow = css({
	mt: "6",
	display: "flex",
	flexWrap: "wrap",
	gap: "6",
	justifyContent: { base: "center", md: "flex-start" },
});

const statBlock = css({ display: "flex", flexDirection: "column", gap: "0.25" });
const statNumber = css({
	fontFamily: "display",
	fontSize: { base: "2xl", md: "3xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	backgroundImage: "linear-gradient(135deg, token(colors.brand.500), token(colors.cyan.500))",
	backgroundClip: "text",
	color: "transparent",
});
const statText = css({ fontSize: "xs", fontWeight: "medium", color: "fg.muted", textTransform: "uppercase", letterSpacing: "wider" });

const socialRow = css({
	mt: "5",
	display: "flex",
	flexWrap: "wrap",
	gap: "3",
	justifyContent: { base: "center", md: "flex-start" },
});

const socialBtn = css({
	display: "inline-flex",
	alignItems: "center",
	justifyContent: "center",
	w: "10",
	h: "10",
	borderRadius: "full",
	bg: "bg.surface",
	color: "fg.muted",
	transition: "all 200ms ease",
	_hover: { bg: "bg.brand", color: "fg.on-brand" },
});

const sectionBlock = css({ mt: "16", maxWidth: "72rem", mx: "auto" });

const sectionTitle = css({
	fontFamily: "display",
	fontSize: { base: "2xl", md: "3xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	color: "fg.primary",
	mb: "8",
});

const grid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", sm: "repeat(2, minmax(0, 1fr))", lg: "repeat(3, minmax(0, 1fr))" },
	gap: "5",
});

const card = css({
	display: "flex",
	flexDirection: "column",
	overflow: "hidden",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textDecoration: "none",
	color: "fg.primary",
	transition: "transform 200ms ease, box-shadow 200ms ease",
	_hover: { transform: "translateY(-2px)", boxShadow: "lg" },
});

const cardThumb = css({
	aspectRatio: "16 / 9",
	overflow: "hidden",
	bg: "bg.sunken",
	"& img": { width: "full", height: "full", objectFit: "cover" },
});

const cardBody = css({ p: "5", display: "flex", flexDirection: "column", gap: "2" });
const cardMeta = css({ fontSize: "xs", color: "fg.muted", fontWeight: "semibold", textTransform: "uppercase", letterSpacing: "wider" });
const cardTitle = css({ fontSize: "md", fontWeight: "semibold", color: "fg.primary", lineHeight: "tight" });

const list = css({
	display: "flex",
	flexDirection: "column",
});

const listItem = css({
	py: "6",
	borderTopWidth: "1px",
	borderTopColor: "border.muted",
	_first: { borderTopWidth: "0" },
});

const listMeta = css({ fontSize: "xs", fontWeight: "semibold", letterSpacing: "wider", textTransform: "uppercase", color: "fg.muted", mb: "2" });
const listTitle = css({
	fontSize: { base: "lg", md: "xl" },
	fontWeight: "semibold",
	color: "fg.primary",
	lineHeight: "tight",
	mb: "2",
});
const listLink = css({ textDecoration: "none", color: "fg.primary", _hover: { color: "fg.brand" } });
const listDesc = css({ color: "fg.secondary", lineHeight: "1.7", maxWidth: "66ch" });
---

<Page
	title={pageTitle}
	description={pageDescription}
	noindex={noindex}
	useImageDirectly={Boolean(person.data.avatarUrl)}
	image={person.data.avatarUrl ? { image: new URL(person.data.avatarUrl) } : undefined}
>
	<PersonJsonLd
		slot="extra-head"
		name={person.data.name}
		url={profileUrl}
		description={pageDescription}
		image={person.data.avatarUrl}
		sameAs={[person.data.github, person.data.twitter, person.data.bluesky, person.data.linkedin, person.data.website, person.data.youtube, person.data.mastodon]}
	/>
	<Fragment slot="extra-head">
		{relMeUrls.map((url) => <link rel="me" href={url} />)}
		<link rel="alternate" type="application/rss+xml" title={`Rawkode Academy — ${person.data.name} (RSS)`} href={`/api/feeds/people/${person.data.id}.xml`} />
	</Fragment>

	<div class={shell}>
		<section class:list={[heroCard, "hero-aurora"]}>
			<div class={avatarWrap}>
				<img src={person.data.avatarUrl ?? "/apple-touch-icon.png"} alt={person.data.name} onerror={`this.onerror=null; this.src='/apple-touch-icon.png';`} />
			</div>
			<div class={heroBody}>
				<h1 class={nameClass}>{person.data.name}</h1>
				{person.data.handles?.twitter && <p class={handle}>@{person.data.handles.twitter}</p>}
				{(videoCount > 0 || showCount > 0 || articleCount > 0 || newsCount > 0) && (
					<div class={statsRow}>
						{showCount > 0 && (
							<div class={statBlock}>
								<span class={statNumber}>{showCount}</span>
								<span class={statText}>{showCount === 1 ? "Show hosted" : "Shows hosted"}</span>
							</div>
						)}
						{videoCount > 0 && (
							<div class={statBlock}>
								<span class={statNumber}>{videoCount}</span>
								<span class={statText}>{videoCount === 1 ? "Appearance" : "Appearances"}</span>
							</div>
						)}
						{articleCount > 0 && (
							<div class={statBlock}>
								<span class={statNumber}>{articleCount}</span>
								<span class={statText}>{articleCount === 1 ? "Article" : "Articles"}</span>
							</div>
						)}
						{newsCount > 0 && (
							<div class={statBlock}>
								<span class={statNumber}>{newsCount}</span>
								<span class={statText}>{newsCount === 1 ? "News story" : "News stories"}</span>
							</div>
						)}
					</div>
				)}
				{socialLinks.length > 0 && (
					<div class={socialRow}>
						{socialLinks.map((link) => (
							<a href={link.url} target="_blank" rel="me noopener noreferrer" class={socialBtn} aria-label={link.name}>
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d={link.icon} />
								</svg>
							</a>
						))}
					</div>
				)}
			</div>
		</section>

		{(hasBiography || pageDescription) && (
			<div style="max-width: 60rem; margin: 3rem auto 0;">
				<Prose>
					<p>{pageDescription}</p>
					{hasBiography && <BiographyContent />}
				</Prose>
			</div>
		)}

		{hostedShows.length > 0 && (
			<section class={sectionBlock}>
				<h2 class={sectionTitle}>Shows Hosted</h2>
				<div class={grid}>
					{hostedShows.map((show) => (
						<a href={`/shows/${show.data.id}`} class={card}>
							{show.data.cover && (
								<div class={cardThumb}>
									<img src={typeof show.data.cover === "string" ? show.data.cover : show.data.cover?.image?.src || ""} alt={show.data.name} loading="lazy" />
								</div>
							)}
							<div class={cardBody}>
								<div class={cardMeta}>Show</div>
								<h3 class={cardTitle}>{show.data.name}</h3>
							</div>
						</a>
					))}
				</div>
			</section>
		)}

		{guestVideoFeed.length > 0 && (
			<section class={sectionBlock}>
				<h2 class={sectionTitle}>Guest Appearances</h2>
				<div class={grid}>
					{guestVideoFeed.slice(0, 9).map((video) => (
						<a href={`/watch/${video.slug}`} class={card}>
							<div class={cardThumb}>
								<img src={video.thumbnailUrl} alt={video.title} loading="lazy" />
							</div>
							<div class={cardBody}>
								<div class={cardMeta}>{formatPublishDate(new Date(video.publishedAt))}</div>
								<h3 class={cardTitle}>{video.title}</h3>
							</div>
						</a>
					))}
				</div>
			</section>
		)}

		{authoredArticles.length > 0 && (
			<section class={sectionBlock} style="max-width: 60rem;">
				<h2 class={sectionTitle}>Articles</h2>
				<ul class={list} style="list-style: none; padding: 0; margin: 0;">
					{authoredArticles.map((article) => (
						<li class={listItem}>
							<article>
								<div class={listMeta}>
									<time datetime={article.data.publishedAt.toISOString()}>{formatPublishDate(article.data.publishedAt)}</time>
								</div>
								<h3 class={listTitle}>
									<a href={`/read/${article.id}`} class={listLink}>{article.data.title}</a>
								</h3>
								<p class={listDesc}>{article.data.description}</p>
							</article>
						</li>
					))}
				</ul>
			</section>
		)}

		{authoredNews.length > 0 && (
			<section class={sectionBlock} style="max-width: 60rem;">
				<h2 class={sectionTitle}>News</h2>
				<ul class={list} style="list-style: none; padding: 0; margin: 0;">
					{authoredNews.map((story) => (
						<li class={listItem}>
							<article>
								<div class={listMeta}>
									<time datetime={story.data.publishedAt.toISOString()}>{formatPublishDate(story.data.publishedAt)}</time>
								</div>
								<h3 class={listTitle}>
									<a href={`/news/${story.id}`} class={listLink}>{story.data.title}</a>
								</h3>
								<p class={listDesc}>{story.data.description}</p>
							</article>
						</li>
					))}
				</ul>
			</section>
		)}
	</div>
</Page>
