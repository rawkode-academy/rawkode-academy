---
export const prerender = true;

import PersonItemListJsonLd from "@/components/html/person-itemlist-jsonld.astro";
import CollectionMasthead from "@/components/ui/CollectionMasthead.astro";
import Page from "@/wrappers/page.astro";
import { getCollection } from "astro:content";

const people = await getCollection("people");
const sortedPeople = people.sort((a, b) =>
	a.data.name.localeCompare(b.data.name),
);

const peopleJsonLd = sortedPeople.map((person) => ({
	id: person.data.id,
	name: person.data.name,
	avatarUrl: person.data.avatarUrl,
	sameAs: [
		person.data.github,
		person.data.twitter,
		person.data.bluesky,
		person.data.linkedin,
		person.data.mastodon,
		person.data.website,
		person.data.youtube,
	],
}));
---

<Page
	title="People"
	description="Meet the hosts, guests, contributors, and instructors behind Rawkode Academy."
	pageType="CollectionPage"
>
	<PersonItemListJsonLd
		slot="extra-head"
		people={peopleJsonLd}
		listUrl={new URL("/people", Astro.site ?? Astro.url).href}
		listName="Rawkode Academy People"
	/>
	<div class="people-page">
		<CollectionMasthead title="People" dek="Hosts, guests, and contributors." />

		<section class="people-page__tools" aria-label="People search">
			<label class="people-page__label" for="people-search">Search people</label>
			<input
				id="people-search"
				type="search"
				placeholder="Name"
				class="people-page__search-input"
				autocomplete="off"
			/>
			<p class="people-page__count">
				Showing <span data-people-visible-count>{people.length}</span> of {people.length}
			</p>
		</section>

		<section id="people" class="people-page__grid-section" aria-label="People">
			<div class="people-page__grid">
				{
					sortedPeople.map((person) => {
						const searchKeywords = person.data.name.toLowerCase();
						const handle = person.data.twitter?.split("/").pop();

						return (
							<a
								href={`/people/${person.data.id}`}
								class="people-card-link"
								data-keywords={searchKeywords}
							>
								<img
									src={person.data.avatarUrl ?? "/apple-touch-icon.png"}
									alt={person.data.name}
									class="people-card-link__avatar"
									loading="lazy"
									onerror={`this.onerror=null; this.src='/apple-touch-icon.png';`}
								/>
								<span class="people-card-link__name">{person.data.name}</span>
								{handle && <span class="people-card-link__handle">@{handle}</span>}
							</a>
						);
					})
				}
			</div>

			<div id="people-empty-state" class="people-page__empty hidden">
				<h2>No people match your search</h2>
				<p>Try a different name.</p>
			</div>
		</section>

		<script>
			document.addEventListener("DOMContentLoaded", () => {
				const searchInput = document.getElementById("people-search") as HTMLInputElement | null;
				const cards = Array.from(
					document.querySelectorAll<HTMLElement>("#people .people-card-link"),
				);
				const emptyState = document.getElementById("people-empty-state");
				const countTargets = document.querySelectorAll<HTMLElement>("[data-people-visible-count]");

				const applySearch = () => {
					const query = (searchInput?.value ?? "").trim().toLowerCase();
					let visible = 0;

					cards.forEach((card) => {
						const keywords = card.dataset.keywords ?? "";
						const matchesSearch = keywords.includes(query);

						card.style.display = matchesSearch ? "" : "none";
						if (matchesSearch) {
							visible += 1;
						}
					});

					countTargets.forEach((el) => {
						el.textContent = visible.toString();
					});

					if (emptyState) {
						emptyState.classList.toggle("hidden", visible !== 0);
					}
				};

				searchInput?.addEventListener("input", applySearch);
				applySearch();
			});
		</script>
	</div>
</Page>

<style>
	.people-page {
		background: var(--editorial-paper);
		color: var(--editorial-ink);
	}

	.people-page__tools {
		display: grid;
		grid-template-columns: auto minmax(14rem, 26rem) 1fr;
		align-items: center;
		gap: 0.875rem 1rem;
		padding: 1rem var(--space-section-pad-x);
		border-bottom: 1px solid var(--editorial-hairline);
	}

	.people-page__label,
	.people-page__count {
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 0.6875rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--editorial-ink-mute);
	}

	.people-page__search-input {
		width: 100%;
		min-height: 2.75rem;
		border: 1px solid var(--editorial-hairline-strong);
		background: var(--editorial-paper-deep);
		color: var(--editorial-ink);
		font-family: var(--font-inter-tight), sans-serif;
		font-size: 1rem;
		padding: 0.625rem 0.75rem;
		border-radius: 0;
		outline: none;
	}

	.people-page__search-input:focus {
		border-color: var(--editorial-ink);
		box-shadow: 0 0 0 2px var(--editorial-paper), 0 0 0 3px var(--editorial-ink);
	}

	.people-page__search-input::placeholder {
		color: var(--editorial-ink-mute);
	}

	.people-page__count {
		justify-self: end;
		margin: 0;
	}

	.people-page__count span {
		color: var(--editorial-ink);
	}

	.people-page__grid-section {
		padding: 2rem var(--space-section-pad-x) 3rem;
	}

	.people-page__grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(10.5rem, 1fr));
		gap: 1rem;
	}

	.people-card-link {
		display: grid;
		grid-template-rows: auto auto 1fr;
		justify-items: center;
		min-width: 0;
		border: 1px solid var(--editorial-hairline);
		background: var(--editorial-paper-deep);
		color: inherit;
		text-align: center;
		text-decoration: none;
		padding: 1.125rem 0.875rem;
		transition: border-color var(--duration-base) var(--ease-standard);
	}

	.people-card-link:hover {
		border-color: var(--editorial-ink);
	}

	.people-card-link__avatar {
		width: 4.25rem;
		height: 4.25rem;
		border-radius: 50%;
		object-fit: cover;
		border: 1px solid var(--editorial-hairline-strong);
		margin-bottom: 0.875rem;
	}

	.people-card-link__name {
		width: 100%;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		font-family: var(--font-inter-tight), sans-serif;
		font-size: 0.975rem;
		font-weight: 700;
		line-height: 1.25;
		color: var(--editorial-ink);
	}

	.people-card-link__handle {
		width: 100%;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		font-family: var(--font-inter-tight), sans-serif;
		font-size: 0.8125rem;
		color: var(--editorial-ink-soft);
		margin-top: 0.2rem;
	}

	.people-page__empty {
		border: 1px solid var(--editorial-hairline);
		background: var(--editorial-paper-deep);
		padding: 2rem;
		max-width: 28rem;
		margin: 0 auto;
		text-align: center;
	}

	.people-page__empty h2 {
		font-family: var(--font-inter-tight), sans-serif;
		font-size: 1.25rem;
		font-weight: 700;
		letter-spacing: 0;
		color: var(--editorial-ink);
		margin: 0;
	}

	.people-page__empty p {
		font-family: var(--font-inter-tight), sans-serif;
		color: var(--editorial-ink-soft);
		margin: 0.5rem 0 0;
	}

	@media (max-width: 720px) {
		.people-page__tools {
			grid-template-columns: 1fr;
			padding: 0.875rem 1rem 1rem;
		}
		.people-page__count {
			justify-self: start;
		}
		.people-page__grid-section {
			padding: 1.25rem 1rem 2.5rem;
		}
		.people-page__grid {
			grid-template-columns: repeat(auto-fill, minmax(8.75rem, 1fr));
			gap: 0.75rem;
		}
		.people-card-link {
			padding: 1rem 0.75rem;
		}
		.people-card-link__avatar {
			width: 3.5rem;
			height: 3.5rem;
		}
	}
</style>
