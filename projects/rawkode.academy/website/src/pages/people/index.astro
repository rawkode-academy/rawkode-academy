---
export const prerender = true;

import { getCollection } from "astro:content";
import PageHero from "@/components/layout/PageHero.astro";
import Page from "@/wrappers/page.astro";
import { css } from "../../../styled-system/css";

const people = await getCollection("people");
const sortedPeople = people.sort((a, b) => a.data.name.localeCompare(b.data.name));

const shell = css({ maxWidth: "80rem", mx: "auto", px: { base: "4", md: "6" }, py: "12" });

const toolbar = css({
	display: "flex",
	flexDirection: { base: "column", md: "row" },
	alignItems: { base: "stretch", md: "center" },
	justifyContent: "space-between",
	gap: "4",
	mb: "8",
});

const searchWrap = css({ position: "relative", width: { base: "full", md: "24rem" } });

const searchInput = css({
	width: "full",
	pl: "10",
	pr: "4",
	py: "3",
	borderRadius: "lg",
	bg: "bg.surface",
	color: "fg.primary",
	borderWidth: "1px",
	borderColor: "border.muted",
	fontSize: "md",
	transition: "border-color 150ms ease",
	_focus: { outline: "2px solid", outlineColor: "border.focus", outlineOffset: "1px", borderColor: "border.focus" },
});

const searchIcon = css({
	position: "absolute",
	left: "3",
	top: "50%",
	transform: "translateY(-50%)",
	width: "5",
	height: "5",
	color: "fg.muted",
	pointerEvents: "none",
});

const countText = css({ fontSize: "sm", color: "fg.muted" });

const grid = css({
	display: "grid",
	gridTemplateColumns: { base: "repeat(2, minmax(0, 1fr))", md: "repeat(3, minmax(0, 1fr))", lg: "repeat(4, minmax(0, 1fr))" },
	gap: "5",
});

const card = css({
	display: "flex",
	flexDirection: "column",
	alignItems: "center",
	textAlign: "center",
	gap: "3",
	p: "6",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textDecoration: "none",
	color: "fg.primary",
	transition: "transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease",
	_hover: { transform: "translateY(-2px)", boxShadow: "lg", borderColor: "border.default" },
});

const avatar = css({
	width: "20",
	height: "20",
	borderRadius: "full",
	overflow: "hidden",
	borderWidth: "2px",
	borderColor: "border.muted",
	"& img": { width: "full", height: "full", objectFit: "cover" },
});

const personName = css({
	fontSize: "md",
	fontWeight: "bold",
	color: "fg.primary",
	letterSpacing: "tight",
	transition: "color 150ms ease",
	"a:hover &": { color: "fg.brand" },
});

const handle = css({ fontSize: "sm", color: "fg.muted" });

const emptyState = css({
	mx: "auto",
	maxWidth: "28rem",
	mt: "12",
	p: "12",
	borderRadius: "3xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textAlign: "center",
	color: "fg.secondary",
});

const hiddenClass = css({ display: "none" });
---

<Page title="People" description="Meet the people behind Rawkode Academy.">
	<PageHero eyebrow="Community" title="Meet the People" subtitle="Hosts, guests, and contributors who make Rawkode Academy possible." />

	<div class={shell}>
		<div class={toolbar}>
			<p class={countText}>
				Showing <span data-people-visible-count>{people.length}</span> of {people.length} people
			</p>
			<div class={searchWrap}>
				<svg class={searchIcon} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
				</svg>
				<input id="people-search" type="search" placeholder="Search people…" class={searchInput} autocomplete="off" />
			</div>
		</div>

		<div id="people" class={grid}>
			{sortedPeople.map((person) => {
				const searchKeywords = person.data.name.toLowerCase();
				return (
					<a href={`/people/${person.data.id}`} class={`${card} people-card-link`} data-keywords={searchKeywords}>
						<div class={avatar}>
							<img
								src={person.data.avatarUrl ?? "/apple-touch-icon.png"}
								alt={person.data.name}
								onerror={`this.onerror=null; this.src='/apple-touch-icon.png';`}
							/>
						</div>
						<h3 class={personName}>{person.data.name}</h3>
						{person.data.twitter && (
							<span class={handle}>@{person.data.twitter.split("/").pop()}</span>
						)}
					</a>
				);
			})}
		</div>

		<div id="people-empty-state" class={`${hiddenClass} ${emptyState}`}>
			<p>No people match your search. Try a different name.</p>
		</div>
	</div>

	<script>
		document.addEventListener("DOMContentLoaded", () => {
			const searchInput = document.getElementById("people-search") as HTMLInputElement | null;
			const cards = Array.from(document.querySelectorAll<HTMLElement>("#people .people-card-link"));
			const emptyState = document.getElementById("people-empty-state");
			const countTargets = document.querySelectorAll<HTMLElement>("[data-people-visible-count]");

			const applySearch = () => {
				const query = (searchInput?.value ?? "").trim().toLowerCase();
				let visible = 0;
				cards.forEach((card) => {
					const keywords = card.dataset.keywords ?? "";
					const matchesSearch = keywords.includes(query);
					card.style.display = matchesSearch ? "" : "none";
					if (matchesSearch) visible += 1;
				});
				countTargets.forEach((el) => { el.textContent = visible.toString(); });
				if (emptyState) {
					if (visible === 0) emptyState.style.display = "block";
					else emptyState.style.display = "none";
				}
			};

			searchInput?.addEventListener("input", applySearch);
			applySearch();
		});
	</script>
</Page>
