---
import { getImage } from "astro:assets";
import { type CollectionEntry, getCollection, getEntries, getEntry, render } from "astro:content";
import Breadcrumb from "@/components/breadcrumb/Breadcrumb.astro";
import Prose from "@/components/prose/Prose.astro";
import Page from "@/wrappers/page.astro";
import ArticleJsonLd from "@/components/html/article-jsonld.astro";
import RelatedVideos from "@/components/articles/RelatedVideos.astro";
import type { GetStaticPaths, GetStaticPathsResult } from "astro";
import { calculateReadingTime } from "@/utils/reading-time";
import { css } from "../../../styled-system/css";

export const prerender = true;

type Props = { article: CollectionEntry<"articles"> };

const computeImageUrl = async (article: CollectionEntry<"articles">): Promise<URL | undefined> => {
	if (article.data.cover) {
		const image = await getImage({ src: article.data.cover.image });
		return new URL(image.src, Astro.site);
	}
	return undefined;
};

export const getStaticPaths: GetStaticPaths = async (): Promise<GetStaticPathsResult> => {
	const articles = await getCollection("articles");
	return articles.map((article: CollectionEntry<"articles">) => ({ params: { slug: article.id }, props: { article } }));
};

const { article } = Astro.props;
const { Content, headings } = await render(article);
const authors = await getEntries(article.data.authors);
const maybeSeries = article.data.series && (await getEntry("series", article.data.series.id));

const imageUrl = await computeImageUrl(article);
const readingTime = calculateReadingTime(article.body || "");

const allTechnologies = await getCollection("technologies");
const technologyNameById = new Map<string, string>();
for (const technology of allTechnologies) {
	const rawId = technology.id.replace(/\/index$/, "");
	technologyNameById.set(rawId, technology.data.name);
}

const formatTechnologyLabel = (v: string) => {
	const fromCollection = technologyNameById.get(v);
	if (fromCollection) return fromCollection;
	return v
		.split(/[-/]/g)
		.filter(Boolean)
		.map((s) => (s.length <= 3 ? s.toUpperCase() : `${s.charAt(0).toUpperCase()}${s.slice(1)}`))
		.join(" ");
};

const tags = (article.data.technologies ?? []).map((id) => ({
	id,
	label: formatTechnologyLabel(id),
	href: `/technology/${id}`,
}));

const breadcrumbElements = [
	{ title: "Home", link: "/" },
	{ title: "Articles", link: "/read" },
	{ title: article.data.title, link: `/read/${article.id}` },
];

const articleType = article.data.type || "tutorial";

const publishDate = new Intl.DateTimeFormat("en-US", { month: "short", day: "numeric", year: "numeric" }).format(article.data.publishedAt);

const tocItems = headings.filter((h) => h.depth === 2 || h.depth === 3);

// Related articles: same technologies, excluding self, max 3
const allArticlesForRelated = await getCollection("articles", ({ data }) => !data.draft);
const articleTechSet = new Set(article.data.technologies ?? []);
const related = allArticlesForRelated
	.filter((a) => a.id !== article.id)
	.map((a) => {
		const overlap = (a.data.technologies ?? []).filter((t) => articleTechSet.has(t)).length;
		return { a, overlap };
	})
	.filter(({ overlap }) => overlap > 0)
	.sort((x, y) => y.overlap - x.overlap || y.a.data.publishedAt.valueOf() - x.a.data.publishedAt.valueOf())
	.slice(0, 3)
	.map(({ a }) => a);

const shell = css({ maxWidth: "80rem", mx: "auto", px: { base: "4", md: "6" }, py: "10" });

const layout = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", lg: "1fr 18rem" },
	gap: "12",
	alignItems: "start",
	mt: "8",
});

const articleHeader = css({ mb: "10" });

const title = css({
	fontFamily: "display",
	fontSize: { base: "3xl", md: "5xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	lineHeight: "1.05",
	color: "fg.primary",
	textWrap: "balance",
});

const typeBadge = css({
	display: "inline-flex",
	px: "3",
	py: "1",
	borderRadius: "full",
	bg: "bg.brand-subtle",
	color: "fg.brand",
	fontSize: "xs",
	fontWeight: "semibold",
	letterSpacing: "wider",
	textTransform: "uppercase",
	mb: "4",
});

const byline = css({
	mt: "5",
	display: "flex",
	flexWrap: "wrap",
	alignItems: "center",
	gap: "3",
	fontSize: "sm",
	color: "fg.muted",
});

const authorLink = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	color: "fg.primary",
	textDecoration: "none",
	fontWeight: "medium",
	_hover: { color: "fg.brand" },
});

const authorAvatar = css({ width: "7", height: "7", borderRadius: "full", objectFit: "cover" });

const sep = css({ color: "border.default" });

const coverWrap = css({
	mt: "10",
	overflow: "hidden",
	borderRadius: "2xl",
	"& img": { width: "full", height: "auto", display: "block" },
});

const aside = css({
	display: "flex",
	flexDirection: "column",
	gap: "5",
	position: { lg: "sticky" },
	top: { lg: "28" },
});

const tocCard = css({
	p: "5",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
});

const tocTitle = css({
	fontSize: "xs",
	fontWeight: "bold",
	letterSpacing: "wider",
	textTransform: "uppercase",
	color: "fg.brand",
	mb: "3",
});

const tocList = css({ display: "flex", flexDirection: "column", gap: "2", fontSize: "sm", listStyle: "none", m: "0", p: "0" });

const tocLink = css({
	color: "fg.secondary",
	textDecoration: "none",
	display: "block",
	py: "1",
	transition: "color 150ms ease",
	_hover: { color: "fg.brand" },
});

const tagsFooter = css({
	mt: "12",
	pt: "6",
	borderTopWidth: "1px",
	borderTopColor: "border.muted",
	display: "flex",
	flexWrap: "wrap",
	alignItems: "center",
	gap: "3",
});

const tag = css({
	display: "inline-flex",
	px: "3",
	py: "1",
	borderRadius: "full",
	borderWidth: "1px",
	borderColor: "border.muted",
	fontSize: "sm",
	fontWeight: "medium",
	color: "fg.secondary",
	textDecoration: "none",
	transition: "all 150ms ease",
	_hover: { color: "fg.brand", borderColor: "border.default", bg: "bg.brand-subtle" },
});

const seriesCard = css({
	p: "5",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	mb: "8",
});
const seriesLabel = css({ fontSize: "xs", fontWeight: "bold", letterSpacing: "wider", textTransform: "uppercase", color: "fg.brand", mb: "2" });
const seriesLink = css({ color: "fg.primary", fontWeight: "semibold", textDecoration: "none", _hover: { color: "fg.brand" } });

const relatedSection = css({ mt: "20" });
const relatedHead = css({
	display: "flex",
	alignItems: "baseline",
	justifyContent: "space-between",
	gap: "4",
	mb: "8",
	flexWrap: "wrap",
});
const relatedTitle = css({
	fontFamily: "display",
	fontSize: { base: "xl", md: "2xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	color: "fg.primary",
});
const relatedAll = css({
	fontSize: "sm",
	fontWeight: "semibold",
	color: "fg.brand",
	textDecoration: "none",
	_hover: { textDecoration: "underline" },
});
const relatedGrid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", md: "repeat(3, minmax(0, 1fr))" },
	gap: "5",
});
const relatedCard = css({
	display: "flex",
	flexDirection: "column",
	overflow: "hidden",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textDecoration: "none",
	color: "fg.primary",
	transition: "transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease",
	_hover: { transform: "translateY(-2px)", boxShadow: "lg", borderColor: "border.default" },
});
const relatedThumb = css({
	aspectRatio: "16 / 9",
	overflow: "hidden",
	bg: "bg.sunken",
	"& img": { width: "full", height: "full", objectFit: "cover" },
});
const relatedBody = css({ p: "5", display: "flex", flexDirection: "column", gap: "2" });
const relatedCardTitle = css({
	fontSize: "md",
	fontWeight: "semibold",
	color: "fg.primary",
	lineHeight: "1.3",
	"a:hover &": { color: "fg.brand" },
});
const relatedMeta = css({ fontSize: "xs", color: "fg.muted" });

const ctaSection = css({
	mt: "16",
	p: { base: "8", md: "10" },
	borderRadius: "3xl",
	textAlign: "center",
	position: "relative",
	overflow: "hidden",
	backgroundImage:
		"radial-gradient(circle at 30% 20%, rgba(95, 94, 215, 0.12), transparent 55%), radial-gradient(circle at 75% 30%, rgba(0, 206, 255, 0.10), transparent 55%)",
	borderWidth: "1px",
	borderColor: "border.muted",
});
const ctaTitle = css({
	fontFamily: "display",
	fontSize: { base: "xl", md: "2xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	color: "fg.primary",
	mb: "3",
	textWrap: "balance",
});
const ctaDesc = css({ fontSize: "sm", color: "fg.secondary", maxWidth: "32rem", mx: "auto", mb: "6" });
const ctaBtns = css({ display: "flex", flexWrap: "wrap", justifyContent: "center", gap: "3" });
const ctaPrimary = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "5",
	py: "2.5",
	borderRadius: "lg",
	fontWeight: "semibold",
	fontSize: "sm",
	color: "fg.on-brand",
	backgroundImage: "linear-gradient(135deg, token(colors.brand.500), token(colors.cyan.500))",
	textDecoration: "none",
	transition: "transform 150ms ease",
	_hover: { transform: "translateY(-1px)" },
});
const ctaSecondary = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "5",
	py: "2.5",
	borderRadius: "lg",
	fontWeight: "semibold",
	fontSize: "sm",
	color: "fg.primary",
	bg: "bg.surface",
	borderWidth: "1px",
	borderColor: "border.default",
	textDecoration: "none",
	_hover: { bg: "bg.sunken" },
});
---

<Page
	title={`${article.data.openGraph?.title || article.data.title}`}
	subtitle={article.data.openGraph?.subtitle}
	description={article.data.description}
	image={imageUrl ? { image: imageUrl, text: article.data.title, format: "png" as const } : undefined}
	useImageDirectly={true}
	isArticle={true}
	publishedAt={article.data.publishedAt}
	updatedAt={article.data.updatedAt}
	authors={authors}
>
	{imageUrl ? (
		<ArticleJsonLd slot="extra-head" article={article} authors={authors} imageUrl={imageUrl} />
	) : (
		<ArticleJsonLd slot="extra-head" article={article} authors={authors} />
	)}
	<link slot="extra-head" rel="alternate" type="application/rss+xml" title="Rawkode Academy - Articles (RSS)" href="/api/feeds/articles.xml" />
	<link slot="extra-head" rel="alternate" type="application/atom+xml" title="Rawkode Academy - Articles (Atom)" href="/api/feeds/articles.atom" />
	<link slot="extra-head" rel="alternate" type="application/feed+json" title="Rawkode Academy - Articles (JSON Feed)" href="/api/feeds/articles.json" />

	<div class={shell}>
		<Breadcrumb elements={breadcrumbElements} />

		<header class={articleHeader}>
			<span class={typeBadge}>{articleType}</span>
			<h1 class={title}>{article.data.title}</h1>
			<div class={byline}>
				{authors.map((author, idx) => (
					<>
						{idx > 0 && <span class={sep}>·</span>}
						<a href={`/people/${author.data.id}`} rel="author" class={authorLink}>
							{author.data.avatarUrl && <img src={author.data.avatarUrl} alt="" class={authorAvatar} loading="lazy" />}
							<span>{author.data.name}</span>
						</a>
					</>
				))}
				<span class={sep}>·</span>
				<time datetime={article.data.publishedAt.toString()}>{publishDate}</time>
				<span class={sep}>·</span>
				<span>{readingTime.text}</span>
			</div>
		</header>

		{article.data.cover && (
			<div class={coverWrap}>
				<img src={typeof article.data.cover.image === "string" ? article.data.cover.image : article.data.cover.image.src} alt={article.data.cover.alt || article.data.title} />
			</div>
		)}

		<section class={layout}>
			<div>
				{maybeSeries && (
					<div class={seriesCard}>
						<div class={seriesLabel}>Part of series</div>
						<a href={`/series/${maybeSeries.id}`} class={seriesLink}>{maybeSeries.data.title}</a>
					</div>
				)}

				<Prose>
					<Content />
				</Prose>

				{tags.length > 0 && (
					<footer class={tagsFooter}>
						<span style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--colors-fg-muted);">Tagged in</span>
						{tags.map((t) => (
							<a href={t.href} class={tag} rel="tag">{t.label}</a>
						))}
					</footer>
				)}

				<RelatedVideos currentArticle={article} limit={3} />
			</div>

			<aside class={aside} aria-label="Article sidebar">
				{tocItems.length > 0 && (
					<div class={tocCard}>
						<h2 class={tocTitle}>On this page</h2>
						<ul class={tocList}>
							{tocItems.map((h) => (
								<li style={`padding-left: ${(h.depth - 2) * 0.75}rem;`}>
									<a href={`#${h.slug}`} class={tocLink}>{h.text}</a>
								</li>
							))}
						</ul>
					</div>
				)}
			</aside>
		</section>

		{related.length > 0 && (
			<section class={relatedSection}>
				<div class={relatedHead}>
					<h2 class={relatedTitle}>Keep reading</h2>
					<a href="/read" class={relatedAll}>Browse all articles →</a>
				</div>
				<div class={relatedGrid}>
					{related.map((r) => (
						<a href={`/read/${r.id}`} class={relatedCard}>
							{r.data.cover && (
								<div class={relatedThumb}>
									<img src={typeof r.data.cover.image === "string" ? r.data.cover.image : r.data.cover.image.src} alt={r.data.cover.alt || r.data.title} loading="lazy" />
								</div>
							)}
							<div class={relatedBody}>
								<h3 class={relatedCardTitle}>{r.data.title}</h3>
								<span class={relatedMeta}>{new Intl.DateTimeFormat("en-US", { month: "short", day: "numeric", year: "numeric" }).format(r.data.publishedAt)}</span>
							</div>
						</a>
					))}
				</div>
			</section>
		)}

		<section class:list={[ctaSection, "hero-aurora"]}>
			<h2 class={ctaTitle}>Hungry for more cloud native engineering?</h2>
			<p class={ctaDesc}>Subscribe to the feed or jump into a guided learning path — fresh field reports and curated curricula straight from the platform.</p>
			<div class={ctaBtns}>
				<a href="/learning-paths" class={ctaPrimary}>Browse Learning Paths</a>
				<a href="/api/feeds/articles.xml" class={ctaSecondary}>
					<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4 11a9 9 0 019 9h-3a6 6 0 00-6-6v-3zm0-7a16 16 0 0116 16h-3A13 13 0 004 7V4zm2 13a2 2 0 110 4 2 2 0 010-4z"/></svg>
					Subscribe via RSS
				</a>
			</div>
		</section>
	</div>
</Page>
