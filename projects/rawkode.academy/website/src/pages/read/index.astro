---
import { getCollection, getEntries } from "astro:content";

import Page from "@/wrappers/page.astro";
import ArticleItemListJsonLd from "@/components/html/article-itemlist-jsonld.astro";

import ReadMasthead from "@/components/read/ReadMasthead.astro";
import FeaturedArticle from "@/components/read/FeaturedArticle.astro";
import FilterRail from "@/components/read/FilterRail.astro";
import ArticleGridItem from "@/components/read/ArticleGridItem.astro";
import ReadFooter from "@/components/read/ReadFooter.astro";
import MLabel from "@/components/ui/MLabel.vue";
import EmptyState from "@/components/ui/EmptyState.vue";
import PagerStrip from "@/components/ui/PagerStrip.astro";

import { calculateReadingTime } from "@/utils/reading-time";
import { getTypeBadgeConfig } from "@/utils/article-types";

export const prerender = false;

// Cache headers — content only changes at deploy time, and nothing here is
// personalised, so filtered variants are publicly cacheable per-URL.
Astro.response.headers.set(
	"Cache-Control",
	"public, max-age=300, s-maxage=3600, stale-while-revalidate=86400",
);
Astro.response.headers.set("CDN-Cache-Control", "public, max-age=3600");
Astro.response.headers.set("Cache-Tag", "articles-page, articles-list");

// ─── Data ──────────────────────────────────────────────────────

const allArticles = (
	await getCollection("articles", ({ data }) => !data.draft)
).sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

// ─── Filters (?type=…&topic=…) ─────────────────────────────────

const typeKeyFor = (article: (typeof allArticles)[number]) =>
	article.data.type || "tutorial";

const typeCounts = new Map<string, number>();
for (const article of allArticles) {
	const key = typeKeyFor(article);
	typeCounts.set(key, (typeCounts.get(key) ?? 0) + 1);
}

// Topics — derived from technologies referenced across the corpus.
const topicCounts = new Map<string, number>();
for (const article of allArticles) {
	for (const tech of article.data.technologies ?? []) {
		topicCounts.set(tech, (topicCounts.get(tech) ?? 0) + 1);
	}
}

const requestedType = Astro.url.searchParams.get("type") || undefined;
const selectedType =
	requestedType && typeCounts.has(requestedType) ? requestedType : undefined;

const requestedTopic = Astro.url.searchParams.get("topic") || undefined;
const selectedTopic =
	requestedTopic && topicCounts.has(requestedTopic)
		? requestedTopic
		: undefined;

const isFiltered = Boolean(selectedType || selectedTopic);

const matchesType = (article: (typeof allArticles)[number]) =>
	!selectedType || typeKeyFor(article) === selectedType;
const matchesTopic = (article: (typeof allArticles)[number]) =>
	!selectedTopic || (article.data.technologies ?? []).includes(selectedTopic);

const visibleArticles = allArticles.filter(
	(article) => matchesType(article) && matchesTopic(article),
);

const requestedPage = Math.max(
	1,
	parseInt(Astro.url.searchParams.get("page") || "1", 10) || 1,
);
const articlesPerPage = 12;

const readHref = (
	overrides: {
		type?: string | undefined;
		topic?: string | undefined;
		page?: number;
	} = {},
) => {
	const type = "type" in overrides ? overrides.type : selectedType;
	const topic = "topic" in overrides ? overrides.topic : selectedTopic;
	// Changing a filter always resets to page 1; only the pager carries pages.
	const targetPage = overrides.page ?? 1;
	const params = new URLSearchParams();
	if (type) params.set("type", type);
	if (topic) params.set("topic", topic);
	if (targetPage > 1) params.set("page", String(targetPage));
	const query = params.toString();
	return `/read${query ? `?${query}` : ""}`;
};

const readPathFor = (targetPage: number) => readHref({ page: targetPage });

const formatTopicLabel = (id: string) =>
	id.replace(/[-_]/g, " ").replace(/\b\w/g, (char) => char.toUpperCase());

// Type rail — every type the corpus actually uses, counted against the
// active topic so the numbers describe what a click returns.
const typeRailCounts = new Map<string, number>();
for (const article of allArticles) {
	if (!matchesTopic(article)) continue;
	const key = typeKeyFor(article);
	typeRailCounts.set(key, (typeRailCounts.get(key) ?? 0) + 1);
}

const navTypes = Array.from(typeRailCounts.entries()).sort(
	(a, b) => b[1] - a[1],
);
if (selectedType && !navTypes.some(([key]) => key === selectedType)) {
	navTypes.push([selectedType, 0]);
}

const typeItems = [
	{ label: "All", href: readHref({ type: undefined }) },
	...navTypes.map(([key]) => ({
		label: getTypeBadgeConfig(key).label,
		href: readHref({ type: key }),
	})),
];
const activeTypeIndex = selectedType
	? Math.max(0, 1 + navTypes.findIndex(([key]) => key === selectedType))
	: 0;

// Topic rail — top topics by article count within the active type.
const topicRailCounts = new Map<string, number>();
for (const article of allArticles) {
	if (!matchesType(article)) continue;
	for (const tech of article.data.technologies ?? []) {
		topicRailCounts.set(tech, (topicRailCounts.get(tech) ?? 0) + 1);
	}
}

const navTopics = Array.from(topicRailCounts.entries())
	.sort((a, b) => b[1] - a[1])
	.slice(0, 8);
if (selectedTopic && !navTopics.some(([id]) => id === selectedTopic)) {
	navTopics.push([selectedTopic, topicRailCounts.get(selectedTopic) ?? 0]);
}

const topicItems = [
	{ label: "All", href: readHref({ topic: undefined }) },
	...navTopics.map(([id]) => ({
		label: formatTopicLabel(id),
		href: readHref({ topic: id }),
	})),
];
const activeTopicIndex = selectedTopic
	? Math.max(0, 1 + navTopics.findIndex(([id]) => id === selectedTopic))
	: 0;

// ─── Featured + grid ───────────────────────────────────────────
// The featured article only fronts page 1; later pages are grid-only.

const featuredCandidate =
	visibleArticles.find((article) => article.data.cover) ?? visibleArticles[0];
// The candidate stays out of the grid on every page so page boundaries
// don't shift between page 1 (featured rendered) and later pages.
const gridArticles = visibleArticles.filter(
	(article) => !featuredCandidate || article.id !== featuredCandidate.id,
);
const totalPages = Math.max(1, Math.ceil(gridArticles.length / articlesPerPage));
// Clamp out-of-range requests so ?page=999 renders the last real page
// instead of an empty grid with prev/next links into a phantom crawl space.
const page = Math.min(requestedPage, totalPages);
const featured = page === 1 ? featuredCandidate : undefined;
const featuredIndex = featured
	? allArticles.findIndex((article) => article.id === featured.id)
	: -1;
const pagedArticles = gridArticles.slice(
	(page - 1) * articlesPerPage,
	page * articlesPerPage,
);
const hasNextPage = page < totalPages;
const featuredAuthors = featured ? await getEntries(featured.data.authors) : [];

// ─── Helpers ───────────────────────────────────────────────────

const dateFormatter = new Intl.DateTimeFormat("en-US", {
	month: "short",
	day: "2-digit",
	year: "numeric",
});

const compactCopy = (text: string, maxLength: number) => {
	const normalized = text.replace(/\s+/g, " ").trim();
	const firstSentence = normalized.match(/^.*?[.!?](?:\s|$)/)?.[0]?.trim();
	if (firstSentence && firstSentence.length <= maxLength) return firstSentence;
	if (normalized.length <= maxLength) return normalized;
	return `${normalized.slice(0, maxLength).trimEnd()}…`;
};

const articleAuthorName = async (
	article: (typeof allArticles)[number],
): Promise<string | undefined> => {
	const authors = await getEntries(article.data.authors);
	if (authors.length === 0) return undefined;
	return authors.map((a) => a.data.name).join(", ");
};

const dispatchNumFor = (idx: number) =>
	String(allArticles.length - idx).padStart(3, "0");

const dispatchNumForArticle = (article: (typeof allArticles)[number]) =>
	dispatchNumFor(
		allArticles.findIndex((candidate) => candidate.id === article.id),
	);

// Pre-resolve authors for the grid (Astro can't await in JSX iteration cleanly).
// Only the current page's slice — not the whole archive.
const restWithMeta = await Promise.all(
	pagedArticles.map(async (article) => ({
		article,
		dispatchNum: dispatchNumForArticle(article),
		author: await articleAuthorName(article),
		readingTime: calculateReadingTime(article.body || "").text,
	})),
);

const activeFilterSummary = [
	selectedType ? getTypeBadgeConfig(selectedType).label : undefined,
	selectedTopic ? formatTopicLabel(selectedTopic) : undefined,
]
	.filter(Boolean)
	.join(" · ");

// SERP title leads with what people search for; the "Field Notes"
// editorial branding stays on the visible masthead.
const pageTitle = "Cloud Native & Kubernetes Articles";
const pageDescription =
	"Long-form articles, tutorials, and field reports on cloud native engineering — Kubernetes, eBPF, containers, supply chain — from Rawkode Academy.";
---

<Page title={pageTitle} description={pageDescription} pageType="CollectionPage">
	<Fragment slot="extra-head">
		{(isFiltered || page > 1) && <meta name="robots" content="noindex,follow" />}
		{page > 1 && <link rel="prev" href={readPathFor(page - 1)} />}
		{hasNextPage && <link rel="next" href={readPathFor(page + 1)} />}
		{!isFiltered && page === 1 && (
			<ArticleItemListJsonLd
				articles={allArticles}
				listUrl={new URL("/read", Astro.site ?? Astro.url).href}
				listName={pageTitle}
			/>
		)}
		<link rel="alternate" type="application/rss+xml" title="Rawkode Academy - Articles (RSS)" href="/api/feeds/articles.xml" />
		<link rel="alternate" type="application/feed+json" title="Rawkode Academy - Articles (JSON Feed)" href="/api/feeds/articles.json" />
		<link rel="alternate" type="application/atom+xml" title="Rawkode Academy - Articles (Atom)" href="/api/feeds/articles.atom" />
	</Fragment>

	<div class="read-page">
		<ReadMasthead />

		{featured && (
			<FeaturedArticle
				href={`/read/${featured.id}`}
				kicker={getTypeBadgeConfig(featured.data.type || "tutorial").label}
				dispatchNum={dispatchNumFor(featuredIndex)}
				title={featured.data.title}
				dek={compactCopy(
					featured.data.openGraph?.subtitle || featured.data.description,
					180,
				)}
				author={featuredAuthors.map((a) => a.data.name).join(", ") || undefined}
				date={dateFormatter.format(featured.data.publishedAt)}
				readingTime={calculateReadingTime(featured.body || "").text}
				cover={featured.data.cover}
			/>
		)}

		<FilterRail
			label="Type"
			ariaLabel="Article types"
			topics={typeItems}
			activeIndex={activeTypeIndex}
		/>

		<FilterRail
			label="Topics"
			ariaLabel="Article topics"
			topics={topicItems}
			activeIndex={activeTopicIndex}
		/>

		{isFiltered && (
			<div class="read-filter-status">
				<MLabel>
					{visibleArticles.length}{" "}
					{visibleArticles.length === 1 ? "article" : "articles"}
					{activeFilterSummary ? ` · ${activeFilterSummary}` : ""}
				</MLabel>
				<div class="read-filter-status__links">
					{selectedTopic && (
						<a
							class="read-filter-status__link"
							href={`/technology/${selectedTopic}`}
						>
							View technology hub →
						</a>
					)}
					<a class="read-filter-status__link" href="/read">Clear filters</a>
				</div>
			</div>
		)}

		{visibleArticles.length === 0 && (
			<div class="read-empty">
				<EmptyState title="No articles match these filters.">
					<Fragment slot="actions">
						<a href="/read">Browse all articles →</a>
					</Fragment>
				</EmptyState>
			</div>
		)}

		<div class="read-grid">
			{restWithMeta.map(({ article, dispatchNum, author, readingTime }) => (
				<ArticleGridItem
					href={`/read/${article.id}`}
					dispatchNum={dispatchNum}
					kicker={getTypeBadgeConfig(article.data.type || "tutorial").label}
					title={article.data.title}
					dek={compactCopy(
						article.data.openGraph?.subtitle ||
							article.data.subtitle ||
							article.data.description,
						130,
					)}
					author={author}
					date={dateFormatter.format(article.data.publishedAt)}
					readingTime={readingTime}
					cover={article.data.cover}
				/>
			))}
		</div>

		{totalPages > 1 && (
			<div class="read-pager">
				<PagerStrip
					page={page}
					totalPages={totalPages}
					prevHref={page > 1 ? readPathFor(page - 1) : undefined}
					nextHref={hasNextPage ? readPathFor(page + 1) : undefined}
					ariaLabel="Article pages"
				/>
			</div>
		)}

		<ReadFooter />
	</div>
</Page>

<style>
	.read-page {
		background: var(--editorial-paper);
		color: var(--editorial-ink);
	}

	.read-filter-status {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.5rem 1.5rem;
		padding: 0.75rem 2.5rem 0;
	}

	.read-filter-status__links {
		display: flex;
		align-items: baseline;
		gap: 1.25rem;
	}

	.read-filter-status__link {
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 0.6875rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--editorial-spruce);
		text-decoration: none;
	}

	.read-filter-status__link:hover {
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 0.35em;
	}

	.read-empty {
		padding: 1.5rem 2.5rem;
	}

	.read-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0;
		padding: 1.5rem 2.5rem 4rem;
	}

	.read-pager {
		display: flex;
		justify-content: center;
		padding: 0 2.5rem 3rem;
	}

	@media (max-width: 960px) {
		.read-filter-status {
			padding-inline: 1.5rem;
		}

		.read-empty {
			padding-inline: 1.5rem;
		}

		.read-grid {
			grid-template-columns: 1fr;
			padding: 1rem 1.5rem 3rem;
		}
	}

	@media (max-width: 640px) {
		.read-grid {
			padding: 0.375rem 1rem 2.5rem;
		}
	}
</style>
