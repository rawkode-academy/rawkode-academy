---
import { getCollection, getEntries } from "astro:content";

import Page from "@/wrappers/page.astro";
import ArticleItemListJsonLd from "@/components/html/article-itemlist-jsonld.astro";

import ReadMasthead from "@/components/read/ReadMasthead.astro";
import FeaturedArticle from "@/components/read/FeaturedArticle.astro";
import FilterRail from "@/components/read/FilterRail.astro";
import ArticleGridItem from "@/components/read/ArticleGridItem.astro";
import ReadFooter from "@/components/read/ReadFooter.astro";

import { calculateReadingTime } from "@/utils/reading-time";
import { getTypeBadgeConfig } from "@/utils/article-types";

export const prerender = true;

// ─── Data ──────────────────────────────────────────────────────

const allArticles = (await getCollection("articles", ({ data }) => !data.draft))
	.sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const featured = allArticles.find((article) => article.data.cover) ?? allArticles[0];
const featuredIndex = featured
	? allArticles.findIndex((article) => article.id === featured.id)
	: -1;
const rest = featured
	? allArticles.filter((article) => article.id !== featured.id)
	: [];
const featuredAuthors = featured ? await getEntries(featured.data.authors) : [];

// Topics — derived from technologies referenced across the corpus.
const topicCounts = new Map<string, number>();
for (const article of allArticles) {
	for (const tech of article.data.technologies ?? []) {
		topicCounts.set(tech, (topicCounts.get(tech) ?? 0) + 1);
	}
}

const topTopics = Array.from(topicCounts.entries())
	.sort((a, b) => b[1] - a[1])
	.slice(0, 8)
	.map(([id]) => ({
		label: id
			.replace(/[-_]/g, " ")
			.replace(/\b\w/g, (char) => char.toUpperCase()),
		href: `/technology/${id}`,
	}));

const topics = topTopics;

// ─── Helpers ───────────────────────────────────────────────────

const dateFormatter = new Intl.DateTimeFormat("en-US", {
	month: "short",
	day: "2-digit",
	year: "numeric",
});

const compactCopy = (text: string, maxLength: number) => {
	const normalized = text.replace(/\s+/g, " ").trim();
	const firstSentence = normalized.match(/^.*?[.!?](?:\s|$)/)?.[0]?.trim();
	if (firstSentence && firstSentence.length <= maxLength) return firstSentence;
	if (normalized.length <= maxLength) return normalized;
	return `${normalized.slice(0, maxLength).trimEnd()}…`;
};

const articleAuthorName = async (
	article: (typeof allArticles)[number],
): Promise<string | undefined> => {
	const authors = await getEntries(article.data.authors);
	if (authors.length === 0) return undefined;
	return authors.map((a) => a.data.name).join(", ");
};

const dispatchNumFor = (idx: number) =>
	String(allArticles.length - idx).padStart(3, "0");

const dispatchNumForArticle = (article: (typeof allArticles)[number]) =>
	dispatchNumFor(allArticles.findIndex((candidate) => candidate.id === article.id));

// Pre-resolve authors for the grid (Astro can't await in JSX iteration cleanly).
const restWithMeta = await Promise.all(
	rest.map(async (article) => ({
		article,
		dispatchNum: dispatchNumForArticle(article),
		author: await articleAuthorName(article),
		readingTime: calculateReadingTime(article.body || "").text,
	})),
);

const pageTitle = "Field Notes — Articles from Rawkode Academy";
const pageDescription =
	"Long-form essays, tutorials, and field reports on cloud native engineering — Kubernetes, eBPF, containers, supply chain.";
---

<Page title={pageTitle} description={pageDescription} pageType="CollectionPage">
	<Fragment slot="extra-head">
		<ArticleItemListJsonLd
			articles={allArticles}
			listUrl={new URL("/read", Astro.site ?? Astro.url).href}
			listName={pageTitle}
		/>
		<link rel="alternate" type="application/rss+xml" title="Rawkode Academy - Articles (RSS)" href="/api/feeds/articles.xml" />
		<link rel="alternate" type="application/feed+json" title="Rawkode Academy - Articles (JSON Feed)" href="/api/feeds/articles.json" />
		<link rel="alternate" type="application/atom+xml" title="Rawkode Academy - Articles (Atom)" href="/api/feeds/articles.atom" />
	</Fragment>

	<div class="read-page">
		<ReadMasthead />

		{featured && (
			<FeaturedArticle
				href={`/read/${featured.id}`}
				kicker={getTypeBadgeConfig(featured.data.type || "tutorial").label}
				dispatchNum={dispatchNumFor(featuredIndex)}
				title={featured.data.title}
				dek={compactCopy(
					featured.data.openGraph?.subtitle || featured.data.description,
					180,
				)}
				author={featuredAuthors.map((a) => a.data.name).join(", ") || undefined}
				date={dateFormatter.format(featured.data.publishedAt)}
				readingTime={calculateReadingTime(featured.body || "").text}
				cover={featured.data.cover}
			/>
		)}

		<FilterRail topics={topics} />

		<div class="read-grid">
			{restWithMeta.map(({ article, dispatchNum, author, readingTime }) => (
				<ArticleGridItem
					href={`/read/${article.id}`}
					dispatchNum={dispatchNum}
					kicker={getTypeBadgeConfig(article.data.type || "tutorial").label}
					title={article.data.title}
					dek={compactCopy(
						article.data.openGraph?.subtitle ||
							article.data.subtitle ||
							article.data.description,
						130,
					)}
					author={author}
					date={dateFormatter.format(article.data.publishedAt)}
					readingTime={readingTime}
					cover={article.data.cover}
				/>
			))}
		</div>

		<ReadFooter />
	</div>
</Page>

<style>
	.read-page {
		background: var(--editorial-paper);
		color: var(--editorial-ink);
	}

	.read-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0;
		padding: 1.5rem 2.5rem 4rem;
	}

	@media (max-width: 960px) {
		.read-grid {
			grid-template-columns: 1fr;
			padding: 1rem 1.5rem 3rem;
		}
	}

	@media (max-width: 640px) {
		.read-grid {
			padding: 0.375rem 1rem 2.5rem;
		}
	}
</style>
