---
import { Image } from "astro:assets";
import { getCollection, getEntries } from "astro:content";
import ArticleItemListJsonLd from "@/components/html/article-itemlist-jsonld.astro";
import PageHero from "@/components/layout/PageHero.astro";
import Page from "@/wrappers/page.astro";
import { css } from "../../../styled-system/css";

export const prerender = true;

const allArticles = (await getCollection("articles", ({ data }) => !data.draft)).sort(
	(a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);

const featured = allArticles[0];
const featuredAuthors = featured ? await getEntries(featured.data.authors) : [];
const remaining = allArticles.slice(1);

const pageTitle = "Cloud Native & Kubernetes Articles | Rawkode Academy";
const pageDescription = "Deep dives into cloud native technologies, Kubernetes, and observability.";

const formatDate = (date: Date) =>
	new Intl.DateTimeFormat("en-US", { month: "short", day: "numeric", year: "numeric" }).format(date);

const shell = css({ maxWidth: "80rem", mx: "auto", px: { base: "4", md: "6" }, py: "12" });

const featuredCard = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", md: "1.2fr 1fr" },
	gap: "8",
	alignItems: "center",
	p: { base: "6", md: "10" },
	borderRadius: "3xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textDecoration: "none",
	color: "fg.primary",
	mb: "12",
	transition: "transform 200ms ease, box-shadow 200ms ease",
	_hover: { transform: "translateY(-2px)", boxShadow: "lg" },
});

const featuredMedia = css({
	aspectRatio: "16 / 10",
	overflow: "hidden",
	borderRadius: "2xl",
	bg: "bg.sunken",
	"& img": { width: "full", height: "full", objectFit: "cover" },
});

const featuredMeta = css({
	display: "flex",
	flexWrap: "wrap",
	gap: "2",
	fontSize: "xs",
	fontWeight: "semibold",
	letterSpacing: "wider",
	textTransform: "uppercase",
	color: "fg.muted",
});

const featuredTitle = css({
	fontFamily: "display",
	fontSize: { base: "3xl", md: "4xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	lineHeight: "1.05",
	color: "fg.primary",
	textWrap: "balance",
	mt: "3",
});

const featuredDesc = css({
	mt: "4",
	fontSize: "md",
	lineHeight: "1.7",
	color: "fg.secondary",
	maxWidth: "44rem",
});

const sectionTitle = css({
	fontFamily: "display",
	fontSize: { base: "2xl", md: "3xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	color: "fg.primary",
	mb: "6",
});

const grid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", sm: "repeat(2, minmax(0, 1fr))", lg: "repeat(3, minmax(0, 1fr))" },
	gap: "5",
});

const card = css({
	display: "flex",
	flexDirection: "column",
	overflow: "hidden",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textDecoration: "none",
	color: "fg.primary",
	transition: "transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease",
	_hover: { transform: "translateY(-2px)", boxShadow: "lg", borderColor: "border.default" },
});
const cardImg = css({
	aspectRatio: "16 / 9",
	overflow: "hidden",
	bg: "bg.sunken",
	"& img": { width: "full", height: "full", objectFit: "cover" },
});
const cardBody = css({ p: "5", display: "flex", flexDirection: "column", gap: "2", flex: "1" });
const cardMeta = css({
	fontSize: "xs",
	fontWeight: "semibold",
	letterSpacing: "wider",
	textTransform: "uppercase",
	color: "fg.muted",
});
const cardTitle = css({
	fontSize: "lg",
	fontWeight: "semibold",
	lineHeight: "tight",
	color: "fg.primary",
	transition: "color 150ms ease",
	"a:hover &": { color: "fg.brand" },
});
const cardDesc = css({
	fontSize: "sm",
	color: "fg.secondary",
	lineHeight: "1.6",
	display: "-webkit-box",
	WebkitLineClamp: "3",
	WebkitBoxOrient: "vertical",
	overflow: "hidden",
});
---

<Page title={pageTitle} description={pageDescription}>
	<Fragment slot="extra-head">
		<ArticleItemListJsonLd articles={allArticles} listUrl={new URL("/read", Astro.site ?? Astro.url).href} listName="Cloud Native & Kubernetes Articles" />
		<link rel="alternate" type="application/rss+xml" title="Rawkode Academy - Articles (RSS)" href="/api/feeds/articles.xml" />
		<link rel="alternate" type="application/feed+json" title="Rawkode Academy - Articles (JSON Feed)" href="/api/feeds/articles.json" />
		<link rel="alternate" type="application/atom+xml" title="Rawkode Academy - Articles (Atom)" href="/api/feeds/articles.atom" />
	</Fragment>

	<PageHero eyebrow="Articles" title="Cloud Native Writing" subtitle="Architecture notes, breakdowns, and context — written by practitioners, for practitioners." />

	<div class={shell}>
		{featured && (
			<a href={`/read/${featured.id}`} class={featuredCard}>
				<div>
					<div class={featuredMeta}>
						<span>{formatDate(featured.data.publishedAt)}</span>
						{featuredAuthors[0] && (
							<>
								<span>·</span>
								<span>{featuredAuthors.map((a) => a.data.name).join(", ")}</span>
							</>
						)}
					</div>
					<h2 class={featuredTitle}>{featured.data.title}</h2>
					<p class={featuredDesc}>{featured.data.openGraph?.subtitle || featured.data.description}</p>
				</div>
				{featured.data.cover ? (
					<div class={featuredMedia}>
						<Image src={featured.data.cover.image} alt={featured.data.cover.alt || featured.data.title} width={800} height={500} loading="eager" />
					</div>
				) : (
					<div class={featuredMedia}></div>
				)}
			</a>
		)}

		<h2 class={sectionTitle}>All articles</h2>
		<div class={grid}>
			{remaining.map((article) => (
				<a href={`/read/${article.id}`} class={card}>
					{article.data.cover ? (
						<div class={cardImg}>
							<Image src={article.data.cover.image} alt={article.data.cover.alt || article.data.title} width={600} height={340} loading="lazy" />
						</div>
					) : (
						<div class={cardImg}></div>
					)}
					<div class={cardBody}>
						<div class={cardMeta}>{formatDate(article.data.publishedAt)}</div>
						<h3 class={cardTitle}>{article.data.title}</h3>
						<p class={cardDesc}>{article.data.description}</p>
					</div>
				</a>
			))}
		</div>
	</div>
</Page>
