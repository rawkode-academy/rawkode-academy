---
import { env } from "cloudflare:workers";
import Page from "@/wrappers/page.astro";
import K8sCheatsheetCTA from "@/components/lead-magnet/K8sCheatsheetCTA.vue";
import { createLearnerId } from "@/actions/newsletter";
import { css } from "../../../../styled-system/css";

export const prerender = false;

const user = Astro.locals.user;
const pagePath = Astro.url.pathname;
const signInUrl = `/sign-in?returnTo=${encodeURIComponent(pagePath)}`;

// Check for the cheatsheet cookie (indicates user has subscribed)
const hasCheatsheetCookie =
	Astro.cookies.get("lead-magnet:k8s-1-35-cheatsheet")?.value === "true";

// Set the cookie if user just subscribed
if (Astro.url.searchParams.has("subscribed")) {
	Astro.cookies.set("lead-magnet:k8s-1-35-cheatsheet", "true", {
		path: "/",
		maxAge: 60 * 60 * 24 * 365, // 1 year
		sameSite: "lax",
	});
}

// Check if signed-in user has subscribed to kubernetes-release-updates newsletter
let hasNewsletterSubscription = false;
if (user) {
	try {
		const prefixedUserId = createLearnerId(user.id);
		const allPrefs = await env.EMAIL_PREFERENCES.getPreferences(prefixedUserId);
		hasNewsletterSubscription = allPrefs.some(
			(pref: { channel: string; audience: string }) =>
				pref.channel === "newsletter" && pref.audience === "kubernetes-release-updates"
		);
	} catch (e) {
		console.error("Failed to fetch email preferences", e);
	}
}

// User has access if they've subscribed (via preferences, cookie, or query param)
const hasAccess = hasNewsletterSubscription || hasCheatsheetCookie || Astro.url.searchParams.has("subscribed");

const pageTitle = "Kubernetes 1.35 Cheat Sheet | Rawkode Academy";
const pageDescription =
	"Your comprehensive guide to Kubernetes 1.35 - breaking changes, new GA features, AI/ML scheduler primitives, and migration checklist. Free for cloud native engineers.";

const codeStyle = css({ bg: { base: "gray.200", _dark: "gray.700" }, px: "1", borderRadius: "xs", fontSize: "xs" });
const sectionBoxBase = { borderRadius: { base: "lg", sm: "xl" } as const, p: { base: "4", sm: "6" } as const, border: "1px solid" as const };
const sectionBox = (color: string, extra?: Record<string, unknown>) => css({ ...sectionBoxBase, bg: { base: `${color}.50`, _dark: `${color}.900/20` }, borderColor: { base: `${color}.200`, _dark: `${color}.800/50` }, ...extra });
const sectionBoxRed = sectionBox("red", { display: "flex", flexDir: "column", gap: { base: "5", sm: "6" } });
const sectionBoxGreen = sectionBox("green");
const sectionBoxPurple = sectionBox("purple");
const sectionBoxBlue = sectionBox("blue");
const codeBlockStyle = css({ bg: "gray.900", borderRadius: "lg", p: { base: "3", sm: "4" }, fontFamily: "mono", fontSize: { base: "xs", sm: "sm" }, overflowX: "auto" });
const headingStyle = css({ fontSize: { base: "lg", sm: "xl" }, fontWeight: "semibold", color: { base: "gray.900", _dark: "white" }, mb: { base: "3", sm: "4" }, display: "flex", alignItems: "center", gap: "2" });
const subHeadingStyle = css({ fontWeight: "semibold", color: { base: "gray.900", _dark: "white" }, mb: "2", fontSize: { base: "sm", sm: "base" } });
const badgeBase = { px: "2" as const, borderRadius: "xs" as const, fontSize: "xs" as const, fontWeight: "medium" as const, py: { base: "0.5", sm: "1" } as const };
const featureGateBadge = (color: string) => css({ ...badgeBase, bg: { base: `${color}.100`, _dark: `${color}.900/30` }, color: { base: `${color}.600`, _dark: `${color}.400` } });
const featureGateBadgeGA = featureGateBadge("green");
const featureGateBadgeBeta = featureGateBadge("blue");
---

<Page title={pageTitle} description={pageDescription}>
	{hasAccess ? (
		<!-- Cheatsheet Content for Subscribed Users -->
		<section class={css({ py: { base: "12", sm: "16", lg: "20" }, px: "4" })}>
			<div class={css({ mx: "auto", maxW: "4xl", w: "full" })}>
				<!-- Success Header -->
				<div class={css({ textAlign: "center", mb: { base: "8", sm: "12" } })}>
					<div class={css({ display: "inline-flex", alignItems: "center", justifyContent: "center", w: { base: "16", sm: "20" }, h: { base: "16", sm: "20" }, borderRadius: "full", bg: { base: "green.100", _dark: "green.900/30" }, mb: { base: "4", sm: "6" } })}>
						<svg class={css({ w: { base: "8", sm: "10" }, h: { base: "8", sm: "10" }, color: "green.500" })} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
						</svg>
					</div>
					<h1 class={css({ fontSize: { base: "2xl", sm: "3xl", md: "4xl" }, fontWeight: "bold", color: { base: "gray.900", _dark: "white" }, mb: { base: "3", sm: "4" } })}>
						Your Kubernetes 1.35 Cheat Sheet
					</h1>
					<p class={css({ fontSize: { base: "base", sm: "lg" }, color: { base: "gray.600", _dark: "gray.400" }, maxW: "2xl", mx: "auto", px: "2" })}>
						Thank you for joining the Rawkode Academy community. Here's everything you need to know about Kubernetes 1.35.
					</p>
				</div>

				<!-- Release Info Banner -->
				<div class={css({ background: "linear-gradient(to right, rgba(59, 130, 246, 0.1), rgba(168, 85, 247, 0.1))", borderRadius: { base: "xl", sm: "2xl" }, p: { base: "4", sm: "6" }, mb: { base: "6", sm: "8" }, border: "1px solid", borderColor: { base: "blue.200", _dark: "blue.800/50" } })}>
					<div class={css({ display: "flex", flexDir: { base: "column", sm: "row" }, sm: { alignItems: "center", justifyContent: "space-between" }, gap: { base: "3", sm: "4" } })}>
						<div>
							<h2 class={css({ fontSize: { base: "base", sm: "lg" }, fontWeight: "semibold", color: { base: "gray.900", _dark: "white" } })}>Release Date: December 17, 2025</h2>
							<p class={css({ fontSize: { base: "xs", sm: "sm" }, color: { base: "gray.600", _dark: "gray.400" } })}>Cycle started September 15, 2025 - Code Freeze: November 6, 2025</p>
						</div>
						<div class={css({ display: "flex", alignItems: "center", gap: "2", px: "3", py: "1", borderRadius: "full", bg: { base: "blue.100", _dark: "blue.900/30" }, color: { base: "blue.600", _dark: "blue.400" }, fontSize: { base: "xs", sm: "sm" }, fontWeight: "medium", w: "fit-content" })}>
							<span class={css({ position: "relative", display: "flex", h: "2", w: "2" })}>
								<span class={css({ animation: "ping", position: "absolute", display: "inline-flex", h: "full", w: "full", borderRadius: "full", bg: "blue.400", opacity: "0.75" })}></span>
								<span class={css({ position: "relative", display: "inline-flex", borderRadius: "full", h: "2", w: "2", bg: "blue.500" })}></span>
							</span>
							~60 Enhancements
						</div>
					</div>
				</div>

				<!-- Cheatsheet Content Card -->
				<div class={css({ borderRadius: { base: "2xl", sm: "3xl" }, p: { base: "4", sm: "6", md: "8", lg: "12" }, mb: { base: "8", sm: "12" }, border: "1px solid", borderColor: "var(--surface-border)", backdropFilter: "blur(40px)", bg: "var(--surface-card)", boxShadow: "var(--surface-shadow)" })}>
					<h2 class={css({ fontSize: { base: "xl", sm: "2xl" }, fontWeight: "bold", color: { base: "gray.900", _dark: "white" }, mb: { base: "6", sm: "8" } })}>
						What's New in Kubernetes 1.35
					</h2>

					<div class={css({ display: "flex", flexDir: "column", gap: { base: "8", sm: "10" } })}>
						<!-- Breaking Changes -->
						<div>
							<h3 class={headingStyle}>
								<span class={css({ color: "red.500" })}>🚨</span> Breaking Changes (Action Required!)
							</h3>
							<div class={sectionBoxRed}>
								<!-- cgroup v1 -->
								<div>
									<h4 class={subHeadingStyle}>cgroup v1 Support Disabled by Default</h4>
									<p class={css({ color: { base: "gray.600", _dark: "gray.400" }, fontSize: { base: "xs", sm: "sm" }, mb: "3" })}>The Kubelet config <code class={codeStyle}>failCgroupV1</code> now defaults to <code class={codeStyle}>true</code>. If a node boots with legacy cgroup v1 hierarchy, the Kubelet <strong>crashes immediately on startup</strong>.</p>
									<div class={css({ bg: "gray.900", borderRadius: "lg", p: { base: "3", sm: "4" }, fontFamily: "mono", fontSize: { base: "xs", sm: "sm" }, overflowX: "auto", display: "flex", flexDir: "column", gap: { base: "1", sm: "2" } })}>
										<div>
											<p class={css({ color: "gray.400" })}># Check if your nodes use cgroups v2</p>
											<p class={css({ color: "green.400", overflowWrap: "break-word" })}>stat -fc %T /sys/fs/cgroup/</p>
											<p class={css({ color: "gray.400" })}># Returns: cgroup2fs (v2) or tmpfs (v1 - WILL FAIL!)</p>
										</div>
									</div>
								</div>

								<!-- containerd -->
								<div>
									<h4 class={subHeadingStyle}>containerd 1.x End of Support</h4>
									<p class={css({ color: { base: "gray.600", _dark: "gray.400" }, fontSize: { base: "xs", sm: "sm" }, mb: "3" })}>Kubernetes 1.35 is the <strong>last version</strong> to support containerd 1.7. You must upgrade to containerd 2.0+ before upgrading to Kubernetes 1.36.</p>
									<div class={codeBlockStyle}>
										<p class={css({ color: "gray.400" })}># Monitor affected nodes with this metric</p>
										<p class={css({ color: "green.400" })}>kubelet_cri_losing_support</p>
									</div>
								</div>

								<!-- Image Pull -->
								<div>
									<h4 class={subHeadingStyle}>Image Pull Credential Verification (Enabled by Default)</h4>
									<p class={css({ color: { base: "gray.600", _dark: "gray.400" }, fontSize: { base: "xs", sm: "sm" }, mb: "3" })}>The <code class={codeStyle}>KubeletEnsureSecretPulledImages</code> feature is now enabled. Pods must have valid credentials for cached images.</p>
								</div>
							</div>
						</div>

						<!-- GA Features -->
						<div>
							<h3 class={headingStyle}>
								<span class={css({ color: "green.500" })}>🎓</span> Graduating to Stable (GA)
							</h3>
							<div class={sectionBoxGreen}>
								<ul class={css({ display: "flex", flexDir: "column", gap: "4", color: { base: "gray.900", _dark: "white" } })}>
									<li class={css({ display: "flex", alignItems: "flex-start", gap: { base: "2", sm: "3" } })}>
										<span class={css({ color: "green.500", mt: { base: "0.5", sm: "1" }, fontWeight: "bold", flexShrink: "0" })}>✓</span>
										<div class={css({ minW: "0" })}>
											<strong class={css({ fontSize: { base: "sm", sm: "base" } })}>In-place Pod Resource Updates</strong>
											<p class={css({ fontSize: { base: "xs", sm: "sm" }, color: { base: "gray.600", _dark: "gray.400" }, mt: "1" })}>Adjust CPU and memory without restarting pods! No more recreating stateful workloads for vertical scaling.</p>
											<div class={css({ bg: "gray.900", borderRadius: "lg", p: { base: "2", sm: "3" }, mt: "2", fontFamily: "mono", fontSize: { base: "2.5", sm: "xs" }, overflowX: "auto" })}>
												<p class={css({ color: "green.400", whiteSpace: "nowrap" })}>kubectl patch pod my-pod --subresource='resize' -p '&#123;"spec":&#123;"containers":[&#123;"name":"app","resources":&#123;"requests":&#123;"memory":"512Mi"&#125;&#125;&#125;]&#125;&#125;'</p>
											</div>
										</div>
									</li>
									<li class={css({ display: "flex", alignItems: "flex-start", gap: { base: "2", sm: "3" } })}>
										<span class={css({ color: "green.500", mt: { base: "0.5", sm: "1" }, fontWeight: "bold", flexShrink: "0" })}>✓</span>
										<div class={css({ minW: "0" })}>
											<strong class={css({ fontSize: { base: "sm", sm: "base" } })}>Structured Authentication Configuration</strong>
											<p class={css({ fontSize: { base: "xs", sm: "sm" }, color: { base: "gray.600", _dark: "gray.400" }, mt: "1" })}>Configure multiple OIDC providers via file, not flags. Hot-reload without API server restarts.</p>
										</div>
									</li>
								</ul>
							</div>
						</div>

						<!-- AI/ML Features -->
						<div>
							<h3 class={headingStyle}>
								<span class={css({ color: "purple.500" })}>🤖</span> AI/ML & Scheduler Enhancements
							</h3>
							<div class={sectionBoxPurple}>
								<ul class={css({ display: "flex", flexDir: "column", gap: "4", color: { base: "gray.900", _dark: "white" } })}>
									<li class={css({ display: "flex", alignItems: "flex-start", gap: { base: "2", sm: "3" } })}>
										<span class={css({ color: "purple.500", mt: { base: "0.5", sm: "1" }, fontWeight: "bold", flexShrink: "0" })}>α</span>
										<div class={css({ minW: "0" })}>
											<strong class={css({ fontSize: { base: "sm", sm: "base" } })}>Gang Scheduling (PodGroup)</strong>
											<p class={css({ fontSize: { base: "xs", sm: "sm" }, color: { base: "gray.600", _dark: "gray.400" }, mt: "1" })}>Native "all-or-nothing" scheduling for distributed training. If a job needs 16 GPUs and only 10 are free, the scheduler waits for all 16.</p>
										</div>
									</li>
									<li class={css({ display: "flex", alignItems: "flex-start", gap: { base: "2", sm: "3" } })}>
										<span class={css({ color: "purple.500", mt: { base: "0.5", sm: "1" }, fontWeight: "bold", flexShrink: "0" })}>β</span>
										<div class={css({ minW: "0" })}>
											<strong class={css({ fontSize: { base: "sm", sm: "base" } })}>DRA Binding Conditions</strong>
											<p class={css({ fontSize: { base: "xs", sm: "sm" }, color: { base: "gray.600", _dark: "gray.400" }, mt: "1" })}>Dynamic Resource Allocation now waits for hardware initialization. GPUs and FPGAs that take seconds to configure won't cause pod failures.</p>
										</div>
									</li>
								</ul>
							</div>
						</div>

						<!-- Security -->
						<div>
							<h3 class={headingStyle}>
								<span class={css({ color: "blue.500" })}>🔐</span> Security
							</h3>
							<div class={sectionBoxBlue}>
								<ul class={css({ display: "flex", flexDir: "column", gap: "4", color: { base: "gray.900", _dark: "white" } })}>
									<li class={css({ display: "flex", alignItems: "flex-start", gap: { base: "2", sm: "3" } })}>
										<span class={css({ color: "blue.500", mt: { base: "0.5", sm: "1" }, fontWeight: "bold", flexShrink: "0" })}>β</span>
										<div class={css({ minW: "0" })}>
											<strong class={css({ fontSize: { base: "sm", sm: "base" } })}>User Namespaces Support</strong>
											<p class={css({ fontSize: { base: "xs", sm: "sm" }, color: { base: "gray.600", _dark: "gray.400" }, mt: "1" })}>Run containers as UID 0 inside, but unprivileged on the host. Set <code class={codeStyle}>hostUsers: false</code> in your pod spec.</p>
										</div>
									</li>
									<li class={css({ display: "flex", alignItems: "flex-start", gap: { base: "2", sm: "3" } })}>
										<span class={css({ color: "blue.500", mt: { base: "0.5", sm: "1" }, fontWeight: "bold", flexShrink: "0" })}>α</span>
										<div class={css({ minW: "0" })}>
											<strong class={css({ fontSize: { base: "sm", sm: "base" } })}>Constrained Impersonation</strong>
											<p class={css({ fontSize: { base: "xs", sm: "sm" }, color: { base: "gray.600", _dark: "gray.400" }, mt: "1" })}>When impersonating another user, you can't escalate beyond your own privileges.</p>
										</div>
									</li>
								</ul>
							</div>
						</div>

						<!-- Migration Checklist -->
						<div>
							<h3 class={headingStyle}>
								<span class={css({ color: "purple.500" })}>✓</span> Migration Checklist
							</h3>
							<div class={sectionBoxPurple}>
								<ul class={css({ display: "flex", flexDir: "column", gap: "3" })}>
									<li class={css({ display: "flex", alignItems: "flex-start", gap: { base: "2", sm: "3" } })}>
										<input type="checkbox" class={css({ w: { base: "4", sm: "5" }, h: { base: "4", sm: "5" }, borderRadius: "sm", borderColor: "gray.300", mt: "0.5", flexShrink: "0" })} />
										<span class={css({ color: { base: "gray.900", _dark: "white" }, fontSize: { base: "xs", sm: "sm" } })}><strong>Verify cgroups v2</strong> - Run <code class={codeStyle}>stat -fc %T /sys/fs/cgroup/</code> on all nodes</span>
									</li>
									<li class={css({ display: "flex", alignItems: "flex-start", gap: { base: "2", sm: "3" } })}>
										<input type="checkbox" class={css({ w: { base: "4", sm: "5" }, h: { base: "4", sm: "5" }, borderRadius: "sm", borderColor: "gray.300", mt: "0.5", flexShrink: "0" })} />
										<span class={css({ color: { base: "gray.900", _dark: "white" }, fontSize: { base: "xs", sm: "sm" } })}><strong>Check containerd version</strong> - Must be 1.7+ (2.0+ recommended)</span>
									</li>
									<li class={css({ display: "flex", alignItems: "flex-start", gap: { base: "2", sm: "3" } })}>
										<input type="checkbox" class={css({ w: { base: "4", sm: "5" }, h: { base: "4", sm: "5" }, borderRadius: "sm", borderColor: "gray.300", mt: "0.5", flexShrink: "0" })} />
										<span class={css({ color: { base: "gray.900", _dark: "white" }, fontSize: { base: "xs", sm: "sm" } })}><strong>Verify image pull secrets</strong> - Pods need valid credentials for cached images</span>
									</li>
									<li class={css({ display: "flex", alignItems: "flex-start", gap: { base: "2", sm: "3" } })}>
										<input type="checkbox" class={css({ w: { base: "4", sm: "5" }, h: { base: "4", sm: "5" }, borderRadius: "sm", borderColor: "gray.300", mt: "0.5", flexShrink: "0" })} />
										<span class={css({ color: { base: "gray.900", _dark: "white" }, fontSize: { base: "xs", sm: "sm" } })}><strong>Test in staging</strong> - Upgrade staging cluster first</span>
									</li>
									<li class={css({ display: "flex", alignItems: "flex-start", gap: { base: "2", sm: "3" } })}>
										<input type="checkbox" class={css({ w: { base: "4", sm: "5" }, h: { base: "4", sm: "5" }, borderRadius: "sm", borderColor: "gray.300", mt: "0.5", flexShrink: "0" })} />
										<span class={css({ color: { base: "gray.900", _dark: "white" }, fontSize: { base: "xs", sm: "sm" } })}><strong>Backup etcd</strong> - Always before any upgrade</span>
									</li>
								</ul>
							</div>
						</div>

						<!-- Feature Gates -->
						<div>
							<h3 class={headingStyle}>
								<span class={css({ color: "gray.500" })}>⚙️</span> Key Feature Gates
							</h3>
							<!-- Mobile: Card view -->
							<div class={css({ display: { base: "block", sm: "none" }, "& > * + *": { mt: "3" } })}>
								<div class={css({ bg: { base: "gray.50", _dark: "gray.800/50" }, borderRadius: "lg", p: "3", border: "1px solid", borderColor: { base: "gray.200", _dark: "gray.700" } })}>
									<div class={css({ display: "flex", alignItems: "center", justifyContent: "space-between", mb: "1" })}>
										<span class={featureGateBadgeGA}>GA</span>
										<span class={css({ fontSize: "xs", color: { base: "gray.600", _dark: "gray.400" } })}>true (locked)</span>
									</div>
									<p class={css({ fontFamily: "mono", fontSize: "xs", color: { base: "gray.900", _dark: "white" }, overflowWrap: "break-word" })}>InPlacePodVerticalScaling</p>
								</div>
								<div class={css({ bg: { base: "gray.50", _dark: "gray.800/50" }, borderRadius: "lg", p: "3", border: "1px solid", borderColor: { base: "gray.200", _dark: "gray.700" } })}>
									<div class={css({ display: "flex", alignItems: "center", justifyContent: "space-between", mb: "1" })}>
										<span class={featureGateBadgeGA}>GA</span>
										<span class={css({ fontSize: "xs", color: { base: "gray.600", _dark: "gray.400" } })}>true (locked)</span>
									</div>
									<p class={css({ fontFamily: "mono", fontSize: "xs", color: { base: "gray.900", _dark: "white" }, overflowWrap: "break-word" })}>StructuredAuthenticationConfiguration</p>
								</div>
								<div class={css({ bg: { base: "gray.50", _dark: "gray.800/50" }, borderRadius: "lg", p: "3", border: "1px solid", borderColor: { base: "gray.200", _dark: "gray.700" } })}>
									<div class={css({ display: "flex", alignItems: "center", justifyContent: "space-between", mb: "1" })}>
										<span class={featureGateBadgeBeta}>Beta</span>
										<span class={css({ fontSize: "xs", color: { base: "gray.600", _dark: "gray.400" } })}>true</span>
									</div>
									<p class={css({ fontFamily: "mono", fontSize: "xs", color: { base: "gray.900", _dark: "white" }, overflowWrap: "break-word" })}>UserNamespacesSupport</p>
								</div>
								<div class={css({ bg: { base: "gray.50", _dark: "gray.800/50" }, borderRadius: "lg", p: "3", border: "1px solid", borderColor: { base: "gray.200", _dark: "gray.700" } })}>
									<div class={css({ display: "flex", alignItems: "center", justifyContent: "space-between", mb: "1" })}>
										<span class={featureGateBadgeBeta}>Beta</span>
										<span class={css({ fontSize: "xs", color: { base: "gray.600", _dark: "gray.400" } })}>true</span>
									</div>
									<p class={css({ fontFamily: "mono", fontSize: "xs", color: { base: "gray.900", _dark: "white" }, overflowWrap: "break-word" })}>KubeletEnsureSecretPulledImages</p>
								</div>
							</div>
							<!-- Desktop: Table view -->
							<div class={css({ display: { base: "none", sm: "block" }, overflowX: "auto" })}>
								<table class={css({ w: "full", fontSize: "sm", minW: "500px" })}>
									<thead>
										<tr class={css({ borderBottom: "1px solid", borderColor: { base: "gray.200", _dark: "gray.700" } })}>
											<th class={css({ textAlign: "left", py: "3", px: "4", color: { base: "gray.900", _dark: "white" } })}>Feature Gate</th>
											<th class={css({ textAlign: "left", py: "3", px: "4", color: { base: "gray.900", _dark: "white" } })}>Stage</th>
