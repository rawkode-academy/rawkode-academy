---
import { getCollection } from "astro:content";
import NewsItemListJsonLd from "@/components/html/news-itemlist-jsonld.astro";
import Page from "@/wrappers/page.astro";

import NewsMasthead from "@/components/news/NewsMasthead.astro";
import NewsLead from "@/components/news/NewsLead.astro";
import CVEAlert from "@/components/news/CVEAlert.astro";
import NewsRow from "@/components/news/NewsRow.astro";
import TrendingPanel from "@/components/news/TrendingPanel.astro";
import WireSubscribeCard from "@/components/news/WireSubscribeCard.astro";
import FilterRail from "@/components/read/FilterRail.astro";
import MLabel from "@/components/ui/MLabel.vue";

export const prerender = true;

const [allNews, allTechnologies] = await Promise.all([
	getCollection("news"),
	getCollection("technologies"),
]);

allNews.sort(
	(a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);

const [leadStory, ...rest] = allNews;

const technologyNameById = new Map<string, string>();
for (const technology of allTechnologies) {
	const rawId = technology.id.replace(/\/index$/, "");
	technologyNameById.set(rawId, technology.data.name);
}

function formatTechnologyLabel(value: string): string {
	const fromCollection = technologyNameById.get(value);
	if (fromCollection) return fromCollection;
	return value
		.split(/[-/]/g)
		.filter(Boolean)
		.map((segment) =>
			segment.length <= 3
				? segment.toUpperCase()
				: `${segment.charAt(0).toUpperCase()}${segment.slice(1)}`,
		)
		.join(" ");
}

const timeFormatter = new Intl.DateTimeFormat("en-US", {
	hour: "2-digit",
	minute: "2-digit",
	hour12: false,
});

const dateFormatter = new Intl.DateTimeFormat("en-US", {
	month: "short",
	day: "2-digit",
});

const now = new Date();
const isToday = (d: Date) =>
	d.getFullYear() === now.getFullYear() &&
	d.getMonth() === now.getMonth() &&
	d.getDate() === now.getDate();
const isYesterday = (d: Date) => {
	const y = new Date(now);
	y.setDate(now.getDate() - 1);
	return (
		d.getFullYear() === y.getFullYear() &&
		d.getMonth() === y.getMonth() &&
		d.getDate() === y.getDate()
	);
};

const formatRelativeDate = (date: Date) => {
	if (isToday(date)) return "Today";
	if (isYesterday(date)) return "Yesterday";
	return dateFormatter.format(date);
};

const kickerFor = (story: (typeof allNews)[number]): string => {
	const tags = story.data.technologies ?? [];
	if (tags.some((t) => /cve|security/i.test(t))) return "CVE";
	if (tags.some((t) => /cncf|graduation/i.test(t))) return "CNCF";
	if (/release|ship|gen|alpha|beta|GA|stable|launch/i.test(story.data.title))
		return "Release";
	if (/acquire|acquisition/i.test(story.data.title)) return "Acquisition";
	return "Field";
};

const isHot = (story: (typeof allNews)[number]) =>
	/cve|critical|urgent|patch immediately|9\.[0-9]|10\.0/i.test(
		`${story.data.title} ${story.data.description}`,
	);

const cveMatch = (s: (typeof allNews)[number]) =>
	(`${s.data.title} ${s.data.description}`.match(/CVE-\d{4}-\d{3,5}/i) || [
		null,
	])[0];

const cveStory = rest.find((s) => cveMatch(s));

const cveSeverityMatch = cveStory
	? `${cveStory.data.title} ${cveStory.data.description}`.match(
			/CVSS\s+([\d.]+)/i,
		)
	: null;

const topicCounts = new Map<string, number>();
for (const story of allNews) {
	for (const tech of story.data.technologies ?? []) {
		topicCounts.set(tech, (topicCounts.get(tech) ?? 0) + 1);
	}
}
const topTopics = Array.from(topicCounts.entries())
	.sort((a, b) => b[1] - a[1])
	.slice(0, 7)
	.map(([id, count]) => ({
		label: formatTechnologyLabel(id).toUpperCase(),
		count,
		href: `/technology/${id}`,
	}));

const topics = [
	{ label: "All", count: allNews.length, href: "/news" },
	...topTopics,
];

const pageTitle = "The Wire — Cloud Native News";
const pageDescription =
	"Cloud native, Kubernetes, and AI infrastructure news for engineers — release notes, security advisories, KEP updates, ecosystem moves, in plain language.";

const leadStoryTags = leadStory
	? (leadStory.data.technologies ?? []).slice(0, 3)
	: [];

const trendingItems = allNews.slice(0, 5).map((s) => ({
	title: s.data.title,
	meta: formatRelativeDate(s.data.publishedAt),
	href: `/news/${s.id}`,
}));

const newsRows = rest
	.filter((s) => s.id !== cveStory?.id)
	.slice(0, 10);
---

<Page title={pageTitle} description={pageDescription} pageType="CollectionPage">
	<Fragment slot="extra-head">
		<NewsItemListJsonLd
			stories={allNews}
			listUrl={new URL("/news", Astro.site ?? Astro.url).href}
		/>
		<link rel="alternate" type="application/rss+xml" title="Rawkode Academy - News (RSS)" href="/api/feeds/news.xml" />
		<link rel="alternate" type="application/atom+xml" title="Rawkode Academy - News (Atom)" href="/api/feeds/news.atom" />
		<link rel="alternate" type="application/feed+json" title="Rawkode Academy - News (JSON Feed)" href="/api/feeds/news.json" />
	</Fragment>

	<div class="news-page">
		<NewsMasthead updatedAt={leadStory?.data.publishedAt} />

		<section class="news-page__top">
			{leadStory && (
				<NewsLead
					href={`/news/${leadStory.id}`}
					kicker={kickerFor(leadStory)}
					time={timeFormatter.format(leadStory.data.publishedAt)}
					title={leadStory.data.title}
					description={leadStory.data.description}
					tags={leadStoryTags}
				/>
			)}
			{cveStory && cveMatch(cveStory) && (
				<CVEAlert
					id={cveMatch(cveStory) ?? "CVE"}
					severity={cveSeverityMatch?.[1] ?? "—"}
					project={
						formatTechnologyLabel(
							(cveStory.data.technologies ?? [])[0] ?? "runtime",
						)
					}
					title={cveStory.data.title}
					description={cveStory.data.description}
					publishedAt={formatRelativeDate(cveStory.data.publishedAt)}
					href={`/news/${cveStory.id}`}
				/>
			)}
		</section>

		<FilterRail topics={topics} activeIndex={0} sortLabel="Newest ↓" />

		<section class="news-page__feed">
			<div>
				<MLabel>Timeline · {newsRows.length} of {allNews.length}</MLabel>
				<div class="news-page__rows">
					{newsRows.map((s) => (
						<NewsRow
							href={`/news/${s.id}`}
							time={timeFormatter.format(s.data.publishedAt)}
							date={formatRelativeDate(s.data.publishedAt)}
							kicker={kickerFor(s)}
							project={
								(s.data.technologies ?? [])[0]
									? formatTechnologyLabel(s.data.technologies[0]!)
									: undefined
							}
							title={s.data.title}
							tags={(s.data.technologies ?? []).slice(0, 2)}
							hot={isHot(s)}
						/>
					))}
				</div>
				<div class="news-page__rows-footer">
					<MLabel tone="ink">← Older items · {allNews.length} total</MLabel>
				</div>
			</div>

			<aside class="news-page__aside">
				<TrendingPanel items={trendingItems} />
				<WireSubscribeCard />
			</aside>
		</section>

		<footer class="news-page__footer">
			<MLabel>
				<a class="news-page__link" href="/api/feeds/news.xml">RSS</a> ·
				<a class="news-page__link" href="/api/feeds/news.atom">Atom</a> ·
				<a class="news-page__link" href="https://hachyderm.io/@rawkode">@rawkode</a>
			</MLabel>
			<MLabel tone="ink">Archive · By project · By year</MLabel>
		</footer>
	</div>
</Page>

<style>
	.news-page {
		background: var(--editorial-paper);
		color: var(--editorial-ink);
	}

	.news-page__top {
		display: grid;
		grid-template-columns: 1fr 24rem;
		gap: var(--space-section-gap);
		padding: var(--space-section-pad-y) var(--space-section-pad-x);
		border-bottom: 1px solid var(--editorial-hairline);
	}

	.news-page__feed {
		display: grid;
		grid-template-columns: 1fr 20rem;
		gap: var(--space-section-gap-lg);
		padding: var(--space-section-pad-y) var(--space-section-pad-x);
		border-bottom: 1px solid var(--editorial-hairline);
	}

	.news-page__rows-footer {
		padding-top: 1.125rem;
	}

	.news-page__aside {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.news-page__footer {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1.5rem;
		padding: 1.5rem var(--space-section-pad-x);
		border-top: 1px solid var(--editorial-ink);
		background: var(--editorial-paper-deep);
	}

	.news-page__link {
		color: inherit;
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 2px;
		text-decoration-color: var(--editorial-hairline-strong);
	}
	.news-page__link:hover { text-decoration-color: currentColor; }

	@media (max-width: 960px) {
		.news-page__top,
		.news-page__feed {
			grid-template-columns: 1fr;
			padding: 1.75rem 1.25rem;
			gap: 2rem;
		}
		.news-page__footer {
			flex-direction: column;
			align-items: flex-start;
			padding: 1.25rem;
		}
	}
</style>
