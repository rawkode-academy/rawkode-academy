---
import { type CollectionEntry, getCollection, getEntries, render } from "astro:content";
import Breadcrumb from "@/components/breadcrumb/Breadcrumb.astro";
import NewsJsonLd from "@/components/html/news-jsonld.astro";
import Prose from "@/components/prose/Prose.astro";
import Page from "@/wrappers/page.astro";
import { calculateReadingTime } from "@/utils/reading-time";
import type { GetStaticPaths, GetStaticPathsResult } from "astro";
import { css } from "../../../styled-system/css";

export const prerender = true;

type Props = { article: CollectionEntry<"news"> };

export const getStaticPaths: GetStaticPaths = async (): Promise<GetStaticPathsResult> => {
	const articles = await getCollection("news");
	return articles.map((article: CollectionEntry<"news">) => ({
		params: { slug: article.id },
		props: { article },
	}));
};

const { article } = Astro.props;
const { Content } = await render(article);
const authors = await getEntries(article.data.authors);

const allTechnologies = await getCollection("technologies");
const technologyNameById = new Map<string, string>();
for (const technology of allTechnologies) {
	const rawId = technology.id.replace(/\/index$/, "");
	technologyNameById.set(rawId, technology.data.name);
}

function formatTechnologyLabel(value: string): string {
	const fromCollection = technologyNameById.get(value);
	if (fromCollection) return fromCollection;
	return value
		.split(/[-/]/g)
		.filter(Boolean)
		.map((s) => (s.length <= 3 ? s.toUpperCase() : `${s.charAt(0).toUpperCase()}${s.slice(1)}`))
		.join(" ");
}

const tags = (article.data.technologies ?? []).map((id) => ({
	id,
	label: formatTechnologyLabel(id),
	href: `/technology/${id}`,
}));

const breadcrumbElements = [
	{ title: "Home", link: "/" },
	{ title: "News", link: "/news" },
	{ title: article.data.title, link: `/news/${article.id}` },
];

const publishDate = new Intl.DateTimeFormat("en-US", { month: "short", day: "numeric", year: "numeric" }).format(article.data.publishedAt);
const readingTime = calculateReadingTime(article.body || "");

const shell = css({ maxWidth: "56rem", mx: "auto", px: { base: "4", md: "6" }, py: "10" });

const title = css({
	fontFamily: "display",
	fontSize: { base: "3xl", md: "4xl", lg: "5xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	lineHeight: "1.1",
	color: "fg.primary",
	mb: "4",
	textWrap: "balance",
});

const byline = css({
	display: "flex",
	flexWrap: "wrap",
	alignItems: "center",
	gap: "3",
	fontSize: "sm",
	color: "fg.muted",
	mb: "10",
});

const authorLink = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	color: "fg.primary",
	textDecoration: "none",
	fontWeight: "medium",
	transition: "color 150ms ease",
	_hover: { color: "fg.brand" },
});

const authorAvatar = css({
	width: "7",
	height: "7",
	borderRadius: "full",
	objectFit: "cover",
});

const sep = css({ color: "border.default" });

const tagsFooter = css({
	display: "flex",
	flexWrap: "wrap",
	alignItems: "center",
	gap: "3",
	mt: "10",
	pt: "6",
	borderTopWidth: "1px",
	borderTopColor: "border.muted",
});

const tagsLabel = css({
	fontSize: "xs",
	fontWeight: "semibold",
	letterSpacing: "wider",
	textTransform: "uppercase",
	color: "fg.muted",
});

const tagsList = css({ display: "flex", flexWrap: "wrap", gap: "2", listStyle: "none", m: "0", p: "0" });

const tag = css({
	display: "inline-flex",
	alignItems: "center",
	px: "3",
	py: "1",
	borderRadius: "full",
	borderWidth: "1px",
	borderColor: "border.muted",
	fontSize: "sm",
	fontWeight: "medium",
	color: "fg.secondary",
	textDecoration: "none",
	transition: "all 150ms ease",
	_hover: { color: "fg.brand", borderColor: "border.default", bg: "bg.brand-subtle" },
});
---

<Page
	title={article.data.title}
	description={article.data.description}
	isArticle={true}
	publishedAt={article.data.publishedAt}
	authors={authors}
>
	<Fragment slot="extra-head">
		<NewsJsonLd article={article} authors={authors} />
		<link rel="alternate" type="application/rss+xml" title="Rawkode Academy - News (RSS)" href="/api/feeds/news.xml" />
		<link rel="alternate" type="application/atom+xml" title="Rawkode Academy - News (Atom)" href="/api/feeds/news.atom" />
		<link rel="alternate" type="application/feed+json" title="Rawkode Academy - News (JSON Feed)" href="/api/feeds/news.json" />
	</Fragment>

	<div class={shell}>
		<Breadcrumb elements={breadcrumbElements} />

		<h1 class={title}>{article.data.title}</h1>

		<div class={byline}>
			{authors.map((author, idx) => (
				<>
					{idx > 0 && <span class={sep}>·</span>}
					<a href={`/people/${author.data.id}`} rel="author" class={authorLink}>
						{author.data.avatarUrl && <img src={author.data.avatarUrl} alt="" class={authorAvatar} loading="lazy" />}
						<span>{author.data.name}</span>
					</a>
				</>
			))}
			<span class={sep}>·</span>
			<time datetime={article.data.publishedAt.toString()}>{publishDate}</time>
			<span class={sep}>·</span>
			<span>{readingTime.text}</span>
		</div>

		<Prose>
			<Content />
		</Prose>

		{tags.length > 0 && (
			<footer class={tagsFooter}>
				<span class={tagsLabel}>Tagged in</span>
				<ul class={tagsList}>
					{tags.map((t) => (
						<li>
							<a href={t.href} class={tag} rel="tag">{t.label}</a>
						</li>
					))}
				</ul>
			</footer>
		)}
	</div>
</Page>
