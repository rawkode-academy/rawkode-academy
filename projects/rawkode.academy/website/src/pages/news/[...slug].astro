---
import {
	type CollectionEntry,
	getCollection,
	getEntries,
	render,
} from "astro:content";
import ArticleHeader from "@/components/read/ArticleHeader.astro";
import ArticleByline from "@/components/read/ArticleByline.astro";
import NewsJsonLd from "@/components/html/news-jsonld.astro";
import RelatedNews from "@/components/news/RelatedNews.astro";
import NewsletterCTA from "@/components/newsletter/NewsletterCTA.astro";
import MLabel from "@/components/ui/MLabel.vue";
import Page from "@/wrappers/page.astro";
import { calculateReadingTime } from "@/utils/reading-time";
import type { GetStaticPaths, GetStaticPathsResult } from "astro";

export const prerender = true;

type Props = {
	article: CollectionEntry<"news">;
};

export const getStaticPaths: GetStaticPaths =
	async (): Promise<GetStaticPathsResult> => {
		const articles = await getCollection("news");
		return articles.map((article: CollectionEntry<"news">) => ({
			params: { slug: article.id },
			props: { article },
		}));
	};

const { article } = Astro.props;
const { Content } = await render(article);
const authors = await getEntries(article.data.authors);

const allTechnologies = await getCollection("technologies");
const technologyNameById = new Map<string, string>();
for (const technology of allTechnologies) {
	const rawId = technology.id.replace(/\/index$/, "");
	technologyNameById.set(rawId, technology.data.name);
}

function formatTechnologyLabel(value: string): string {
	const fromCollection = technologyNameById.get(value);
	if (fromCollection) return fromCollection;
	return value
		.split(/[-/]/g)
		.filter(Boolean)
		.map((segment) =>
			segment.length <= 3
				? segment.toUpperCase()
				: `${segment.charAt(0).toUpperCase()}${segment.slice(1)}`,
		)
		.join(" ");
}

const tags = (article.data.technologies ?? []).map((technologyId) => ({
	id: technologyId,
	label: formatTechnologyLabel(technologyId),
	href: `/technology/${technologyId}`,
}));

const publishDate = new Intl.DateTimeFormat("en-US", {
	month: "short",
	day: "numeric",
	year: "numeric",
}).format(article.data.publishedAt);

const readingTime = calculateReadingTime(article.body || "");

// Editorial kicker — pick a single mono label for the dispatch type.
const kickerFor = (a: typeof article): string => {
	const techs = a.data.technologies ?? [];
	if (techs.some((t) => /cve|security/i.test(t))) return "CVE";
	if (techs.some((t) => /cncf|graduation/i.test(t))) return "CNCF";
	if (/release|ship|gen|alpha|beta|GA|stable|launch/i.test(a.data.title))
		return "Release";
	if (/acquire|acquisition/i.test(a.data.title)) return "Acquisition";
	return "Dispatch";
};
const kicker = kickerFor(article);

// Dispatch number = position in the corpus, oldest = 001
const corpus = (await getCollection("news")).sort(
	(a, b) => a.data.publishedAt.valueOf() - b.data.publishedAt.valueOf(),
);
const dispatchIndex = corpus.findIndex((a) => a.id === article.id);
const dispatchNum = String(
	dispatchIndex >= 0 ? dispatchIndex + 1 : corpus.length,
).padStart(3, "0");

const categoryTrail = tags[0]?.label;
---

<Page
	title={article.data.title}
	description={article.data.description}
	isArticle={true}
	publishedAt={article.data.publishedAt}
	authors={authors}
	articleSection="News"
	articleTags={tags.map((tag) => tag.label)}
>
	<Fragment slot="extra-head">
		<NewsJsonLd article={article} authors={authors} />
		<link
			rel="alternate"
			type="application/rss+xml"
			title="Rawkode Academy - News (RSS)"
			href="/api/feeds/news.xml"
		/>
		<link
			rel="alternate"
			type="application/atom+xml"
			title="Rawkode Academy - News (Atom)"
			href="/api/feeds/news.atom"
		/>
		<link
			rel="alternate"
			type="application/feed+json"
			title="Rawkode Academy - News (JSON Feed)"
			href="/api/feeds/news.json"
		/>
	</Fragment>

	<div class="news-detail">
		<ArticleHeader
			breadcrumbs={[
				{ label: "The Wire", href: "/news" },
				{ label: kicker },
				{ label: article.data.title, current: true },
			]}
			dispatchNum={dispatchNum}
			kicker={kicker}
			categoryTrail={categoryTrail}
			title={article.data.title}
			dek={article.data.description}
			readingTime={readingTime.text}
		>
			<ArticleByline
				authors={authors}
				date={publishDate}
				readingTime={readingTime.text}
				tags={tags.map((t) => ({ label: t.label, href: t.href }))}
			/>
		</ArticleHeader>

		<div class="news-detail__body">
			<article class="prose">
				<Content />
			</article>

			<NewsletterCTA
				class="my-12 not-prose"
				audience="news"
				badge="Cloud Native news weekly"
				headline="Stay on top of the cloud-native release wire"
				subtitle="Kubernetes, AI infra, and CNCF moves, delivered when they matter."
			/>

			{tags.length > 0 && (
				<footer class="news-detail__tags">
					<MLabel>Tagged in</MLabel>
					<ul class="news-detail__taglist">
						{tags.map((tag) => (
							<li>
								<a class="news-detail__tag" href={tag.href} rel="tag">
									#{tag.label}
								</a>
							</li>
						))}
					</ul>
				</footer>
			)}
		</div>

		<RelatedNews currentStory={article} limit={3} />
	</div>
</Page>

<style>
	.news-detail {
		background: var(--editorial-paper);
		color: var(--editorial-ink);
	}

	.news-detail__body {
		max-width: 70rem;
		margin: 0 auto;
		padding: 3rem 2.5rem 4rem;
	}

	.news-detail__body :global(.prose) {
		max-width: 46rem;
	}

	.news-detail__tags {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75rem 1rem;
		margin-top: 2.5rem;
		padding-top: 1.5rem;
		border-top: 1px solid var(--editorial-hairline);
	}

	.news-detail__taglist {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.news-detail__tag {
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 0.65rem;
		font-weight: 500;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		padding: 0.2rem 0.5rem;
		color: var(--editorial-ink-soft);
		border: 1px solid var(--editorial-hairline-strong);
		border-radius: 2px;
		text-decoration: none;
		transition: color var(--duration-base) var(--ease-standard),
			border-color var(--duration-base) var(--ease-standard);
	}

	.news-detail__tag:hover {
		color: var(--editorial-ink);
		border-color: var(--editorial-ink);
	}

	@media (max-width: 720px) {
		.news-detail__body {
			padding: 2rem 1.25rem 3rem;
		}
	}
</style>
