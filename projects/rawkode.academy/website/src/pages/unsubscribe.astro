---
import { css } from "../../../styled-system/css";
import { env } from "cloudflare:workers";
import Page from "@/wrappers/page.astro";
import { createEmailId, createLearnerId } from "@/actions/newsletter";
import { createLogger } from "@/lib/logger";

export const prerender = false;

const logger = createLogger("unsubscribe");

// Get email from query parameter
const email = Astro.url.searchParams.get("email");
const success = Astro.url.searchParams.get("success");
const user = Astro.locals.user;
const pagePath = Astro.url.pathname;

let unsubscribeResult: { success: boolean; message: string } | null = null;

// Handle form submission for anonymous users
if (Astro.request.method === "POST" && !user) {
	const formData = await Astro.request.formData();
	const submittedEmail = formData
		.get("email")
		?.toString()
		?.toLowerCase()
		?.trim();

	if (submittedEmail) {
		try {
			const prefixedUserId = createEmailId(submittedEmail);
			await env.EMAIL_PREFERENCES.setPreference(
				prefixedUserId,
				{
					audience: "academy",
					channel: "newsletter",
					status: "unsubscribed",
					source: `website:newsletter:${pagePath}`,
				},
			);

			// Clear the newsletter cookie if present
			Astro.cookies.delete("newsletter:academy:updates", { path: "/" });

			// Redirect to success state
			return Astro.redirect(`/unsubscribe?success=true`);
		} catch (e) {
			logger.error("Failed to unsubscribe", e);
			unsubscribeResult = {
				success: false,
				message:
					"Failed to process your unsubscribe request. Please try again.",
			};
		}
	} else {
		unsubscribeResult = {
			success: false,
			message: "Please enter a valid email address.",
		};
	}
}

// Handle form submission for signed-in users
if (Astro.request.method === "POST" && user) {
	try {
		const prefixedUserId = createLearnerId(user.id);
		await env.EMAIL_PREFERENCES.setPreference(
			prefixedUserId,
			{
				audience: "academy",
				channel: "newsletter",
				status: "unsubscribed",
				source: `website:newsletter:${pagePath}`,
			},
		);

		// Redirect to success state
		return Astro.redirect(`/unsubscribe?success=true`);
	} catch (e) {
		logger.error("Failed to unsubscribe", e);
		unsubscribeResult = {
			success: false,
			message: "Failed to process your unsubscribe request. Please try again.",
		};
	}
}
---

<Page title="Unsubscribe - Rawkode Academy" description="Unsubscribe from the Rawkode Academy newsletter.">
	<div class={css({
	minH: '60vh',
	display: 'flex',
	flexDir: 'column',
	alignItems: 'center',
	justifyContent: 'center',
	px: '4',
	textAlign: 'center',
})}>
		{success === "true" ? (
			<>
				<div class={css({
	w: '24',
	h: '24',
	bg: 'green.100',
	rounded: 'full',
	display: 'flex',
	alignItems: 'center',
	justifyContent: 'center',
	mb: '8',
}) + " dark:bg-green-900/30"}>
					<svg xmlns="http://www.w3.org/2000/svg" class={css({
	h: '12',
	w: '12',
	color: 'green.600',
}) + " dark:text-green-400"} fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
					</svg>
				</div>
				
				<h1 class={css({
	fontSize: '4xl',
	fontWeight: 'bold',
	mb: '4',
}) + " text-primary-content"}>
					Unsubscribed Successfully
				</h1>
				
				<p class={css({
	fontSize: 'xl',
	maxW: '2xl',
	mb: '8',
}) + " text-muted"}>
					You have been unsubscribed from the Rawkode Academy newsletter. We're sorry to see you go!
				</p>
				
				<a 
					href="/"
					class={css({
	display: 'inline-flex',
	alignItems: 'center',
	justifyContent: 'center',
	px: '6',
	py: '3',
	borderWidth: '1px',
	borderColor: 'transparent',
	fontSize: 'base',
	fontWeight: 'medium',
	rounded: 'md',
	color: 'white',
	_hover: {
		bg: 'primary/90',
	},
	transition: 'colors',
}) + " bg-primary"}
				>
					Back to Home
				</a>
			</>
		) : (
			<>
				<h1 class={css({
	fontSize: '4xl',
	fontWeight: 'bold',
	mb: '4',
}) + " text-primary-content"}>
					Unsubscribe from Newsletter
				</h1>
				
				<p class={css({
	fontSize: 'xl',
	maxW: '2xl',
	mb: '8',
}) + " text-muted"}>
					{user 
						? "Click the button below to unsubscribe from the Rawkode Academy newsletter."
						: "Enter your email address to unsubscribe from the Rawkode Academy newsletter."
					}
				</p>

				{unsubscribeResult?.success === false && (
					<div class={css({
	mb: '6',
	p: '4',
	rounded: 'lg',
	bg: 'red.50',
	color: 'red.700',
	maxW: 'md',
}) + " dark:bg-red-900/20 dark:text-red-400"}>
						{unsubscribeResult.message}
					</div>
				)}

				<form method="POST" class={css({
	w: 'full',
	maxW: 'md',
	gap: '4',
})}>
					{!user && (
						<input
							type="email"
							name="email"
							value={email || ""}
							placeholder="Enter your email address"
							required
							class={css({
	w: 'full',
	py: '3',
	px: '4',
	rounded: 'lg',
	borderWidth: '1px',
	borderColor: 'neutral.200',
	bg: 'white',
	color: 'neutral.900',
	_focus: {
		ringWidth: '2',
		borderColor: 'transparent',
	},
}) + " dark:border-neutral-700 dark:bg-neutral-800 dark:text-white placeholder-neutral-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-primary"}
						/>
					)}
					
					<button
						type="submit"
						class={css({
	w: 'full',
	py: '3',
	px: '6',
	rounded: 'lg',
	bg: 'red.600',
	_hover: {
		bg: 'red.700',
	},
	color: 'white',
	fontWeight: 'medium',
	transition: 'colors',
})}
					>
						Unsubscribe
					</button>
				</form>

				<p class={css({
	mt: '8',
	fontSize: 'sm',
}) + " text-muted"}>
					Changed your mind? <a href="/" class={css({
	_hover: {
		textDecoration: 'underline',
	},
}) + " text-primary"}>Go back home</a>
				</p>
			</>
		)}
	</div>
</Page>
