---
import { env } from "cloudflare:workers";
import Page from "@/wrappers/page.astro";
import { createEmailId, createLearnerId } from "@/actions/newsletter";
import { createLogger } from "@/lib/logger";
import { css } from "../../styled-system/css";

export const prerender = false;

const logger = createLogger("unsubscribe");

// Get email from query parameter
const email = Astro.url.searchParams.get("email");
const success = Astro.url.searchParams.get("success");
const user = Astro.locals.user;
const pagePath = Astro.url.pathname;

let unsubscribeResult: { success: boolean; message: string } | null = null;

// Handle form submission for anonymous users
if (Astro.request.method === "POST" && !user) {
	const formData = await Astro.request.formData();
	const submittedEmail = formData
		.get("email")
		?.toString()
		?.toLowerCase()
		?.trim();

	if (submittedEmail) {
		try {
			const prefixedUserId = createEmailId(submittedEmail);
			await env.EMAIL_PREFERENCES.setPreference(
				prefixedUserId,
				{
					audience: "academy",
					channel: "newsletter",
					status: "unsubscribed",
					source: `website:newsletter:${pagePath}`,
				},
			);

			// Clear the newsletter cookie if present
			Astro.cookies.delete("newsletter:academy:updates", { path: "/" });

			// Redirect to success state
			return Astro.redirect(`/unsubscribe?success=true`);
		} catch (e) {
			logger.error("Failed to unsubscribe", e);
			unsubscribeResult = {
				success: false,
				message:
					"Failed to process your unsubscribe request. Please try again.",
			};
		}
	} else {
		unsubscribeResult = {
			success: false,
			message: "Please enter a valid email address.",
		};
	}
}

// Handle form submission for signed-in users
if (Astro.request.method === "POST" && user) {
	try {
		const prefixedUserId = createLearnerId(user.id);
		await env.EMAIL_PREFERENCES.setPreference(
			prefixedUserId,
			{
				audience: "academy",
				channel: "newsletter",
				status: "unsubscribed",
				source: `website:newsletter:${pagePath}`,
			},
		);

		// Redirect to success state
		return Astro.redirect(`/unsubscribe?success=true`);
	} catch (e) {
		logger.error("Failed to unsubscribe", e);
		unsubscribeResult = {
			success: false,
			message: "Failed to process your unsubscribe request. Please try again.",
		};
	}
}
---

<Page title="Unsubscribe - Rawkode Academy" description="Unsubscribe from the Rawkode Academy newsletter.">
	<div class={css({ minH: "60vh", display: "flex", flexDir: "column", alignItems: "center", justifyContent: "center", px: "4", textAlign: "center" })}>
		{success === "true" ? (
			<>
				<div class={css({ w: "24", h: "24", bg: { base: "green.100", _dark: "green.900/30" }, borderRadius: "full", display: "flex", alignItems: "center", justifyContent: "center", mb: "8" })}>
					<svg xmlns="http://www.w3.org/2000/svg" class={css({ h: "12", w: "12", color: { base: "green.600", _dark: "green.400" } })} fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
					</svg>
				</div>

				<h1 class={css({ fontSize: "4xl", fontWeight: "bold", color: { base: "gray.900", _dark: "white" }, mb: "4" })}>
					Unsubscribed Successfully
				</h1>

				<p class={css({ fontSize: "xl", color: { base: "gray.600", _dark: "gray.400" }, maxW: "2xl", mb: "8" })}>
					You have been unsubscribed from the Rawkode Academy newsletter. We're sorry to see you go!
				</p>

				<a
					href="/"
					class={css({ display: "inline-flex", alignItems: "center", justifyContent: "center", px: "6", py: "3", border: "1px solid transparent", fontSize: "base", fontWeight: "medium", borderRadius: "md", color: "white", bg: "rgb(var(--brand-primary))", transition: "colors", _hover: { opacity: "0.9" } })}
				>
					Back to Home
				</a>
			</>
		) : (
			<>
				<h1 class={css({ fontSize: "4xl", fontWeight: "bold", color: { base: "gray.900", _dark: "white" }, mb: "4" })}>
					Unsubscribe from Newsletter
				</h1>

				<p class={css({ fontSize: "xl", color: { base: "gray.600", _dark: "gray.400" }, maxW: "2xl", mb: "8" })}>
					{user
						? "Click the button below to unsubscribe from the Rawkode Academy newsletter."
						: "Enter your email address to unsubscribe from the Rawkode Academy newsletter."
					}
				</p>

				{unsubscribeResult?.success === false && (
					<div class={css({ mb: "6", p: "4", borderRadius: "lg", bg: { base: "red.50", _dark: "red.900/20" }, color: { base: "red.700", _dark: "red.400" }, maxW: "md" })}>
						{unsubscribeResult.message}
					</div>
				)}

				<form method="POST" class={css({ w: "full", maxW: "md", display: "flex", flexDir: "column", gap: "4" })}>
					{!user && (
						<input
							type="email"
							name="email"
							value={email || ""}
							placeholder="Enter your email address"
							required
							class={css({ w: "full", py: "3", px: "4", borderRadius: "lg", border: "1px solid", borderColor: { base: "neutral.200", _dark: "neutral.700" }, bg: { base: "white", _dark: "neutral.800" }, color: { base: "neutral.900", _dark: "white" }, _placeholder: { color: { base: "neutral.400", _dark: "neutral.500" } }, _focus: { outline: "none", ring: "2px solid", ringColor: "rgb(var(--brand-primary))", borderColor: "transparent" } })}
						/>
					)}

					<button
						type="submit"
						class={css({ w: "full", py: "3", px: "6", borderRadius: "lg", bg: "red.600", color: "white", fontWeight: "medium", transition: "colors", _hover: { bg: "red.700" } })}
					>
						Unsubscribe
					</button>
				</form>

				<p class={css({ mt: "8", fontSize: "sm", color: { base: "gray.600", _dark: "gray.400" } })}>
					Changed your mind? <a href="/" class={css({ color: "rgb(var(--brand-primary))", _hover: { textDecoration: "underline" } })}>Go back home</a>
				</p>
			</>
		)}
	</div>
</Page>
