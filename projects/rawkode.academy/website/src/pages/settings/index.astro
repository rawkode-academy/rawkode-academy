---
import { css } from "../../../../styled-system/css";
import { env } from "cloudflare:workers";
import Page from "@/wrappers/page.astro";
import EmailPreferences from "@/components/settings/EmailPreferences.vue";
import TestEmailButton from "@/components/settings/TestEmailButton.vue";
import Avatar from "vue-boring-avatars";
import { createLearnerId } from "@/actions/newsletter";

export const prerender = false;

const user = Astro.locals.user;

if (!user) {
	return Astro.redirect(`/sign-in?returnTo=${encodeURIComponent("/settings")}`);
}

const prefixedUserId = createLearnerId(user.id);

interface EmailPreference {
	channel: string;
	audience: string;
}

let academyNewsletter = false;
let matrixNewsletter = false;
let kubernetesReleaseUpdates = false;
let marketingEmails = false;
let serviceEmails = false;
let technologySubscriptions: string[] = [];

try {
	const allPrefs: EmailPreference[] =
		await env.EMAIL_PREFERENCES.getPreferences(
			prefixedUserId,
		);

	for (const pref of allPrefs) {
		if (pref.channel === "newsletter" && pref.audience === "academy") {
			academyNewsletter = true;
		} else if (pref.channel === "newsletter" && pref.audience === "matrix") {
			matrixNewsletter = true;
		} else if (pref.channel === "newsletter" && pref.audience === "kubernetes-release-updates") {
			kubernetesReleaseUpdates = true;
		} else if (pref.channel === "marketing" && pref.audience === "academy") {
			marketingEmails = true;
		} else if (pref.channel === "service" && pref.audience === "academy") {
			serviceEmails = true;
		} else if (
			pref.channel === "newsletter" &&
			pref.audience.startsWith("technology:")
		) {
			technologySubscriptions.push(pref.audience.replace("technology:", ""));
		}
	}
} catch (e) {
	console.error("Failed to fetch email preferences", e);
}
---

<Page title="Settings - Rawkode Academy" description="Manage your account settings and email preferences.">
	<div class={css({
	maxW: '3xl',
	mx: 'auto',
	py: '8',
	px: '4',
})}>
		<h1 class={css({
	fontSize: '3xl',
	fontWeight: 'bold',
	color: 'neutral.900',
	mb: '8',
}) + " dark:text-white"}>
			Settings
		</h1>

		<div class={css({
	gap: '8',
})}>
			<!-- Profile Section -->
			<section class={css({
	rounded: '2xl',
	bg: 'white',
	borderWidth: '1px',
	borderColor: 'neutral.200',
	overflow: 'hidden',
}) + " dark:bg-neutral-900 dark:border-neutral-800"}>
				<div class={css({
	px: '6',
	py: '4',
	borderBottomWidth: '1px',
	borderColor: 'neutral.200',
}) + " dark:border-neutral-800"}>
					<h2 class={css({
	fontSize: 'lg',
	fontWeight: 'semibold',
	color: 'neutral.900',
}) + " dark:text-white"}>
						Profile
					</h2>
				</div>
				<div class={css({
	p: '6',
})}>
					<div class={css({
	display: 'flex',
	alignItems: 'center',
	gap: '4',
})}>
						{user.image ? (
							<img 
								src={user.image} 
								alt={`Profile picture for ${user.name || 'user'}`}
								class={css({
	w: '16',
	h: '16',
	rounded: 'full',
})}
								loading="lazy"
							/>
						) : (
							<Avatar client:load name={user.name || ""} variant="pixel" class={css({
	w: '16',
	h: '16',
	rounded: 'full',
})} />
						)}
						<div>
							<p class={css({
	fontSize: 'lg',
	fontWeight: 'medium',
	color: 'neutral.900',
}) + " dark:text-white"}>
								{user.name}
							</p>
							<p class={css({
	fontSize: 'sm',
	color: 'neutral.500',
}) + " dark:text-neutral-400"}>
								{user.email}
							</p>
						</div>
					</div>
				</div>
			</section>

			<!-- Email Preferences Section -->
				<section class={css({
	rounded: '2xl',
	bg: 'white',
	borderWidth: '1px',
	borderColor: 'neutral.200',
	overflow: 'hidden',
}) + " dark:bg-neutral-900 dark:border-neutral-800"}>
					<div class={css({
	px: '6',
	py: '4',
	borderBottomWidth: '1px',
	borderColor: 'neutral.200',
}) + " dark:border-neutral-800"}>
						<h2 class={css({
	fontSize: 'lg',
	fontWeight: 'semibold',
	color: 'neutral.900',
}) + " dark:text-white"}>
							Email Preferences
						</h2>
					<p class={css({
	fontSize: 'sm',
	color: 'neutral.500',
	mt: '1',
}) + " dark:text-neutral-400"}>
						Manage what emails you receive from Rawkode Academy.
					</p>
				</div>
					<div class={css({
	p: '6',
})}>
						<EmailPreferences
							client:load
							academyNewsletter={academyNewsletter}
							matrixNewsletter={matrixNewsletter}
							kubernetesReleaseUpdates={kubernetesReleaseUpdates}
							marketingEmails={marketingEmails}
							serviceEmails={serviceEmails}
							technologySubscriptions={technologySubscriptions}
						/>
					</div>
				</section>

				<!-- Email Tools -->
				<section class={css({
	rounded: '2xl',
	bg: 'white',
	borderWidth: '1px',
	borderColor: 'neutral.200',
	overflow: 'hidden',
}) + " dark:bg-neutral-900 dark:border-neutral-800"}>
					<div class={css({
	px: '6',
	py: '4',
	borderBottomWidth: '1px',
	borderColor: 'neutral.200',
}) + " dark:border-neutral-800"}>
						<h2 class={css({
	fontSize: 'lg',
	fontWeight: 'semibold',
	color: 'neutral.900',
}) + " dark:text-white"}>
							Email Tools
						</h2>
						<p class={css({
	fontSize: 'sm',
	color: 'neutral.500',
	mt: '1',
}) + " dark:text-neutral-400"}>
							Send yourself a quick test message to confirm email delivery works.
						</p>
					</div>
					<div class={css({
	p: '6',
})}>
						<TestEmailButton client:load />
					</div>
				</section>
			</div>
		</div>
	</Page>
