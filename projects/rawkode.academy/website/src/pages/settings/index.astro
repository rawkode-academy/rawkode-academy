---
import { env } from "cloudflare:workers";
import Page from "@/wrappers/page.astro";
import EmailPreferences from "@/components/settings/EmailPreferences.vue";
import TestEmailButton from "@/components/settings/TestEmailButton.vue";
import Avatar from "vue-boring-avatars";
import { createLearnerId } from "@/actions/newsletter";
import { css } from "../../../styled-system/css";

export const prerender = false;

const user = Astro.locals.user;
if (!user) return Astro.redirect(`/sign-in?returnTo=${encodeURIComponent("/settings")}`);

const prefixedUserId = createLearnerId(user.id);

interface EmailPreference {
	channel: string;
	audience: string;
}

let academyNewsletter = false;
let matrixNewsletter = false;
let kubernetesReleaseUpdates = false;
let marketingEmails = false;
let serviceEmails = false;
const technologySubscriptions: string[] = [];

try {
	const allPrefs: EmailPreference[] = await env.EMAIL_PREFERENCES.getPreferences(prefixedUserId);
	for (const pref of allPrefs) {
		if (pref.channel === "newsletter" && pref.audience === "academy") academyNewsletter = true;
		else if (pref.channel === "newsletter" && pref.audience === "matrix") matrixNewsletter = true;
		else if (pref.channel === "newsletter" && pref.audience === "kubernetes-release-updates") kubernetesReleaseUpdates = true;
		else if (pref.channel === "marketing" && pref.audience === "academy") marketingEmails = true;
		else if (pref.channel === "service" && pref.audience === "academy") serviceEmails = true;
		else if (pref.channel === "newsletter" && pref.audience.startsWith("technology:")) technologySubscriptions.push(pref.audience.replace("technology:", ""));
	}
} catch (e) {
	console.error("Failed to fetch email preferences", e);
}

const shell = css({ maxWidth: "56rem", mx: "auto", px: { base: "4", md: "6" }, py: "12" });

const pageTitle = css({
	fontFamily: "display",
	fontSize: { base: "3xl", md: "4xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	color: "fg.primary",
	mb: "10",
});

const section = css({
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	overflow: "hidden",
	mb: "6",
});

const sectionHeader = css({
	px: "6",
	py: "4",
	borderBottomWidth: "1px",
	borderBottomColor: "border.muted",
});

const sectionTitle = css({
	fontFamily: "display",
	fontSize: "lg",
	fontWeight: "bold",
	color: "fg.primary",
});

const sectionSubtitle = css({ fontSize: "sm", color: "fg.muted", mt: "1" });

const sectionBody = css({ p: "6" });

const profileRow = css({ display: "flex", alignItems: "center", gap: "4" });

const profileAvatar = css({
	width: "16",
	height: "16",
	borderRadius: "full",
	objectFit: "cover",
	overflow: "hidden",
});

const profileName = css({ fontSize: "lg", fontWeight: "semibold", color: "fg.primary" });
const profileEmail = css({ fontSize: "sm", color: "fg.muted" });
---

<Page title="Settings - Rawkode Academy" description="Manage your account settings and email preferences.">
	<div class={shell}>
		<h1 class={pageTitle}>Settings</h1>

		<section class={section}>
			<div class={sectionHeader}>
				<h2 class={sectionTitle}>Profile</h2>
			</div>
			<div class={sectionBody}>
				<div class={profileRow}>
					{user.image ? (
						<img src={user.image} alt={`Profile picture for ${user.name || "user"}`} class={profileAvatar} loading="lazy" />
					) : (
						<div class={profileAvatar}>
							<Avatar client:load name={user.name || ""} variant="pixel" size={64} />
						</div>
					)}
					<div>
						<p class={profileName}>{user.name}</p>
						<p class={profileEmail}>{user.email}</p>
					</div>
				</div>
			</div>
		</section>

		<section class={section}>
			<div class={sectionHeader}>
				<h2 class={sectionTitle}>Email Preferences</h2>
				<p class={sectionSubtitle}>Manage what emails you receive from Rawkode Academy.</p>
			</div>
			<div class={sectionBody}>
				<EmailPreferences
					client:load
					academyNewsletter={academyNewsletter}
					matrixNewsletter={matrixNewsletter}
					kubernetesReleaseUpdates={kubernetesReleaseUpdates}
					marketingEmails={marketingEmails}
					serviceEmails={serviceEmails}
					technologySubscriptions={technologySubscriptions}
				/>
			</div>
		</section>

		<section class={section}>
			<div class={sectionHeader}>
				<h2 class={sectionTitle}>Email Tools</h2>
				<p class={sectionSubtitle}>Send yourself a quick test message to confirm delivery works.</p>
			</div>
			<div class={sectionBody}>
				<TestEmailButton client:load />
			</div>
		</section>
	</div>
</Page>
