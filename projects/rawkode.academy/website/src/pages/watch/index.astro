---
export const prerender = false;

import { getPublishedVideos } from "@/lib/content";
import VideoItemListJsonLd from "@/components/html/video-itemlist-jsonld.astro";
import VideoMetadata from "@/components/html/video-metadata.astro";
import PageHero from "@/components/layout/PageHero.astro";
import Page from "@/wrappers/page.astro";
import { css } from "../../../styled-system/css";

Astro.response.headers.set(
	"Cache-Control",
	"public, max-age=300, s-maxage=300, stale-while-revalidate=86400",
);

const allVideos = await getPublishedVideos();
const featured = allVideos[0];
const rest = allVideos.slice(1, 18);

const pageTitle = "Cloud Native Videos | Rawkode Academy";
const pageDescription = "Watch live sessions, screencasts, and deep-dives on cloud native engineering.";

const formatDate = (date: Date) =>
	new Intl.DateTimeFormat("en-US", { month: "short", day: "numeric", year: "numeric" }).format(date);

const fmtDuration = (s?: number | null) => {
	if (!s || s <= 0) return "";
	const h = Math.floor(s / 3600);
	const m = Math.floor((s % 3600) / 60);
	const r = s % 60;
	return h > 0 ? `${h}:${String(m).padStart(2, "0")}:${String(r).padStart(2, "0")}` : `${m}:${String(r).padStart(2, "0")}`;
};

const shell = css({ maxWidth: "80rem", mx: "auto", px: { base: "4", md: "6" }, py: "12" });

const featuredCard = css({
	position: "relative",
	display: "grid",
	gridTemplateColumns: { base: "1fr", md: "1.4fr 1fr" },
	gap: { base: "6", md: "10" },
	alignItems: "stretch",
	p: { base: "5", md: "5" },
	borderRadius: "3xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textDecoration: "none",
	color: "fg.primary",
	mb: "14",
	overflow: "hidden",
	transition: "transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease",
	_hover: { transform: "translateY(-2px)", boxShadow: "xl", borderColor: "border.default" },
});

const thumbHero = css({
	position: "relative",
	aspectRatio: "16 / 9",
	overflow: "hidden",
	borderRadius: "2xl",
	bg: "bg.sunken",
	"& img": { width: "full", height: "full", objectFit: "cover", transition: "transform 400ms ease" },
	"a:hover &": { "& img": { transform: "scale(1.04)" } },
});

const playOverlay = css({
	position: "absolute",
	inset: "0",
	display: "flex",
	alignItems: "center",
	justifyContent: "center",
	pointerEvents: "none",
	"& svg": {
		w: "16",
		h: "16",
		color: "white",
		filter: "drop-shadow(0 4px 12px rgba(0,0,0,0.5))",
		transition: "transform 200ms ease",
	},
	"a:hover &": { "& svg": { transform: "scale(1.1)" } },
});

const featuredBody = css({
	display: "flex",
	flexDirection: "column",
	justifyContent: "center",
	p: { base: "2", md: "6" },
});

const featuredBadgeRow = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	mb: "4",
	flexWrap: "wrap",
});

const featuredFlag = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "1.5",
	px: "3",
	py: "1",
	borderRadius: "full",
	fontSize: "xs",
	fontWeight: "bold",
	letterSpacing: "wider",
	textTransform: "uppercase",
	color: "fg.on-brand",
	backgroundImage: "linear-gradient(135deg, token(colors.brand.500), token(colors.cyan.500))",
});

const featuredTitle = css({
	fontFamily: "display",
	fontSize: { base: "3xl", md: "4xl", lg: "5xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	lineHeight: "1.05",
	color: "fg.primary",
	textWrap: "balance",
	transition: "color 150ms ease",
	"a:hover &": { color: "fg.brand" },
});

const featuredDesc = css({ mt: "5", fontSize: { base: "md", md: "lg" }, lineHeight: "1.7", color: "fg.secondary", maxWidth: "40rem" });

const featuredFooter = css({
	mt: "6",
	display: "flex",
	flexWrap: "wrap",
	gap: "3",
	fontSize: "sm",
	color: "fg.muted",
	alignItems: "center",
});

const sectionHead = css({
	display: "flex",
	alignItems: "baseline",
	justifyContent: "space-between",
	gap: "4",
	mb: "8",
	flexWrap: "wrap",
});

const sectionTitle = css({
	fontFamily: "display",
	fontSize: { base: "2xl", md: "3xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	color: "fg.primary",
});

const sectionCount = css({ fontSize: "sm", color: "fg.muted", fontWeight: "medium" });

const feedLinks = css({ display: "flex", gap: "2", flexWrap: "wrap" });

const feedLink = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "1.5",
	px: "3",
	py: "1.5",
	borderRadius: "full",
	fontSize: "xs",
	fontWeight: "semibold",
	color: "fg.muted",
	borderWidth: "1px",
	borderColor: "border.muted",
	textDecoration: "none",
	transition: "all 150ms ease",
	_hover: { color: "fg.brand", borderColor: "border.default", bg: "bg.brand-subtle" },
});

const grid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", sm: "repeat(2, minmax(0, 1fr))", lg: "repeat(3, minmax(0, 1fr))" },
	gap: "6",
});

const card = css({
	display: "flex",
	flexDirection: "column",
	overflow: "hidden",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textDecoration: "none",
	color: "fg.primary",
	transition: "transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease",
	_hover: { transform: "translateY(-2px)", boxShadow: "lg", borderColor: "border.default" },
});

const cardThumb = css({
	position: "relative",
	aspectRatio: "16 / 9",
	overflow: "hidden",
	bg: "bg.sunken",
	"& img": { width: "full", height: "full", objectFit: "cover" },
});

const durationBadge = css({
	position: "absolute",
	right: "2",
	bottom: "2",
	px: "2",
	py: "0.5",
	borderRadius: "md",
	fontSize: "xs",
	fontWeight: "semibold",
	color: "white",
	bg: "rgba(0, 0, 0, 0.75)",
	backdropFilter: "blur(4px)",
});

const cardPlay = css({
	position: "absolute",
	inset: "0",
	display: "flex",
	alignItems: "center",
	justifyContent: "center",
	opacity: 0,
	bg: "rgba(0,0,0,0.35)",
	transition: "opacity 200ms ease",
	"a:hover &": { opacity: 1 },
	"& svg": { w: "12", h: "12", color: "white", filter: "drop-shadow(0 4px 12px rgba(0,0,0,0.5))" },
});

const cardBody = css({ p: "5", display: "flex", flexDirection: "column", gap: "2", flex: "1" });
const cardMeta = css({
	fontSize: "xs",
	fontWeight: "semibold",
	letterSpacing: "wider",
	textTransform: "uppercase",
	color: "fg.muted",
});
const cardTitle = css({
	fontSize: "lg",
	fontWeight: "semibold",
	lineHeight: "tight",
	color: "fg.primary",
	transition: "color 150ms ease",
	"a:hover &": { color: "fg.brand" },
});
const cardDesc = css({
	fontSize: "sm",
	color: "fg.secondary",
	lineHeight: "1.6",
	display: "-webkit-box",
	WebkitLineClamp: "2",
	overflow: "hidden",
});
---

<Page title={pageTitle} description={pageDescription}>
	<Fragment slot="extra-head">
		<VideoItemListJsonLd
			videos={allVideos.map((v) => ({
				id: v.data.id,
				slug: v.data.slug,
				title: v.data.title,
				description: v.data.description,
				publishedAt: v.data.publishedAt instanceof Date ? v.data.publishedAt : new Date(v.data.publishedAt),
				...(typeof v.data.duration === "number" ? { duration: v.data.duration } : {}),
			}))}
			listUrl={new URL("/watch", Astro.site ?? Astro.url).href}
			listName="Cloud Native Videos"
		/>
		<VideoMetadata title={pageTitle} description={pageDescription} isVideoList={true} />
	</Fragment>

	<PageHero eyebrow="Videos" title="Watch & Learn" subtitle="Live sessions, screencasts, and deep dives from the sharp end of cloud native engineering." />

	<div class={shell}>
		{featured && (
			<a href={`/watch/${featured.data.slug}`} class={featuredCard}>
				<div class={thumbHero}>
					<img src={`https://content.rawkode.academy/videos/${featured.data.id}/thumbnail.jpg`} alt={featured.data.title} loading="eager" />
					<div class={playOverlay} aria-hidden="true">
						<svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="11" fill="rgba(0,0,0,0.55)"/><path d="M10 8l6 4-6 4V8z" fill="white"/></svg>
					</div>
					{fmtDuration(typeof featured.data.duration === "number" ? featured.data.duration : undefined) && (
						<span class={durationBadge}>{fmtDuration(typeof featured.data.duration === "number" ? featured.data.duration : undefined)}</span>
					)}
				</div>
				<div class={featuredBody}>
					<div class={featuredBadgeRow}>
						<span class={featuredFlag}>
							<svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M10 8l6 4-6 4V8z"/></svg>
							Latest video
						</span>
					</div>
					<h2 class={featuredTitle}>{featured.data.title}</h2>
					<p class={featuredDesc}>{featured.data.subtitle || featured.data.description}</p>
					<div class={featuredFooter}>
						<span>{formatDate(featured.data.publishedAt as Date)}</span>
						{fmtDuration(typeof featured.data.duration === "number" ? featured.data.duration : undefined) && (
							<>
								<span style="color: var(--colors-border-default);">·</span>
								<span>{fmtDuration(typeof featured.data.duration === "number" ? featured.data.duration : undefined)}</span>
							</>
						)}
					</div>
				</div>
			</a>
		)}

		<div class={sectionHead}>
			<div style="display: flex; align-items: baseline; gap: 1rem; flex-wrap: wrap;">
				<h2 class={sectionTitle}>Latest videos</h2>
				<span class={sectionCount}>{allVideos.length} video{allVideos.length === 1 ? "" : "s"}</span>
			</div>
			<div class={feedLinks}>
				<a href="/api/feeds/videos.xml" class={feedLink}>
					<svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4 11a9 9 0 019 9h-3a6 6 0 00-6-6v-3zm0-7a16 16 0 0116 16h-3A13 13 0 004 7V4zm2 13a2 2 0 110 4 2 2 0 010-4z"/></svg>
					RSS
				</a>
				<a href="/shows" class={feedLink}>Browse by show</a>
			</div>
		</div>

		<div class={grid}>
			{rest.map((video) => (
				<a href={`/watch/${video.data.slug}`} class={card}>
					<div class={cardThumb}>
						<img src={`https://content.rawkode.academy/videos/${video.data.id}/thumbnail.jpg`} alt={video.data.title} loading="lazy" />
						<div class={cardPlay} aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="11" fill="rgba(0,0,0,0.6)"/><path d="M10 8l6 4-6 4V8z" fill="white"/></svg>
						</div>
						{fmtDuration(typeof video.data.duration === "number" ? video.data.duration : undefined) && (
							<span class={durationBadge}>{fmtDuration(typeof video.data.duration === "number" ? video.data.duration : undefined)}</span>
						)}
					</div>
					<div class={cardBody}>
						<div class={cardMeta}>{formatDate(video.data.publishedAt as Date)}</div>
						<h3 class={cardTitle}>{video.data.title}</h3>
						<p class={cardDesc}>{video.data.subtitle || video.data.description}</p>
					</div>
				</a>
			))}
		</div>
	</div>
</Page>
