---
export const prerender = false;

import { getPublishedVideos, getUpcomingVideos } from "@/lib/content";
import { getCollection } from "astro:content";
import VideoItemListJsonLd from "@/components/html/video-itemlist-jsonld.astro";
import VideoMetadata from "@/components/html/video-metadata.astro";
import Page from "@/wrappers/page.astro";
import { getVideoThumbnailUrl } from "@/lib/video-thumbnail";
import {
	resolveTechnologyHorizontalLogoUrl,
	resolveTechnologyIconUrl,
} from "@/utils/resolve-technology-icon";

import VideoMasthead from "@/components/video/VideoMasthead.astro";
import VideoHero from "@/components/video/VideoHero.astro";
import VideoStill from "@/components/video/VideoStill.astro";
import SeriesFilter from "@/components/video/SeriesFilter.astro";
import VideoGridItem from "@/components/video/VideoGridItem.astro";
import MLabel from "@/components/ui/MLabel.vue";

const user = Astro.locals.user;

// Cache headers
if (user) {
	Astro.response.headers.set("Cache-Control", "private, no-store");
} else {
	Astro.response.headers.set(
		"Cache-Control",
		"public, max-age=300, s-maxage=3600, stale-while-revalidate=86400",
	);
	Astro.response.headers.set("CDN-Cache-Control", "public, max-age=3600");
	Astro.response.headers.set(
		"Cache-Tag",
		"videos-page, videos-list, videos-latest",
	);
}

Astro.response.headers.set("X-Build-Time", new Date().toISOString());

const page = Math.max(
	1,
	parseInt(Astro.url.searchParams.get("page") || "1", 10) || 1,
);
const videosPerPage = 15;

const allVideos = (await getPublishedVideos()).map((v) => v.data);
const upcomingVideos = (await getUpcomingVideos()).map((v) => v.data);
const visibleUpcomingVideos = upcomingVideos.slice(0, 6);
const technologyEntries = await getCollection("technologies");
const technologyById = new Map(
	technologyEntries.map((technology) => [technology.id, technology]),
);

const totalVideoCount = allVideos.length;
const seriesKeyFor = (video: (typeof allVideos)[number]) =>
	(video.category || video.type || "Library").toString();

// Series counts are derived from `category` when present, falling back to `type`.
const seriesCounts = new Map<string, number>();
for (const v of allVideos) {
	const key = seriesKeyFor(v);
	seriesCounts.set(key, (seriesCounts.get(key) ?? 0) + 1);
}

const requestedSeries = Astro.url.searchParams.get("series") || undefined;
const selectedSeries =
	requestedSeries && seriesCounts.has(requestedSeries) ? requestedSeries : undefined;
const visibleVideos = selectedSeries
	? allVideos.filter((video) => seriesKeyFor(video) === selectedSeries)
	: allVideos;
const visibleCount = visibleVideos.length;

// Pagination. Page one promotes the newest visible video, then starts the grid after it.
const featuredVideo = page === 1 ? (visibleVideos[0] ?? null) : null;
const start = page === 1 ? 1 : 1 + (page - 1) * videosPerPage;
const end = start + videosPerPage;
const feedVideos = visibleVideos.slice(start, end);
const hasNextPage = end < visibleVideos.length;

const topSeries = Array.from(seriesCounts.entries())
	.sort((a, b) => b[1] - a[1])
	.slice(0, 7);

const navSeries =
	selectedSeries && !topSeries.some(([label]) => label === selectedSeries)
		? [
				...topSeries,
				[selectedSeries, seriesCounts.get(selectedSeries) ?? 0] as [
					string,
					number,
				],
			]
		: topSeries;

const watchPathFor = (targetPage = 1) => {
	const params = new URLSearchParams();
	if (selectedSeries) params.set("series", selectedSeries);
	if (targetPage > 1) params.set("page", String(targetPage));
	const query = params.toString();
	return `/watch${query ? `?${query}` : ""}`;
};

const seriesItems = [
	{ label: "All", count: totalVideoCount, href: "/watch" },
	...navSeries.map(([label, count]) => ({
		label: label.replace(/[-_]/g, " ").replace(/\b\w/g, (c) => c.toUpperCase()),
		count,
		href: `/watch?series=${encodeURIComponent(label)}`,
	})),
];

const activeSeriesIndex = selectedSeries
	? Math.max(0, 1 + navSeries.findIndex(([label]) => label === selectedSeries))
	: 0;

// Helpers
const formatDuration = (seconds?: number | null) => {
	if (typeof seconds !== "number" || seconds <= 0 || Number.isNaN(seconds)) {
		return "--:--";
	}
	const h = Math.floor(seconds / 3600);
	const m = Math.floor((seconds % 3600) / 60);
	const s = seconds % 60;
	return h > 0
		? `${h}:${String(m).padStart(2, "0")}:${String(s).padStart(2, "0")}`
		: `${m}:${String(s).padStart(2, "0")}`;
};

const dateFormatter = new Intl.DateTimeFormat("en-US", {
	month: "short",
	day: "2-digit",
});

const upcomingDateFormatter = new Intl.DateTimeFormat("en-GB", {
	weekday: "short",
	month: "short",
	day: "numeric",
	hour: "2-digit",
	minute: "2-digit",
	timeZone: "Europe/London",
	timeZoneName: "short",
});

const formatUpcomingDate = (date: Date | string) =>
	upcomingDateFormatter.format(date instanceof Date ? date : new Date(date));

const formatLabel = (value?: string | null) =>
	value
		? value.replace(/[-_]/g, " ").replace(/\b\w/g, (c) => c.toUpperCase())
		: undefined;

const dispatchNumFor = (idx: number) =>
	String(visibleCount - idx).padStart(3, "0");

const featuredEpisodeNum = featuredVideo ? dispatchNumFor(0) : undefined;
const featuredSeries = featuredVideo
	? formatLabel(featuredVideo.category || featuredVideo.type)
	: undefined;

const technologyLogosFor = (video: (typeof upcomingVideos)[number]) =>
	(video.technologies ?? [])
		.map((technologyRef) => {
			const technology = technologyById.get(String(technologyRef));
			if (!technology) return undefined;

			const horizontalSrc = resolveTechnologyHorizontalLogoUrl(
				technology.id,
				technology.data.logos,
			);
			if (horizontalSrc) {
				return {
					src: horizontalSrc,
					name: technology.data.name,
					kind: "horizontal" as const,
				};
			}

			const iconSrc = resolveTechnologyIconUrl(
				technology.id,
				technology.data.logos,
			);
			return iconSrc
				? {
						src: iconSrc,
						name: technology.data.name,
						kind: "icon" as const,
					}
				: undefined;
		})
		.filter(
			(
				logo,
			): logo is { src: string; name: string; kind: "horizontal" | "icon" } =>
				Boolean(logo),
		)
		.slice(0, 1);
---

<Page
	title="Cloud Native & Kubernetes Videos"
	description="Watch hands-on cloud native and Kubernetes tutorials, deep dives, and live builds for engineers shipping production systems."
	pageType="CollectionPage"
>
	{page > 1 && (
		<Fragment slot="extra-head">
			<meta name="robots" content="noindex,follow" />
		</Fragment>
	)}
	{page > 1 && (
		<link
			slot="extra-head"
			rel="prev"
			href={watchPathFor(page - 1)}
		/>
	)}
	{hasNextPage && (
		<link slot="extra-head" rel="next" href={watchPathFor(page + 1)} />
	)}
	<VideoMetadata
		slot="extra-head"
		title="Rawkode Academy Videos"
		description="Explore our collection of educational videos about cloud native technologies, development practices, and more."
		isVideoList={true}
	/>
	<link slot="extra-head" rel="alternate" type="application/rss+xml" title="Rawkode Academy - Videos (RSS)" href="/api/feeds/videos.xml" />
	<link slot="extra-head" rel="alternate" type="application/atom+xml" title="Rawkode Academy - Videos (Atom)" href="/api/feeds/videos.atom" />
	<link slot="extra-head" rel="alternate" type="application/feed+json" title="Rawkode Academy - Videos (JSON Feed)" href="/api/feeds/videos.json" />
	{page === 1 && (
		<VideoItemListJsonLd
			slot="extra-head"
			videos={allVideos.map((v) => ({
				id: v.id,
				slug: v.slug,
				title: v.title,
				description: v.description,
				publishedAt:
					v.publishedAt instanceof Date
						? v.publishedAt
						: new Date(v.publishedAt),
				...(typeof v.duration === "number" ? { duration: v.duration } : {}),
			}))}
			listUrl={new URL("/watch", Astro.site ?? Astro.url).href}
			listName="Rawkode Academy Videos"
		/>
	)}

	<div class="watch-page">
		<VideoMasthead
			title="Latest Videos"
			dek="Tutorials, talks, and live builds."
		/>

		{visibleUpcomingVideos.length > 0 && (
			<section class="watch-upcoming" aria-labelledby="watch-upcoming-title">
				<div class="watch-upcoming__header">
					<MLabel tone="amber">Upcoming Streams</MLabel>
					<h2 id="watch-upcoming-title">Next live sessions</h2>
				</div>

				<div class="watch-upcoming__list">
					{visibleUpcomingVideos.map((v) => (
						<a class="watch-upcoming__item" href={`/watch/${v.slug}`}>
							<div class="watch-upcoming__still">
								<VideoStill
									title={v.title}
									series="Upcoming stream"
									thumbnailUrl={getVideoThumbnailUrl(v.id)}
									technologyLogos={technologyLogosFor(v)}
									accent="amber"
								/>
							</div>
							<div class="watch-upcoming__copy">
								<MLabel tone="amber">
									{formatUpcomingDate(v.publishedAt)}
								</MLabel>
								<h3>{v.title}</h3>
								<p>{v.description}</p>
							</div>
						</a>
					))}
				</div>
			</section>
		)}

		{featuredVideo && (
			<VideoHero
				href={`/watch/${featuredVideo.slug}`}
				episodeNum={featuredEpisodeNum}
				title={featuredVideo.title}
				series={featuredSeries}
				duration={formatDuration(
					typeof featuredVideo.duration === "number"
						? featuredVideo.duration
						: undefined,
				)}
				thumbnailUrl={getVideoThumbnailUrl(featuredVideo.id)}
				description={featuredVideo.description}
				date={dateFormatter.format(
					featuredVideo.publishedAt instanceof Date
						? featuredVideo.publishedAt
						: new Date(featuredVideo.publishedAt),
				)}
				primaryCtaLabel="Watch session →"
			/>
		)}

		<SeriesFilter items={seriesItems} activeIndex={activeSeriesIndex} />

		<div class="watch-grid">
			{feedVideos.map((v, idx) => (
				<VideoGridItem
					href={`/watch/${v.slug}`}
					episodeNum={dispatchNumFor(start + idx)}
					title={v.title}
					series={formatLabel(v.category || v.type) || undefined}
					duration={formatDuration(
						typeof v.duration === "number" ? v.duration : undefined,
					)}
					thumbnailUrl={getVideoThumbnailUrl(v.id)}
					date={dateFormatter.format(
						v.publishedAt instanceof Date
							? v.publishedAt
							: new Date(v.publishedAt),
					)}
				/>
			))}
		</div>

		<footer class="watch-footer">
			<MLabel>
				<a class="watch-footer__link" href="/api/feeds/videos.xml">RSS</a> ·
				<a class="watch-footer__link" href="/api/feeds/videos.json">JSON Feed</a> ·
				<a class="watch-footer__link" href="/watch">All videos</a>
			</MLabel>
			<div class="watch-footer__pager">
				{page > 1 && (
					<a class="watch-footer__pager-btn" href={watchPathFor(page - 1)}>
						<MLabel tone="ink">← Previous</MLabel>
					</a>
				)}
				<MLabel>Page {page}</MLabel>
				{hasNextPage && (
					<a class="watch-footer__pager-btn" href={watchPathFor(page + 1)}>
						<MLabel tone="ink">Next →</MLabel>
					</a>
				)}
			</div>
		</footer>
	</div>
</Page>

<style>
	.watch-page {
		background: var(--editorial-paper);
		color: var(--editorial-ink);
	}

	.watch-upcoming {
		border-bottom: 1px solid var(--editorial-hairline);
		background: var(--editorial-paper-deep);
		padding: 1.25rem 2.5rem 1.5rem;
	}

	.watch-upcoming__header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		margin-bottom: 1rem;
	}

	.watch-upcoming__header h2 {
		margin: 0;
		font-family: var(--font-instrument-serif), serif;
		font-size: 1.75rem;
		font-style: italic;
		font-weight: 400;
		line-height: 1;
		letter-spacing: 0;
		color: var(--editorial-ink);
	}

	.watch-upcoming__list {
		display: grid;
		gap: 0.75rem;
	}

	.watch-upcoming__item {
		display: grid;
		grid-template-columns: 10rem minmax(0, 1fr);
		gap: 1rem;
		align-items: center;
		padding-block: 0.75rem;
		border-top: 1px solid var(--editorial-hairline);
		color: inherit;
		text-decoration: none;
	}

	.watch-upcoming__item:hover h3 {
		color: var(--editorial-spruce);
	}

	.watch-upcoming__still {
		width: 10rem;
	}

	.watch-upcoming__copy {
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
	}

	.watch-upcoming__copy h3 {
		margin: 0;
		font-family: var(--font-instrument-serif), serif;
		font-size: 1.25rem;
		font-style: italic;
		font-weight: 400;
		line-height: 1.1;
		letter-spacing: 0;
		color: var(--editorial-ink);
	}

	.watch-upcoming__copy p {
		margin: 0;
		max-width: 56rem;
		color: var(--editorial-ink-soft);
		font-family: var(--font-inter-tight), sans-serif;
		font-size: 0.95rem;
		line-height: 1.4;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.watch-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem 1.75rem;
		padding: 2rem 2.5rem 3rem;
	}

	.watch-footer {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1.5rem;
		padding: 1.5rem var(--space-section-pad-x);
		border-top: 1px solid var(--editorial-ink);
		background: var(--editorial-paper-deep);
	}

	.watch-footer__link {
		color: inherit;
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 2px;
		text-decoration-color: var(--editorial-hairline-strong);
	}
	.watch-footer__link:hover { text-decoration-color: currentColor; }

	.watch-footer__pager {
		display: flex;
		gap: 1rem;
		align-items: center;
	}

	.watch-footer__pager-btn {
		text-decoration: none;
	}

	@media (max-width: 960px) {
		.watch-grid {
			grid-template-columns: repeat(2, 1fr);
			padding-inline: 1.25rem;
		}

		.watch-grid {
			padding-top: 1.5rem;
			padding-bottom: 2rem;
		}

		.watch-upcoming__header {
			align-items: flex-start;
			flex-direction: column;
			gap: 0.5rem;
		}

		.watch-upcoming {
			padding-inline: 1.25rem;
		}
	}
	@media (max-width: 640px) {
		.watch-grid { grid-template-columns: 1fr; }
		.watch-upcoming__item {
			grid-template-columns: 7.5rem minmax(0, 1fr);
			gap: 0.75rem;
		}
		.watch-upcoming__still {
			width: 7.5rem;
		}
		.watch-upcoming__copy h3 {
			font-size: 1.05rem;
		}
		.watch-upcoming__copy p {
			-webkit-line-clamp: 1;
		}
		.watch-footer {
			flex-direction: column;
			align-items: flex-start;
			padding: 1.25rem;
		}
	}
</style>
