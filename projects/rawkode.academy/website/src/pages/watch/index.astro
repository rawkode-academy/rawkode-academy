---
export const prerender = false;

import { getPublishedVideos, getUpcomingVideos } from "@/lib/content";
import { formatVideoRuntimeLabel } from "@/lib/video-runtime";
import { getCollection } from "astro:content";
import VideoItemListJsonLd from "@/components/html/video-itemlist-jsonld.astro";
import VideoMetadata from "@/components/html/video-metadata.astro";
import Page from "@/wrappers/page.astro";
import { formatStreamingCountdown } from "@/lib/streaming-countdown";
import { getVideoThumbnailUrl } from "@/lib/video-thumbnail";
import { resolveTechnologyIconUrl } from "@/utils/resolve-technology-icon";
import { normalizeTechnologyReferences } from "@/utils/normalize-technology-refs";

import VideoMasthead from "@/components/video/VideoMasthead.astro";
import VideoHero from "@/components/video/VideoHero.astro";
import VideoStill from "@/components/video/VideoStill.astro";
import SeriesFilter from "@/components/video/SeriesFilter.astro";
import VideoGridItem from "@/components/video/VideoGridItem.astro";
import ContinueWatchingRail from "@/components/video/ContinueWatchingRail.astro";
import MLabel from "@/components/ui/MLabel.vue";
import PagerStrip from "@/components/ui/PagerStrip.astro";

const user = Astro.locals.user;

// Cache headers
if (user) {
	Astro.response.headers.set("Cache-Control", "private, no-store");
} else {
	Astro.response.headers.set(
		"Cache-Control",
		"public, max-age=300, s-maxage=3600, stale-while-revalidate=86400",
	);
	Astro.response.headers.set("CDN-Cache-Control", "public, max-age=3600");
	Astro.response.headers.set(
		"Cache-Tag",
		"videos-page, videos-list, videos-latest",
	);
}

Astro.response.headers.set("X-Build-Time", new Date().toISOString());

const page = Math.max(
	1,
	parseInt(Astro.url.searchParams.get("page") || "1", 10) || 1,
);
const videosPerPage = 15;

const allVideos = (await getPublishedVideos()).map((v) => v.data);
const upcomingVideos = (await getUpcomingVideos()).map((v) => v.data);
const visibleUpcomingVideos = upcomingVideos.slice(0, 6);
const renderedAt = new Date();
const technologyEntries = await getCollection("technologies");
const technologyById = new Map(
	technologyEntries.map((technology) => [
		technology.id.replace(/\/index$/, ""),
		technology,
	]),
);

const totalVideoCount = allVideos.length;
const categoryKeyFor = (video: (typeof allVideos)[number]) =>
	(video.category || video.type || "Library").toString();

const technologyIdsFor = (video: (typeof allVideos)[number]) =>
	normalizeTechnologyReferences(video.technologies);

// Category counts are derived from `category` when present, falling back to `type`.
const allCategoryKeys = new Set(allVideos.map(categoryKeyFor));
const allTechnologyIds = new Set(allVideos.flatMap(technologyIdsFor));

// "category" is the canonical param; "series" is read for backwards
// compatibility with links minted before the facet was renamed.
const requestedCategory =
	Astro.url.searchParams.get("category") ||
	Astro.url.searchParams.get("series") ||
	undefined;
const selectedCategory =
	requestedCategory && allCategoryKeys.has(requestedCategory)
		? requestedCategory
		: undefined;

const requestedTechnology =
	Astro.url.searchParams.get("technology") || undefined;
const selectedTechnology =
	requestedTechnology && allTechnologyIds.has(requestedTechnology)
		? requestedTechnology
		: undefined;

const SORT_OPTIONS = ["newest", "oldest", "longest"] as const;
type SortOption = (typeof SORT_OPTIONS)[number];
const requestedSort = Astro.url.searchParams.get("sort") || "newest";
const selectedSort: SortOption = (SORT_OPTIONS as readonly string[]).includes(
	requestedSort,
)
	? (requestedSort as SortOption)
	: "newest";

const matchesCategory = (video: (typeof allVideos)[number]) =>
	!selectedCategory || categoryKeyFor(video) === selectedCategory;
const matchesTechnology = (video: (typeof allVideos)[number]) =>
	!selectedTechnology || technologyIdsFor(video).includes(selectedTechnology);

// Facets compose: each rail's counts reflect the *other* active facet, so the
// numbers always describe what a click will actually return.
const visibleVideos = allVideos.filter(
	(video) => matchesCategory(video) && matchesTechnology(video),
);
const visibleCount = visibleVideos.length;

// Dispatch numbers stay chronological (newest = highest) within the filtered
// set, regardless of the active sort order.
const dispatchNumByVideoId = new Map(
	visibleVideos.map((video, idx) => [
		video.id,
		String(visibleCount - idx).padStart(3, "0"),
	]),
);

const sortedVideos =
	selectedSort === "oldest"
		? [...visibleVideos].reverse()
		: selectedSort === "longest"
			? [...visibleVideos].sort(
					(a, b) =>
						(typeof b.duration === "number" ? b.duration : 0) -
						(typeof a.duration === "number" ? a.duration : 0),
				)
			: visibleVideos;

// Pagination. Page one promotes the first visible video, then starts the grid after it.
const featuredVideo = page === 1 ? (sortedVideos[0] ?? null) : null;
const start = page === 1 ? 1 : 1 + (page - 1) * videosPerPage;
const end = start + videosPerPage;
const feedVideos = sortedVideos.slice(start, end);
const hasNextPage = end < sortedVideos.length;

const isFiltered = Boolean(
	selectedCategory || selectedTechnology || selectedSort !== "newest",
);

const watchHref = (
	overrides: {
		category?: string | undefined;
		technology?: string | undefined;
		sort?: SortOption;
		page?: number;
	} = {},
) => {
	const category =
		"category" in overrides ? overrides.category : selectedCategory;
	const technology =
		"technology" in overrides ? overrides.technology : selectedTechnology;
	const sort = overrides.sort ?? selectedSort;
	const targetPage = overrides.page ?? 1;

	const params = new URLSearchParams();
	if (category) params.set("category", category);
	if (technology) params.set("technology", technology);
	if (sort !== "newest") params.set("sort", sort);
	if (targetPage > 1) params.set("page", String(targetPage));
	const query = params.toString();
	return `/watch${query ? `?${query}` : ""}`;
};

const watchPathFor = (targetPage: number) => watchHref({ page: targetPage });

// ─── Category facet ────────────────────────────────────────────

const categoryCounts = new Map<string, number>();
for (const video of allVideos) {
	if (!matchesTechnology(video)) continue;
	const key = categoryKeyFor(video);
	categoryCounts.set(key, (categoryCounts.get(key) ?? 0) + 1);
}

const topCategories = Array.from(categoryCounts.entries())
	.sort((a, b) => b[1] - a[1])
	.slice(0, 7);

const navCategories =
	selectedCategory && !topCategories.some(([key]) => key === selectedCategory)
		? [
				...topCategories,
				[selectedCategory, categoryCounts.get(selectedCategory) ?? 0] as [
					string,
					number,
				],
			]
		: topCategories;

const categoryAllCount = selectedTechnology
	? Array.from(categoryCounts.values()).reduce((sum, count) => sum + count, 0)
	: totalVideoCount;

const categoryItems = [
	{
		label: "All",
		count: categoryAllCount,
		href: watchHref({ category: undefined }),
	},
	...navCategories.map(([key, count]) => ({
		label: key.replace(/[-_]/g, " ").replace(/\b\w/g, (c) => c.toUpperCase()),
		count,
		href: watchHref({ category: key }),
	})),
];

const activeCategoryIndex = selectedCategory
	? Math.max(
			0,
			1 + navCategories.findIndex(([key]) => key === selectedCategory),
		)
	: 0;

// ─── Technology facet ──────────────────────────────────────────

const technologyCounts = new Map<string, number>();
for (const video of allVideos) {
	if (!matchesCategory(video)) continue;
	for (const technologyId of technologyIdsFor(video)) {
		technologyCounts.set(
			technologyId,
			(technologyCounts.get(technologyId) ?? 0) + 1,
		);
	}
}

const topTechnologies = Array.from(technologyCounts.entries())
	.sort((a, b) => b[1] - a[1])
	.slice(0, 12);

const navTechnologies =
	selectedTechnology &&
	!topTechnologies.some(([id]) => id === selectedTechnology)
		? [
				...topTechnologies,
				[selectedTechnology, technologyCounts.get(selectedTechnology) ?? 0] as [
					string,
					number,
				],
			]
		: topTechnologies;

const technologyLabelFor = (technologyId: string) =>
	technologyById.get(technologyId)?.data.name ??
	technologyId.replace(/[-_]/g, " ").replace(/\b\w/g, (c) => c.toUpperCase());

const technologyItems = [
	{
		label: "All",
		href: watchHref({ technology: undefined }),
	},
	...navTechnologies.map(([id, count]) => ({
		label: technologyLabelFor(id),
		count,
		href: watchHref({ technology: id }),
	})),
];

const activeTechnologyIndex = selectedTechnology
	? Math.max(
			0,
			1 + navTechnologies.findIndex(([id]) => id === selectedTechnology),
		)
	: 0;

// ─── Sort ──────────────────────────────────────────────────────

const sortItems = SORT_OPTIONS.map((sort) => ({
	sort,
	label: sort.replace(/\b\w/, (c) => c.toUpperCase()),
	href: watchHref({ sort }),
}));

const dateFormatter = new Intl.DateTimeFormat("en-US", {
	month: "short",
	day: "2-digit",
});

const formatLabel = (value?: string | null) =>
	value
		? value.replace(/[-_]/g, " ").replace(/\b\w/g, (c) => c.toUpperCase())
		: undefined;

const formatDateTimeAttribute = (date: Date | string) =>
	(date instanceof Date ? date : new Date(date)).toISOString();

const runtimeLabelFor = (video: (typeof allVideos)[number]) =>
	formatVideoRuntimeLabel(
		{
			duration: typeof video.duration === "number" ? video.duration : undefined,
			publishedAt: video.publishedAt,
			type: video.type,
		},
		renderedAt,
	);

const featuredEpisodeNum = featuredVideo
	? dispatchNumByVideoId.get(featuredVideo.id)
	: undefined;
const featuredCategory = featuredVideo
	? formatLabel(featuredVideo.category || featuredVideo.type)
	: undefined;

const technologyLogosFor = (video: (typeof upcomingVideos)[number]) =>
	normalizeTechnologyReferences(video.technologies)
		.map((technologyId) => {
			const technology = technologyById.get(technologyId);
			if (!technology) return undefined;

			const iconSrc = resolveTechnologyIconUrl(
				technology.id,
				technology.data.logos,
			);
			return iconSrc
				? {
						src: iconSrc,
						name: technology.data.name,
						kind: "icon" as const,
					}
				: undefined;
		})
		.filter((logo): logo is { src: string; name: string; kind: "icon" } =>
			Boolean(logo),
		)
		.slice(0, 1);
---

<Page
	title="Cloud Native & Kubernetes Videos"
	description="Watch hands-on cloud native and Kubernetes tutorials, deep dives, and live builds for engineers shipping production systems."
	pageType="CollectionPage"
>
	{(page > 1 || isFiltered) && (
		<Fragment slot="extra-head">
			<meta name="robots" content="noindex,follow" />
		</Fragment>
	)}
	{page > 1 && (
		<link
			slot="extra-head"
			rel="prev"
			href={watchPathFor(page - 1)}
		/>
	)}
	{hasNextPage && (
		<link slot="extra-head" rel="next" href={watchPathFor(page + 1)} />
	)}
	<VideoMetadata
		slot="extra-head"
		title="Rawkode Academy Videos"
		description="Explore our collection of educational videos about cloud native technologies, development practices, and more."
		isVideoList={true}
	/>
	<link slot="extra-head" rel="alternate" type="application/rss+xml" title="Rawkode Academy - Videos (RSS)" href="/api/feeds/videos.xml" />
	<link slot="extra-head" rel="alternate" type="application/atom+xml" title="Rawkode Academy - Videos (Atom)" href="/api/feeds/videos.atom" />
	<link slot="extra-head" rel="alternate" type="application/feed+json" title="Rawkode Academy - Videos (JSON Feed)" href="/api/feeds/videos.json" />
	{page === 1 && !isFiltered && (
		<VideoItemListJsonLd
			slot="extra-head"
			videos={allVideos.map((v) => ({
				id: v.id,
				slug: v.slug,
				title: v.title,
				description: v.description,
				publishedAt:
					v.publishedAt instanceof Date
						? v.publishedAt
						: new Date(v.publishedAt),
				...(typeof v.duration === "number" ? { duration: v.duration } : {}),
			}))}
			listUrl={new URL("/watch", Astro.site ?? Astro.url).href}
			listName="Rawkode Academy Videos"
		/>
	)}

	<div class="watch-page">
		<VideoMasthead
			title="Latest Videos"
			dek="Tutorials, talks, and live builds."
		/>

		<ContinueWatchingRail server:defer />

		{visibleUpcomingVideos.length > 0 && (
			<section class="watch-upcoming" aria-labelledby="watch-upcoming-title">
				<div class="watch-upcoming__header">
					<MLabel tone="amber">Upcoming Streams</MLabel>
					<h2 id="watch-upcoming-title">Next live sessions</h2>
				</div>

				<div class="watch-upcoming__list">
					{visibleUpcomingVideos.map((v) => (
						<a class="watch-upcoming__item" href={`/watch/${v.slug}`}>
							<div class="watch-upcoming__still">
								<VideoStill
									title={v.title}
									series="Upcoming stream"
									thumbnailUrl={getVideoThumbnailUrl(v.id)}
									technologyLogos={technologyLogosFor(v)}
									accent="amber"
								/>
							</div>
							<div class="watch-upcoming__copy">
								<MLabel tone="amber">
									<time datetime={formatDateTimeAttribute(v.publishedAt)}>
										{formatStreamingCountdown(v.publishedAt, renderedAt)}
									</time>
								</MLabel>
								<h3>{v.title}</h3>
								<p>{v.description}</p>
							</div>
						</a>
					))}
				</div>
			</section>
		)}

		{featuredVideo && (
			<VideoHero
				href={`/watch/${featuredVideo.slug}`}
				episodeNum={featuredEpisodeNum}
				title={featuredVideo.title}
				series={featuredCategory}
				duration={runtimeLabelFor(featuredVideo)}
				thumbnailUrl={getVideoThumbnailUrl(featuredVideo.id)}
				description={featuredVideo.description}
				date={dateFormatter.format(
					featuredVideo.publishedAt instanceof Date
						? featuredVideo.publishedAt
						: new Date(featuredVideo.publishedAt),
				)}
				primaryCtaLabel="Watch session →"
			/>
		)}

		<SeriesFilter
			label="Category"
			ariaLabel="Video categories"
			items={categoryItems}
			activeIndex={activeCategoryIndex}
		/>

		<SeriesFilter
			label="Technology"
			ariaLabel="Video technologies"
			items={technologyItems}
			activeIndex={activeTechnologyIndex}
		/>

		<div class="watch-toolbar">
			<nav class="watch-toolbar__sort" aria-label="Sort videos">
				<MLabel>Sort</MLabel>
				{sortItems.map((item) => (
					<a
						class={`watch-toolbar__sort-link ${item.sort === selectedSort ? "watch-toolbar__sort-link--active" : ""}`}
						href={item.href}
						aria-current={item.sort === selectedSort ? "page" : undefined}
					>
						{item.label}
					</a>
				))}
			</nav>
			<form
				class="watch-toolbar__search"
				method="get"
				action="/search"
				role="search"
			>
				<input type="hidden" name="type" value="video" />
				<label class="sr-only" for="watch-search-input">Search videos</label>
				<input
					id="watch-search-input"
					class="watch-toolbar__search-input"
					type="search"
					name="q"
					placeholder="Search videos…"
					required
				/>
				<button class="watch-toolbar__search-btn" type="submit">Search</button>
			</form>
		</div>

		<div class="watch-grid">
			{feedVideos.map((v) => (
				<VideoGridItem
					href={`/watch/${v.slug}`}
					episodeNum={dispatchNumByVideoId.get(v.id)}
					title={v.title}
					series={formatLabel(v.category || v.type) || undefined}
					duration={runtimeLabelFor(v)}
					thumbnailUrl={getVideoThumbnailUrl(v.id)}
					date={dateFormatter.format(
						v.publishedAt instanceof Date
							? v.publishedAt
							: new Date(v.publishedAt),
					)}
				/>
			))}
		</div>

		<footer class="watch-footer">
			<MLabel>
				<a class="watch-footer__link" href="/api/feeds/videos.xml">RSS</a> ·
				<a class="watch-footer__link" href="/api/feeds/videos.json">JSON Feed</a> ·
				<a class="watch-footer__link" href="/watch">All videos</a>
			</MLabel>
			<PagerStrip
				page={page}
				prevHref={page > 1 ? watchPathFor(page - 1) : undefined}
				nextHref={hasNextPage ? watchPathFor(page + 1) : undefined}
				ariaLabel="Video pages"
			/>
		</footer>
	</div>
</Page>

<style>
	.watch-page {
		background: var(--editorial-paper);
		color: var(--editorial-ink);
	}

	.watch-upcoming {
		border-bottom: 1px solid var(--editorial-hairline);
		background: var(--editorial-paper-deep);
		padding: 1.25rem 2.5rem 1.5rem;
	}

	.watch-upcoming__header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		margin-bottom: 1rem;
	}

	.watch-upcoming__header h2 {
		margin: 0;
		font-family: var(--font-instrument-serif), serif;
		font-size: 1.75rem;
		font-style: italic;
		font-weight: 400;
		line-height: 1;
		letter-spacing: 0;
		color: var(--editorial-ink);
	}

	.watch-upcoming__list {
		display: grid;
		gap: 0.75rem;
	}

	.watch-upcoming__item {
		display: grid;
		grid-template-columns: 10rem minmax(0, 1fr);
		gap: 1rem;
		align-items: center;
		padding-block: 0.75rem;
		border-top: 1px solid var(--editorial-hairline);
		color: inherit;
		text-decoration: none;
	}

	.watch-upcoming__item:hover h3 {
		color: var(--editorial-spruce);
	}

	.watch-upcoming__still {
		width: 10rem;
	}

	.watch-upcoming__copy {
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
	}

	.watch-upcoming__copy h3 {
		margin: 0;
		font-family: var(--font-instrument-serif), serif;
		font-size: 1.25rem;
		font-style: italic;
		font-weight: 400;
		line-height: 1.1;
		letter-spacing: 0;
		color: var(--editorial-ink);
	}

	.watch-upcoming__copy p {
		margin: 0;
		max-width: 56rem;
		color: var(--editorial-ink-soft);
		font-family: var(--font-inter-tight), sans-serif;
		font-size: 0.95rem;
		line-height: 1.4;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.watch-toolbar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.75rem 1.5rem;
		padding: 0.875rem 2.5rem 0.75rem;
		border-bottom: 1px solid var(--editorial-hairline);
	}

	.watch-toolbar__sort {
		display: flex;
		align-items: baseline;
		gap: 1rem;
	}

	.watch-toolbar__sort-link {
		display: inline-flex;
		align-items: center;
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 0.6875rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--editorial-ink-soft);
		text-decoration: none;
		transition: color var(--duration-base) var(--ease-standard),
			text-decoration-color var(--duration-base) var(--ease-standard);
	}

	.watch-toolbar__sort-link:hover {
		color: var(--editorial-ink);
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 0.35em;
	}

	.watch-toolbar__sort-link--active {
		color: var(--editorial-ink);
		text-decoration: underline;
		text-decoration-thickness: 2px;
		text-underline-offset: 0.35em;
	}

	.watch-toolbar__search {
		display: flex;
		align-items: stretch;
		gap: 0;
		border: 1px solid var(--editorial-hairline-strong);
		border-radius: var(--radius-sm);
		background: var(--editorial-paper);
	}

	.watch-toolbar__search-input {
		width: 14rem;
		max-width: 100%;
		min-height: 2.5rem;
		padding: 0.4rem 0.625rem;
		border: none;
		background: transparent;
		color: var(--editorial-ink);
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 0.75rem;
	}

	.watch-toolbar__search-input::placeholder {
		color: var(--editorial-ink-mute);
	}

	.watch-toolbar__search-input:focus-visible {
		outline: 2px solid var(--editorial-spruce);
		outline-offset: -2px;
	}

	.watch-toolbar__search-btn {
		padding: 0.4rem 0.75rem;
		border: none;
		border-left: 1px solid var(--editorial-hairline-strong);
		background: var(--editorial-paper-deep);
		color: var(--editorial-ink);
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 0.6875rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		cursor: pointer;
		transition: color var(--duration-base) var(--ease-standard);
	}

	.watch-toolbar__search-btn:hover {
		color: var(--editorial-spruce);
	}

	.watch-toolbar__search-btn:focus-visible {
		outline: 2px solid var(--editorial-spruce);
		outline-offset: -2px;
	}

	.watch-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem 1.75rem;
		padding: 2rem 2.5rem 3rem;
	}

	.watch-footer {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1.5rem;
		padding: 1.5rem var(--space-section-pad-x);
		border-top: 1px solid var(--editorial-ink);
		background: var(--editorial-paper-deep);
	}

	.watch-footer__link {
		color: inherit;
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 2px;
		text-decoration-color: var(--editorial-hairline-strong);
	}
	.watch-footer__link:hover { text-decoration-color: currentColor; }

	@media (max-width: 960px) {
		.watch-grid {
			grid-template-columns: repeat(2, 1fr);
			padding-inline: 1.25rem;
		}

		.watch-grid {
			padding-top: 1.5rem;
			padding-bottom: 2rem;
		}

		.watch-upcoming__header {
			align-items: flex-start;
			flex-direction: column;
			gap: 0.5rem;
		}

		.watch-upcoming {
			padding-inline: 1.25rem;
		}

		.watch-toolbar {
			padding-inline: 1.25rem;
		}

		.watch-toolbar__search {
			flex: 1 1 100%;
		}

		.watch-toolbar__search-input {
			flex: 1;
			width: auto;
		}
	}
	@media (max-width: 640px) {
