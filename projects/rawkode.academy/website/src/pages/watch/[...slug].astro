---
import { getCollection, getEntry } from "astro:content";
import Breadcrumb from "@/components/breadcrumb/Breadcrumb.astro";
import VideoMetadata from "@/components/html/video-metadata.astro";
import VideoPlayer from "@/components/video/player.vue";
import Page from "@/wrappers/page.astro";
import { Marked } from "marked";
import { resolveTechnologyIconUrl } from "@/utils/resolve-technology-icon";
import { normalizeTechnologyReferences } from "@/utils/normalize-technology-refs";
import { buildWatchVideoSeoText } from "@/utils/watch-video-seo";
import { css } from "../../../styled-system/css";

export const prerender = false;

const { slug } = Astro.params;
const videos = await getCollection("videos");
let video: (typeof videos)[0] | undefined = videos.find((v) => v.data.slug === slug);

if (!video) {
	return Astro.redirect("/404");
}

Astro.response.headers.set("Cache-Control", "public, max-age=600, s-maxage=7200, stale-while-revalidate=172800");
Astro.response.headers.set("CDN-Cache-Control", "public, max-age=7200");
Astro.response.headers.set("Cache-Tag", `video-${video.data.slug}, videos-page, video-detail`);

const marked = new Marked({ breaks: true, gfm: true });
const processedDescription = video.data.description.replace(/\\n/g, "\n");
const renderedDescriptionHtml = marked.parse(processedDescription);

type Chapter = { startTime: number; title: string };
let clips: Array<{ name: string; startOffset: number; endOffset?: number }> = [];
const durationSec: number | null = typeof video.data.duration === "number" ? video.data.duration : null;
const chapterSource: Chapter[] = Array.isArray(video.data.chapters)
	? (video.data.chapters as Chapter[]).map((c) => ({ title: c.title, startTime: Math.max(0, Math.floor(c?.startTime ?? 0)) }))
	: [];
if (chapterSource.length > 0) {
	chapterSource.sort((a, b) => a.startTime - b.startTime);
	clips = chapterSource.map((c, i) => {
		const next = chapterSource[i + 1];
		return { name: c.title, startOffset: c.startTime, ...(next ? { endOffset: next.startTime } : {}) };
	});
}

const formatDate = (date: Date | string) => {
	const d = typeof date === "string" ? new Date(date) : date;
	return d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
};

const showRef = video.data.show;
const showId =
	typeof showRef === "string" ? showRef : showRef && typeof showRef === "object" && "id" in showRef ? (showRef as { id: string }).id : null;
const showEntry = showId ? await getEntry("shows", showId) : null;

const normalizedTechIds = normalizeTechnologyReferences(video.data.technologies);
const techEntries = (
	await Promise.all(
		normalizedTechIds.map(async (id) => {
			try {
				return await getEntry("technologies", id);
			} catch {
				return null;
			}
		}),
	)
).filter((t): t is NonNullable<typeof t> => Boolean(t));

const hostEntries =
	showEntry && Array.isArray(showEntry.data.hosts)
		? (
				await Promise.all(
					showEntry.data.hosts.map(async (hostRef) => {
						try {
							return await getEntry("people", hostRef.id);
						} catch {
							return null;
						}
					}),
				)
			).filter((h): h is NonNullable<typeof h> => Boolean(h))
		: [];

const guestEntries = Array.isArray(video.data.guests)
	? (
			await Promise.all(
				video.data.guests.map(async (guestRef) => {
					try {
						return await getEntry("people", guestRef.id);
					} catch {
						return null;
					}
				}),
			)
		).filter((g): g is NonNullable<typeof g> => Boolean(g))
	: [];

const cast = [...hostEntries.map((h) => ({ person: h, role: "Host" })), ...guestEntries.map((g) => ({ person: g, role: "Guest" }))];

// Related videos: same show first, then chronological neighbours
const otherVideos = videos.filter((v) => v.data.slug !== video.data.slug);
const sameShowVideos = showEntry
	? otherVideos.filter((v) => {
			const id = typeof v.data.show === "string" ? v.data.show : v.data.show && typeof v.data.show === "object" && "id" in v.data.show ? (v.data.show as { id: string }).id : null;
			return id === showEntry.id;
		})
	: [];
const relatedVideos = (sameShowVideos.length >= 3 ? sameShowVideos : [...sameShowVideos, ...otherVideos.filter((v) => !sameShowVideos.includes(v))])
	.sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime())
	.slice(0, 4);

const fmtChapterTime = (sec: number) => {
	const h = Math.floor(sec / 3600);
	const m = Math.floor((sec % 3600) / 60);
	const s = Math.floor(sec % 60);
	return h > 0 ? `${h}:${String(m).padStart(2, "0")}:${String(s).padStart(2, "0")}` : `${m}:${String(s).padStart(2, "0")}`;
};

const breadcrumbElements = showEntry
	? [
			{ title: "Home", link: "/" },
			{ title: "Videos", link: "/watch" },
			{ title: showEntry.data.name, link: `/shows/${showEntry.id}` },
			{ title: video.data.title, link: `/watch/${video.data.slug}` },
		]
	: [
			{ title: "Home", link: "/" },
			{ title: "Videos", link: "/watch" },
			{ title: video.data.title, link: `/watch/${video.data.slug}` },
		];

const thumbnailUrl = `https://content.rawkode.academy/videos/${video.data.id}/thumbnail.jpg`;
const streamUrl = `https://content.rawkode.academy/videos/${video.data.id}/stream.m3u8`;
const captionUrl = `https://content.rawkode.academy/videos/${video.data.id}/captions/en.vtt`;
const watchVideoSeoText = await buildWatchVideoSeoText({ captionUrl, description: processedDescription, chapters: chapterSource });

const user = Astro.locals.user;
const isAuthenticated = !!user;

let initialPosition = 0;
if (isAuthenticated && user?.id) {
	try {
		const response = await fetch("https://api.rawkode.academy/graphql", {
			method: "POST",
			headers: { "Content-Type": "application/json" },
			body: JSON.stringify({
				query: `
					query GetWatchPosition($userId: String!, $videoId: String!) {
						getWatchPosition(userId: $userId, videoId: $videoId) {
							positionSeconds
						}
					}
				`,
				variables: { userId: user.id, videoId: video.data.id },
			}),
		});
		const result = (await response.json()) as { data?: { getWatchPosition?: { positionSeconds?: number } } };
		initialPosition = result?.data?.getWatchPosition?.positionSeconds ?? 0;
	} catch {}
}

const shell = css({ maxWidth: "72rem", mx: "auto", px: { base: "4", md: "6" }, py: "8" });

const title = css({
	fontFamily: "display",
	fontSize: { base: "2xl", md: "4xl", lg: "5xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	lineHeight: "1.1",
	color: "fg.primary",
	mb: "3",
	textWrap: "balance",
});

const meta = css({ display: "flex", flexWrap: "wrap", alignItems: "center", gap: "3", fontSize: "sm", color: "fg.muted", mb: "6" });
const sep = css({ color: "border.default" });

const playerWrap = css({
	position: "relative",
	aspectRatio: "16 / 9",
	width: "full",
	overflow: "hidden",
	borderRadius: "2xl",
	bg: "black",
	boxShadow: "xl",
	mb: "8",
});

const sectionCard = css({
	p: { base: "5", md: "8" },
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	mb: "8",
});

const sectionEyebrow = css({
	fontSize: "xs",
	fontWeight: "bold",
	letterSpacing: "wider",
	textTransform: "uppercase",
	color: "fg.brand",
	mb: "2",
});

const sectionTitle = css({
	fontFamily: "display",
	fontSize: "xl",
	fontWeight: "bold",
	color: "fg.primary",
	mb: "4",
});

const proseClass = css({
	color: "fg.secondary",
	fontSize: "md",
	lineHeight: "1.7",
	"& p": { my: "3" },
	"& a": { color: "fg.brand", textDecoration: "underline" },
	"& code": { fontFamily: "mono", bg: "bg.sunken", px: "1.5", py: "0.5", borderRadius: "sm" },
});

const techList = css({ display: "flex", flexWrap: "wrap", gap: "2" });

const techPill = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "3",
	py: "2",
	borderRadius: "full",
	bg: "bg.surface",
	borderWidth: "1px",
	borderColor: "border.muted",
	color: "fg.secondary",
	textDecoration: "none",
	fontSize: "sm",
	transition: "all 150ms ease",
	_hover: { color: "fg.brand", bg: "bg.brand-subtle", borderColor: "border.default" },
});

const techIcon = css({ flexShrink: 0, objectFit: "contain" });
const techIconStyle = "width: 20px; height: 20px;";

const castGrid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", sm: "repeat(2, minmax(0, 1fr))", md: "repeat(3, minmax(0, 1fr))" },
	gap: "3",
});

const castMember = css({
	display: "flex",
	alignItems: "center",
	gap: "3",
	p: "3",
	borderRadius: "xl",
	bg: "bg.surface",
	textDecoration: "none",
	color: "fg.primary",
	transition: "background 150ms ease",
	_hover: { bg: "bg.sunken" },
});

const castAvatar = css({ flexShrink: 0, borderRadius: "full", objectFit: "cover" });
const castAvatarStyle = "width: 40px; height: 40px;";
const castName = css({ fontWeight: "semibold", fontSize: "sm" });
const castRole = css({ fontSize: "xs", color: "fg.muted" });

const showPill = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "3",
	py: "1.5",
	borderRadius: "full",
	bg: "bg.brand-subtle",
	color: "fg.brand",
	fontSize: "xs",
	fontWeight: "semibold",
	letterSpacing: "wider",
	textTransform: "uppercase",
	textDecoration: "none",
	mb: "4",
	transition: "transform 150ms ease",
	_hover: { transform: "translateX(2px)" },
});

const chapterList = css({ display: "flex", flexDirection: "column", gap: "0" });

const chapterRow = css({
	display: "grid",
	gridTemplateColumns: "auto 1fr",
	gap: "4",
	alignItems: "center",
	py: "3",
	borderBottomWidth: "1px",
	borderBottomColor: "border.muted",
	color: "fg.primary",
	textDecoration: "none",
	transition: "background 150ms ease, padding 150ms ease",
	_hover: { bg: "bg.surface", pl: "2", borderRadius: "md" },
	_last: { borderBottomWidth: "0" },
});

const chapterTime = css({
	fontFamily: "mono",
	fontSize: "xs",
	fontWeight: "semibold",
	color: "fg.brand",
	bg: "bg.brand-subtle",
	px: "2",
	py: "1",
	borderRadius: "md",
	minWidth: "3.5rem",
	textAlign: "center",
});

const chapterTitle = css({ fontSize: "sm", color: "fg.secondary", _hover: { color: "fg.primary" } });

const relatedSection = css({ mt: "16" });
const relatedHead = css({
	display: "flex",
	alignItems: "baseline",
	justifyContent: "space-between",
	gap: "4",
	mb: "6",
	flexWrap: "wrap",
});
const relatedTitle = css({
	fontFamily: "display",
	fontSize: { base: "xl", md: "2xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	color: "fg.primary",
});
const relatedAll = css({ fontSize: "sm", fontWeight: "semibold", color: "fg.brand", textDecoration: "none", _hover: { textDecoration: "underline" } });
const relatedGrid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", sm: "repeat(2, minmax(0, 1fr))", lg: "repeat(4, minmax(0, 1fr))" },
	gap: "4",
});
const relatedCard = css({
	display: "flex",
	flexDirection: "column",
	overflow: "hidden",
	borderRadius: "xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textDecoration: "none",
	color: "fg.primary",
	transition: "transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease",
	_hover: { transform: "translateY(-2px)", boxShadow: "md", borderColor: "border.default" },
});
const relatedThumb = css({
	position: "relative",
	aspectRatio: "16 / 9",
	overflow: "hidden",
	bg: "bg.sunken",
	"& img": { width: "full", height: "full", objectFit: "cover" },
});
const relatedThumbDuration = css({
	position: "absolute",
	right: "1.5",
	bottom: "1.5",
	px: "1.5",
	py: "0.5",
	borderRadius: "sm",
	fontSize: "2xs",
	fontWeight: "semibold",
	color: "white",
	bg: "rgba(0,0,0,0.75)",
});
const relatedBody = css({ p: "3", display: "flex", flexDirection: "column", gap: "1.5" });
const relatedCardTitle = css({
	fontSize: "sm",
	fontWeight: "semibold",
	color: "fg.primary",
	lineHeight: "1.3",
	display: "-webkit-box",
	WebkitLineClamp: "2",
	overflow: "hidden",
});
const relatedMeta = css({ fontSize: "xs", color: "fg.muted" });

const fmtDurationShort = (sec: number) => {
	if (!sec || sec <= 0) return "";
	const h = Math.floor(sec / 3600);
	const m = Math.floor((sec % 3600) / 60);
	const s = sec % 60;
	return h > 0 ? `${h}:${String(m).padStart(2, "0")}:${String(s).padStart(2, "0")}` : `${m}:${String(s).padStart(2, "0")}`;
};
---

<Page title={video.data.title} description={video.data.description} useImageDirectly={true} image={{ image: new URL(thumbnailUrl) }}>
	<VideoMetadata
		slot="extra-head"
		title={video.data.title}
		description={video.data.description}
		thumbnailUrl={thumbnailUrl}
		publishedAt={video.data.publishedAt instanceof Date ? video.data.publishedAt.toISOString() : String(video.data.publishedAt)}
		duration={durationSec ?? 0}
		streamUrl={streamUrl}
		captionUrl={captionUrl}
		transcript={watchVideoSeoText.transcriptExcerpt}
		keywords={techEntries.map((t) => t.data.name)}
		isLiveBroadcast={video.data.type === "live"}
		category={video.data.category}
		clips={clips}
	/>
	<link slot="extra-head" rel="alternate" type="application/rss+xml" title="Rawkode Academy - Videos (RSS)" href="/api/feeds/videos.xml" />
	<link slot="extra-head" rel="alternate" type="application/atom+xml" title="Rawkode Academy - Videos (Atom)" href="/api/feeds/videos.atom" />
	<link slot="extra-head" rel="alternate" type="application/feed+json" title="Rawkode Academy - Videos (JSON Feed)" href="/api/feeds/videos.json" />

	<div class={shell}>
		<Breadcrumb elements={breadcrumbElements} />

		{showEntry && (
			<a href={`/shows/${showEntry.id}`} class={showPill}>
				<svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21 6.5l-7-4-7 4-7-4v15l7 4 7-4 7 4v-15zM10 18.39l-4-2.28V5.61l4 2.28v10.5zm6-2.28l-4 2.28V7.89l4-2.28v10.5z"/></svg>
				{showEntry.data.name}
			</a>
		)}

		<h1 class={title}>{video.data.title}</h1>
		<div class={meta}>
			<time datetime={video.data.publishedAt instanceof Date ? video.data.publishedAt.toISOString() : String(video.data.publishedAt)}>
				{formatDate(video.data.publishedAt)}
			</time>
			{durationSec && durationSec > 0 && <>
				<span class={sep}>·</span>
				<span>{Math.floor(durationSec / 60)} min watch</span>
			</>}
		</div>

		<div class={playerWrap}>
			<VideoPlayer client:only="vue" video={video.data.id} thumbnailUrl={thumbnailUrl} initialPosition={initialPosition} isAuthenticated={isAuthenticated} />
		</div>

		<section class={sectionCard}>
			<span class={sectionEyebrow}>Overview</span>
			<h2 class={sectionTitle}>About this video</h2>
			<div class={proseClass} set:html={renderedDescriptionHtml}></div>
		</section>

		{techEntries.length > 0 && (
			<section class={sectionCard}>
				<span class={sectionEyebrow}>Technologies</span>
				<h2 class={sectionTitle}>Featured in this video</h2>
				<div class={techList}>
					{techEntries.map((tech) => (
						<a href={`/technology/${tech.id.replace(/\/index$/, "")}`} class={techPill}>
							<img src={resolveTechnologyIconUrl(tech.id, tech.data.logos) || "/apple-touch-icon.png"} alt={tech.data.name} class={techIcon} style={techIconStyle} onerror="this.onerror=null; this.src='/apple-touch-icon.png'" />
							<span>{tech.data.name}</span>
						</a>
					))}
				</div>
			</section>
		)}

		{cast.length > 0 && (
			<section class={sectionCard}>
				<span class={sectionEyebrow}>Cast</span>
				<h2 class={sectionTitle}>Hosts & Guests</h2>
				<div class={castGrid}>
					{cast.map(({ person, role }) => (
						<a href={`/people/${person.data.id}`} class={castMember}>
							<img src={person.data.avatarUrl ?? "/apple-touch-icon.png"} alt={person.data.name} class={castAvatar} style={castAvatarStyle} onerror="this.onerror=null; this.src='/apple-touch-icon.png'" />
							<div>
								<div class={castName}>{person.data.name}</div>
								<div class={castRole}>{role}</div>
							</div>
						</a>
					))}
				</div>
			</section>
		)}

		{chapterSource.length > 0 && (
			<section class={sectionCard}>
				<span class={sectionEyebrow}>Chapters</span>
				<h2 class={sectionTitle}>Jump to a section</h2>
				<div class={chapterList}>
					{chapterSource.map((chapter) => (
						<a href={`#t=${chapter.startTime}`} class={chapterRow} data-chapter-time={chapter.startTime}>
							<span class={chapterTime}>{fmtChapterTime(chapter.startTime)}</span>
							<span class={chapterTitle}>{chapter.title}</span>
						</a>
					))}
				</div>
			</section>
		)}

		{relatedVideos.length > 0 && (
			<section class={relatedSection}>
				<div class={relatedHead}>
					<h2 class={relatedTitle}>{showEntry && sameShowVideos.length > 0 ? `More from ${showEntry.data.name}` : "Keep watching"}</h2>
					<a href={showEntry && sameShowVideos.length > 0 ? `/shows/${showEntry.id}` : "/watch"} class={relatedAll}>Browse all videos →</a>
				</div>
				<div class={relatedGrid}>
					{relatedVideos.map((v) => {
						const dur = typeof v.data.duration === "number" ? v.data.duration : 0;
						return (
							<a href={`/watch/${v.data.slug}`} class={relatedCard}>
								<div class={relatedThumb}>
									<img src={`https://content.rawkode.academy/videos/${v.data.id}/thumbnail.jpg`} alt={v.data.title} loading="lazy" />
									{dur > 0 && <span class={relatedThumbDuration}>{fmtDurationShort(dur)}</span>}
								</div>
								<div class={relatedBody}>
									<h3 class={relatedCardTitle}>{v.data.title}</h3>
									<span class={relatedMeta}>{formatDate(v.data.publishedAt as Date | string)}</span>
								</div>
							</a>
						);
					})}
				</div>
			</section>
		)}
	</div>
</Page>
