		font-weight: 700;
		color: var(--text-muted);
	}

	@media (max-width: 768px) {
		.other-header {
			flex-direction: column;
		}

		.other-grid {
			flex-direction: column;
		}

		.other-group {
			min-width: 100%;
		}
