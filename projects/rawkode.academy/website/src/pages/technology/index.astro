---
export const prerender = true;

import { getCollection } from "astro:content";
import PageHero from "@/components/layout/PageHero.astro";
import Page from "@/wrappers/page.astro";
import { resolveTechnologyIconUrl } from "@/utils/resolve-technology-icon";
import { createLogger } from "@/lib/logger";
import { css } from "../../../styled-system/css";

const logger = createLogger("technology");

type Technology = {
	id: string;
	name: string;
	logo?: string;
	website?: string;
	documentation?: string;
	category?: string;
	cncfStatus?: string;
};

let technologies: Technology[] = [];
try {
	const items = await getCollection("technologies");
	technologies = items.map((e) => {
		const logo = resolveTechnologyIconUrl(e.id, e.data.logos);
		return {
			id: e.id,
			name: e.data.name,
			...(logo && { logo }),
			...(e.data.website && { website: e.data.website }),
			...(e.data.documentation && { documentation: e.data.documentation }),
			...(e.data.category && { category: e.data.category }),
			...(e.data.cncf?.status && { cncfStatus: e.data.cncf.status }),
		};
	});
} catch (error) {
	logger.error("Failed to load technologies from content collection", error);
}

technologies.sort((a, b) => a.name.localeCompare(b.name));

const categoryCounts = new Map<string, number>();
for (const tech of technologies) {
	const cat = tech.category ?? "Uncategorised";
	categoryCounts.set(cat, (categoryCounts.get(cat) ?? 0) + 1);
}
const categoryEntries = [...categoryCounts.entries()].sort((a, b) => b[1] - a[1]);
const cncfCount = technologies.filter((t) => t.cncfStatus).length;

const shell = css({ maxWidth: "80rem", mx: "auto", px: { base: "4", md: "6" }, py: "12" });

const statsRow = css({
	display: "grid",
	gridTemplateColumns: { base: "repeat(3, minmax(0, 1fr))" },
	gap: "3",
	mb: "10",
	maxWidth: "44rem",
	mx: "auto",
});

const statBox = css({
	textAlign: "center",
	p: "4",
	borderRadius: "xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
});

const statValue = css({
	fontFamily: "display",
	fontSize: { base: "2xl", md: "3xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	backgroundImage: "linear-gradient(135deg, token(colors.brand.500), token(colors.cyan.500))",
	backgroundClip: "text",
	color: "transparent",
});

const statLabel = css({ mt: "1", fontSize: "xs", color: "fg.muted", fontWeight: "medium", textTransform: "uppercase", letterSpacing: "wider" });

const toolbar = css({
	display: "flex",
	flexDirection: { base: "column", md: "row" },
	alignItems: { base: "stretch", md: "center" },
	justifyContent: "space-between",
	gap: "4",
	mb: "6",
});

const filterRow = css({
	display: "flex",
	flexWrap: "wrap",
	gap: "2",
	mb: "10",
});

const filterChip = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "1.5",
	px: "3.5",
	py: "1.5",
	borderRadius: "full",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.surface",
	color: "fg.secondary",
	fontSize: "sm",
	fontWeight: "medium",
	cursor: "pointer",
	transition: "all 150ms ease",
	_hover: { borderColor: "border.default", color: "fg.primary" },
	"&[aria-pressed='true']": {
		bg: "bg.brand-subtle",
		borderColor: "fg.brand",
		color: "fg.brand",
	},
});

const filterChipCount = css({
	fontSize: "xs",
	fontWeight: "semibold",
	opacity: "0.7",
});

const searchWrap = css({ position: "relative", width: { base: "full", md: "24rem" } });

const searchInput = css({
	width: "full",
	pl: "10",
	pr: "4",
	py: "3",
	borderRadius: "lg",
	bg: "bg.surface",
	color: "fg.primary",
	borderWidth: "1px",
	borderColor: "border.muted",
	fontSize: "md",
	transition: "border-color 150ms ease",
	_focus: { outline: "2px solid", outlineColor: "border.focus", outlineOffset: "1px", borderColor: "border.focus" },
});

const searchIcon = css({
	position: "absolute",
	left: "3",
	top: "50%",
	transform: "translateY(-50%)",
	width: "5",
	height: "5",
	color: "fg.muted",
	pointerEvents: "none",
});

const countText = css({ fontSize: "sm", color: "fg.muted" });

const grid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", sm: "repeat(2, minmax(0, 1fr))", lg: "repeat(3, minmax(0, 1fr))" },
	gap: "5",
});

const card = css({
	position: "relative",
	display: "flex",
	flexDirection: "column",
	overflow: "hidden",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textDecoration: "none",
	color: "fg.primary",
	transition: "transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease",
	_hover: { transform: "translateY(-2px)", boxShadow: "lg", borderColor: "border.default" },
});

const cncfFlag = css({
	position: "absolute",
	top: "3",
	right: "3",
	display: "inline-flex",
	alignItems: "center",
	px: "2",
	py: "0.5",
	borderRadius: "full",
	bg: "bg.brand-subtle",
	color: "fg.brand",
	fontSize: "2xs",
	fontWeight: "bold",
	letterSpacing: "wider",
	textTransform: "uppercase",
});

const cardCategory = css({
	fontSize: "xs",
	color: "fg.muted",
	fontWeight: "medium",
	letterSpacing: "wider",
	textTransform: "uppercase",
	overflow: "hidden",
	textOverflow: "ellipsis",
	whiteSpace: "nowrap",
});

const logoWrap = css({
	display: "flex",
	alignItems: "center",
	justifyContent: "center",
	h: "32",
	p: "6",
	bg: "bg.sunken",
	"& img": { maxWidth: "5rem", maxHeight: "5rem", objectFit: "contain" },
});

const cardBody = css({ p: "5", display: "flex", flexDirection: "column", gap: "3", flex: "1" });

const techName = css({
	fontSize: "lg",
	fontWeight: "bold",
	color: "fg.primary",
	letterSpacing: "tight",
});

const learnMore = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "1.5",
	fontSize: "sm",
	fontWeight: "semibold",
	color: "fg.brand",
	mt: "auto",
});

const emptyCard = css({
	mx: "auto",
	maxWidth: "28rem",
	mt: "12",
	p: "12",
	borderRadius: "3xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textAlign: "center",
	color: "fg.secondary",
});

const hiddenClass = css({ display: "none" });
---

<Page title="Technologies" description="Explore the various technologies covered on Rawkode Academy.">
	<PageHero eyebrow="Technology Hub" title="Explore Technologies" subtitle="Browse Rawkode Academy's catalogue of tools and platforms. Start typing to find what you're looking for." />

	<div class={shell}>
		<div class={statsRow}>
			<div class={statBox}>
				<p class={statValue}>{technologies.length}</p>
				<p class={statLabel}>Projects</p>
			</div>
			<div class={statBox}>
				<p class={statValue}>{categoryEntries.length}</p>
				<p class={statLabel}>Categories</p>
			</div>
			<div class={statBox}>
				<p class={statValue}>{cncfCount}</p>
				<p class={statLabel}>CNCF</p>
			</div>
		</div>

		<div class={toolbar}>
			<p class={countText}>
				Showing <span data-tech-visible-count>{technologies.length}</span> of {technologies.length} technologies
			</p>
			<div class={searchWrap}>
				<svg class={searchIcon} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
				</svg>
				<input id="technology-search" type="search" placeholder="e.g. Grafana, Kubernetes…" class={searchInput} autocomplete="off" />
			</div>
		</div>

		<div class={filterRow}>
			<button type="button" class={filterChip} data-filter="all" aria-pressed="true">
				All <span class={filterChipCount}>{technologies.length}</span>
			</button>
			<button type="button" class={filterChip} data-filter="__cncf">
				CNCF <span class={filterChipCount}>{cncfCount}</span>
			</button>
			{categoryEntries.map(([cat, count]) => (
				<button type="button" class={filterChip} data-filter={cat} aria-pressed="false">
					{cat} <span class={filterChipCount}>{count}</span>
				</button>
			))}
		</div>

		<div id="technologies" class={grid}>
			{technologies.map((tech) => {
				const searchKeywords = tech.name.toLowerCase();
				const category = tech.category ?? "Uncategorised";
				return (
					<a href={`/technology/${tech.id}`} class={`${card} tech-card-link`} data-keywords={searchKeywords} data-category={category} data-cncf={tech.cncfStatus ? "1" : "0"}>
						{tech.cncfStatus && <span class={cncfFlag}>{tech.cncfStatus}</span>}
						<div class={logoWrap}>
							<img src={tech.logo ?? "/apple-touch-icon.png"} alt={`${tech.name} logo`} onerror={`this.onerror=null; this.src='/apple-touch-icon.png';`} />
						</div>
						<div class={cardBody}>
							{tech.category && <span class={cardCategory}>{tech.category}</span>}
							<h3 class={techName}>{tech.name}</h3>
							<span class={learnMore}>
								Learn more
								<svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
							</span>
						</div>
					</a>
				);
			})}
		</div>

		<div id="technology-empty-state" class={`${hiddenClass} ${emptyCard}`}>
			<p>No technologies match your search. Try a different term.</p>
		</div>
	</div>

	<script>
		document.addEventListener("DOMContentLoaded", () => {
			const searchInput = document.getElementById("technology-search") as HTMLInputElement | null;
			const cards = Array.from(document.querySelectorAll<HTMLElement>("#technologies .tech-card-link"));
			const emptyState = document.getElementById("technology-empty-state");
			const countTargets = document.querySelectorAll<HTMLElement>("[data-tech-visible-count]");
			const filterButtons = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-filter]"));

			let activeFilter = "all";

			const applyFilters = () => {
				const query = (searchInput?.value ?? "").trim().toLowerCase();
				let visible = 0;
				cards.forEach((card) => {
					const keywords = card.dataset.keywords ?? "";
					const category = card.dataset.category ?? "";
					const isCncf = card.dataset.cncf === "1";
					const matchesSearch = keywords.includes(query);
					const matchesFilter =
						activeFilter === "all"
							? true
							: activeFilter === "__cncf"
								? isCncf
								: category === activeFilter;
					const matches = matchesSearch && matchesFilter;
					card.style.display = matches ? "" : "none";
					if (matches) visible += 1;
				});
				countTargets.forEach((el) => { el.textContent = visible.toString(); });
				if (emptyState) emptyState.style.display = visible === 0 ? "block" : "none";
			};

			filterButtons.forEach((btn) => {
				btn.addEventListener("click", () => {
					activeFilter = btn.dataset.filter ?? "all";
					filterButtons.forEach((b) => b.setAttribute("aria-pressed", b === btn ? "true" : "false"));
					applyFilters();
				});
			});

			searchInput?.addEventListener("input", applyFilters);
			applyFilters();
		});
	</script>
</Page>
