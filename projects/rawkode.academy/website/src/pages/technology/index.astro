---
import { css } from "styled-system/css";
export const prerender = true;

import Page from "@/wrappers/page.astro";
import { getCollection } from "astro:content";
import { resolveTechnologyIconUrl } from "@/utils/resolve-technology-icon";
import { createLogger } from "@/lib/logger";

const logger = createLogger("technology");

type Technology = {
	id: string;
	name: string;
	logo?: string;
	website?: string;
	documentation?: string;
};

let technologies: Technology[] = [];
try {
	const items = await getCollection("technologies");

	technologies = items.map((e) => {
		const logo = resolveTechnologyIconUrl(e.id, e.data.logos);

		const tech: Technology = {
			id: e.id,
			name: e.data.name,
			...(logo && { logo }),
			...(e.data.website && { website: e.data.website }),
			...(e.data.documentation && { documentation: e.data.documentation }),
		};
		return tech;
	});
} catch (error) {
	logger.error("Failed to load technologies from content collection", error);
}
---

<Page
	title="Technologies"
	description="Explore the various technologies covered on Rawkode Academy."
>
	<div class={css({
	display: 'flex',
	flexDir: 'column',
}) + " stack-gap-lg section-py section-pt-0 page-px"}>
		<!-- Hero Section -->
		<section class={css({
	w: 'full',
})}>
			<div class={css({
	rounded: '3xl',
	p: '6',
	md: {
		p: '8',
	},
	maxW: '7xl',
	mx: 'auto',
}) + " glass-panel"}>
				<div class={css({
	display: 'flex',
	flexDir: 'column',
	lg: {
		flexDir: 'row',
		alignItems: 'flex-start',
		justifyContent: 'space-between',
	},
	gap: '8',
})}>
					<!-- Hero Copy -->
					<div class={css({
	display: 'flex',
	flexDir: 'column',
	flex: '1',
	gap: '4',
	lg: {
		maxW: '80',
	},
})}>
						<span class="glass-chip">
							<svg class={css({
	w: '4',
	h: '4',
	mr: '1.5',
})} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
							</svg>
							Technology Hub
						</span>
						<h1 class={css({
	fontSize: '3xl',
	lineHeight: '1.1',
	letterSpacing: 'tight',
	md: {
		fontSize: '4xl',
	},
	fontWeight: 'extrabold',
}) + " text-primary-content"}>
							Explore technologies
						</h1>
						<p class={css({
	color: 'gray.600',
	maxW: 'xl',
}) + " dark:text-gray-300"}>
							Browse Rawkode Academy's catalogue of tools and platforms. Start typing to find what you're looking for.
						</p>
					</div>

					<!-- Search Controls -->
					<div class={css({
	display: 'flex',
	flexDir: 'column',
	w: 'full',
	flexShrink: '0',
	lg: {
		w: '96',
	},
	gap: '3',
})}>
						<label for="technology-search" class={css({
	display: 'block',
	fontSize: 'sm',
	fontWeight: 'medium',
	color: 'gray.700',
}) + " dark:text-gray-200"}>
							Search technologies
						</label>
						<div class={css({
	pos: 'relative',
})}>
							<svg class={css({
	pos: 'absolute',
	left: '4',
	top: '1/2',
	translateY: '-1/2',
	w: '5',
	h: '5',
	color: 'gray.400',
})} xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
							</svg>
							<input
								id="technology-search"
								type="search"
								placeholder="e.g. Grafana, Crossplane, Kubernetes..."
								class={css({
	w: 'full',
	rounded: 'xl',
	py: '3',
	pl: '12',
	pr: '4',
	fontSize: 'base',
	bg: 'white/60',
	backdropBlur: 'sm',
	borderWidth: '1px',
	borderColor: 'white/40',
	_focus: {
		ringWidth: '2',
		borderColor: 'primary/40',
	},
	transition: 'all',
}) + " text-primary-content placeholder-gray-400 dark:bg-gray-800/60 dark:border-gray-600/50 focus:outline-none focus:ring-primary/40"}
								autocomplete="off"
							/>
						</div>
						<p class={css({
	fontSize: 'sm',
	color: 'gray.500',
}) + " dark:text-gray-400"}>
							Showing <span class={css({
	fontWeight: 'medium',
	color: 'gray.700',
}) + " dark:text-gray-200"} data-tech-visible-count>{technologies.length}</span> of {technologies.length} technologies
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Technologies Grid -->
		<section id="technologies" class={css({
	w: 'full',
})}>
			<div class={css({
	maxW: '7xl',
	mx: 'auto',
})}>
				<div class={css({
	display: 'grid',
	gridTemplateColumns: '1fr',
	sm: {
		gridTemplateColumns: 'repeat(2, 1fr)',
	},
	lg: {
		gridTemplateColumns: 'repeat(3, 1fr)',
	},
	gap: '6',
})}>
					{
						technologies.map((tech) => {
							const searchKeywords = tech.name.toLowerCase();
							
							return (
								<a
									href={`/technology/${tech.id}`}
									class={css({
	display: 'flex',
	flexDir: 'column',
	overflow: 'hidden',
}) + " tech-card-link glass-card-shimmer card-hover"}
									data-keywords={searchKeywords}
								>
									{/* Logo Container */}
									<div class={css({
	h: '36',
	display: 'flex',
	alignItems: 'center',
	justifyContent: 'center',
	p: '6',
}) + " glass-media-brand"}>
										<img
											src={tech.logo ?? '/apple-touch-icon.png'}
											alt={`${tech.name} Logo`}
											class={css({
	w: '20',
	h: '20',
	objectFit: 'contain',
	dropShadow: 'lg',
})}
											onerror={`this.onerror=null; this.src='/apple-touch-icon.png';`}
										/>
									</div>
									
									{/* Content */}
									<div class={css({
	flex: '1',
	p: '5',
	display: 'flex',
	flexDir: 'column',
	gap: '3',
	pos: 'relative',
	zIndex: '10',
})}>
										<h3 class={css({
	fontSize: 'lg',
	fontWeight: 'bold',
}) + " text-primary-content"}>
											{tech.name}
										</h3>
										<span class={css({
	display: 'inline-flex',
	alignItems: 'center',
	gap: '1.5',
	fontSize: 'sm',
	fontWeight: 'medium',
	mt: 'auto',
}) + " text-primary"}>
											Learn more
											<svg class={css({
	w: '4',
	h: '4',
	transition: 'transform',
	_groupHover: {
		translateX: '0.5',
	},
})} xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
												<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
											</svg>
										</span>
									</div>
								</a>
							);
						})
					}
				</div>
				
				<!-- Empty State -->
				<div id="technology-empty-state" class={css({
	display: 'none',
})}>
					<div class={css({
	rounded: '2xl',
	p: '12',
	textAlign: 'center',
	maxW: 'md',
	mx: 'auto',
}) + " glass-card-shimmer"}>
						<svg class={css({
	w: '12',
	h: '12',
	mx: 'auto',
	color: 'gray.400',
	mb: '4',
}) + " dark:text-gray-500"} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
							<path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
						</svg>
						<p class={css({
	fontWeight: 'medium',
}) + " text-muted"}>No technologies match your search</p>
						<p class={css({
	fontSize: 'sm',
	color: 'gray.500',
	mt: '1',
}) + " dark:text-gray-500"}>Try a different term</p>
					</div>
				</div>
			</div>
		</section>

		<script>
			document.addEventListener("DOMContentLoaded", () => {
				const searchInput = document.getElementById("technology-search") as HTMLInputElement | null;
				const cards = Array.from(
					document.querySelectorAll<HTMLElement>("#technologies .tech-card-link"),
				);
				const emptyState = document.getElementById("technology-empty-state");
				const countTargets = document.querySelectorAll<HTMLElement>("[data-tech-visible-count]");

				const applySearch = () => {
					const query = (searchInput?.value ?? "").trim().toLowerCase();
					let visible = 0;

					cards.forEach((card) => {
						const keywords = card.dataset.keywords ?? "";
						const matchesSearch = keywords.includes(query);

						card.style.display = matchesSearch ? "" : "none";
						if (matchesSearch) {
							visible += 1;
						}
					});

					countTargets.forEach((el) => {
						el.textContent = visible.toString();
					});

					if (emptyState) {
						emptyState.classList.toggle("hidden", visible !== 0);
					}
				};

				searchInput?.addEventListener("input", applySearch);
				applySearch();
			});
		</script>
	</div>
</Page>
