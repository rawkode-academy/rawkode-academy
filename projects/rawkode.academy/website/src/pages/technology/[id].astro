<style>
	/* Adoption-stage tokens derive from the editorial palette so both
	   color schemes resolve automatically; no hand-flipped dark overrides. */
	.matrix-badge {
		--stage-skip: var(--editorial-rust);
		--stage-watch: var(--editorial-amber-text);
		--stage-explore: color-mix(
			in oklab,
			var(--editorial-amber-text) 45%,
			var(--editorial-spruce) 55%
		);
		--stage-learn: var(--editorial-violet);
		--stage-adopt: var(--editorial-spruce);
		--stage-advocate: var(--editorial-ink);
		--stage-graveyard: var(--editorial-ink-mute);
		--stage-guilty-pleasure: color-mix(
			in oklab,
			var(--editorial-rust) 50%,
			var(--editorial-violet) 50%
		);
		display: inline-flex;
		align-items: center;
		padding: 0.25rem 0.75rem;
		border-radius: 9999px;
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	/* Violet is not re-pointed by html.dark; lift the violet-derived
	   stages locally for contrast on dark surfaces. */
	:global(html.dark) .matrix-badge {
		--stage-learn: color-mix(in oklab, var(--editorial-violet) 60%, white 40%);
		--stage-guilty-pleasure: color-mix(
			in oklab,
			var(--editorial-violet) 35%,
			var(--editorial-rust) 65%
		);
	}

	.matrix-badge-skip,
	.matrix-badge-hold {
		background: color-mix(in oklab, var(--stage-skip) 12%, transparent);
		color: var(--stage-skip);
		border: 1px solid color-mix(in oklab, var(--stage-skip) 30%, transparent);
	}

	.matrix-badge-watch,
	.matrix-badge-assess {
		background: color-mix(in oklab, var(--stage-watch) 12%, transparent);
		color: var(--stage-watch);
		border: 1px solid color-mix(in oklab, var(--stage-watch) 30%, transparent);
	}

	.matrix-badge-explore,
	.matrix-badge-trial {
		background: color-mix(in oklab, var(--stage-explore) 12%, transparent);
		color: var(--stage-explore);
		border: 1px solid color-mix(in oklab, var(--stage-explore) 30%, transparent);
	}

	.matrix-badge-learn {
		background: color-mix(in oklab, var(--stage-learn) 12%, transparent);
		color: var(--stage-learn);
		border: 1px solid color-mix(in oklab, var(--stage-learn) 30%, transparent);
	}

	.matrix-badge-adopt {
		background: color-mix(in oklab, var(--stage-adopt) 12%, transparent);
		color: var(--stage-adopt);
		border: 1px solid color-mix(in oklab, var(--stage-adopt) 30%, transparent);
	}

	.matrix-badge-advocate {
		background: color-mix(in oklab, var(--stage-advocate) 12%, transparent);
		color: var(--stage-advocate);
		border: 1px solid color-mix(in oklab, var(--stage-advocate) 30%, transparent);
	}

	/* Special zones */
	.matrix-badge-graveyard {
		background: color-mix(in oklab, var(--stage-graveyard) 12%, transparent);
		color: var(--stage-graveyard);
		border: 1px solid color-mix(in oklab, var(--stage-graveyard) 30%, transparent);
	}

	.matrix-badge-guilty-pleasure {
		background: color-mix(in oklab, var(--stage-guilty-pleasure) 12%, transparent);
		color: var(--stage-guilty-pleasure);
		border: 1px solid color-mix(in oklab, var(--stage-guilty-pleasure) 30%, transparent);
	}

	.technology-stage {
		max-width: 84rem;
		margin: 0 auto;
		display: grid;
		gap: clamp(1.5rem, 3vw, 2.5rem);
	}

	.technology-hero {
		position: relative;
	}

	.technology-hero-logo {
		flex-shrink: 0;
		width: 3rem;
		height: 3rem;
		display: grid;
		place-items: center;
	}

	@media (min-width: 768px) {
		.technology-hero-logo {
			width: 4rem;
			height: 4rem;
		}
	}

	.technology-hero-logo img {
		max-width: 100%;
		max-height: 100%;
	}

	.matrix-badge-link {
		text-decoration: none;
		transition: transform 180ms ease, filter 180ms ease;
	}

	.matrix-badge-link:hover {
		transform: translateY(-1px);
		filter: brightness(1.05);
	}

	.technology-cta-row {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.875rem;
	}

	@media (min-width: 640px) {
		.technology-cta-row {
			flex-direction: row;
			flex-wrap: wrap;
			align-items: center;
			gap: 0.5rem 1.25rem;
		}
	}

	.btn-outline {
		color: var(--text-primary-content);
		background: transparent;
		border: 1px solid rgba(148, 163, 184, 0.45);
		transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
	}

	.btn-outline:hover {
		transform: translateY(-1px);
		border-color: var(--brand-primary);
		background: rgb(var(--brand-primary) / 0.04);
	}

	:global(.dark) .btn-outline {
		border-color: rgba(148, 163, 184, 0.32);
	}

	.text-link {
		color: var(--text-secondary-content);
		font-weight: 500;
		text-decoration: none;
		transition: color 180ms ease;
	}

	.text-link:hover {
		color: var(--brand-primary);
		text-decoration: underline;
		text-underline-offset: 3px;
	}

	.technology-primary-link,
	.technology-primary-link:visited {
		background: var(--editorial-ink) !important;
		border-color: var(--editorial-ink) !important;
		color: var(--editorial-paper) !important;
	}

	.technology-primary-link:hover {
		color: var(--editorial-paper) !important;
	}

	.technology-kicker {
		/* retained for the Field Guide kicker further down the page */
		margin: 0 0 0.85rem;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: rgb(13, 148, 136);
	}

	.technology-taxonomy-pill {
		display: inline-flex;
		align-items: center;
		padding: 0.25rem 0.65rem;
		border-radius: 9999px;
		font-size: 0.72rem;
		font-weight: 600;
		color: var(--text-secondary-content);
		background: rgba(148, 163, 184, 0.12);
		border: 1px solid rgba(148, 163, 184, 0.22);
	}

	.technology-title {
		margin: 0;
		font-size: clamp(2rem, 6vw, 3.2rem);
		line-height: 1.04;
		font-weight: 800;
		letter-spacing: -0.04em;
		color: var(--text-primary-content);
		text-wrap: balance;
	}

	.main-content-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		gap: 1.25rem;
		align-items: start;
	}

	.main-content-grid > * {
		min-width: 0;
	}

	.media-rail {
		display: grid;
		gap: 1rem;
	}

	.guide-panel {
		min-width: 0;
		overflow-wrap: anywhere;
		border: 1px solid rgba(148, 163, 184, 0.16);
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(255, 255, 255, 0.9)),
			radial-gradient(circle at top left, rgba(45, 212, 191, 0.08), transparent 32%);
		box-shadow:
			0 18px 44px rgba(15, 23, 42, 0.06),
			inset 0 1px 0 rgba(255, 255, 255, 0.82);
	}

	/* Mobile: pull the grid all the way out to the viewport edges (escapes
	 * both the main layout's page-px and .technology-stage's page-px) and
	 * strip card chrome on each panel so content reaches the device edges.
	 * The panels' internal padding stays put, keeping prose aligned with
	 * the breadcrumb/hero. */
	@media (max-width: 639px) {
		.main-content-grid {
			margin-inline: calc(50% - 50vw);
		}

		.guide-panel,
		.video-panel,
		.matrix-rail-panel {
			border-radius: 0;
			border-inline: 0;
			box-shadow: none;
		}

		.technology-signal-panel {
