						{technology.license && (
							<p class={css({
	mt: '3',
	fontSize: 'sm',
}) + " text-muted"}>
								License: <span class={css({
	fontWeight: 'medium',
}) + " text-secondary-content"}>{technology.license}</span>
							</p>
						)}
					</div>
				</div>
			</div>
		</section>

		<!-- Rawkode's Take (Card Back) -->
		{technology.matrix && (technology.matrix.why || technology.matrix.spicyTake || technology.matrix.makesMeFeel) && (
			<section class={css({
	w: 'full',
})}>
				<div class={css({
	rounded: '3xl',
	p: '6',
	md: {
		p: '8',
	},
	maxW: '7xl',
	mx: 'auto',
}) + " glass-panel"}>
					<div class={css({
	display: 'flex',
	flexDir: 'column',
	md: {
		flexDir: 'row',
	},
	gap: '6',
})}>
						<!-- Left: Emoji & Why -->
						<div class={css({
	flex: '1',
})}>
							<div class={css({
	display: 'flex',
	alignItems: 'center',
	gap: '3',
	mb: '4',
})}>
								{technology.matrix.makesMeFeel && (
									<span class={css({
	fontSize: '4xl',
})}>{technology.matrix.makesMeFeel}</span>
								)}
								<div>
									<h2 class={css({
	fontSize: 'xl',
	fontWeight: 'bold',
}) + " text-primary-content"}>Rawkode's Take</h2>
									<p class={css({
	fontSize: 'sm',
}) + " text-muted"}>Personal opinion, not gospel</p>
								</div>
							</div>
							{technology.matrix.why && (
								<p class={css({
	lineHeight: 'relaxed',
	mb: '4',
}) + " text-secondary-content"}>
									{technology.matrix.why}
								</p>
							)}
							{technology.matrix.spicyTake && (
								<div class={css({
	display: 'flex',
	alignItems: 'flex-start',
	gap: '2',
	p: '3',
	bg: 'red.50',
	borderWidth: '1px',
	borderColor: 'red.200',
	rounded: 'xl',
}) + " dark:bg-red-900/20 dark:border-red-800/40"}>
									<span class={css({
	fontSize: 'lg',
	flexShrink: '0',
})}>🌶️</span>
									<p class={css({
	fontSize: 'sm',
	fontStyle: 'italic',
	color: 'red.800',
}) + " dark:text-red-200"}>
										{technology.matrix.spicyTake}
									</p>
								</div>
							)}
