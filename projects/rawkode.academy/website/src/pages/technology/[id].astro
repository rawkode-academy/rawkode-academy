---
export const prerender = true;

import Breadcrumb from "@/components/breadcrumb/Breadcrumb.astro";
import Prose from "@/components/prose/Prose.astro";
import TechnologyJsonLd from "@/components/html/technology-jsonld.astro";
import Page from "@/wrappers/page.astro";
import type { GetStaticPaths } from "astro";
import { getCollection, render } from "astro:content";
import matter from "gray-matter";
import { readdir, readFile } from "node:fs/promises";
import { join } from "node:path";
import {
	type TechnologyData,
	DEFAULT_TECHNOLOGY_STATUS,
	DEFAULT_TECHNOLOGY_LICENSE,
} from "@rawkodeacademy/content";
import { resolveContentDirSync } from "@rawkodeacademy/content/utils";
import { resolveTechnologyIconUrl } from "@/utils/resolve-technology-icon";
import { getVideosForTechnology } from "@/utils/get-videos-for-technology";
import { css } from "../../../styled-system/css";

export interface Technology extends Omit<TechnologyData, "logos"> {
	id: string;
	logo?: string | undefined;
	videos?: { id: string; title: string; thumbnailUrl: string; slug: string }[] | undefined;
	videoCount?: number;
	articleCount?: number;
}

export const getStaticPaths = (async () => {
	try {
		const items = await getCollection("technologies");
		if (items.length > 0) {
			return Promise.all(
				items.map(async (e) => {
					const logo = resolveTechnologyIconUrl(e.id, e.data.logos) ?? undefined;
					const videos = await getVideosForTechnology(e.id);
					return {
						params: { id: e.id },
						props: {
							technology: {
								id: e.id,
								name: e.data.name,
								seo: e.data.seo,
								documentation: e.data.documentation,
								website: e.data.website,
								source: e.data.source,
								license: e.data.license,
								category: e.data.category,
								subcategory: e.data.subcategory,
								status: e.data.status,
								logo,
								videos,
								matrix: e.data.matrix,
								cncf: e.data.cncf,
								community: e.data.community,
							} as Technology,
						},
					};
				}),
			);
		}
	} catch (error) {
		console.warn("getCollection('technologies') failed; falling back to FS glob:", error);
	}

	try {
		const base = resolveContentDirSync("technologies");
		async function walk(dir: string, rel = ""): Promise<string[]> {
			const out: string[] = [];
			const entries = await readdir(dir, { withFileTypes: true });
			for (const e of entries) {
				const p = join(dir, e.name);
				const r = rel ? join(rel, e.name) : e.name;
				if (e.isDirectory()) out.push(...(await walk(p, r)));
				else if (e.isFile() && /\.mdx$/i.test(e.name)) out.push(r);
			}
			return out;
		}
		const files = await walk(base);
		return await Promise.all(
			files.map(async (rel) => {
				const id = rel.replace(/\.mdx$/i, "");
				try {
					const raw = await readFile(join(base, rel), "utf8");
					const fm = matter(raw).data as any;
					const logo = resolveTechnologyIconUrl(id, fm.logos) ?? undefined;
					const videos = await getVideosForTechnology(id);
					return {
						params: { id },
						props: {
							technology: {
								id,
								name: fm.name ?? id,
								seo: fm.seo,
								documentation: fm.documentation,
								website: fm.website,
								source: fm.source,
								license: fm.license,
								category: fm.category,
								subcategory: fm.subcategory,
								status: fm.status,
								logo,
								videos,
								matrix: fm.matrix,
								cncf: fm.cncf,
								community: fm.community,
							} as Technology,
						},
					};
				} catch {
					const videos = await getVideosForTechnology(id);
					return {
						params: { id },
						props: {
							technology: {
								id,
								name: id,
								videos,
								status: DEFAULT_TECHNOLOGY_STATUS,
								website: "",
								license: DEFAULT_TECHNOLOGY_LICENSE,
							} as Technology,
						},
					};
				}
			}),
		);
	} catch (error) {
		console.error("FS fallback for technologies failed:", error);
		return [];
	}
}) satisfies GetStaticPaths;

let { technology } = Astro.props as { technology?: Technology };
const id = Astro.params.id as string;
const items = await getCollection("technologies");
const technologyEntry = items.find((x) => x.id === id);
let Content: any = null;
let hasContent = false;
if (technologyEntry) {
	try {
		const rendered = await render(technologyEntry);
		Content = rendered.Content;
		hasContent = Boolean(technologyEntry.body && technologyEntry.body.trim().length > 0);
	} catch (err) {
		console.warn("Failed to render technology content:", err);
	}
}

if (!technology && technologyEntry) {
	const logo = resolveTechnologyIconUrl(technologyEntry.id, technologyEntry.data.logos) ?? undefined;
	const videos = await getVideosForTechnology(technologyEntry.id);
	technology = {
		id: technologyEntry.id,
		name: technologyEntry.data.name,
		seo: technologyEntry.data.seo,
		documentation: technologyEntry.data.documentation,
		website: technologyEntry.data.website,
		source: technologyEntry.data.source,
		license: technologyEntry.data.license,
		category: technologyEntry.data.category,
		subcategory: technologyEntry.data.subcategory,
		status: technologyEntry.data.status,
		logo,
		videos,
		matrix: technologyEntry.data.matrix,
		cncf: technologyEntry.data.cncf,
		community: technologyEntry.data.community,
	};
}

if (!technology) return Astro.redirect("/technology");

const placeholderLogo = "/apple-touch-icon.png";
const videoCount = technology.videos?.length ?? 0;
const featuredVideos = (technology.videos ?? []).slice(0, 6);
const categoryLabel = technology.subcategory ?? technology.category ?? "Cloud Native";

const seoTitle = technology.seo?.title ?? (videoCount > 0 ? `${technology.name} Tutorials, Videos & Guides | Rawkode Academy` : `${technology.name} — ${categoryLabel} | Rawkode Academy`);

const seoDescription = (() => {
	if (technology.seo?.description) return technology.seo.description;
	const cncfUseCase = (technology as any).cncf?.useCase as string | undefined;
	const parts: string[] = [];
	if (videoCount > 0) parts.push(`${videoCount} video${videoCount === 1 ? "" : "s"} and tutorials covering ${technology.name}`);
	else parts.push(`${technology.name}, a ${categoryLabel} project`);
	if (cncfUseCase) parts.push(cncfUseCase);
	parts.push(`Watch deep-dives, live coding, and interviews from Rawkode Academy.`);
	return parts.join(". ");
})();

const noindex = !hasContent && videoCount === 0;

const technologyUrl = new URL(`/technology/${technology.id.replace(/\/index$/, "")}`, Astro.site).href;
const absoluteLogo = technology.logo ? (technology.logo.startsWith("http") ? technology.logo : new URL(technology.logo, Astro.site).href) : undefined;

const cncfStatusLabels: Record<string, string> = {
	sandbox: "Sandbox",
	incubating: "Incubating",
	graduated: "Graduated",
	archived: "Archived",
};

const hasCommunityLinks =
	technology.community &&
	(technology.community.twitter ||
		technology.community.youtube ||
		technology.community.slack ||
		technology.community.blog ||
		technology.community.mailingList ||
		technology.community.githubDiscussions ||
		technology.community.chat);

const shell = css({ maxWidth: "80rem", mx: "auto", px: { base: "4", md: "6" }, py: "10" });

const heroCard = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", md: "1fr auto" },
	gap: "8",
	alignItems: "center",
	p: { base: "8", md: "12" },
	borderRadius: "3xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	backgroundImage:
		"radial-gradient(circle at 20% 20%, token(colors.brand.500)/10, transparent 50%), radial-gradient(circle at 80% 30%, token(colors.cyan.500)/10, transparent 50%)",
});

const tagRow = css({ display: "flex", flexWrap: "wrap", gap: "2", mb: "4" });

const cncfBadge = css({
	display: "inline-flex",
	alignItems: "center",
	px: "2.5",
	py: "1",
	borderRadius: "full",
	bg: "bg.brand-subtle",
	color: "fg.brand",
	fontSize: "xs",
	fontWeight: "semibold",
});

const catPill = css({
	display: "inline-flex",
	px: "2.5",
	py: "1",
	borderRadius: "full",
	bg: "bg.surface",
	borderWidth: "1px",
	borderColor: "border.muted",
	color: "fg.muted",
	fontSize: "xs",
	fontWeight: "medium",
});

const eyebrow = css({ fontSize: "xs", fontWeight: "bold", letterSpacing: "wider", textTransform: "uppercase", color: "fg.brand", mb: "2" });

const title = css({
	fontFamily: "display",
	fontSize: { base: "4xl", md: "5xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	color: "fg.primary",
	mb: "6",
});

const btnRow = css({ display: "flex", flexWrap: "wrap", gap: "3", alignItems: "center" });

const primaryBtn = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "5",
	py: "2.5",
	borderRadius: "lg",
	fontWeight: "semibold",
	color: "fg.on-brand",
	backgroundImage: "linear-gradient(135deg, token(colors.brand.500), token(colors.cyan.500))",
	textDecoration: "none",
	transition: "transform 150ms ease",
	_hover: { transform: "translateY(-1px)" },
});

const ghostBtn = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "5",
	py: "2.5",
	borderRadius: "lg",
	fontWeight: "semibold",
	color: "fg.primary",
	bg: "bg.surface",
	borderWidth: "1px",
	borderColor: "border.default",
	textDecoration: "none",
	_hover: { bg: "bg.sunken" },
});

const licenseLine = css({ mt: "4", fontSize: "sm", color: "fg.muted" });
const licenseEm = css({ fontWeight: "medium", color: "fg.secondary" });

const logoBox = css({
	w: "40",
	h: "40",
	p: "6",
	borderRadius: "3xl",
	bg: "bg.surface",
	borderWidth: "1px",
	borderColor: "border.muted",
	display: "flex",
	alignItems: "center",
	justifyContent: "center",
	"& img": { maxWidth: "full", maxHeight: "full", objectFit: "contain" },
});

const sectionBlock = css({ mt: "16" });

const sectionTitle = css({
	fontFamily: "display",
	fontSize: { base: "2xl", md: "3xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	color: "fg.primary",
	mb: "6",
});

const videoGrid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", sm: "repeat(2, minmax(0, 1fr))", lg: "repeat(3, minmax(0, 1fr))" },
	gap: "5",
});

const videoCard = css({
	display: "flex",
	flexDirection: "column",
	overflow: "hidden",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textDecoration: "none",
	color: "fg.primary",
	transition: "transform 200ms ease, box-shadow 200ms ease",
	_hover: { transform: "translateY(-2px)", boxShadow: "lg" },
});

const videoThumb = css({
	aspectRatio: "16 / 9",
	bg: "bg.sunken",
	overflow: "hidden",
	"& img": { width: "full", height: "full", objectFit: "cover" },
});

const videoBody = css({ p: "5" });
const videoTitle = css({ fontSize: "md", fontWeight: "semibold", color: "fg.primary", lineHeight: "tight", display: "-webkit-box", WebkitLineClamp: "2", WebkitBoxOrient: "vertical", overflow: "hidden" });

const communityGrid = css({
	display: "grid",
	gridTemplateColumns: { base: "repeat(2, minmax(0, 1fr))", sm: "repeat(3, minmax(0, 1fr))", md: "repeat(4, minmax(0, 1fr))" },
	gap: "3",
});

const communityLink = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "4",
	py: "3",
	borderRadius: "xl",
	bg: "bg.surface",
	color: "fg.secondary",
	textDecoration: "none",
	fontSize: "sm",
	fontWeight: "medium",
	transition: "all 150ms ease",
	_hover: { bg: "bg.brand-subtle", color: "fg.brand" },
});

const guideCard = css({
	mt: "16",
	p: { base: "6", md: "10" },
	borderRadius: "3xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
});

const guideEyebrow = css({
	fontSize: "xs",
	fontWeight: "bold",
	letterSpacing: "wider",
	textTransform: "uppercase",
	color: "fg.brand",
});

const guideTitle = css({
	fontFamily: "display",
	fontSize: { base: "2xl", md: "3xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	color: "fg.primary",
	mt: "2",
	mb: "6",
});
---

<Page
	title={seoTitle}
	description={seoDescription}
	noindex={noindex}
	useImageDirectly={Boolean(absoluteLogo)}
	image={absoluteLogo ? { image: new URL(absoluteLogo) } : undefined}
>
	<TechnologyJsonLd
		slot="extra-head"
		name={technology.name}
		url={technologyUrl}
		description={seoDescription}
		image={absoluteLogo}
		website={technology.website}
		source={technology.source}
		documentation={technology.documentation}
		category={categoryLabel}
	/>
	<Fragment slot="extra-head">
		<link rel="alternate" type="application/rss+xml" title={`Rawkode Academy — ${technology.name} (RSS)`} href={`/api/feeds/technology/${technology.id.replace(/\/index$/, "")}.xml`} />
	</Fragment>

	<div class={shell}>
		<Breadcrumb elements={[{ title: "Home", link: "/" }, { title: "Technologies", link: "/technology" }, { title: technology.name, link: `/technology/${technology.id}` }]} />

		<section class={heroCard}>
			<div>
				<div class={tagRow}>
					{technology.cncf?.status && (
						<span class={cncfBadge}>CNCF {cncfStatusLabels[technology.cncf.status] ?? technology.cncf.status}</span>
					)}
					{technology.category && (
						<span class={catPill}>
							{technology.category}{technology.subcategory && ` / ${technology.subcategory}`}
						</span>
					)}
				</div>
				<p class={eyebrow}>{hasContent ? "Technology Guide" : "Technology Overview"}</p>
				<h1 class={title}>{technology.name}</h1>
				<div class={btnRow}>
					{technology.website && (
						<a href={technology.website} target="_blank" rel="noopener noreferrer" class={primaryBtn}>Official Website</a>
					)}
					{technology.documentation && (
						<a href={technology.documentation} target="_blank" rel="noopener noreferrer" class={ghostBtn}>Documentation</a>
					)}
					{technology.source && (
						<a href={technology.source} target="_blank" rel="noopener noreferrer" class={ghostBtn}>Source Code</a>
					)}
				</div>
				{technology.license && (
					<p class={licenseLine}>License: <span class={licenseEm}>{technology.license}</span></p>
				)}
			</div>
			<div class={logoBox}>
				<img src={technology.logo ? technology.logo : placeholderLogo} alt={`${technology.name} logo`} onerror={`this.onerror=null; this.src='${placeholderLogo}';`} />
			</div>
		</section>

		{featuredVideos.length > 0 && (
			<section class={sectionBlock}>
				<h2 class={sectionTitle}>Videos & Tutorials</h2>
				<div class={videoGrid}>
					{featuredVideos.map((v) => (
						<a href={`/watch/${v.slug}`} class={videoCard}>
							<div class={videoThumb}>
								<img src={v.thumbnailUrl} alt={v.title} loading="lazy" />
							</div>
							<div class={videoBody}>
								<h3 class={videoTitle}>{v.title}</h3>
							</div>
						</a>
					))}
				</div>
			</section>
		)}

		{hasCommunityLinks && technology.community && (
			<section class={sectionBlock}>
				<h2 class={sectionTitle}>Community</h2>
				<div class={communityGrid}>
					{technology.community.twitter && <a href={technology.community.twitter} target="_blank" rel="noopener noreferrer" class={communityLink}>Twitter</a>}
					{technology.community.youtube && <a href={technology.community.youtube} target="_blank" rel="noopener noreferrer" class={communityLink}>YouTube</a>}
					{technology.community.slack && <a href={technology.community.slack} target="_blank" rel="noopener noreferrer" class={communityLink}>Slack</a>}
					{technology.community.blog && <a href={technology.community.blog} target="_blank" rel="noopener noreferrer" class={communityLink}>Blog</a>}
					{technology.community.mailingList && <a href={technology.community.mailingList} target="_blank" rel="noopener noreferrer" class={communityLink}>Mailing List</a>}
					{technology.community.githubDiscussions && <a href={technology.community.githubDiscussions} target="_blank" rel="noopener noreferrer" class={communityLink}>GitHub Discussions</a>}
					{technology.community.chat && <a href={technology.community.chat} target="_blank" rel="noopener noreferrer" class={communityLink}>Chat</a>}
				</div>
			</section>
		)}

		{hasContent && Content && (
			<section id="complete-guide" class={guideCard}>
				<span class={guideEyebrow}>Field Guide</span>
				<h2 class={guideTitle}>Complete Guide</h2>
				<Prose>
					<Content />
				</Prose>
			</section>
		)}
	</div>
</Page>
