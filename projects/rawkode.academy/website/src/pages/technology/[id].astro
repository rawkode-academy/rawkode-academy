						<div class={css({
	display: 'flex',
	flexWrap: 'wrap',
	alignItems: 'center',
	gap: '2',
	mb: '3',
	justifyContent: 'center',
	md: {
		justifyContent: 'flex-start',
	},
})}>
							{technology.matrix && (
								<a href="/technology/matrix" class={css({
	display: 'inline-flex',
	flexWrap: 'wrap',
	alignItems: 'center',
	gap: '2',
}) + " group"}>
									<span class={`matrix-badge matrix-badge-${technology.matrix.status}`}>
										{statusLabel}
									</span>
									<span class={css({
	fontSize: 'sm',
	transition: 'colors',
}) + " text-muted group-hover:text-primary"}>
										{groupingLabel}
									</span>
									{trajectoryIcon && (
										<span class={css({
	fontSize: 'sm',
})} title={`Trajectory: ${technology.matrix.trajectory}`}>
											{trajectoryIcon}
										</span>
									)}
									<svg class={css({
	w: '4',
	h: '4',
	color: 'gray.400',
	transition: 'colors',
}) + " group-hover:text-primary"} fill="none" viewBox="0 0 24 24" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
									</svg>
								</a>
							)}
							{technology.cncf?.status && (
								<span class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold border ${cncfStatusColors[technology.cncf.status]}`}>
