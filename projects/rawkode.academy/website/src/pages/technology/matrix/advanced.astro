---
export const prerender = true;

import { getCollection } from "astro:content";
import Page from "@/wrappers/page.astro";
import { Container } from "@/components/ui";
import {
	normalizeTechnology,
	serializeForClient,
	type RawTechnology,
} from "@/lib/explorer/data-layer";
import { resolveTechnologyIconUrl } from "@/utils/resolve-technology-icon";
import TechnologyExplorer from "@/components/explorer/TechnologyExplorer.vue";

// Helper to normalize technology references from videos
function normalizeTechnologyRef(value: unknown): string | undefined {
	if (typeof value === "string") {
		return value.replace(/\/index$/, "");
	}
	if (typeof value === "object" && value !== null) {
		const ref = (value as any).id ?? (value as any).slug;
		if (typeof ref === "string") return ref.replace(/\/index$/, "");
	}
	return undefined;
}

// Compute video counts per technology
const allVideos = await getCollection("videos");
const videoCountsByTech = new Map<string, number>();
for (const video of allVideos) {
	const techs = video.data.technologies;
	if (Array.isArray(techs)) {
		for (const tech of techs) {
			const techId = normalizeTechnologyRef(tech);
			if (techId) {
				videoCountsByTech.set(techId, (videoCountsByTech.get(techId) || 0) + 1);
			}
		}
	}
}

// Get all technologies
const allTechnologies = await getCollection("technologies");

// Normalize technologies for the explorer
const normalizedTechnologies = allTechnologies.map((tech) => {
	const rawTech: RawTechnology = {
		id: tech.id,
		data: tech.data as RawTechnology["data"],
	};
	// Resolve icon URL using Vite's asset processing
	const iconUrl = resolveTechnologyIconUrl(tech.id, tech.data.logos) ?? null;
	return normalizeTechnology(
		rawTech,
		videoCountsByTech.get(tech.id) || 0,
		0, // articleCount - TODO: wire up when available
		iconUrl,
	);
});

// Serialize for client
const technologiesJson = serializeForClient(normalizedTechnologies);

// Stats for meta
const totalTechnologies = normalizedTechnologies.length;
---

<Page
	title="Advanced Technology Matrix"
	description="Filter and compare cloud native and platform engineering technologies by adoption stage, category, confidence, and trajectory."
>
	<section class="explorer-hero">
		<div class="hero-background">
			<div class="hero-gradient"></div>
			<div class="hero-grid"></div>
		</div>
		<Container size="xl" padding="lg">
			<div class="hero-content">
				<a href="/technology/matrix" class="back-link">Technology Matrix</a>
				<div class="hero-badge hairline-chip">
					<span class="badge-dot"></span>
					<span>{totalTechnologies} technologies</span>
				</div>
				<h1 class="hero-title">Advanced Technology Matrix</h1>
				<p class="hero-subtitle text-secondary-content">
					Filter and compare tools by adoption stage, category, confidence, and trajectory.
				</p>
			</div>
		</Container>
	</section>

	<Container size="xl" padding="lg">
		<div class="explorer-shell">
			<TechnologyExplorer
				client:load
				technologies={JSON.parse(technologiesJson)}
			/>
		</div>
	</Container>
</Page>

<style>
	.explorer-hero {
		position: relative;
		padding: clamp(2rem, 4vw, 3.5rem) 0 clamp(1.5rem, 3vw, 2.5rem);
		overflow: hidden;
		border-bottom: 1px solid var(--editorial-hairline);
	}

	.hero-background {
		position: absolute;
		inset: 0;
		z-index: 0;
	}

	.hero-gradient {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			135deg,
			color-mix(in oklab, var(--editorial-paper-deep) 74%, transparent),
			color-mix(in oklab, var(--editorial-paper) 92%, transparent)
		);
	}

	.hero-grid {
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(var(--surface-border) 1px, transparent 1px),
			linear-gradient(90deg, var(--surface-border) 1px, transparent 1px);
		background-size: 60px 60px;
		opacity: 0.55;
	}

	.hero-content {
		position: relative;
		z-index: 1;
		text-align: left;
	}

	.back-link {
		display: inline-flex;
		margin-bottom: 1rem;
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		text-decoration: none;
		color: var(--editorial-spruce);
	}

	.hero-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		margin-bottom: 1rem;
	}

	.badge-dot {
		width: 6px;
		height: 6px;
		background: rgb(var(--brand-primary));
		border-radius: 50%;
	}

	.hero-title {
		max-width: 58rem;
		font-family: var(--font-instrument-serif), serif;
		font-size: clamp(2.75rem, 7vw, 6rem);
		font-style: italic;
		font-weight: 500;
		letter-spacing: 0;
		line-height: 0.95;
		margin: 0 0 0.75rem;
		color: var(--editorial-ink);
	}

	.hero-subtitle {
		max-width: 44rem;
		font-size: clamp(1rem, 1.8vw, 1.28rem);
		margin: 0;
		line-height: 1.45;
	}

	.explorer-shell {
		padding: clamp(1.25rem, 3vw, 2rem) 0 4rem;
	}

	@media (max-width: 768px) {
		.explorer-hero {
			padding: 1.75rem 0 1.5rem;
		}
	}
</style>
