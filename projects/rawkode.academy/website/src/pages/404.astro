---
import MinimalLayout from "@/layouts/minimal.astro";
import { css } from "../../styled-system/css";

export const prerender = true;

const quickLinks = [
	{
		title: "Return home",
		description: "Head back to the front page and resume your journey.",
		href: "/",
	},
	{
		title: "Browse courses",
		description: "Deep dives, labs, and workshops from Rawkode Academy.",
		href: "/courses",
	},
	{
		title: "Learning paths",
		description: "Opinionated roadmaps to master cloud native topics.",
		href: "/learning-paths",
	},
	{
		title: "Technology guides",
		description: "Explore the tools, runtimes, and projects we teach.",
		href: "/technology",
	},
];

const supportLinks = [
	{
		title: "Search the site",
		description: "Find videos, articles, and docs across the academy.",
		href: "/search",
	},
	{
		title: "Chat on Discord",
		description: "Ask the community for a direct link or recommendation.",
		href: "https://discord.gg/rawkode",
	},
];
---

<MinimalLayout title="404 – Rawkode Academy" description="We couldn't find that page, but here are a few quick ways to get back on course.">
	<main class={css({ position: "relative", isolation: "isolate", minH: "100vh", overflow: "hidden", bg: "slate.950", color: "slate.100" })}>
		<div class={css({ pointerEvents: "none", position: "absolute", inset: "0" })}>
			<div class={css({ position: "absolute", top: "-8rem", left: "50%", h: "20rem", w: "20rem", transform: "translateX(-50%)", borderRadius: "full", bg: "rgba(var(--brand-primary), 0.3)", filter: "blur(48px)" })}></div>
			<div class={css({ position: "absolute", bottom: "0", left: "0", right: "0", h: "10rem", background: "linear-gradient(to top, rgb(2 6 23), rgba(2, 6, 23, 0.7), transparent)" })}></div>
			<div class={css({ position: "absolute", inset: "0", background: "radial-gradient(circle at top, rgba(148,163,184,0.12), transparent 55%)" })}></div>
		</div>

		<section class={css({ position: "relative", zIndex: "10", px: "6", py: { base: "24", sm: "32" } })}>
			<div class={css({ mx: "auto", display: "flex", maxW: "4xl", flexDir: "column", alignItems: "center", textAlign: "center" })}>
				<p class={css({ fontSize: "xs", textTransform: "uppercase", letterSpacing: "0.4em", color: "rgba(var(--brand-primary), 0.7)" })}>Lost in the cluster</p>
				<h1 class={css({ mt: "6", fontSize: { base: "4xl", sm: "5xl" }, fontWeight: "semibold", lineHeight: "tight", color: "white" })}>
					We couldn't route that request.
				</h1>
				<p class={css({ mt: "4", fontSize: "lg", color: "slate.300" })}>
					The page you're looking for may have moved, or the URL has a typo. Let's get you
					back to shipping something great.
				</p>
				<div class={css({ mt: "10", display: "flex", flexWrap: "wrap", alignItems: "center", justifyContent: "center", gap: "4" })}>
					<a
						href="/"
						class={css({ display: "inline-flex", alignItems: "center", gap: "2", borderRadius: "2xl", background: "linear-gradient(to right, rgb(var(--brand-primary)), rgb(var(--brand-secondary)))", px: "6", py: "3", fontSize: "base", fontWeight: "semibold", color: "white", boxShadow: "0 10px 15px -3px rgba(var(--brand-primary), 0.3)", transition: "all", _hover: { transform: "scale(1.01)" } })}
					>
						<span>Back to homepage</span>
						<svg class={css({ h: "5", w: "5" })} fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14m-7-7l7 7-7 7" />
						</svg>
					</a>
					<a
						href="https://github.com/rawkode-academy/rawkode-academy/issues/new/choose"
						class={css({ display: "inline-flex", alignItems: "center", gap: "2", borderRadius: "2xl", border: "1px solid rgba(255, 255, 255, 0.2)", px: "6", py: "3", fontSize: "base", fontWeight: "semibold", color: "rgba(255, 255, 255, 0.9)", transition: "all", _hover: { borderColor: "rgba(255, 255, 255, 0.4)" } })}
						target="_blank"
						rel="noopener noreferrer"
					>
						Report an issue
						<svg class={css({ h: "5", w: "5" })} fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h4m0 0v4m0-4l-5 5m-1 6a9 9 0 110-18 9 9 0 010 18z" />
						</svg>
					</a>
				</div>
			</div>

			<form action="/search" method="get" class={css({ mx: "auto", mt: "12", display: "flex", maxW: "3xl", alignItems: "center", justifyContent: "space-between", gap: "2", borderRadius: "3xl", border: "1px solid rgba(255, 255, 255, 0.1)", bg: "rgba(255, 255, 255, 0.05)", px: "4", py: "3", textAlign: "left", backdropFilter: "blur(12px)" })}>
				<div class={css({ display: "flex", flex: "1", flexDir: "column" })}>
					<label for="not-found-search" class={css({ fontSize: "xs", textTransform: "uppercase", letterSpacing: "0.3em", color: "rgba(255, 255, 255, 0.6)" })}>Search everything</label>
					<input
						type="search"
						name="q"
						id="not-found-search"
						placeholder="Videos, docs, workshops, experiments..."
						class={css({ mt: "2", bg: "transparent", fontSize: "base", color: "white", outline: "none", _placeholder: { color: "slate.400" } })}
						required
					/>
				</div>
				<button
					type="submit"
					class={css({ display: "inline-flex", h: "12", w: "12", alignItems: "center", justifyContent: "center", borderRadius: "2xl", bg: "rgba(255, 255, 255, 0.1)", color: "white", transition: "all", _hover: { bg: "rgba(255, 255, 255, 0.2)" } })}
					aria-label="Search"
				>
					<svg class={css({ h: "5", w: "5" })} fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
					</svg>
				</button>
			</form>

			<div class={css({ mx: "auto", mt: "16", display: "grid", maxW: "5xl", gap: "6", gridTemplateColumns: { md: "repeat(2, 1fr)" } })}>
				{quickLinks.map((link) => (
					<a
						href={link.href}
						class={css({ position: "relative", overflow: "hidden", borderRadius: "3xl", border: "1px solid rgba(255, 255, 255, 0.1)", bg: "rgba(255, 255, 255, 0.05)", p: "6", textAlign: "left", backdropFilter: "blur(12px)", transition: "all", _hover: { borderColor: "rgba(255, 255, 255, 0.3)", bg: "rgba(255, 255, 255, 0.1)" } })}
					>
						<div class={css({ display: "flex", alignItems: "center", justifyContent: "space-between", gap: "6" })}>
							<div>
								<p class={css({ fontSize: "sm", textTransform: "uppercase", letterSpacing: "0.3em", color: "rgba(var(--brand-primary), 0.8)" })}>{link.title}</p>
								<p class={css({ mt: "3", fontSize: "base", color: "slate.200" })}>{link.description}</p>
							</div>
							<div class={css({ display: "flex", h: "12", w: "12", alignItems: "center", justifyContent: "center", borderRadius: "2xl", bg: "rgba(255, 255, 255, 0.1)", color: "white", transition: "all", "& a:hover > &, .group:hover &": { transform: "translateX(4px)" } })}>
								<svg class={css({ h: "5", w: "5" })} fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
								</svg>
							</div>
						</div>
					</a>
				))}
			</div>

			<div class={css({ mx: "auto", mt: "16", display: "grid", maxW: "4xl", gap: "6", gridTemplateColumns: { md: "repeat(2, 1fr)" } })}>
				{supportLinks.map((link) => (
					<a
						href={link.href}
						class={css({ display: "flex", flexDir: "column", gap: "3", borderRadius: "3xl", border: "1px solid rgba(255, 255, 255, 0.1)", bg: "rgba(255, 255, 255, 0.05)", p: "6", textAlign: "left", backdropFilter: "blur(12px)", transition: "all", _hover: { borderColor: "rgba(255, 255, 255, 0.3)", bg: "rgba(255, 255, 255, 0.1)" } })}
					>
						<p class={css({ fontSize: "sm", fontWeight: "semibold", letterSpacing: "wide", color: "rgba(255, 255, 255, 0.8)" })}>{link.title}</p>
						<p class={css({ fontSize: "base", color: "slate.300" })}>{link.description}</p>
						<span class={css({ display: "inline-flex", alignItems: "center", gap: "2", fontSize: "sm", fontWeight: "semibold", color: "rgba(var(--brand-primary), 0.8)" })}>
							<span>Open</span>
							<svg class={css({ h: "4", w: "4" })} fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14m-7-7l7 7-7 7" />
							</svg>
						</span>
					</a>
				))}
			</div>
		</section>
	</main>
</MinimalLayout>
