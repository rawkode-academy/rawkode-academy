---
import MinimalLayout from "@/layouts/minimal.astro";
import { css } from "../../styled-system/css";

export const prerender = true;

const quickLinks = [
	{ title: "Home", description: "Return to the front page.", href: "/" },
	{ title: "Browse Videos", description: "Live sessions and screencasts.", href: "/watch" },
	{ title: "Learning Paths", description: "Structured cloud native roadmaps.", href: "/learning-paths" },
	{ title: "Technologies", description: "Tools and projects we cover.", href: "/technology" },
];

const main = css({
	position: "relative",
	minH: "100vh",
	overflow: "hidden",
	color: "fg.primary",
	bg: "bg.canvas",
});

const bgFx = css({
	position: "absolute",
	inset: "0",
	pointerEvents: "none",
	backgroundImage:
		"radial-gradient(circle at 50% -10%, token(colors.brand.500)/20, transparent 50%), radial-gradient(circle at 80% 80%, token(colors.cyan.500)/15, transparent 50%)",
});

const shell = css({
	position: "relative",
	zIndex: "1",
	maxWidth: "60rem",
	mx: "auto",
	px: { base: "6", md: "10" },
	py: { base: "20", md: "32" },
	textAlign: "center",
});

const eyebrow = css({
	fontSize: "xs",
	letterSpacing: "0.4em",
	textTransform: "uppercase",
	color: "fg.brand",
	fontWeight: "semibold",
});

const heading = css({
	fontFamily: "display",
	fontSize: { base: "4xl", md: "6xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	lineHeight: "1.05",
	color: "fg.primary",
	mt: "6",
	textWrap: "balance",
});

const subtitle = css({ mt: "4", fontSize: { base: "md", md: "lg" }, color: "fg.secondary", lineHeight: "1.6", maxWidth: "36rem", mx: "auto" });

const buttonsRow = css({ mt: "10", display: "flex", flexWrap: "wrap", justifyContent: "center", gap: "3" });

const primaryBtn = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "6",
	py: "3",
	borderRadius: "lg",
	fontWeight: "semibold",
	color: "fg.on-brand",
	backgroundImage: "linear-gradient(135deg, token(colors.brand.500), token(colors.cyan.500))",
	textDecoration: "none",
	boxShadow: "md",
	transition: "transform 150ms ease",
	_hover: { transform: "translateY(-1px)" },
});

const ghostBtn = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "6",
	py: "3",
	borderRadius: "lg",
	fontWeight: "semibold",
	color: "fg.primary",
	bg: "bg.surface",
	borderWidth: "1px",
	borderColor: "border.default",
	textDecoration: "none",
	_hover: { bg: "bg.sunken" },
});

const searchForm = css({
	mt: "12",
	mx: "auto",
	maxWidth: "40rem",
	display: "flex",
	alignItems: "center",
	gap: "3",
	p: "2",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
});

const searchInput = css({
	flex: "1",
	bg: "transparent",
	color: "fg.primary",
	border: "none",
	px: "4",
	py: "2",
	fontSize: "md",
	_focus: { outline: "none" },
});

const searchBtn = css({
	display: "inline-flex",
	alignItems: "center",
	justifyContent: "center",
	w: "10",
	h: "10",
	borderRadius: "lg",
	color: "fg.on-brand",
	backgroundImage: "linear-gradient(135deg, token(colors.brand.500), token(colors.cyan.500))",
	border: "none",
	cursor: "pointer",
});

const grid = css({
	mt: "16",
	display: "grid",
	gridTemplateColumns: { base: "1fr", sm: "repeat(2, minmax(0, 1fr))" },
	gap: "4",
	maxWidth: "48rem",
	mx: "auto",
});

const card = css({
	display: "flex",
	flexDirection: "column",
	gap: "2",
	p: "5",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textDecoration: "none",
	color: "fg.primary",
	textAlign: "left",
	transition: "transform 200ms ease, border-color 200ms ease",
	_hover: { transform: "translateY(-2px)", borderColor: "border.default" },
});

const cardTitle = css({ fontSize: "md", fontWeight: "semibold", color: "fg.primary" });
const cardDesc = css({ fontSize: "sm", color: "fg.muted" });
---

<MinimalLayout title="404 – Rawkode Academy" description="We couldn't find that page, but here are a few quick ways to get back on course.">
	<main class={main}>
		<div class={bgFx} aria-hidden="true"></div>
		<section class={shell}>
			<p class={eyebrow}>Lost in the cluster</p>
			<h1 class={heading}>We couldn't route that request.</h1>
			<p class={subtitle}>The page you're looking for may have moved or the URL has a typo. Let's get you back to shipping something great.</p>

			<div class={buttonsRow}>
				<a href="/" class={primaryBtn}>
					Back to homepage
					<svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M13 5l7 7-7 7" /></svg>
				</a>
				<a href="https://github.com/rawkode-academy/rawkode-academy/issues/new/choose" target="_blank" rel="noopener noreferrer" class={ghostBtn}>
					Report an issue
				</a>
			</div>

			<form action="/search" method="get" class={searchForm}>
				<input type="search" name="q" placeholder="Search videos, articles, technologies…" class={searchInput} required />
				<button type="submit" class={searchBtn} aria-label="Search">
					<svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
				</button>
			</form>

			<div class={grid}>
				{quickLinks.map((link) => (
					<a href={link.href} class={card}>
						<span class={cardTitle}>{link.title}</span>
						<span class={cardDesc}>{link.description}</span>
					</a>
				))}
			</div>
		</section>
	</main>
</MinimalLayout>
