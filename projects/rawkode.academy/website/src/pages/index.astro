---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import HeroTypewriter from "@/components/hero/typewriter.tsx";
import NewsletterCTA from "@/components/newsletter/NewsletterCTA.astro";
import Page from "@/wrappers/page.astro";
import { getPublishedVideos } from "@/lib/content";
import { resolveTechnologyIconUrl } from "@/utils/resolve-technology-icon";
import { css } from "../../styled-system/css";

const allArticles = await getCollection("articles", ({ data }) => !data.draft);
const latestArticles = allArticles
	.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
	.slice(0, 4);

const allVideos = await getPublishedVideos();
const latestVideos = allVideos.slice(0, 4);

const allNews = await getCollection("news");
const latestNews = allNews
	.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
	.slice(0, 4);

const allLearningPaths = await getCollection("learningPaths");
const latestLearningPaths = allLearningPaths
	.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
	.slice(0, 4);

const allTechnologies = await getCollection("technologies");
const technologyNameById = new Map<string, string>();
for (const technology of allTechnologies) {
	const rawId = technology.id.replace(/\/index$/, "");
	technologyNameById.set(rawId, technology.data.name);
}

const heroLogos = allTechnologies
	.filter((tech) => tech.data.logos?.icon === true)
	.map((tech) => ({
		name: tech.data.name,
		iconUrl: resolveTechnologyIconUrl(tech.id, tech.data.logos) || "",
	}))
	.filter((logo) => logo.iconUrl)
	.sort(() => Math.random() - 0.5)
	.slice(0, 4);
function formatTechnologyLabel(value: string): string {
	const fromCollection = technologyNameById.get(value);
	if (fromCollection) return fromCollection;
	return value
		.split(/[-/]/g)
		.filter(Boolean)
		.map((s) => (s.length <= 3 ? s.toUpperCase() : `${s.charAt(0).toUpperCase()}${s.slice(1)}`))
		.join(" ");
}

const allCourses = await getCollection("courses");
const allTestimonials = await getCollection("testimonials");
const viewerTestimonials = allTestimonials
	.filter((t) => t.data.type === "viewer")
	.slice(0, 4);

const partners = [
	{ name: "Spectro Cloud", url: "https://spectrocloud.com", since: "2025", industry: "Kubernetes" },
];
const totalContent = allVideos.length + allArticles.length + allCourses.length;
const totalSeconds = allVideos.reduce((acc, video) => {
	const duration = video.data.duration;
	return acc + (typeof duration === "number" && duration > 0 ? duration : 0);
}, 0);
const totalHours = Math.floor(totalSeconds / 3600);

const stats = [
	{ value: `${totalContent}+`, label: "Resources" },
	{ value: `${totalHours}+`, label: "Hours of video" },
	{ value: "30K+", label: "Engineers learning" },
];

const formatDate = (date: Date) =>
	date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });

const compact = (text: string, max = 160) => {
	const t = text.replace(/\s+/g, " ").trim();
	return t.length <= max ? t : `${t.slice(0, max).trimEnd()}…`;
};

const difficultyLabel: Record<string, string> = {
	beginner: "Beginner",
	intermediate: "Intermediate",
	advanced: "Advanced",
};
const fmtPathDuration = (m: number) => {
	if (!m) return "Self-paced";
	const h = Math.floor(m / 60);
	const r = m % 60;
	return !h ? `${r}m` : !r ? `${h}h` : `${h}h ${r}m`;
};

const fmtVideoDuration = (seconds: number | undefined | null): string | null => {
	if (!seconds || typeof seconds !== "number" || seconds <= 0) return null;
	const m = Math.floor(seconds / 60);
	const s = Math.floor(seconds % 60);
	const h = Math.floor(m / 60);
	const mm = m % 60;
	if (h > 0) return `${h}:${mm.toString().padStart(2, "0")}:${s.toString().padStart(2, "0")}`;
	return `${mm}:${s.toString().padStart(2, "0")}`;
};

const principles = [
	{
		title: "Authenticity",
		body: "We show the trade-offs and the rough edges, not just the happy path. Real engineering is messy.",
	},
	{
		title: "Organic curriculum",
		body: "Lessons grow from the problems we actually hit in production — never from a marketing brief.",
	},
	{
		title: "Embrace failure",
		body: "Misconfigured clusters and broken builds stay in the cut. The recovery is the lesson.",
	},
	{
		title: "Hands-on",
		body: "Terminals over slideware. If you can't run it, you don't understand it.",
	},
	{
		title: "Forward thinking",
		body: "We test new tools early so you don't have to. Some make it. Most don't. We tell you why.",
	},
	{
		title: "Vendor-neutral",
		body: "Open and closed source get the same scrutiny. We answer to engineers, not roadmaps.",
	},
];

const pageTitle = "Cloud Native & Kubernetes Education | Rawkode Academy";
const pageDescription =
	"Master Cloud Native technologies and Kubernetes with Rawkode Academy's expert-led courses, articles, and live streams.";

const sectionsWrap = css({
	mt: { base: "16", md: "24" },
	display: "flex",
	flexDirection: "column",
	gap: { base: "20", md: "28" },
	maxWidth: "80rem",
	mx: "auto",
	px: { base: "4", md: "0" },
});

const sectionHeader = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", md: "minmax(0,1fr) auto" },
	alignItems: "end",
	gap: "4",
	mb: "8",
});

const sectionEyebrow = css({
	fontSize: "xs",
	fontWeight: "bold",
	letterSpacing: "wider",
	textTransform: "uppercase",
	color: "fg.brand",
});

const sectionTitle = css({
	fontFamily: "display",
	fontSize: { base: "3xl", md: "4xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	color: "fg.primary",
	mt: "2",
});

const sectionSubtitle = css({
	mt: "3",
	maxWidth: "40rem",
	color: "fg.secondary",
	fontSize: "md",
	lineHeight: "1.6",
});

const sectionLink = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	fontSize: "sm",
	fontWeight: "semibold",
	color: "fg.brand",
	textDecoration: "none",
	transition: "gap 150ms ease",
	_hover: { gap: "3" },
});

const grid4 = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", sm: "repeat(2, minmax(0, 1fr))", lg: "repeat(4, minmax(0, 1fr))" },
	gap: "4",
});
const grid3 = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", sm: "repeat(2, minmax(0, 1fr))", lg: "repeat(3, minmax(0, 1fr))" },
	gap: "4",
});

const cardLink = css({
	position: "relative",
	display: "flex",
	flexDirection: "column",
	gap: "3",
	h: "full",
	p: { base: "5", md: "6" },
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textDecoration: "none",
	color: "fg.primary",
	overflow: "hidden",
	transition: "transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease",
	_before: {
		content: '""',
		position: "absolute",
		inset: "0",
		borderRadius: "2xl",
		padding: "1px",
		background: "linear-gradient(135deg, rgba(95, 94, 215, 0.00), rgba(0, 206, 255, 0.00))",
		WebkitMask: "linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0)",
		WebkitMaskComposite: "xor",
		maskComposite: "exclude",
		pointerEvents: "none",
		opacity: "0",
		transition: "opacity 200ms ease, background 200ms ease",
	},
	_hover: {
		transform: "translateY(-2px)",
		boxShadow: "lg",
		borderColor: "transparent",
		_before: {
			opacity: "1",
			background: "linear-gradient(135deg, token(colors.brand.500), token(colors.cyan.500))",
		},
	},
});

const cardMeta = css({
	display: "flex",
	flexWrap: "wrap",
	alignItems: "center",
	gap: "2",
	fontSize: "xs",
	fontWeight: "semibold",
	letterSpacing: "wider",
	textTransform: "uppercase",
	color: "fg.muted",
});

const cardDivider = css({
	w: "1",
	h: "1",
	borderRadius: "full",
	bg: "border.default",
});

const cardTag = css({
	color: "fg.brand",
});

const cardTitle = css({
	fontSize: "lg",
	fontWeight: "semibold",
	lineHeight: "1.25",
	color: "fg.primary",
	letterSpacing: "tight",
	transition: "color 150ms ease",
	"a:hover &": { color: "fg.brand" },
});

const cardBody = css({
	fontSize: "sm",
	color: "fg.secondary",
	lineHeight: "1.6",
	display: "-webkit-box",
	WebkitLineClamp: "3",
	overflow: "hidden",
});

const featuredGrid = css({
	position: "relative",
	display: "grid",
	gridTemplateColumns: { base: "1fr", md: "minmax(0, 1.05fr) minmax(0, 1fr)" },
	alignItems: "stretch",
	gap: { base: "5", md: "8" },
	p: { base: "5", md: "7" },
	borderRadius: "3xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textDecoration: "none",
	color: "fg.primary",
	overflow: "hidden",
	transition: "transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease",
	_hover: {
		transform: "translateY(-2px)",
		boxShadow: "xl",
		borderColor: "fg.brand",
	},
});

const featuredBody = css({
	display: "flex",
	flexDirection: "column",
	gap: "4",
	justifyContent: "center",
	py: { md: "4" },
});

const featuredMedia = css({
	position: "relative",
	aspectRatio: "16 / 10",
	overflow: "hidden",
	borderRadius: "2xl",
	bg: "bg.sunken",
	"& img": { width: "full", height: "full", objectFit: "cover", transition: "transform 400ms ease" },
	"a:hover &": { "& img": { transform: "scale(1.03)" } },
});

const featuredBadge = css({
	position: "absolute",
	top: "3",
	left: "3",
	display: "inline-flex",
	alignItems: "center",
	gap: "1.5",
	px: "3",
	py: "1.5",
	borderRadius: "full",
	bg: "bg.canvas/85",
	color: "fg.primary",
	fontSize: "xs",
	fontWeight: "semibold",
	letterSpacing: "wider",
	textTransform: "uppercase",
	backdropFilter: "blur(8px)",
	borderWidth: "1px",
	borderColor: "border.muted",
});

const playIcon = css({
	display: "inline-flex",
	alignItems: "center",
	justifyContent: "center",
	w: "4",
	h: "4",
	color: "fg.brand",
});

const durationPill = css({
	position: "absolute",
	bottom: "3",
	right: "3",
	px: "2.5",
	py: "1",
	borderRadius: "md",
	bg: "rgba(0,0,0,0.75)",
	color: "white",
	fontSize: "xs",
	fontFamily: "mono",
	fontWeight: "semibold",
});

const featuredTitle = css({
	fontFamily: "display",
	fontSize: { base: "2xl", md: "3xl", lg: "4xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	lineHeight: "1.05",
	color: "fg.primary",
	textWrap: "balance",
	transition: "color 150ms ease",
	"a:hover &": { color: "fg.brand" },
});

const featuredDesc = css({
	fontSize: { base: "sm", md: "md" },
	color: "fg.secondary",
	lineHeight: "1.6",
	display: "-webkit-box",
	WebkitLineClamp: "3",
	overflow: "hidden",
});

const principlesSection = css({
	position: "relative",
	overflow: "hidden",
	borderRadius: "3xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	px: { base: "6", md: "10", lg: "14" },
	py: { base: "12", md: "16" },
});

const principlesHeader = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", md: "minmax(0,1fr) minmax(0,1fr)" },
	gap: { base: "4", md: "12" },
	alignItems: "end",
	mb: "12",
});

const principlesGrid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", sm: "repeat(2, minmax(0, 1fr))", lg: "repeat(3, minmax(0, 1fr))" },
	gap: { base: "5", md: "8" },
});

const principleItem = css({
	position: "relative",
	pl: "10",
});

const principleNumber = css({
	position: "absolute",
	left: "0",
	top: "0",
	fontFamily: "display",
	fontSize: "sm",
	fontWeight: "bold",
	color: "fg.brand",
	letterSpacing: "wider",
	"&::after": {
		content: '""',
		display: "block",
		mt: "1.5",
		width: "6",
		height: "1px",
		bg: "fg.brand",
	},
});

const principleTitle = css({
	fontFamily: "display",
	fontSize: "lg",
	fontWeight: "semibold",
	letterSpacing: "tight",
	color: "fg.primary",
	mb: "2",
});

const principleBody = css({
	fontSize: "sm",
	color: "fg.secondary",
	lineHeight: "1.6",
});

const ctaCard = css({
	position: "relative",
	overflow: "hidden",
	mx: { base: "0", md: "auto" },
	maxWidth: "70rem",
	p: { base: "10", md: "16" },
	borderRadius: "3xl",
	textAlign: "center",
	color: "white",
	backgroundImage:
		"linear-gradient(135deg, token(colors.brand.600) 0%, token(colors.brand.500) 45%, token(colors.cyan.500) 100%)",
	boxShadow: "2xl",
});

const ctaPattern = css({
	position: "absolute",
	inset: "0",
	opacity: "0.25",
	backgroundImage:
		"radial-gradient(circle at 20% 20%, white 1px, transparent 1px), radial-gradient(circle at 70% 70%, white 1px, transparent 1px)",
	backgroundSize: "40px 40px, 60px 60px",
	pointerEvents: "none",
});

const ctaInner = css({ position: "relative", zIndex: "1" });

const ctaEyebrow = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "3",
	py: "1",
	borderRadius: "full",
	bg: "rgba(255,255,255,0.18)",
	color: "white",
	fontSize: "xs",
	fontWeight: "semibold",
	letterSpacing: "wider",
	textTransform: "uppercase",
	mb: "6",
});

const ctaTitle = css({
	fontFamily: "display",
	fontSize: { base: "3xl", md: "5xl" },
	fontWeight: "bold",
	textWrap: "balance",
	letterSpacing: "tight",
	lineHeight: "1.05",
});
const ctaSubtitle = css({
	mt: "5",
	fontSize: { base: "md", md: "lg" },
	opacity: "0.92",
	maxWidth: "44rem",
	mx: "auto",
	lineHeight: "1.6",
});
const ctaActions = css({
	mt: "8",
	display: "flex",
	flexWrap: "wrap",
	justifyContent: "center",
	gap: "3",
});
const ctaButton = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "7",
	py: "3.5",
	borderRadius: "lg",
	fontWeight: "semibold",
	fontSize: "md",
	color: "brand.700",
	bg: "white",
	textDecoration: "none",
	boxShadow: "md",
	transition: "transform 150ms ease, box-shadow 150ms ease",
	_hover: { transform: "translateY(-1px)", boxShadow: "lg" },
});
const ctaButtonGhost = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "7",
	py: "3.5",
	borderRadius: "lg",
	fontWeight: "semibold",
	fontSize: "md",
	color: "white",
	bg: "rgba(255,255,255,0.12)",
	borderWidth: "1px",
	borderColor: "rgba(255,255,255,0.35)",
	textDecoration: "none",
	transition: "background 150ms ease",
	_hover: { bg: "rgba(255,255,255,0.2)" },
});

const arrowIcon = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>`;
const playSvg = `<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>`;
const sparkleSvg = `<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 6.4L21 11l-6.6 2.6L12 20l-2.4-6.4L3 11l6.6-2.6L12 2z"/></svg>`;
---

<Page title={pageTitle} description={pageDescription}>
	<HeroTypewriter
		client:only="react"
		highlight="hard"
		logos={heroLogos}
		primaryButton={{ text: "Start watching free", link: "/watch" }}
		secondaryButton={{ text: "Get weekly insights", link: "#newsletter-signup" }}
		rotatedPrefixes={[
			"Cloud Native",
			"Kubernetes",
			"Platform Engineering",
			"Observability",
			"WebAssembly",
			"GitOps",
			"SRE",
			"Microservices",
		]}
		suffix="may be complex, but it doesn't need to be hard."
		socialProof={stats.map((s) => ({ icon: "", value: s.value, label: s.label }))}
	/>

	<div id="newsletter-signup">
		<NewsletterCTA
			variant="section"
			badge="Weekly Cloud Native insights"
			headline="Get Cloud Native insights weekly"
			subtitle="Tutorials, deep dives, and curated events. No spam, unsubscribe anytime."
		/>
	</div>

	<div class={sectionsWrap}>
		{latestNews.length > 0 && (
			<section>
				<header class={sectionHeader}>
					<div>
						<span class={sectionEyebrow}>News</span>
						<h2 class={sectionTitle}>Cloud Native News</h2>
						<p class={sectionSubtitle}>Curated stories from across the cloud native ecosystem.</p>
					</div>
					<a href="/news" class={sectionLink}>
						All news
						<Fragment set:html={arrowIcon} />
					</a>
				</header>
				<div class={grid4}>
					{latestNews.map((item) => {
						const topTech = item.data.technologies?.[0];
						return (
							<a href={`/news/${item.id}`} class={cardLink}>
								<div class={cardMeta}>
									<time datetime={item.data.publishedAt.toISOString()}>{formatDate(item.data.publishedAt)}</time>
									{topTech && (
										<>
											<span class={cardDivider}></span>
											<span class={cardTag}>{formatTechnologyLabel(topTech)}</span>
										</>
									)}
								</div>
								<h3 class={cardTitle}>{item.data.title}</h3>
								<p class={cardBody}>{compact(item.data.description, 140)}</p>
							</a>
						);
					})}
				</div>
			</section>
		)}

		{latestLearningPaths.length > 0 && (
			<section>
				<header class={sectionHeader}>
					<div>
						<span class={sectionEyebrow}>Learn</span>
						<h2 class={sectionTitle}>Learning Paths</h2>
						<p class={sectionSubtitle}>Structured roadmaps to take you from zero to production.</p>
					</div>
					<a href="/learning-paths" class={sectionLink}>
						All paths
						<Fragment set:html={arrowIcon} />
					</a>
				</header>
				<div class={grid4}>
					{latestLearningPaths.map((path) => (
						<a href={`/learning-paths/${path.id}`} class={cardLink}>
							<div class={cardMeta}>
								<span class={cardTag}>{difficultyLabel[path.data.difficulty] ?? path.data.difficulty}</span>
								<span class={cardDivider}></span>
								<span>{fmtPathDuration(path.data.estimatedDuration)}</span>
							</div>
							<h3 class={cardTitle}>{path.data.title}</h3>
							<p class={cardBody}>{compact(path.data.description, 140)}</p>
						</a>
					))}
				</div>
			</section>
		)}

		{latestVideos.length > 0 && (
			<section>
				<header class={sectionHeader}>
					<div>
						<span class={sectionEyebrow}>Watch</span>
						<h2 class={sectionTitle}>Videos</h2>
						<p class={sectionSubtitle}>New sessions and walkthroughs from the sharp end of cloud native engineering.</p>
					</div>
					<a href="/watch" class={sectionLink}>
						Browse videos
						<Fragment set:html={arrowIcon} />
					</a>
				</header>
				{latestVideos[0] && (
					<a href={`/watch/${latestVideos[0].data.slug}`} class={featuredGrid}>
						<div class={featuredMedia}>
							<img
								src={`https://content.rawkode.academy/videos/${latestVideos[0].data.id}/thumbnail.jpg`}
								alt={latestVideos[0].data.title}
								loading="lazy"
							/>
							<span class={featuredBadge}>
								<span class={playIcon}><Fragment set:html={playSvg} /></span>
								Featured
							</span>
							{fmtVideoDuration(latestVideos[0].data.duration as number | undefined) && (
								<span class={durationPill}>{fmtVideoDuration(latestVideos[0].data.duration as number | undefined)}</span>
							)}
						</div>
						<div class={featuredBody}>
							<div class={cardMeta}>
								<time datetime={(latestVideos[0].data.publishedAt as Date).toISOString()}>{formatDate(latestVideos[0].data.publishedAt as Date)}</time>
							</div>
							<h3 class={featuredTitle}>{latestVideos[0].data.title}</h3>
							<p class={featuredDesc}>{compact(latestVideos[0].data.subtitle || latestVideos[0].data.description, 220)}</p>
						</div>
					</a>
				)}
				<div class={grid3} style="margin-top: 1rem;">
					{latestVideos.slice(1, 4).map((video) => (
						<a href={`/watch/${video.data.slug}`} class={cardLink}>
							<div class={cardMeta}>
								<time datetime={(video.data.publishedAt as Date).toISOString()}>{formatDate(video.data.publishedAt as Date)}</time>
								{fmtVideoDuration(video.data.duration as number | undefined) && (
									<>
										<span class={cardDivider}></span>
										<span>{fmtVideoDuration(video.data.duration as number | undefined)}</span>
									</>
								)}
							</div>
							<h3 class={cardTitle}>{video.data.title}</h3>
							<p class={cardBody}>{compact(video.data.subtitle || video.data.description, 140)}</p>
						</a>
					))}
				</div>
			</section>
		)}

		{latestArticles.length > 0 && (
			<section>
				<header class={sectionHeader}>
					<div>
						<span class={sectionEyebrow}>Read</span>
						<h2 class={sectionTitle}>Articles</h2>
						<p class={sectionSubtitle}>Architecture notes, breakdowns, and context for the parts that need more than a runtime.</p>
					</div>
					<a href="/read" class={sectionLink}>
						Browse articles
						<Fragment set:html={arrowIcon} />
					</a>
				</header>
				{latestArticles[0] && (
					<a href={`/read/${latestArticles[0].id}`} class={featuredGrid}>
						{latestArticles[0].data.cover ? (
							<div class={featuredMedia}>
								<Image
									src={latestArticles[0].data.cover.image}
									alt={latestArticles[0].data.cover.alt || latestArticles[0].data.title}
									width={800}
									height={500}
									loading="lazy"
								/>
								<span class={featuredBadge}>Featured</span>
							</div>
						) : (
							<div class={featuredMedia}></div>
						)}
						<div class={featuredBody}>
							<div class={cardMeta}>
								<time datetime={latestArticles[0].data.publishedAt.toISOString()}>{formatDate(latestArticles[0].data.publishedAt)}</time>
							</div>
							<h3 class={featuredTitle}>{latestArticles[0].data.title}</h3>
							<p class={featuredDesc}>{compact(latestArticles[0].data.description, 220)}</p>
						</div>
					</a>
				)}
				<div class={grid3} style="margin-top: 1rem;">
					{latestArticles.slice(1, 4).map((article) => (
						<a href={`/read/${article.id}`} class={cardLink}>
							<div class={cardMeta}>
								<time datetime={article.data.publishedAt.toISOString()}>{formatDate(article.data.publishedAt)}</time>
							</div>
							<h3 class={cardTitle}>{article.data.title}</h3>
							<p class={cardBody}>{compact(article.data.description, 140)}</p>
						</a>
					))}
				</div>
			</section>
		)}

		<section class={principlesSection}>
			<div class={principlesHeader}>
				<div>
					<span class={sectionEyebrow}>How we teach</span>
					<h2 class={sectionTitle}>Six principles, no compromises</h2>
				</div>
				<p class={sectionSubtitle} style="margin-top: 0;">
					This is what every video, article, and learning path is measured against. If it doesn't land here, it doesn't ship.
				</p>
			</div>
			<div class={principlesGrid}>
				{principles.map((p, i) => (
					<div class={principleItem}>
						<span class={principleNumber}>{(i + 1).toString().padStart(2, "0")}</span>
						<h3 class={principleTitle}>{p.title}</h3>
						<p class={principleBody}>{p.body}</p>
					</div>
				))}
			</div>
		</section>

		{viewerTestimonials.length > 0 && (
			<section style="display: flex; flex-direction: column; gap: 2rem;">
				<div>
					<span class={sectionEyebrow}>Community signal</span>
					<h2 class={sectionTitle}>What our viewers say</h2>
					<p class={sectionSubtitle}>Feedback from viewers learning in public with us.</p>
				</div>
				<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr)); gap: 1.5rem;">
					{viewerTestimonials.map((t) => (
						<figure style="display: flex; flex-direction: column; gap: 1rem; padding: 1.75rem; border-radius: 1.25rem; border: 1px solid var(--colors-border-muted); background: var(--colors-bg-raised); margin: 0;">
							<svg width="32" height="32" viewBox="0 0 32 32" aria-hidden="true" style="color: var(--colors-fg-brand); flex-shrink: 0;">
								<path fill="currentColor" d="M9.352 4C4.456 7.456 1 13.12 1 19.36c0 5.088 3.072 8.064 6.624 8.064 3.36 0 5.856-2.688 5.856-5.856 0-3.168-2.208-5.472-5.088-5.472-.576 0-1.344.096-1.536.192.48-3.264 3.552-7.104 6.624-9.024L9.352 4zm16.512 0c-4.8 3.456-8.256 9.12-8.256 15.36 0 5.088 3.072 8.064 6.624 8.064 3.264 0 5.856-2.688 5.856-5.856 0-3.168-2.304-5.472-5.184-5.472-.576 0-1.248.096-1.44.192.48-3.264 3.456-7.104 6.528-9.024L25.864 4z"/>
							</svg>
							<blockquote style="margin: 0; font-size: 0.95rem; line-height: 1.7; color: var(--colors-fg-secondary); display: -webkit-box; -webkit-line-clamp: 6; -webkit-box-orient: vertical; overflow: hidden;">
								{t.data.quote}
							</blockquote>
							<figcaption style="display: flex; align-items: center; gap: 0.75rem; margin-top: auto;">
								<img src={t.data.author.image} alt={t.data.author.name} style="width: 2.5rem; height: 2.5rem; border-radius: 9999px; object-fit: cover;" loading="lazy" />
								<div>
									<div style="font-weight: 600; color: var(--colors-fg-primary); font-size: 0.9rem;">{t.data.author.name}</div>
									<div style="font-size: 0.78rem; color: var(--colors-fg-muted);">{t.data.author.title}</div>
								</div>
							</figcaption>
						</figure>
					))}
				</div>
			</section>
		)}

		<section style="display: flex; flex-direction: column; gap: 2rem;">
			<div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; flex-wrap: wrap;">
				<div>
					<span class={sectionEyebrow}>Partners</span>
					<h2 class={sectionTitle}>Supporting the academy</h2>
					<p class={sectionSubtitle}>Teams that fund the work while leaving us free to speak plainly about the tools.</p>
				</div>
				<a href="/organizations/partnerships" class={sectionLink}>
					Partner with Rawkode
					<Fragment set:html={arrowIcon} />
				</a>
			</div>
			<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr)); gap: 1rem;">
				{partners.map((p) => (
					<a href={p.url} target="_blank" rel="noopener noreferrer" style="display: flex; flex-direction: column; gap: 0.5rem; padding: 1.5rem; border-radius: 1.25rem; border: 1px solid var(--colors-border-muted); background: var(--colors-bg-raised); color: var(--colors-fg-primary); text-decoration: none; transition: transform 200ms ease, border-color 200ms ease;">
						<div style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--colors-fg-muted);">
							<span style="color: var(--colors-fg-brand);">{p.industry}</span>
							<span>·</span>
							<span>Since {p.since}</span>
						</div>
						<div style="font-family: var(--fonts-display); font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; color: var(--colors-fg-primary);">{p.name}</div>
					</a>
				))}
			</div>
		</section>

		<section class={ctaCard}>
			<div class={ctaPattern}></div>
			<div class={ctaInner}>
				<span class={ctaEyebrow}><Fragment set:html={sparkleSvg} /> Weekly digest</span>
				<h2 class={ctaTitle}>Cloud Native, delivered weekly</h2>
				<p class={ctaSubtitle}>Tutorials, deep dives, and curated events — straight to your inbox. No spam, unsubscribe anytime.</p>
				<div class={ctaActions}>
					<a href="/feeds" class={ctaButton}>
						Subscribe to feeds
						<Fragment set:html={arrowIcon} />
					</a>
					<a href="/news" class={ctaButtonGhost}>Read the news</a>
				</div>
			</div>
		</section>
	</div>
</Page>
