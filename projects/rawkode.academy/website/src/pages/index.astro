---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import Page from "@/wrappers/page.astro";
import { getPublishedVideos } from "@/lib/content";
import { css } from "../../styled-system/css";

const allArticles = await getCollection("articles", ({ data }) => !data.draft);
const latestArticles = allArticles
	.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
	.slice(0, 6);

const allVideos = await getPublishedVideos();
const latestVideos = allVideos.slice(0, 6);

const allNews = await getCollection("news");
const latestNews = allNews
	.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
	.slice(0, 4);

const allLearningPaths = await getCollection("learningPaths");
const latestLearningPaths = allLearningPaths
	.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
	.slice(0, 4);

const allCourses = await getCollection("courses");
const totalContent = allVideos.length + allArticles.length + allCourses.length;
const totalSeconds = allVideos.reduce((acc, video) => {
	const duration = video.data.duration;
	return acc + (typeof duration === "number" && duration > 0 ? duration : 0);
}, 0);
const totalHours = Math.floor(totalSeconds / 3600);

const stats = [
	{ value: `${totalContent}+`, label: "Resources" },
	{ value: `${totalHours}+`, label: "Hours of video" },
	{ value: "30K+", label: "Learners" },
];

const formatDate = (date: Date) =>
	date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });

const compact = (text: string, max = 160) => {
	const t = text.replace(/\s+/g, " ").trim();
	return t.length <= max ? t : `${t.slice(0, max).trimEnd()}…`;
};

const difficultyLabel: Record<string, string> = {
	beginner: "Beginner",
	intermediate: "Intermediate",
	advanced: "Advanced",
};
const fmtPathDuration = (m: number) => {
	if (!m) return "Self-paced";
	const h = Math.floor(m / 60);
	const r = m % 60;
	return !h ? `${r}m` : !r ? `${h}h` : `${h}h ${r}m`;
};

const pageTitle = "Cloud Native & Kubernetes Education | Rawkode Academy";
const pageDescription =
	"Master Cloud Native technologies and Kubernetes with Rawkode Academy's expert-led courses, articles, and live streams.";

const heroWrap = css({
	position: "relative",
	mt: "8",
	mx: { base: "2", md: "0" },
	overflow: "hidden",
	borderRadius: "3xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	px: { base: "6", md: "12", lg: "16" },
	py: { base: "12", md: "16", lg: "20" },
	backgroundImage:
		"radial-gradient(circle at 15% 20%, token(colors.brand.500)/15, transparent 45%), radial-gradient(circle at 85% 30%, token(colors.cyan.500)/15, transparent 45%)",
	_dark: {
		backgroundImage:
			"radial-gradient(circle at 15% 20%, token(colors.brand.500)/25, transparent 45%), radial-gradient(circle at 85% 30%, token(colors.cyan.500)/20, transparent 45%)",
	},
});

const eyebrow = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "3",
	py: "1",
	borderRadius: "full",
	bg: "bg.brand-subtle",
	color: "fg.brand",
	fontSize: "xs",
	fontWeight: "semibold",
	letterSpacing: "wider",
	textTransform: "uppercase",
});

const heroTitle = css({
	fontFamily: "display",
	fontSize: { base: "4xl", md: "5xl", lg: "6xl" },
	fontWeight: "bold",
	lineHeight: "1.05",
	letterSpacing: "tight",
	color: "fg.primary",
	textWrap: "balance",
	mt: "5",
	maxWidth: "44rem",
});

const heroTitleAccent = css({
	backgroundImage: "linear-gradient(135deg, token(colors.brand.500), token(colors.cyan.500))",
	WebkitBackgroundClip: "text",
	backgroundClip: "text",
	color: "transparent",
});

const heroSubtitle = css({
	mt: "5",
	fontSize: { base: "lg", md: "xl" },
	color: "fg.secondary",
	lineHeight: "1.6",
	maxWidth: "42rem",
	textWrap: "pretty",
});

const heroActions = css({
	mt: "8",
	display: "flex",
	flexWrap: "wrap",
	gap: "3",
});

const buttonSolid = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "6",
	py: "3",
	borderRadius: "lg",
	fontWeight: "semibold",
	fontSize: "md",
	color: "fg.on-brand",
	backgroundImage: "linear-gradient(135deg, token(colors.brand.500), token(colors.cyan.500))",
	textDecoration: "none",
	boxShadow: "md",
	transition: "transform 150ms ease, box-shadow 150ms ease",
	_hover: { transform: "translateY(-1px)", boxShadow: "lg" },
});

const buttonOutline = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "6",
	py: "3",
	borderRadius: "lg",
	fontWeight: "semibold",
	fontSize: "md",
	color: "fg.primary",
	bg: "bg.surface",
	borderWidth: "1px",
	borderColor: "border.default",
	textDecoration: "none",
	transition: "background 150ms ease",
	_hover: { bg: "bg.sunken" },
});

const statsRow = css({
	mt: "10",
	display: "flex",
	flexWrap: "wrap",
	gap: { base: "6", md: "10" },
});
const statItem = css({ display: "flex", flexDirection: "column", gap: "1" });
const statValue = css({
	fontFamily: "display",
	fontSize: "3xl",
	fontWeight: "bold",
	color: "fg.primary",
});
const statLabel = css({ fontSize: "sm", color: "fg.muted" });

const sectionsWrap = css({
	mt: "16",
	display: "flex",
	flexDirection: "column",
	gap: { base: "16", md: "20" },
	maxWidth: "80rem",
	mx: "auto",
	px: { base: "4", md: "0" },
});

const sectionHeader = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", md: "minmax(0,1fr) auto" },
	alignItems: "end",
	gap: "4",
	mb: "8",
});

const sectionEyebrow = css({
	fontSize: "xs",
	fontWeight: "bold",
	letterSpacing: "wider",
	textTransform: "uppercase",
	color: "fg.brand",
});

const sectionTitle = css({
	fontFamily: "display",
	fontSize: { base: "3xl", md: "4xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	color: "fg.primary",
	mt: "2",
});

const sectionSubtitle = css({
	mt: "3",
	maxWidth: "40rem",
	color: "fg.secondary",
	fontSize: "md",
	lineHeight: "1.6",
});

const sectionLink = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	fontSize: "sm",
	fontWeight: "semibold",
	color: "fg.brand",
	textDecoration: "none",
	transition: "transform 150ms ease",
	_hover: { transform: "translateX(2px)" },
});

const grid4 = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", sm: "repeat(2, minmax(0, 1fr))", lg: "repeat(4, minmax(0, 1fr))" },
	gap: "4",
});
const grid3 = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", sm: "repeat(2, minmax(0, 1fr))", lg: "repeat(3, minmax(0, 1fr))" },
	gap: "4",
});

const cardLink = css({
	display: "flex",
	flexDirection: "column",
	gap: "3",
	h: "full",
	p: { base: "5", md: "6" },
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textDecoration: "none",
	color: "fg.primary",
	transition: "transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease",
	_hover: {
		transform: "translateY(-2px)",
		boxShadow: "lg",
		borderColor: "border.default",
	},
});

const cardMeta = css({
	display: "flex",
	flexWrap: "wrap",
	alignItems: "center",
	gap: "2",
	fontSize: "xs",
	fontWeight: "semibold",
	letterSpacing: "wider",
	textTransform: "uppercase",
	color: "fg.muted",
});

const cardDivider = css({
	w: "1",
	h: "1",
	borderRadius: "full",
	bg: "border.default",
});

const cardTitle = css({
	fontSize: "lg",
	fontWeight: "semibold",
	lineHeight: "tight",
	color: "fg.primary",
	transition: "color 150ms ease",
	"a:hover &": { color: "fg.brand" },
});

const cardBody = css({
	fontSize: "sm",
	color: "fg.secondary",
	lineHeight: "1.6",
	display: "-webkit-box",
	WebkitLineClamp: "3",
	WebkitBoxOrient: "vertical",
	overflow: "hidden",
});

const featuredGrid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", md: "20rem 1fr" },
	alignItems: "center",
	gap: "8",
	p: { base: "5", md: "6" },
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textDecoration: "none",
	color: "fg.primary",
	transition: "transform 200ms ease, box-shadow 200ms ease",
	_hover: { transform: "translateY(-2px)", boxShadow: "lg" },
});

const featuredMedia = css({
	position: "relative",
	aspectRatio: "16 / 10",
	overflow: "hidden",
	borderRadius: "xl",
	bg: "bg.sunken",
	"& img": { width: "full", height: "full", objectFit: "cover" },
});

const featuredTitle = css({
	fontFamily: "display",
	fontSize: { base: "2xl", md: "3xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	lineHeight: "1.1",
	color: "fg.primary",
	textWrap: "balance",
});

const ctaCard = css({
	mt: "16",
	mx: { base: "4", md: "auto" },
	maxWidth: "60rem",
	p: { base: "8", md: "12" },
	borderRadius: "3xl",
	textAlign: "center",
	color: "white",
	backgroundImage: "linear-gradient(135deg, token(colors.brand.500), token(colors.cyan.500))",
	boxShadow: "xl",
});
const ctaTitle = css({
	fontFamily: "display",
	fontSize: { base: "2xl", md: "3xl" },
	fontWeight: "bold",
	textWrap: "balance",
});
const ctaSubtitle = css({
	mt: "3",
	fontSize: { base: "md", md: "lg" },
	opacity: "0.92",
	maxWidth: "40rem",
	mx: "auto",
});
const ctaActions = css({
	mt: "8",
	display: "flex",
	flexWrap: "wrap",
	justifyContent: "center",
	gap: "3",
});
const ctaButton = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "6",
	py: "3",
	borderRadius: "lg",
	fontWeight: "semibold",
	fontSize: "md",
	color: "fg.primary",
	bg: "white",
	textDecoration: "none",
	transition: "transform 150ms ease",
	_hover: { transform: "translateY(-1px)" },
});

const arrowIcon = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>`;
---

<Page title={pageTitle} description={pageDescription}>
	<section class={heroWrap}>
		<span class={eyebrow}>Rawkode Academy</span>
		<h1 class={heroTitle}>
			<span class={heroTitleAccent}>Cloud Native</span> education<br />
			that respects your time.
		</h1>
		<p class={heroSubtitle}>
			Tutorials, articles, learning paths, and live builds from real production engineering. No fluff, no sponsored-only content — just the work.
		</p>
		<div class={heroActions}>
			<a href="/watch" class={buttonSolid}>
				Start Watching Free
				<Fragment set:html={arrowIcon} />
			</a>
			<a href="/learning-paths" class={buttonOutline}>Explore Learning Paths</a>
		</div>
		<div class={statsRow}>
			{stats.map((s) => (
				<div class={statItem}>
					<span class={statValue}>{s.value}</span>
					<span class={statLabel}>{s.label}</span>
				</div>
			))}
		</div>
	</section>

	<div class={sectionsWrap}>
		{latestNews.length > 0 && (
			<section>
				<header class={sectionHeader}>
					<div>
						<span class={sectionEyebrow}>News</span>
						<h2 class={sectionTitle}>Cloud Native News</h2>
						<p class={sectionSubtitle}>Curated stories from across the cloud native ecosystem.</p>
					</div>
					<a href="/news" class={sectionLink}>
						All news
						<Fragment set:html={arrowIcon} />
					</a>
				</header>
				<div class={grid4}>
					{latestNews.map((item) => (
						<a href={`/news/${item.id}`} class={cardLink}>
							<div class={cardMeta}>
								<span>{formatDate(item.data.publishedAt)}</span>
							</div>
							<h3 class={cardTitle}>{item.data.title}</h3>
							<p class={cardBody}>{compact(item.data.description, 140)}</p>
						</a>
					))}
				</div>
			</section>
		)}

		{latestLearningPaths.length > 0 && (
			<section>
				<header class={sectionHeader}>
					<div>
						<span class={sectionEyebrow}>Learn</span>
						<h2 class={sectionTitle}>Learning Paths</h2>
						<p class={sectionSubtitle}>Structured roadmaps to take you from zero to production.</p>
					</div>
					<a href="/learning-paths" class={sectionLink}>
						All paths
						<Fragment set:html={arrowIcon} />
					</a>
				</header>
				<div class={grid4}>
					{latestLearningPaths.map((path) => (
						<a href={`/learning-paths/${path.id}`} class={cardLink}>
							<div class={cardMeta}>
								<span>{difficultyLabel[path.data.difficulty] ?? path.data.difficulty}</span>
								<span class={cardDivider}></span>
								<span>{fmtPathDuration(path.data.estimatedDuration)}</span>
							</div>
							<h3 class={cardTitle}>{path.data.title}</h3>
							<p class={cardBody}>{compact(path.data.description, 140)}</p>
						</a>
					))}
				</div>
			</section>
		)}

		{latestVideos.length > 0 && (
			<section>
				<header class={sectionHeader}>
					<div>
						<span class={sectionEyebrow}>Watch</span>
						<h2 class={sectionTitle}>Videos</h2>
						<p class={sectionSubtitle}>New sessions and walkthroughs from the sharp end of cloud native engineering.</p>
					</div>
					<a href="/watch" class={sectionLink}>
						Browse videos
						<Fragment set:html={arrowIcon} />
					</a>
				</header>
				{latestVideos[0] && (
					<a href={`/watch/${latestVideos[0].data.slug}`} class={featuredGrid}>
						<div class={featuredMedia}>
							<img
								src={`https://content.rawkode.academy/videos/${latestVideos[0].data.id}/thumbnail.jpg`}
								alt={latestVideos[0].data.title}
								loading="lazy"
							/>
						</div>
						<div style="display: flex; flex-direction: column; gap: 0.75rem;">
							<div class={cardMeta}>
								<span>{formatDate(latestVideos[0].data.publishedAt as Date)}</span>
							</div>
							<h3 class={featuredTitle}>{latestVideos[0].data.title}</h3>
							<p class={cardBody}>{compact(latestVideos[0].data.subtitle || latestVideos[0].data.description, 200)}</p>
						</div>
					</a>
				)}
				<div class={grid3} style="margin-top: 1rem;">
					{latestVideos.slice(1, 4).map((video) => (
						<a href={`/watch/${video.data.slug}`} class={cardLink}>
							<div class={cardMeta}>
								<span>{formatDate(video.data.publishedAt as Date)}</span>
							</div>
							<h3 class={cardTitle}>{video.data.title}</h3>
							<p class={cardBody}>{compact(video.data.subtitle || video.data.description, 140)}</p>
						</a>
					))}
				</div>
			</section>
		)}

		{latestArticles.length > 0 && (
			<section>
				<header class={sectionHeader}>
					<div>
						<span class={sectionEyebrow}>Read</span>
						<h2 class={sectionTitle}>Articles</h2>
						<p class={sectionSubtitle}>Architecture notes, breakdowns, and context for the parts that need more than a runtime.</p>
					</div>
					<a href="/read" class={sectionLink}>
						Browse articles
						<Fragment set:html={arrowIcon} />
					</a>
				</header>
				{latestArticles[0] && (
					<a href={`/read/${latestArticles[0].id}`} class={featuredGrid} style="grid-template-columns: 1fr 20rem;">
						<div style="display: flex; flex-direction: column; gap: 0.75rem;">
							<div class={cardMeta}>
								<span>{formatDate(latestArticles[0].data.publishedAt)}</span>
							</div>
							<h3 class={featuredTitle}>{latestArticles[0].data.title}</h3>
							<p class={cardBody}>{compact(latestArticles[0].data.description, 200)}</p>
						</div>
						{latestArticles[0].data.cover ? (
							<div class={featuredMedia}>
								<Image
									src={latestArticles[0].data.cover.image}
									alt={latestArticles[0].data.cover.alt || latestArticles[0].data.title}
									width={640}
									height={400}
									loading="lazy"
								/>
							</div>
						) : (
							<div class={featuredMedia}></div>
						)}
					</a>
				)}
				<div class={grid3} style="margin-top: 1rem;">
					{latestArticles.slice(1, 4).map((article) => (
						<a href={`/read/${article.id}`} class={cardLink}>
							<div class={cardMeta}>
								<span>{formatDate(article.data.publishedAt)}</span>
							</div>
							<h3 class={cardTitle}>{article.data.title}</h3>
							<p class={cardBody}>{compact(article.data.description, 140)}</p>
						</a>
					))}
				</div>
			</section>
		)}

		<section class={ctaCard}>
			<h2 class={ctaTitle}>Get weekly Cloud Native insights</h2>
			<p class={ctaSubtitle}>Tutorials, deep dives, and curated events — straight to your inbox. No spam, unsubscribe anytime.</p>
			<div class={ctaActions}>
				<a href="/feeds" class={ctaButton}>
					Browse feeds
					<Fragment set:html={arrowIcon} />
				</a>
			</div>
		</section>
	</div>
</Page>
