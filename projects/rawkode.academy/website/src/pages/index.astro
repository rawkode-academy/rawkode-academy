	<section id="newsletter-signup" class={css({
	px: '4',
	pt: '6',
	sm: {
		pt: '8',
	},
})}>
		<div class={css({
	mx: 'auto',
	maxW: '3xl',
	scrollMarginTop: '24',
})}>
			<NewsletterCTA
				server:defer
