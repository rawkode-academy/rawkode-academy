---
import { css } from "../../styled-system/css";
import FeatureList from "@/components/feature/list.vue";
import HeroTypewriter from "@/components/hero/typewriter.tsx";
import PartnerLogos from "@/components/partner/logos.astro";
import TestimonialSlider from "@/components/testimonial/slider.astro";
import Page from "@/wrappers/page.astro";
import { getCollection } from "astro:content";
import { getPublishedVideos } from "@/lib/content";
import ArticleCard from "@/components/articles/ArticleCard.astro";
import NewsletterCTA from "@/components/newsletter/NewsletterCTA.astro";
import { resolveTechnologyIconUrl } from "@/utils/resolve-technology-icon";

// Fetch random technologies for hero
const allTechnologies = await getCollection("technologies");
const heroLogos = allTechnologies
	.filter((tech) => tech.data.logos?.icon === true)
	.map((tech) => ({
		name: tech.data.name,
		iconUrl: resolveTechnologyIconUrl(tech.id, tech.data.logos) || "",
	}))
	.filter((logo) => logo.iconUrl)
	.sort(() => Math.random() - 0.5)
	.slice(0, 4);

// Fetch latest content
const allArticles = await getCollection("articles", ({ data }) => !data.draft);
const latestArticles = allArticles
	.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
	.slice(0, 3);

// Get published videos only (filters out future-dated for scheduled publishing)
const allVideos = await getPublishedVideos();
const latestVideos = allVideos.slice(0, 4); // Already sorted by getPublishedVideos

// Social proof stats - simplified metrics
const allCourses = await getCollection("courses");
const totalContent = allVideos.length + allArticles.length + allCourses.length;

// Calculate total hours from video durations (duration is in seconds)
const totalSeconds = allVideos.reduce((acc, video) => {
	const duration = video.data.duration;
	return acc + (typeof duration === "number" && duration > 0 ? duration : 0);
}, 0);
const totalHours = Math.floor(totalSeconds / 3600);

const socialProofStats = [
	{ icon: "📚", value: `${totalContent}+`, label: "Resources" },
	{ icon: "⏱️", value: `${totalHours}+`, label: "Hours of Video" },
	{ icon: "👥", value: "30K+", label: "Learners" },
];

const pageTitle = "Cloud Native & Kubernetes Education | Rawkode Academy";
const pageDescription =
	"Master Cloud Native technologies and Kubernetes with Rawkode Academy's expert-led courses, articles, and live streams. Stay ahead in the fast-evolving tech landscape.";

// Format duration helper
const formatDuration = (seconds?: number | null) => {
	if (typeof seconds !== "number" || seconds <= 0 || Number.isNaN(seconds)) {
		return "--:--";
	}
	const hours = Math.floor(seconds / 3600);
	const minutes = Math.floor((seconds % 3600) / 60);
	const secs = seconds % 60;

	if (hours > 0) {
		return `${hours}:${minutes.toString().padStart(2, "0")}:${secs
			.toString()
			.padStart(2, "0")}`;
	}
	return `${minutes}:${secs.toString().padStart(2, "0")}`;
};

const featuredTechnologies = [
	{ slug: "kubernetes", emoji: "☸️", label: "Kubernetes" },
	{ slug: "docker", emoji: "🐳", label: "Docker" },
	{ slug: "fluxcd", emoji: "🔄", label: "FluxCD" },
	{ slug: "cilium", emoji: "🐝", label: "Cilium" },
	{ slug: "dagger", emoji: "⚡", label: "Dagger" },
];

const sectionHeadingStyle = css({ fontSize: "2xl", fontWeight: "bold", color: { base: "gray.900", _dark: "white" }, display: "flex", alignItems: "center", gap: "2" });
const viewAllLinkStyle = css({ color: "rgb(var(--brand-primary))", fontWeight: "medium", display: "flex", alignItems: "center", transition: "colors", transitionDuration: "200ms", _hover: { color: "rgb(var(--brand-secondary))" } });
const techLinkStyle = css({ display: "flex", flexDirection: "column", alignItems: "center", p: "4", rounded: "xl", transition: "colors", transitionDuration: "200ms", _hover: { bg: "rgba(var(--brand-primary),0.1)" } });
---

<Page title={pageTitle} description={pageDescription}>
	<HeroTypewriter
		client:only="react"
		highlight="hard"
		logos={heroLogos}
		primaryButton={{
					text: "Get Weekly Insights",
					link: "#newsletter-signup",
				}}
		secondaryButton={{
			text: "Start Watching Free",
			link: "/watch",
		}}
		rotatedPrefixes={[
			"Cloud Native",
			"Kubernetes",
			"Microservices",
			"WebAssembly",
			"Platform Engineering",
			"SRE",
			"Observability",
			"DevOps",
			"Infrastructure as Code",
		]}
		suffix="may be complex, but it doesn't need to be hard."
		socialProof={socialProofStats}
	/>

	<section id="newsletter-signup" class={css({ px: "4", pt: { base: "6", sm: "8" } })}>
		<div class={css({ mx: "auto", maxW: "3xl", scrollMarginTop: "6" })}>
			<NewsletterCTA
				server:defer
				class={css({ mb: "12" })}
				badge="Weekly Cloud Native insights"
				headline="Get cloud native insights weekly"
				subtitle="Tutorials, deep dives, and curated events. No spam, unsubscribe anytime."
			/>
		</div>
	</section>

	{/* Latest Content Section */}
	<section class={css({ py: { base: "16", sm: "20" }, px: "4" })}>
		<div class={css({ mx: "auto", maxW: "7xl" })}>
			<div class={css({ textAlign: "center", mb: "12" })}>
				<h2 class={css({ fontSize: { base: "3xl", md: "4xl" }, fontWeight: "bold", letterSpacing: "tight", color: { base: "gray.900", _dark: "white" }, mb: "4" })}>
					Latest from the <span class={css({ color: "rgb(var(--brand-primary))" })}>Academy</span>
				</h2>
				<p class={css({ color: { base: "gray.500", _dark: "gray.400" }, fontSize: "lg", maxW: "3xl", mx: "auto" })}>
					Fresh content to keep you ahead in the cloud-native landscape
				</p>
			</div>

			{/* Latest Videos */}
			<div class={css({ mb: "16" })}>
				<div class={css({ display: "flex", alignItems: "center", justifyContent: "space-between", mb: "8" })}>
					<h3 class={sectionHeadingStyle}>
						<span class={css({ color: "rgb(var(--brand-primary))" })}>📺</span> Latest Videos
					</h3>
					<a href="/watch" class={viewAllLinkStyle}>
						View All <svg class={css({ w: "4", h: "4", ml: "1" })} xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
					</a>
				</div>
				<div class={css({ display: "grid", gap: "6", gridTemplateColumns: { md: "repeat(2, 1fr)", lg: "repeat(3, 1fr)" } })}>
					{latestVideos.slice(0, 3).map((video) => (
						<a
							href={`/watch/${video.data.slug}`}
							data-group
							class={css({
								display: "block",
								bg: { base: "white", _dark: "gray.800" },
								rounded: "2xl",
								shadow: "sm",
								transition: "all",
								transitionDuration: "300ms",
								overflow: "hidden",
								border: "1px solid",
								borderColor: { base: "gray.100", _dark: "gray.700" },
								_hover: { shadow: "xl" },
							})}
						>
							{/* Thumbnail */}
							<div class={css({ position: "relative", aspectRatio: "16/9", overflow: "hidden", bg: { base: "gray.100", _dark: "gray.700" } })}>
								<img
									src={`https://content.rawkode.academy/videos/${video.data.id}/thumbnail.jpg`}
									alt={video.data.title}
									class={css({ w: "full", h: "full", objectFit: "cover", transition: "transform", transitionDuration: "500ms", _groupHover: { transform: "scale(1.05)" } })}
									loading="lazy"
								/>
								{/* Duration badge */}
								<div class={css({ position: "absolute", bottom: "2", right: "2", bg: "rgba(0,0,0,0.8)", color: "white", fontSize: "xs", px: "2", py: "1", rounded: "md", backdropFilter: "blur(4px)" })}>
									{formatDuration(typeof video.data.duration === "number" ? video.data.duration : undefined)}
								</div>
								{/* Play overlay */}
								<div class={css({ position: "absolute", inset: "0", display: "flex", alignItems: "center", justifyContent: "center", opacity: 0, transition: "opacity", transitionDuration: "300ms", bg: "rgba(0,0,0,0.2)", _groupHover: { opacity: 1 } })}>
									<div class={css({ w: "12", h: "12", rounded: "full", bg: "rgba(255,255,255,0.9)", display: "flex", alignItems: "center", justifyContent: "center", color: "rgb(var(--brand-primary))", shadow: "lg", transform: "scale(0.75)", transition: "transform", transitionDuration: "300ms", _groupHover: { transform: "scale(1)" } })}>
										<svg class={css({ w: "6", h: "6", ml: "1" })} fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
									</div>
								</div>
							</div>

							{/* Content */}
							<div class={css({ p: "5" })}>
								<h3 class={css({ fontSize: "lg", fontWeight: "semibold", color: { base: "gray.900", _dark: "white" }, lineClamp: 2, transition: "colors", transitionDuration: "200ms", mb: "2", _groupHover: { color: "rgb(var(--brand-primary))" } })}>
									{video.data.title}
								</h3>

								<div class={css({ display: "flex", alignItems: "center", fontSize: "sm", color: { base: "gray.500", _dark: "gray.400" } })}>
									<svg class={css({ w: "4", h: "4", mr: "1" })} fill="none" viewBox="0 0 24 24" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
									</svg>
									{video.data.publishedAt.toLocaleDateString("en-US", { year: 'numeric', month: 'short', day: 'numeric' })}
								</div>
							</div>
						</a>
					))}
				</div>
			</div>

			{/* Latest Articles */}
			<div class={css({ mb: "16" })}>
				<div class={css({ display: "flex", alignItems: "center", justifyContent: "space-between", mb: "8" })}>
					<h3 class={sectionHeadingStyle}>
						<span class={css({ color: "rgb(var(--brand-primary))" })}>📝</span> Latest Articles
					</h3>
					<a href="/read" class={viewAllLinkStyle}>
						View All <svg class={css({ w: "4", h: "4", ml: "1" })} xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
					</a>
				</div>
				<div class={css({ display: "grid", gap: "6", gridTemplateColumns: { md: "repeat(2, 1fr)", lg: "repeat(3, 1fr)" } })}>
					{latestArticles.map((article) => (
						<ArticleCard article={article} />
					))}
				</div>
			</div>

			{/* Featured Technologies Highlight */}
			<div class={`glass-panel ${css({ rounded: "3xl", p: "8" })}`}>
				<h3 class={css({ fontSize: "2xl", fontWeight: "bold", color: { base: "gray.900", _dark: "white" }, mb: "6", textAlign: "center" })}>
					🚀 Featured Technology Guides
				</h3>
				<div class={css({ display: "grid", gridTemplateColumns: { base: "repeat(2, 1fr)", md: "repeat(5, 1fr)" }, gap: "4" })}>
					{featuredTechnologies.map((tech) => (
						<a href={`/technology/${tech.slug}`} class={techLinkStyle}>
							<div class={css({ fontSize: "4xl", mb: "2" })}>{tech.emoji}</div>
							<span class={css({ fontSize: "sm", fontWeight: "medium", color: { base: "gray.900", _dark: "white" } })}>{tech.label}</span>
						</a>
					))}
				</div>
			</div>
		</div>
	</section>

	<FeatureList
		title="Our Learning Path & Values"
		description="The Rawkode Academy provides educational, entertaining, and cutting-edge learning paths for you, or your developers, to keep up with the fast-paced, ever-evolving, and extremely volatile Cloud Native and Kubernetes landscape."
		segments={[
			{
				title: "Authenticity",
				emoji: "🎭",
				description:
					"The content we produce is authentic, and we don't shy away from the hard topics.",
			},
			{
				title: "Organic Content",
				emoji: "🌱",
				description:
					"As we learn, you learn. You'll notice a lot of the more recent content features: us solving our own problems, building this platform, and the technologies we used.",
			},
			{
				title: "Embracing Failure",
				emoji: "🤦",
				description:
					"Our live content won't be without mistakes. In fact, we encourage things to go wrong. We all learn through failures, why edit them out?",
			},
			{
				title: "Hands-On",
				emoji: "⌨️",
				description:
					"Forget the slides, we're all about the hands-on keyboard experience. We'll be in the terminal, writing code, and building things together.",
			},
			{
				title: "Forward-Facing, Forward-Thinking",
				emoji: "🔭",
				description:
					"We're always looking for the greatest and latest technologies, and we're not afraid to dive in headfirst.",
			},
			{
				title: "Open & Closed Source",
				emoji: "🔐",
				description:
					"There's a time to build and there's a time to buy. We'll cover both and do our best to explain when you should trade your money for time.",
			},
		]}
	/>

	<section class={css({ bg: { base: "gray.50", _dark: "gray.900/50" } })}>
		<div class={css({ py: "12", px: "4", mx: "auto", maxW: "7xl", lg: { py: "16", px: "6" } })}>
				<TestimonialSlider type="viewer" blurb="We're proud of the content we produce, but don't take our word for it. Here's what our viewers have to say about the Rawkode Academy." />
		</div>
	</section>

	<section class={css({ position: "relative", py: { base: "16", sm: "20" }, px: "4" })}>
		<div class={css({ pointerEvents: "none", position: "absolute", inset: "0", display: "flex", justifyContent: "center" })}>
			<div class={css({ h: "full", w: "5/6", maxW: "6xl", rounded: "3xl", background: "linear-gradient(to right, rgba(var(--brand-primary),0.25), rgba(255,255,255,0.3), rgba(var(--brand-secondary),0.25))", filter: "blur(220px)", opacity: 0.4, _dark: { background: "linear-gradient(to right, rgba(var(--brand-primary),0.4), rgba(17,24,39,0.4), rgba(var(--brand-secondary),0.4))" } })}></div>
		</div>
		<div class={`glass-panel ${css({ position: "relative", mx: "auto", maxW: "7xl", rounded: "3xl", overflow: "hidden" })}`}>
			<div class={css({ position: "absolute", inset: "0", opacity: 0.6 })}>
				<div class={css({ position: "absolute", inset: "0", background: "linear-gradient(to bottom right, rgba(255,255,255,0.3), transparent, rgba(var(--brand-primary),0.1))", _dark: { background: "linear-gradient(to bottom right, rgba(17,24,39,0.2), transparent, transparent)" } })}></div>
				<div class={css({ position: "absolute", top: "-6", right: "-6", h: "72", w: "72", rounded: "full", background: "linear-gradient(to bottom right, rgba(var(--brand-secondary),0.4), rgba(var(--brand-primary),0.3))", filter: "blur(48px)" })}></div>
			</div>
			<div class={css({ position: "relative", px: { base: "6", sm: "12", lg: "16" }, py: "12" })}>
				<div class={css({ mb: { base: "10", lg: "14" }, textAlign: "center" })}>
					<h2 class={css({ mb: "4", fontSize: { base: "3xl", md: "4xl" }, fontWeight: "bold", letterSpacing: "tight", color: { base: "gray.900", _dark: "white" } })}>
						Our <span class={css({ color: "rgb(var(--brand-primary))" })}>Trusted</span> Partners
					</h2>
					<p class={css({ color: { base: "gray.600", _dark: "gray.300" }, fontSize: { sm: "xl" }, maxW: "3xl", mx: "auto" })}>
						The Rawkode Academy couldn't exist without the support of our partners. Visit their websites, contact them, and remember to let them know that you found them right here.
					</p>
					<div class={css({ mt: "6" })}>
						<a
							href="/organizations/partnerships"
							title="Become a Partner"
							class={css({
								display: "inline-flex",
								alignItems: "center",
								gap: "2",
								px: "6",
								py: "3",
								fontSize: "base",
								fontWeight: "semibold",
								color: "white",
								rounded: "2xl",
								border: "1px solid",
								borderColor: { base: "rgba(255,255,255,0.4)", _dark: "rgba(255,255,255,0.1)" },
								background: "linear-gradient(to right, rgb(var(--brand-primary)), rgb(var(--brand-secondary)))",
								shadow: "0 15px 40px rgba(99,102,241,0.35)",
								transition: "all",
								transitionDuration: "200ms",
								_hover: {
									transform: "scale(1.02)",
									shadow: "0 20px 45px rgba(99,102,241,0.45)",
								},
								_dark: {
									shadow: "0 30px 70px rgba(0,0,0,0.6)",
								},
							})}
						>
							Become a Partner
							<svg aria-hidden="true" class={css({ w: "5", h: "5" })} xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
								<path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
							</svg>
						</a>
					</div>
				</div>
				<div class={css({ position: "relative" })}>
					<PartnerLogos />
				</div>
			</div>
		</div>
	</section>
</Page>
