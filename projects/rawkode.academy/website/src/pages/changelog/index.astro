---
import { getCollection, getEntry } from "astro:content";
import { marked } from "marked";
import PageHero from "@/components/layout/PageHero.astro";
import Prose from "@/components/prose/Prose.astro";
import Page from "@/wrappers/page.astro";
import { css } from "../../../styled-system/css";

marked.setOptions({ breaks: true, gfm: true, pedantic: false });

const changelogEntries = await getCollection("changelog");
const sortedChangelog = changelogEntries.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const processedChangelog = await Promise.all(
	sortedChangelog.map(async (entry) => {
		const renderedContent = marked(entry.body || "");
		const authorEntry = await getEntry(entry.data.author);
		return {
			...entry.data,
			id: entry.id,
			renderedContent: String(renderedContent),
			author: {
				name: authorEntry?.data.name || "Unknown",
				avatar_url: authorEntry?.data.avatarUrl || "",
			},
		};
	}),
);

const typeStyles: Record<string, { bg: string; color: string }> = {
	feature: { bg: "rgba(34, 197, 94, 0.15)", color: "rgb(34, 197, 94)" },
	fix: { bg: "rgba(239, 68, 68, 0.15)", color: "rgb(239, 68, 68)" },
	chore: { bg: "rgba(95, 94, 215, 0.15)", color: "rgb(95, 94, 215)" },
	docs: { bg: "rgba(0, 206, 255, 0.15)", color: "rgb(0, 206, 255)" },
	breaking: { bg: "rgba(249, 115, 22, 0.15)", color: "rgb(249, 115, 22)" },
};

const shell = css({ maxWidth: "56rem", mx: "auto", px: { base: "4", md: "6" }, py: "12" });

const emptyState = css({ textAlign: "center", py: "12", color: "fg.muted" });

const list = css({ display: "flex", flexDirection: "column", gap: "6" });

const entryCard = css({
	p: "6",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
});

const tagRow = css({ mb: "3" });

const typeTag = css({
	display: "inline-flex",
	px: "3",
	py: "1",
	borderRadius: "full",
	fontSize: "xs",
	fontWeight: "semibold",
	textTransform: "uppercase",
	letterSpacing: "wider",
});

const entryTitle = css({
	fontFamily: "display",
	fontSize: "xl",
	fontWeight: "bold",
	color: "fg.primary",
	mb: "3",
});

const footer = css({
	display: "flex",
	alignItems: "center",
	gap: "4",
	mt: "5",
	pt: "4",
	borderTopWidth: "1px",
	borderTopColor: "border.muted",
	fontSize: "sm",
	color: "fg.muted",
});

const authorRow = css({ display: "flex", alignItems: "center", gap: "2" });
const avatar = css({ width: "6", height: "6", borderRadius: "full", objectFit: "cover" });
---

<Page title="Changelog" description="Stay up to date with the latest changes and improvements to Rawkode Academy.">
	<PageHero eyebrow="What's New" title="Changelog" subtitle="Stay up to date with the latest updates, features, and improvements." />

	<div class={shell}>
		{processedChangelog.length === 0 ? (
			<p class={emptyState}>No changelog entries found.</p>
		) : (
			<div class={list}>
				{processedChangelog.map((entry) => {
					const style = typeStyles[entry.type as keyof typeof typeStyles] ?? typeStyles.chore;
					return (
						<article class={entryCard}>
							<div class={tagRow}>
								<span class={typeTag} style={`background: ${style.bg}; color: ${style.color};`}>
									{entry.type}
								</span>
							</div>
							<h2 class={entryTitle}>{entry.title}</h2>
							<Prose>
								<div set:html={entry.renderedContent} />
							</Prose>
							<div class={footer}>
								<time datetime={entry.date.toISOString()}>
									{entry.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
								</time>
								<div class={authorRow}>
									{entry.author.avatar_url && <img src={entry.author.avatar_url} alt={entry.author.name} class={avatar} />}
									<span>by {entry.author.name}</span>
								</div>
							</div>
						</article>
					);
				})}
			</div>
		)}
	</div>
</Page>
