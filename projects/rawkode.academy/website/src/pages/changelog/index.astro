---
import { getCollection, getEntry } from "astro:content";
import { marked } from "marked";
import PageHero from "@/components/layout/PageHero.astro";
import Prose from "@/components/prose/Prose.astro";
import Page from "@/wrappers/page.astro";
import { css } from "../../../styled-system/css";

marked.setOptions({ breaks: true, gfm: true, pedantic: false });

const changelogEntries = await getCollection("changelog");
const sortedChangelog = changelogEntries.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const processedChangelog = await Promise.all(
	sortedChangelog.map(async (entry) => {
		const renderedContent = marked(entry.body || "");
		const authorEntry = await getEntry(entry.data.author);
		return {
			...entry.data,
			id: entry.id,
			renderedContent: String(renderedContent),
			author: {
				name: authorEntry?.data.name || "Unknown",
				avatar_url: authorEntry?.data.avatarUrl || "",
			},
		};
	}),
);

const typeStyles: Record<string, { bg: string; color: string }> = {
	feature: { bg: "rgba(34, 197, 94, 0.15)", color: "rgb(34, 197, 94)" },
	fix: { bg: "rgba(239, 68, 68, 0.15)", color: "rgb(239, 68, 68)" },
	chore: { bg: "rgba(95, 94, 215, 0.15)", color: "rgb(95, 94, 215)" },
	docs: { bg: "rgba(0, 206, 255, 0.15)", color: "rgb(0, 206, 255)" },
	breaking: { bg: "rgba(249, 115, 22, 0.15)", color: "rgb(249, 115, 22)" },
};

const typeCounts = new Map<string, number>();
for (const entry of processedChangelog) {
	typeCounts.set(entry.type, (typeCounts.get(entry.type) ?? 0) + 1);
}
const typeFilterEntries = [...typeCounts.entries()].sort((a, b) => b[1] - a[1]);

const shell = css({ maxWidth: "56rem", mx: "auto", px: { base: "4", md: "6" }, py: "12" });

const summaryBar = css({
	display: "flex",
	flexWrap: "wrap",
	gap: "3",
	alignItems: "center",
	justifyContent: "space-between",
	mb: "6",
});

const summaryCount = css({ fontSize: "sm", color: "fg.muted", fontWeight: "medium" });
const summaryCountStrong = css({
	fontFamily: "display",
	fontSize: "lg",
	fontWeight: "bold",
	color: "fg.primary",
});

const filterRow = css({ display: "flex", flexWrap: "wrap", gap: "2", mb: "8" });

const filterChip = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "1.5",
	px: "3.5",
	py: "1.5",
	borderRadius: "full",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.surface",
	color: "fg.secondary",
	fontSize: "sm",
	fontWeight: "medium",
	cursor: "pointer",
	textTransform: "capitalize",
	transition: "all 150ms ease",
	_hover: { borderColor: "border.default", color: "fg.primary" },
	"&[aria-pressed='true']": {
		bg: "bg.brand-subtle",
		borderColor: "fg.brand",
		color: "fg.brand",
	},
});

const filterCount = css({ fontSize: "xs", fontWeight: "semibold", opacity: "0.7" });

const emptyState = css({ textAlign: "center", py: "12", color: "fg.muted" });

const list = css({ display: "flex", flexDirection: "column", gap: "6" });

const entryCard = css({
	p: "6",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
});

const tagRow = css({ mb: "3" });

const typeTag = css({
	display: "inline-flex",
	px: "3",
	py: "1",
	borderRadius: "full",
	fontSize: "xs",
	fontWeight: "semibold",
	textTransform: "uppercase",
	letterSpacing: "wider",
});

const entryTitle = css({
	fontFamily: "display",
	fontSize: "xl",
	fontWeight: "bold",
	color: "fg.primary",
	mb: "3",
});

const footer = css({
	display: "flex",
	alignItems: "center",
	gap: "4",
	mt: "5",
	pt: "4",
	borderTopWidth: "1px",
	borderTopColor: "border.muted",
	fontSize: "sm",
	color: "fg.muted",
});

const authorRow = css({ display: "flex", alignItems: "center", gap: "2" });
const avatar = css({ flexShrink: 0, borderRadius: "full", objectFit: "cover" });
const avatarStyle = "width: 24px; height: 24px;";
---

<Page title="Changelog" description="Stay up to date with the latest changes and improvements to Rawkode Academy.">
	<PageHero eyebrow="What's New" title="Changelog" subtitle="Stay up to date with the latest updates, features, and improvements." />

	<div class={shell}>
		{processedChangelog.length === 0 ? (
			<p class={emptyState}>No changelog entries found.</p>
		) : (
			<>
				<div class={summaryBar}>
					<p class={summaryCount}>
						<span class={summaryCountStrong} data-visible-count>{processedChangelog.length}</span>
						{" "}updates · most recent first
					</p>
				</div>
				<div class={filterRow}>
					<button type="button" class={filterChip} data-type-filter="all" aria-pressed="true">
						All <span class={filterCount}>{processedChangelog.length}</span>
					</button>
					{typeFilterEntries.map(([type, count]) => (
						<button type="button" class={filterChip} data-type-filter={type} aria-pressed="false">
							{type} <span class={filterCount}>{count}</span>
						</button>
					))}
				</div>
				<div class={list} data-changelog-list>
					{processedChangelog.map((entry) => {
						const style = (typeStyles[entry.type as keyof typeof typeStyles] ?? typeStyles.chore) as { bg: string; color: string };
						return (
							<article class={entryCard} data-type={entry.type}>
								<div class={tagRow}>
									<span class={typeTag} style={`background: ${style.bg}; color: ${style.color};`}>
										{entry.type}
									</span>
								</div>
								<h2 class={entryTitle}>{entry.title}</h2>
								<Prose>
									<div set:html={entry.renderedContent} />
								</Prose>
								<div class={footer}>
									<time datetime={entry.date.toISOString()}>
										{entry.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
									</time>
									<div class={authorRow}>
										{entry.author.avatar_url && <img src={entry.author.avatar_url} alt={entry.author.name} class={avatar} style={avatarStyle} />}
										<span>by {entry.author.name}</span>
									</div>
								</div>
							</article>
						);
					})}
				</div>
			</>
		)}
	</div>

	<script>
		document.addEventListener("DOMContentLoaded", () => {
			const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-type-filter]"));
			const entries = Array.from(document.querySelectorAll<HTMLElement>("[data-changelog-list] > article"));
			const countTarget = document.querySelector<HTMLElement>("[data-visible-count]");

			buttons.forEach((btn) => {
				btn.addEventListener("click", () => {
					const filter = btn.dataset.typeFilter ?? "all";
					buttons.forEach((b) => b.setAttribute("aria-pressed", b === btn ? "true" : "false"));
					let visible = 0;
					entries.forEach((entry) => {
						const matches = filter === "all" || entry.dataset.type === filter;
						entry.style.display = matches ? "" : "none";
						if (matches) visible += 1;
					});
					if (countTarget) countTarget.textContent = visible.toString();
				});
			});
		});
	</script>
</Page>
