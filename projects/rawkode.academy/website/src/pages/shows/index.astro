---
export const prerender = false;

import { getCollection, getEntries } from "astro:content";
import ShowCard from "@/components/show/ShowCard.astro";
import Page from "@/wrappers/page.astro";
import type { ShowSummary } from "@/types/show";
import { css } from "../../../styled-system/css";

Astro.response.headers.set(
	"Cache-Control",
	"public, max-age=300, s-maxage=3600, stale-while-revalidate=86400",
);
Astro.response.headers.set("CDN-Cache-Control", "public, max-age=3600");
Astro.response.headers.set("Cache-Tag", "shows-page, shows-list");
Astro.response.headers.set("X-Build-Time", new Date().toISOString());

// Build shows from local content + videos
const showEntries = await getCollection("shows");
const videos = await getCollection("videos");

const getShowId = (value: unknown): string | null => {
	if (!value) return null;
	if (typeof value === "string") return value;
	if (typeof value === "object" && value !== null && "id" in value) {
		const id = (value as { id?: unknown }).id;
		return typeof id === "string" ? id : null;
	}
	return null;
};

const showsToRender: ShowSummary[] = await (async () => {
	const list: ShowSummary[] = [];
	for (const s of showEntries) {
		const people = await getEntries(s.data.hosts);
		const hosts = people.map((p) => {
			const parts = String(p.data.name).trim().split(/\s+/);
			return {
				forename: parts[0] || "",
				surname: parts.slice(1).join(" ") || "",
			};
		});
		const eps = videos
			.filter((v) => getShowId(v.data.show) === s.data.id)
			.map((v) => ({
				video: {
					title: v.data.title,
					thumbnailUrl: `https://content.rawkode.academy/videos/${v.data.id}/thumbnail.jpg`,
					publishedAt:
						v.data.publishedAt instanceof Date
							? v.data.publishedAt.toISOString()
							: String(v.data.publishedAt),
				},
			}));
		list.push({
			id: s.data.id,
			name: s.data.name,
			hosts,
			episodes: eps,
			cover: s.data.cover,
		});
	}
	return list;
})();

const hasShows = showsToRender.length > 0;

const sectionStyles = css({
	position: "relative",
	overflow: "hidden",
	py: { base: "16", sm: "20" },
});

const bgGradientStyles = css({
	position: "absolute",
	inset: "0",
	background: { base: "linear-gradient(to bottom, rgba(var(--brand-primary), 0.05), transparent, transparent)", _dark: "linear-gradient(to bottom, rgba(var(--brand-primary), 0.1), transparent, transparent)" },
});

const containerStyles = css({
	position: "relative",
	mx: "auto",
	maxW: "7xl",
});

const headerStyles = css({
	mb: "12",
	textAlign: "center",
});

const badgeStyles = css({
	mb: "4",
	display: "inline-flex",
	alignItems: "center",
	justifyContent: "center",
	borderRadius: "full",
	bg: { base: "rgba(var(--brand-primary), 0.1)", _dark: "rgba(var(--brand-primary), 0.2)" },
	px: "4",
	py: "2",
});

const badgeIconStyles = css({
	mr: "2",
	h: "5",
	w: "5",
	color: "colorPalette.default",
});

const badgeTextStyles = css({
	fontSize: "sm",
	fontWeight: "semibold",
	color: "colorPalette.default",
});

const titleStyles = css({
	fontSize: { base: "4xl", sm: "5xl", lg: "6xl" },
	fontWeight: "extrabold",
	letterSpacing: "tight",
	color: "fg.default",
});

const subtitleStyles = css({
	mx: "auto",
	mt: "6",
	maxW: "2xl",
	fontSize: "lg",
	lineHeight: "relaxed",
	color: "fg.muted",
});

const gridStyles = css({
	display: "grid",
	gap: "8",
	gridTemplateColumns: { sm: "repeat(2, 1fr)", lg: "repeat(3, 1fr)" },
});

const emptyStateStyles = css({
	mx: "auto",
	maxW: "2xl",
	borderRadius: "2xl",
	p: "12",
	textAlign: "center",
});

const emptyIconStyles = css({
	mx: "auto",
	h: "16",
	w: "16",
	color: { base: "rgba(var(--brand-primary), 0.3)", _dark: "rgba(var(--brand-primary), 0.2)" },
});

const emptyTitleStyles = css({
	mt: "4",
	fontSize: "lg",
	fontWeight: "medium",
	color: "fg.default",
});

const emptySubtitleStyles = css({
	mt: "2",
	fontSize: "sm",
	color: "fg.muted",
});
---

<Page title="Shows">
	<section class={sectionStyles}>
		<!-- Background gradient -->
		<div class={bgGradientStyles} aria-hidden="true"></div>

		<div class:list={[containerStyles, "content-px"]}>
			<!-- Header -->
			<div class={headerStyles}>
				<div class={badgeStyles}>
					<svg
						class={badgeIconStyles}
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
						aria-hidden="true"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M6 20.25h12m-7.5-3v3m3-3v3m-10.125-3h17.25c.621 0 1.125-.504 1.125-1.125V4.875c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125z"
						/>
					</svg>
					<span class={badgeTextStyles}>Original Series</span>
				</div>
				<h1 class={titleStyles}>
					Shows
				</h1>
				<p class={subtitleStyles}>
					Discover our collection of shows, each bringing you in-depth content and expert insights from passionate hosts.
				</p>
			</div>

			<!-- Content -->
			<div class={css({ mt: "16" })}>
				{hasShows ? (
					<div class={gridStyles}>
						{showsToRender.map((show) => (
							<ShowCard show={show} />
						))}
					</div>
				) : (
					<div class:list={["glass-card", emptyStateStyles]}>
						<svg
							class={emptyIconStyles}
							fill="none"
							viewBox="0 0 24 24"
							stroke="currentColor"
							aria-hidden="true"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.5"
								d="M6 20.25h12m-7.5-3v3m3-3v3m-10.125-3h17.25c.621 0 1.125-.504 1.125-1.125V4.875c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125z"
							/>
						</svg>
						<p class={emptyTitleStyles}>
							No shows available yet
						</p>
						<p class={emptySubtitleStyles}>
							We're working on bringing you exciting new content. Check back soon!
						</p>
					</div>
				)}
			</div>
		</div>
	</section>
</Page>
