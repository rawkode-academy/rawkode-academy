---
export const prerender = false;

import { getCollection, getEntries } from "astro:content";
import PageHero from "@/components/layout/PageHero.astro";
import Page from "@/wrappers/page.astro";
import type { ShowSummary } from "@/types/show";
import { css } from "../../../styled-system/css";

Astro.response.headers.set("Cache-Control", "public, max-age=300, s-maxage=3600, stale-while-revalidate=86400");
Astro.response.headers.set("CDN-Cache-Control", "public, max-age=3600");
Astro.response.headers.set("Cache-Tag", "shows-page, shows-list");

const showEntries = await getCollection("shows");
const videos = await getCollection("videos");

const getShowId = (value: unknown): string | null => {
	if (!value) return null;
	if (typeof value === "string") return value;
	if (typeof value === "object" && value !== null && "id" in value) {
		const id = (value as { id?: unknown }).id;
		return typeof id === "string" ? id : null;
	}
	return null;
};

const showsToRender: ShowSummary[] = await (async () => {
	const list: ShowSummary[] = [];
	for (const s of showEntries) {
		const people = await getEntries(s.data.hosts);
		const hosts = people.map((p) => {
			const parts = String(p.data.name).trim().split(/\s+/);
			return { forename: parts[0] || "", surname: parts.slice(1).join(" ") || "" };
		});
		const eps = videos
			.filter((v) => getShowId(v.data.show) === s.data.id)
			.map((v) => ({
				video: {
					title: v.data.title,
					thumbnailUrl: `https://content.rawkode.academy/videos/${v.data.id}/thumbnail.jpg`,
					publishedAt:
						v.data.publishedAt instanceof Date
							? v.data.publishedAt.toISOString()
							: String(v.data.publishedAt),
				},
			}));
		list.push({ id: s.data.id, name: s.data.name, hosts, episodes: eps, cover: s.data.cover });
	}
	return list;
})();

const hasShows = showsToRender.length > 0;

const shell = css({ maxWidth: "80rem", mx: "auto", px: { base: "4", md: "6" }, py: "12" });

const grid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", sm: "repeat(2, minmax(0, 1fr))", lg: "repeat(3, minmax(0, 1fr))" },
	gap: "6",
});

const showCard = css({
	display: "flex",
	flexDirection: "column",
	overflow: "hidden",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textDecoration: "none",
	color: "fg.primary",
	transition: "transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease",
	_hover: { transform: "translateY(-2px)", boxShadow: "lg", borderColor: "border.default" },
});

const coverWrap = css({
	aspectRatio: "16 / 9",
	overflow: "hidden",
	bg: "bg.sunken",
	"& img": { width: "full", height: "full", objectFit: "cover" },
});

const body = css({ p: "6", display: "flex", flexDirection: "column", gap: "3", flex: "1" });

const showName = css({
	fontFamily: "display",
	fontSize: "xl",
	fontWeight: "bold",
	letterSpacing: "tight",
	color: "fg.primary",
	transition: "color 150ms ease",
	"a:hover &": { color: "fg.brand" },
});

const hostsLine = css({ fontSize: "sm", color: "fg.muted" });

const episodeCount = css({
	mt: "auto",
	fontSize: "xs",
	fontWeight: "semibold",
	color: "fg.brand",
	letterSpacing: "wider",
	textTransform: "uppercase",
});

const emptyCard = css({
	mx: "auto",
	maxWidth: "32rem",
	p: "12",
	borderRadius: "3xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textAlign: "center",
});
---

<Page title="Shows">
	<PageHero eyebrow="Original Series" title="Shows" subtitle="In-depth content and expert insights from passionate hosts." />

	<div class={shell}>
		{hasShows ? (
			<div class={grid}>
				{showsToRender.map((show) => (
					<a href={`/shows/${show.id}`} class={showCard}>
						{show.cover ? (
							<div class={coverWrap}>
								<img src={typeof show.cover === "string" ? show.cover : show.cover?.image?.src || ""} alt={show.name} loading="lazy" />
							</div>
						) : (
							<div class={coverWrap}></div>
						)}
						<div class={body}>
							<h2 class={showName}>{show.name}</h2>
							{show.hosts.length > 0 && (
								<p class={hostsLine}>
									Hosted by {show.hosts.map((h) => `${h.forename} ${h.surname}`.trim()).join(", ")}
								</p>
							)}
							<span class={episodeCount}>
								{show.episodes.length} episode{show.episodes.length === 1 ? "" : "s"}
							</span>
						</div>
					</a>
				))}
			</div>
		) : (
			<div class={emptyCard}>
				<p>No shows available yet. We're working on bringing you exciting new content — check back soon!</p>
			</div>
		)}
	</div>
</Page>
