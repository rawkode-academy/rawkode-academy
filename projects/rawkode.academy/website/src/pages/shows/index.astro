---
export const prerender = false;

import { getCollection, getEntries } from "astro:content";
import PageHero from "@/components/layout/PageHero.astro";
import Page from "@/wrappers/page.astro";
import type { ShowSummary } from "@/types/show";
import { css } from "../../../styled-system/css";

Astro.response.headers.set("Cache-Control", "public, max-age=300, s-maxage=3600, stale-while-revalidate=86400");
Astro.response.headers.set("CDN-Cache-Control", "public, max-age=3600");
Astro.response.headers.set("Cache-Tag", "shows-page, shows-list");

const showEntries = await getCollection("shows");
const videos = await getCollection("videos");

const getShowId = (value: unknown): string | null => {
	if (!value) return null;
	if (typeof value === "string") return value;
	if (typeof value === "object" && value !== null && "id" in value) {
		const id = (value as { id?: unknown }).id;
		return typeof id === "string" ? id : null;
	}
	return null;
};

type ShowWithLatest = ShowSummary & {
	latestEpisode?: { title: string; publishedAt: string } | undefined;
};

const showsToRender: ShowWithLatest[] = await (async () => {
	const list: ShowWithLatest[] = [];
	for (const s of showEntries) {
		const people = await getEntries(s.data.hosts);
		const hosts = people.map((p) => {
			const parts = String(p.data.name).trim().split(/\s+/);
			return { forename: parts[0] || "", surname: parts.slice(1).join(" ") || "" };
		});
		const eps = videos
			.filter((v) => getShowId(v.data.show) === s.data.id)
			.sort((a, b) => new Date(b.data.publishedAt as Date | string).getTime() - new Date(a.data.publishedAt as Date | string).getTime())
			.map((v) => ({
				video: {
					title: v.data.title,
					thumbnailUrl: `https://content.rawkode.academy/videos/${v.data.id}/thumbnail.jpg`,
					publishedAt:
						v.data.publishedAt instanceof Date
							? v.data.publishedAt.toISOString()
							: String(v.data.publishedAt),
				},
			}));
		list.push({
			id: s.data.id,
			name: s.data.name,
			hosts,
			episodes: eps,
			cover: s.data.cover,
			latestEpisode: eps[0]
				? { title: eps[0].video.title, publishedAt: eps[0].video.publishedAt }
				: undefined,
		});
	}
	return list.sort((a, b) => (b.episodes?.length ?? 0) - (a.episodes?.length ?? 0));
})();

const hasShows = showsToRender.length > 0;
const totalEpisodes = showsToRender.reduce((acc, s) => acc + (s.episodes?.length ?? 0), 0);

const formatDate = (iso: string) =>
	new Intl.DateTimeFormat("en-US", { month: "short", day: "numeric", year: "numeric" }).format(new Date(iso));

const shell = css({ maxWidth: "80rem", mx: "auto", px: { base: "4", md: "6" }, py: "12" });

const sectionHead = css({
	display: "flex",
	alignItems: "baseline",
	justifyContent: "space-between",
	gap: "4",
	mb: "8",
	flexWrap: "wrap",
});

const sectionTitle = css({
	fontFamily: "display",
	fontSize: { base: "2xl", md: "3xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	color: "fg.primary",
});

const sectionCount = css({ fontSize: "sm", color: "fg.muted", fontWeight: "medium" });

const grid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", sm: "repeat(2, minmax(0, 1fr))", lg: "repeat(3, minmax(0, 1fr))" },
	gap: "6",
});

const showCard = css({
	position: "relative",
	display: "flex",
	flexDirection: "column",
	overflow: "hidden",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textDecoration: "none",
	color: "fg.primary",
	transition: "transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease",
	_hover: { transform: "translateY(-3px)", boxShadow: "xl", borderColor: "border.default" },
});

const coverWrap = css({
	position: "relative",
	aspectRatio: "16 / 9",
	overflow: "hidden",
	bg: "bg.sunken",
	"& img": { width: "full", height: "full", objectFit: "cover", transition: "transform 400ms ease" },
	"a:hover &": { "& img": { transform: "scale(1.04)" } },
});

const coverFallback = css({
	width: "full",
	height: "full",
	display: "flex",
	alignItems: "center",
	justifyContent: "center",
	color: "fg.brand",
	fontSize: "6xl",
	fontFamily: "display",
	fontWeight: "bold",
	backgroundImage: "linear-gradient(135deg, token(colors.brand.500)/20, token(colors.cyan.500)/15)",
});

const episodeBadge = css({
	position: "absolute",
	top: "3",
	left: "3",
	display: "inline-flex",
	alignItems: "center",
	gap: "1.5",
	px: "2.5",
	py: "1",
	borderRadius: "full",
	fontSize: "2xs",
	fontWeight: "bold",
	letterSpacing: "wider",
	textTransform: "uppercase",
	bg: "bg.canvas/85",
	color: "fg.brand",
	backdropFilter: "blur(8px)",
});

const body = css({ p: "6", display: "flex", flexDirection: "column", gap: "3", flex: "1" });

const showName = css({
	fontFamily: "display",
	fontSize: "xl",
	fontWeight: "bold",
	letterSpacing: "tight",
	color: "fg.primary",
	lineHeight: "1.2",
	transition: "color 150ms ease",
	"a:hover &": { color: "fg.brand" },
});

const hostsLine = css({ fontSize: "sm", color: "fg.muted" });

const latestBlock = css({
	mt: "auto",
	pt: "4",
	borderTopWidth: "1px",
	borderTopColor: "border.muted",
	display: "flex",
	flexDirection: "column",
	gap: "1",
});

const latestLabel = css({
	fontSize: "2xs",
	fontWeight: "bold",
	letterSpacing: "wider",
	textTransform: "uppercase",
	color: "fg.brand",
});

const latestTitle = css({
	fontSize: "sm",
	fontWeight: "medium",
	color: "fg.primary",
	display: "-webkit-box",
	WebkitLineClamp: "2",
	overflow: "hidden",
	lineHeight: "1.4",
});

const latestDate = css({ fontSize: "xs", color: "fg.muted" });

const noEpisodes = css({
	mt: "auto",
	pt: "4",
	borderTopWidth: "1px",
	borderTopColor: "border.muted",
	fontSize: "xs",
	color: "fg.muted",
	fontStyle: "italic",
});

const emptyCard = css({
	mx: "auto",
	maxWidth: "32rem",
	p: "12",
	borderRadius: "3xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textAlign: "center",
});
---

<Page title="Shows">
	<PageHero eyebrow="Original Series" title="Shows" subtitle="In-depth content and expert insights from passionate hosts." />

	<div class={shell}>
		{hasShows ? (
			<>
				<div class={sectionHead}>
					<div style="display: flex; align-items: baseline; gap: 1rem; flex-wrap: wrap;">
						<h2 class={sectionTitle}>Browse our shows</h2>
						<span class={sectionCount}>{showsToRender.length} show{showsToRender.length === 1 ? "" : "s"} · {totalEpisodes} episodes</span>
					</div>
				</div>
				<div class={grid}>
					{showsToRender.map((show) => (
						<a href={`/shows/${show.id}`} class={showCard}>
							<div class={coverWrap}>
								{show.cover ? (
									<img src={typeof show.cover === "string" ? show.cover : show.cover?.image?.src || ""} alt={show.name} loading="lazy" />
								) : (
									<div class={coverFallback}>{show.name.charAt(0)}</div>
								)}
								<span class={episodeBadge}>
									<svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M10 8l6 4-6 4V8z"/></svg>
									{show.episodes?.length ?? 0} ep{(show.episodes?.length ?? 0) === 1 ? "" : "s"}
								</span>
							</div>
							<div class={body}>
								<h2 class={showName}>{show.name}</h2>
								{(show.hosts?.length ?? 0) > 0 && (
									<p class={hostsLine}>
										Hosted by {(show.hosts ?? []).map((h) => `${h.forename} ${h.surname}`.trim()).join(", ")}
									</p>
								)}
								{show.latestEpisode ? (
									<div class={latestBlock}>
										<span class={latestLabel}>Latest episode</span>
										<span class={latestTitle}>{show.latestEpisode.title}</span>
										<span class={latestDate}>{formatDate(show.latestEpisode.publishedAt)}</span>
									</div>
								) : (
									<span class={noEpisodes}>Episodes coming soon</span>
								)}
							</div>
						</a>
					))}
				</div>
			</>
		) : (
			<div class={emptyCard}>
				<p>No shows available yet. We're working on bringing you exciting new content — check back soon!</p>
			</div>
		)}
	</div>
</Page>
</content>
</invoke>