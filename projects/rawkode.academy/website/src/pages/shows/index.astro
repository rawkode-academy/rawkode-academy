---
export const prerender = false;

import { getCollection, getEntries } from "astro:content";
import ShowCard from "@/components/show/ShowCard.astro";
import ShowItemListJsonLd from "@/components/html/show-itemlist-jsonld.astro";
import Page from "@/wrappers/page.astro";
import type { ShowSummary } from "@/types/show";
import { getVideoThumbnailUrl } from "@/lib/video-thumbnail";

Astro.response.headers.set(
	"Cache-Control",
	"public, max-age=300, s-maxage=3600, stale-while-revalidate=86400",
);
Astro.response.headers.set("CDN-Cache-Control", "public, max-age=3600");
Astro.response.headers.set("Cache-Tag", "shows-page, shows-list");
Astro.response.headers.set("X-Build-Time", new Date().toISOString());

// Build shows from local content + videos. `publish: false` shows are
// drafts / archived - they don't belong in the public directory.
const showEntries = (await getCollection("shows")).filter(
	(s) => s.data.publish,
);
const videos = await getCollection("videos");

const getShowId = (value: unknown): string | null => {
	if (!value) return null;
	if (typeof value === "string") return value;
	if (typeof value === "object" && value !== null && "id" in value) {
		const id = (value as { id?: unknown }).id;
		return typeof id === "string" ? id : null;
	}
	return null;
};

const showsToRender: ShowSummary[] = await (async () => {
	const list: ShowSummary[] = [];
	for (const s of showEntries) {
		const people = await getEntries(s.data.hosts);
		const hosts = people.map((p) => {
			const parts = String(p.data.name).trim().split(/\s+/);
			return {
				forename: parts[0] || "",
				surname: parts.slice(1).join(" ") || "",
			};
		});
		const eps = videos
			.filter((v) => getShowId(v.data.show) === s.data.id)
			.map((v) => ({
				video: {
					title: v.data.title,
					thumbnailUrl: getVideoThumbnailUrl(v.data.id),
					publishedAt:
						v.data.publishedAt instanceof Date
							? v.data.publishedAt.toISOString()
							: String(v.data.publishedAt),
				},
			}));
		list.push({
			id: s.data.id,
			name: s.data.name,
			hosts,
			episodes: eps,
			cover: s.data.cover,
		});
	}
	return list;
})();

const hasShows = showsToRender.length > 0;

const showsJsonLd = showEntries.map((s) => {
	const episodeCount = videos.filter(
		(v) => getShowId(v.data.show) === s.data.id,
	).length;
	return {
		id: s.data.id,
		name: s.data.name,
		...(s.data.description ? { description: s.data.description } : {}),
		...(episodeCount > 0 ? { episodeCount } : {}),
	};
});
---

<Page
	title="Shows"
	description="Browse the live and recurring shows from Rawkode Academy - interviews, deep dives, and hands-on streams covering the cloud native ecosystem."
	pageType="CollectionPage"
>
	<ShowItemListJsonLd
		slot="extra-head"
		shows={showsJsonLd}
		listUrl={new URL("/shows", Astro.site ?? Astro.url).href}
		listName="Rawkode Academy Shows"
	/>
 <section class="relative overflow-hidden py-16 sm:py-20">
 <!-- Background gradient -->
 <div class="absolute inset-0 bg-transparent" aria-hidden="true"></div>

 <div class="relative mx-auto max-w-7xl content-px">
 <!-- Header -->
 <div class="shows-header">
 <div class="shows-header__meta">
 <span class="shows-header__kicker">§ Original series</span>
 </div>
 <h1 class="shows-header__title">
 Shows<span class="shows-header__title-soft"> — long-form programs from the academy</span>
 </h1>
 <p class="shows-header__lede">
 Recurring programs that go deeper than a single video. Each show carries its own hosts, cadence, and editorial style.
 </p>
 </div>

 <!-- Content -->
 <div class="mt-16">
 {hasShows ? (
 <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
 {showsToRender.map((show) => (
 <ShowCard show={show} />
 ))}
 </div>
 ) : (
 <div class="mx-auto max-w-2xl border border-[var(--editorial-hairline)] bg-[var(--editorial-paper-deep)] p-12 text-center">
 <svg
 class="mx-auto h-16 w-16 text-primary/30 dark:text-primary/20"
 fill="none"
 viewBox="0 0 24 24"
 stroke="currentColor"
 aria-hidden="true"
 >
 <path
 stroke-linecap="round"
 stroke-linejoin="round"
 stroke-width="1.5"
 d="M6 20.25h12m-7.5-3v3m3-3v3m-10.125-3h17.25c.621 0 1.125-.504 1.125-1.125V4.875c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125z"
 />
 </svg>
 <p class="mt-4 text-lg font-medium text-secondary-content">
 No shows available yet
 </p>
 <p class="mt-2 text-sm text-muted">
 We're working on bringing you exciting new content. Check back soon!
 </p>
 </div>
 )}
 </div>
 </div>
 </section>
</Page>

<style>
	.shows-header {
		text-align: left;
		max-width: 60rem;
		margin: 0 0 3rem;
		padding-bottom: 2rem;
		border-bottom: 1px solid var(--editorial-hairline);
	}
	.shows-header__meta {
		margin-bottom: 1rem;
	}
	.shows-header__kicker {
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 0.6875rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--editorial-spruce);
	}
	.shows-header__title {
		font-family: var(--font-instrument-serif), serif;
		font-style: italic;
		font-weight: 400;
		font-size: clamp(2.75rem, 6vw, 4.5rem);
		line-height: 0.98;
		letter-spacing: -0.025em;
		color: var(--editorial-ink);
		margin: 0;
		text-wrap: balance;
	}
	.shows-header__title-soft {
		color: var(--editorial-ink-soft);
	}
	.shows-header__lede {
		font-family: var(--font-inter-tight), sans-serif;
		font-size: 1.125rem;
		line-height: 1.5;
		color: var(--editorial-ink-soft);
		margin: 1.25rem 0 0;
		max-width: 40rem;
	}
</style>
