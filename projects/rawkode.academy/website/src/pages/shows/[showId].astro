---
export const prerender = false;

import { Image, getImage } from "astro:assets";
import { getCollection, getEntries } from "astro:content";
import { getPublishedVideos } from "@/lib/content";
import Breadcrumb from "@/components/breadcrumb/Breadcrumb.astro";
import VideoMetadata from "@/components/html/video-metadata.astro";
import PodcastSeriesJsonLd from "@/components/html/podcast-series-jsonld.astro";
import Page from "@/wrappers/page.astro";
import { createLogger } from "@/lib/logger";
import { css } from "../../../styled-system/css";

const logger = createLogger("shows");
const { showId } = Astro.params;

if (!showId) {
	logger.error("Missing showId parameter for show page");
	return new Response(null, { status: 404 });
}

const shows = await getCollection("shows");
const showEntry = shows.find((s) => s.data.id === showId);
if (!showEntry) return new Response(null, { status: 404 });

const videos = await getPublishedVideos();

const getRefId = (value: unknown): string | null => {
	if (!value) return null;
	if (typeof value === "string") return value;
	if (typeof value === "object" && value !== null && "id" in value) {
		const id = (value as { id?: unknown }).id;
		return typeof id === "string" ? id : null;
	}
	return null;
};

const videosForShow = videos.filter((v) => getRefId(v.data.show) === showEntry.data.id);
const hostEntries = await getEntries(showEntry.data.hosts);
const hostNames = hostEntries.map((h) => String(h.data.name).trim()).filter((n) => n.length > 0);

const feedVideos = videosForShow
	.map((v) => ({
		id: v.data.id,
		title: v.data.title,
		thumbnailUrl: `https://content.rawkode.academy/videos/${v.data.id}/thumbnail.jpg`,
		duration: typeof v.data.duration === "number" ? v.data.duration : 0,
		slug: v.data.slug,
		publishedAt: v.data.publishedAt instanceof Date ? v.data.publishedAt.toISOString() : String(v.data.publishedAt),
	}))
	.sort((a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime());

Astro.response.headers.set("Cache-Control", "public, max-age=600, s-maxage=7200, stale-while-revalidate=172800");
Astro.response.headers.set("CDN-Cache-Control", "public, max-age=7200");
Astro.response.headers.set("Cache-Tag", `show-${showEntry.data.id}, shows-page, show-detail`);

const showDescription = showEntry.data.description?.trim() || "Episode guide coming soon.";

const breadcrumbElements = [
	{ title: "Home", link: "/" },
	{ title: "Shows", link: "/shows" },
	{ title: showEntry.data.name, link: `/shows/${showEntry.data.id}` },
];

const pageTitle = `${showEntry.data.name} Episodes`;
const totalDurationSeconds = feedVideos.reduce((s, v) => s + v.duration, 0);
const totalHours = Math.floor(totalDurationSeconds / 3600);

let podcastImageUrl: string | undefined;
if (showEntry.data.podcast?.artworkUrl) {
	podcastImageUrl = showEntry.data.podcast.artworkUrl;
} else if (showEntry.data.cover) {
	try {
		const resolved = await getImage({ src: showEntry.data.cover.image });
		podcastImageUrl = new URL(resolved.src, Astro.site ?? Astro.url).href;
	} catch {}
}

const fmtDate = (s: string) =>
	new Date(s).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });

const fmtDuration = (sec: number) => {
	if (sec <= 0) return "";
	const h = Math.floor(sec / 3600);
	const m = Math.floor((sec % 3600) / 60);
	return h > 0 ? `${h}:${String(m).padStart(2, "0")}` : `${m}m`;
};

const shell = css({ maxWidth: "80rem", mx: "auto", px: { base: "4", md: "6" }, py: "10" });

const heroLayout = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", lg: "1.4fr 1fr" },
	gap: "8",
	alignItems: "center",
	p: { base: "6", md: "10" },
	borderRadius: "3xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	backgroundImage:
		"radial-gradient(circle at 20% 20%, token(colors.brand.500)/12, transparent 50%), radial-gradient(circle at 80% 30%, token(colors.cyan.500)/12, transparent 50%)",
});

const eyebrow = css({
	display: "inline-flex",
	px: "3",
	py: "1",
	borderRadius: "full",
	bg: "bg.brand-subtle",
	color: "fg.brand",
	fontSize: "xs",
	fontWeight: "semibold",
	letterSpacing: "wider",
	textTransform: "uppercase",
	mb: "4",
});

const title = css({
	fontFamily: "display",
	fontSize: { base: "3xl", md: "5xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	lineHeight: "1.1",
	color: "fg.primary",
});

const subtitle = css({ mt: "4", fontSize: "lg", color: "fg.secondary", lineHeight: "1.7" });

const hosts = css({ mt: "5", display: "flex", flexWrap: "wrap", alignItems: "center", gap: "2", fontSize: "sm", color: "fg.muted" });

const hostChip = css({
	display: "inline-flex",
	px: "3",
	py: "1",
	borderRadius: "full",
	bg: "bg.surface",
	borderWidth: "1px",
	borderColor: "border.muted",
	color: "fg.primary",
	fontWeight: "medium",
});

const meta = css({ mt: "5", display: "flex", flexWrap: "wrap", gap: "4", fontSize: "sm", color: "fg.muted" });

const coverWrap = css({
	overflow: "hidden",
	borderRadius: "2xl",
	boxShadow: "lg",
	"& img": { width: "full", height: "auto", display: "block" },
});

const sectionTitle = css({
	fontFamily: "display",
	fontSize: { base: "2xl", md: "3xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	color: "fg.primary",
	mt: "16",
	mb: "8",
});

const grid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", sm: "repeat(2, minmax(0, 1fr))", lg: "repeat(3, minmax(0, 1fr))" },
	gap: "5",
});

const card = css({
	display: "flex",
	flexDirection: "column",
	overflow: "hidden",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textDecoration: "none",
	color: "fg.primary",
	transition: "transform 200ms ease, box-shadow 200ms ease",
	_hover: { transform: "translateY(-2px)", boxShadow: "lg" },
});

const thumb = css({
	position: "relative",
	aspectRatio: "16 / 9",
	overflow: "hidden",
	bg: "bg.sunken",
	"& img": { width: "full", height: "full", objectFit: "cover" },
});

const cardBody = css({ p: "5", display: "flex", flexDirection: "column", gap: "2", flex: "1" });
const cardMeta = css({ fontSize: "xs", fontWeight: "semibold", letterSpacing: "wider", textTransform: "uppercase", color: "fg.muted" });
const cardTitle = css({
	fontSize: "md",
	fontWeight: "semibold",
	color: "fg.primary",
	lineHeight: "tight",
	display: "-webkit-box",
	WebkitLineClamp: "2",
	WebkitBoxOrient: "vertical",
	overflow: "hidden",
});

const emptyState = css({
	mx: "auto",
	maxWidth: "32rem",
	p: "12",
	textAlign: "center",
	borderRadius: "3xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
});
---

<Page title={pageTitle} description={showDescription}>
	<PodcastSeriesJsonLd slot="extra-head" show={showEntry} hosts={hostEntries} episodeCount={feedVideos.length} {...(podcastImageUrl ? { imageUrl: podcastImageUrl } : {})} />
	<VideoMetadata slot="extra-head" title={pageTitle} description={showDescription} isVideoList={true} />

	<div class={shell}>
		<Breadcrumb elements={breadcrumbElements} />

		<div class={heroLayout}>
			<div>
				<span class={eyebrow}>Show</span>
				<h1 class={title}>{showEntry.data.name}</h1>
				<p class={subtitle}>{showDescription}</p>
				{hostNames.length > 0 && (
					<div class={hosts}>
						<span>Hosted by</span>
						{hostNames.map((host) => <span class={hostChip}>{host}</span>)}
					</div>
				)}
				{feedVideos.length > 0 && (
					<div class={meta}>
						<span>{feedVideos.length} episode{feedVideos.length === 1 ? "" : "s"}</span>
						{totalHours > 0 && <><span>·</span><span>{totalHours}+ hours of content</span></>}
					</div>
				)}
			</div>

			{showEntry.data.cover && (
				<div class={coverWrap}>
					<Image src={showEntry.data.cover.image} alt={showEntry.data.cover.alt} width={800} height={600} />
				</div>
			)}
		</div>

		<h2 class={sectionTitle}>Episodes</h2>
		{feedVideos.length > 0 ? (
			<div class={grid}>
				{feedVideos.map((video) => (
					<a href={`/watch/${video.slug}`} class={card}>
						<div class={thumb}>
							<img src={video.thumbnailUrl} alt={video.title} loading="lazy" />
						</div>
						<div class={cardBody}>
							<div class={cardMeta}>
								{fmtDate(video.publishedAt)}
								{fmtDuration(video.duration) && <> · {fmtDuration(video.duration)}</>}
							</div>
							<h3 class={cardTitle}>{video.title}</h3>
						</div>
					</a>
				))}
			</div>
		) : (
			<div class={emptyState}>
				<p>No episodes yet. Episodes for this show are coming soon — check back later!</p>
			</div>
		)}
	</div>
</Page>
