---
export const prerender = false;

import { getCollection, getEntries } from "astro:content";
import { getPublishedVideos } from "@/lib/content";
import Breadcrumb from "@/components/breadcrumb/Breadcrumb.astro";
import VideoMetadata from "@/components/html/video-metadata.astro";
import VideoFeed from "@/components/video/video-feed.astro";
import SubscribeLinks from "@/components/show/SubscribeLinks.vue";
import NewsletterCTA from "@/components/newsletter/NewsletterCTA.astro";
import Page from "@/wrappers/page.astro";
import { Image } from "astro:assets";
import { createLogger } from "@/lib/logger";
import { css, cx } from "../../../styled-system/css";

const logger = createLogger("shows");
const { showId } = Astro.params;

if (!showId) {
	logger.error("Missing showId parameter for show page");
	return new Response(null, { status: 404 });
}

const shows = await getCollection("shows");
const showEntry = shows.find((s) => s.data.id === showId);

if (!showEntry) {
	return new Response(null, { status: 404 });
}

// Get published videos only (filters out future-dated for scheduled publishing)
const videos = await getPublishedVideos();

const getShowId = (value: unknown): string | null => {
	if (!value) return null;
	if (typeof value === "string") return value;
	if (typeof value === "object" && value !== null && "id" in value) {
		const id = (value as { id?: unknown }).id;
		return typeof id === "string" ? id : null;
	}
	return null;
};

const videosForShow = videos.filter(
	(video) => getShowId(video.data.show) === showEntry.data.id,
);

const hostEntries = await getEntries(showEntry.data.hosts);
const hostNames = hostEntries
	.map((host) => String(host.data.name).trim())
	.filter((name) => name.length > 0);

const feedVideos = videosForShow
	.map((video) => ({
		id: video.data.id,
		title: video.data.title,
		thumbnailUrl: `https://content.rawkode.academy/videos/${video.data.id}/thumbnail.jpg`,
		streamUrl: `https://content.rawkode.academy/videos/${video.data.id}/stream.m3u8`,
		duration: typeof video.data.duration === "number" ? video.data.duration : 0,
		slug: video.data.slug,
		publishedAt:
			video.data.publishedAt instanceof Date
				? video.data.publishedAt.toISOString()
				: String(video.data.publishedAt),
	}))
	.sort(
		(a, b) =>
			new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime(),
	);

Astro.response.headers.set(
	"Cache-Control",
	"public, max-age=600, s-maxage=7200, stale-while-revalidate=172800",
);
Astro.response.headers.set("CDN-Cache-Control", "public, max-age=7200");
Astro.response.headers.set(
	"Cache-Tag",
	`show-${showEntry.data.id}, shows-page, show-detail`,
);
Astro.response.headers.set("X-Build-Time", new Date().toISOString());

const showDescription =
	showEntry.data.description?.trim() || "Episode guide coming soon.";

const breadcrumbElements = [
	{ title: "Home", link: "/" },
	{ title: "Shows", link: "/shows" },
	{ title: showEntry.data.name, link: `/shows/${showEntry.data.id}` },
];

const pageTitle = `${showEntry.data.name} Episodes`;

const latestEpisode = feedVideos[0];
const totalDurationSeconds = feedVideos.reduce((sum, v) => sum + v.duration, 0);
const totalHours = Math.floor(totalDurationSeconds / 3600);

function formatDate(dateString: string) {
	return new Date(dateString).toLocaleDateString("en-US", {
		year: "numeric",
		month: "short",
		day: "numeric",
	});
}

function formatDuration(seconds: number) {
	if (seconds <= 0) return "--:--";
	const hours = Math.floor(seconds / 3600);
	const minutes = Math.floor((seconds % 3600) / 60);
	const remainingSeconds = Math.floor(seconds % 60);
	if (hours > 0) {
		return `${hours}:${minutes.toString().padStart(2, "0")}:${remainingSeconds.toString().padStart(2, "0")}`;
	}
	return `${minutes}:${remainingSeconds.toString().padStart(2, "0")}`;
}

const heroSectionStyles = css({
	position: "relative",
	overflow: "hidden",
});

const heroBgStyles = css({
	position: "absolute",
	inset: "0",
	background: { base: "linear-gradient(to bottom right, rgba(var(--brand-primary), 0.1), transparent, rgba(var(--brand-secondary), 0.05))", _dark: "linear-gradient(to bottom right, rgba(var(--brand-primary), 0.2), transparent, rgba(var(--brand-secondary), 0.1))" },
});

const heroRadialBgStyles = css({
	position: "absolute",
	inset: "0",
	background: { base: "radial-gradient(ellipse 80% 50% at 50% -20%, rgba(var(--brand-primary), 0.15), transparent)", _dark: "radial-gradient(ellipse 80% 50% at 50% -20%, rgba(var(--brand-primary), 0.25), transparent)" },
});

const heroContainerStyles = css({
	position: "relative",
	mx: "auto",
	maxW: "7xl",
	pb: "12",
	pt: "8",
});

const heroFlexStyles = css({
	mt: "8",
	display: "flex",
	flexDirection: "column",
	gap: "8",
	lg: {
		flexDirection: "row",
		alignItems: "center",
		gap: "12",
	},
});

const showInfoStyles = css({
	flex: "1",
	display: "flex",
	flexDirection: "column",
	gap: "5",
});

const showTagStyles = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	borderRadius: "full",
	bg: { base: "rgba(var(--brand-primary), 0.1)", _dark: "rgba(var(--brand-primary), 0.2)" },
	px: "3",
	py: "1",
});

const showTagIconStyles = css({
	h: "4",
	w: "4",
	color: "colorPalette.default",
});

const showTagTextStyles = css({
	fontSize: "sm",
	fontWeight: "semibold",
	color: "colorPalette.default",
});

const showTitleStyles = css({
	fontSize: { base: "4xl", sm: "5xl", lg: "6xl" },
	fontWeight: "extrabold",
	letterSpacing: "tight",
	color: "fg.default",
});

const hostsContainerStyles = css({
	display: "flex",
	flexWrap: "wrap",
	alignItems: "center",
	gap: "2",
});

const hostedByTextStyles = css({
	fontSize: "sm",
	color: "fg.muted",
});

const descriptionStyles = css({
	maxW: "2xl",
	fontSize: "lg",
	lineHeight: "relaxed",
	color: "fg.default",
});

const statsContainerStyles = css({
	display: "flex",
	flexWrap: "wrap",
	alignItems: "center",
	gap: "4",
	fontSize: "sm",
	color: "fg.muted",
});

const statItemStyles = css({
	display: "flex",
	alignItems: "center",
	gap: "1.5",
});

const statIconStyles = css({
	h: "4",
	w: "4",
});

const coverContainerStyles = css({
	flexShrink: 0,
	w: "full",
	lg: { w: "2/5" },
	maxW: "md",
});

const coverImageWrapperStyles = css({
	overflow: "hidden",
	borderRadius: "2xl",
	shadow: "xl",
});

const coverImgStyles = css({
	w: "full",
	h: "auto",
	objectFit: "cover",
});

const latestEpThumbnailStyles = css({
	aspectRatio: "16/9",
	w: "full",
	objectFit: "cover",
	transition: "transform",
	transitionDuration: "200ms",
	_groupHover: {
		transform: "scale(1.03)",
	},
});

const latestEpOverlayStyles = css({
	position: "absolute",
	inset: "0",
	background: "linear-gradient(to top, rgba(0, 0, 0, 0.6), transparent, transparent)",
});

const playButtonContainerStyles = css({
	position: "absolute",
	inset: "0",
	display: "flex",
	alignItems: "center",
	justifyContent: "center",
	opacity: 0,
	transition: "opacity",
	_groupHover: { opacity: 1 },
});

const playButtonStyles = css({
	display: "flex",
	h: "16",
	w: "16",
	alignItems: "center",
	justifyContent: "center",
	borderRadius: "full",
	bg: "rgba(var(--brand-primary), 0.9)",
	color: "white",
	shadow: "lg",
	backdropFilter: "blur(4px)",
});

const playIconStyles = css({
	h: "7",
	w: "7",
	ml: "1",
});

const latestEpInfoStyles = css({
	position: "absolute",
	bottom: "0",
	left: "0",
	right: "0",
	p: "4",
});

const latestEpLabelStyles = css({
	fontSize: "xs",
	fontWeight: "medium",
	color: "rgba(255, 255, 255, 0.8)",
});

const latestEpTitleStyles = css({
	mt: "1",
	lineClamp: 2,
	fontSize: "sm",
	fontWeight: "semibold",
	color: "white",
});

const latestEpMetaStyles = css({
	mt: "2",
	display: "flex",
	alignItems: "center",
	gap: "3",
	fontSize: "xs",
	color: "rgba(255, 255, 255, 0.7)",
});

const newsletterContainerStyles = css({
	mt: "8",
});

const episodesSectionStyles = css({
	py: "section",
});

const episodesContainerStyles = css({
	mx: "auto",
	display: "flex",
	maxW: "7xl",
	flexDirection: "column",
	gap: "10",
});

const emptyStateWrapperStyles = css({
	mx: "auto",
	maxW: "2xl",
	borderRadius: "2xl",
	p: "12",
	textAlign: "center",
});

const emptyIconStyles = css({
	mx: "auto",
	h: "16",
	w: "16",
	color: { base: "rgba(var(--brand-primary), 0.3)", _dark: "rgba(var(--brand-primary), 0.2)" },
});

const emptyTitleStyles = css({
	mt: "4",
	fontSize: "lg",
	fontWeight: "medium",
	color: "fg.default",
});

const emptySubStyles = css({
	mt: "2",
	fontSize: "sm",
	color: "fg.muted",
});
---

<Page title={pageTitle} description={showDescription}>
	<VideoMetadata
		slot="extra-head"
		title={pageTitle}
		description={showDescription}
		isVideoList={true}
	/>

	<!-- Hero -->
	<section class={heroSectionStyles} style="border-bottom: 1px solid var(--surface-border)">
		<div class={heroBgStyles} aria-hidden="true"></div>
		<div class={heroRadialBgStyles} aria-hidden="true"></div>

		<div class:list={[heroContainerStyles, "content-px"]}>
			<Breadcrumb elements={breadcrumbElements} />

			<div class={heroFlexStyles}>
				<!-- Show info -->
				<div class={showInfoStyles}>
					<div class={showTagStyles}>
						<svg class={showTagIconStyles} fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 20.25h12m-7.5-3v3m3-3v3m-10.125-3h17.25c.621 0 1.125-.504 1.125-1.125V4.875c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125z" />
						</svg>
						<span class={showTagTextStyles}>Show</span>
					</div>

					<h1 class={showTitleStyles}>
						{showEntry.data.name}
					</h1>

					{hostNames.length > 0 && (
						<div class={hostsContainerStyles}>
							<span class={hostedByTextStyles}>Hosted by</span>
							{hostNames.map((host) => (
								<span class={cx("glass-chip", css({ fontSize: "sm", fontWeight: "medium", color: "fg.default" }))}>
									{host}
								</span>
							))}
						</div>
					)}

					<p class={descriptionStyles}>
						{showDescription}
					</p>

					{feedVideos.length > 0 && (
						<div class={statsContainerStyles}>
							<div class={statItemStyles}>
								<svg class={statIconStyles} fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347a1.125 1.125 0 0 1-1.667-.986V5.653Z" />
								</svg>
								<span>{feedVideos.length} {feedVideos.length === 1 ? "episode" : "episodes"}</span>
							</div>
							{totalHours > 0 && (
								<div class={statItemStyles}>
									<svg class={statIconStyles} fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
									</svg>
									<span>{totalHours}+ hours of content</span>
								</div>
							)}
						</div>
					)}

					<SubscribeLinks links={showEntry.data.subscribeLinks} client:load />
				</div>

				<!-- Cover image or latest episode thumbnail -->
				{showEntry.data.cover ? (
					<div class={coverContainerStyles}>
						<div class={coverImageWrapperStyles} style="border: 1px solid var(--surface-border)">
							<Image
								src={showEntry.data.cover.image}
								alt={showEntry.data.cover.alt}
								class={coverImgStyles}
							/>
						</div>
					</div>
				) : latestEpisode ? (
					<div class={coverContainerStyles}>
						<a href={`/watch/${latestEpisode.slug}`} class="group block">
							<div class={css({ position: "relative", overflow: "hidden", borderRadius: "2xl", shadow: "xl" })} style="border: 1px solid var(--surface-border)">
								<img
									src={latestEpisode.thumbnailUrl}
									alt={`Latest episode: ${latestEpisode.title}`}
									class={latestEpThumbnailStyles}
									loading="eager"
								/>
								<div class={latestEpOverlayStyles}></div>
								<div class={playButtonContainerStyles}>
									<div class={playButtonStyles}>
										<svg class={playIconStyles} fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
											<path d="M8 5v14l11-7z" />
										</svg>
									</div>
								</div>
								<div class={latestEpInfoStyles}>
									<p class={latestEpLabelStyles}>Latest Episode</p>
									<p class={latestEpTitleStyles}>{latestEpisode.title}</p>
									<div class={latestEpMetaStyles}>
										<span>{formatDate(latestEpisode.publishedAt)}</span>
										{latestEpisode.duration > 0 && (
											<span>{formatDuration(latestEpisode.duration)}</span>
										)}
									</div>
								</div>
							</div>
						</a>
					</div>
				) : null}
			</div>

			<!-- Newsletter - full width, subtle -->
			<div class={newsletterContainerStyles}>
				<NewsletterCTA
					class="!py-0"
					audience={`show:${showEntry.data.id}`}
					badge="Get notified of new episodes"
					headline={`Subscribe to ${showEntry.data.name}`}
					subtitle="Be the first to know when new episodes drop."
				/>
			</div>
		</div>
	</section>

	<!-- Episodes -->
	<section class={episodesSectionStyles} style="background: var(--surface-base)">
		<div class:list={[episodesContainerStyles, "content-px"]}>
			{feedVideos.length > 0 ? (
				<VideoFeed
					title="Episodes"
					description={`Watch all ${feedVideos.length} episodes from ${showEntry.data.name}.`}
					videos={feedVideos}
				/>
			) : (
				<div class:list={["glass-card", emptyStateWrapperStyles]}>
					<svg
						class={emptyIconStyles}
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
						aria-hidden="true"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="1.5"
							d="M15.75 10.5l4.72-4.72a.75.75 0 011.28.53v11.38a.75.75 0 01-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 002.25-2.25v-9a2.25 2.25 0 00-2.25-2.25h-9A2.25 2.25 0 002.25 7.5v9a2.25 2.25 0 002.25 2.25z"
						/>
					</svg>
					<p class={emptyTitleStyles}>
						No episodes yet
					</p>
					<p class={emptySubStyles}>
						Episodes for this show are coming soon. Check back later!
					</p>
				</div>
			)}
		</div>
	</section>
</Page>
