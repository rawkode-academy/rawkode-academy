---
export const prerender = false;

import { Image, getImage } from "astro:assets";
import { getCollection, getEntries } from "astro:content";
import { getPublishedVideos } from "@/lib/content";
import Breadcrumb from "@/components/breadcrumb/Breadcrumb.astro";
import VideoMetadata from "@/components/html/video-metadata.astro";
import PodcastSeriesJsonLd from "@/components/html/podcast-series-jsonld.astro";
import Page from "@/wrappers/page.astro";
import { createLogger } from "@/lib/logger";
import { css } from "../../../styled-system/css";

const logger = createLogger("shows");
const { showId } = Astro.params;

if (!showId) {
	logger.error("Missing showId parameter for show page");
	return new Response(null, { status: 404 });
}

const shows = await getCollection("shows");
const showEntry = shows.find((s) => s.data.id === showId);
if (!showEntry) return new Response(null, { status: 404 });

const videos = await getPublishedVideos();

const getRefId = (value: unknown): string | null => {
	if (!value) return null;
	if (typeof value === "string") return value;
	if (typeof value === "object" && value !== null && "id" in value) {
		const id = (value as { id?: unknown }).id;
		return typeof id === "string" ? id : null;
	}
	return null;
};

const videosForShow = videos.filter((v) => getRefId(v.data.show) === showEntry.data.id);
const hostEntries = await getEntries(showEntry.data.hosts);
const hostNames = hostEntries.map((h) => String(h.data.name).trim()).filter((n) => n.length > 0);

const feedVideos = videosForShow
	.map((v) => ({
		id: v.data.id,
		title: v.data.title,
		thumbnailUrl: `https://content.rawkode.academy/videos/${v.data.id}/thumbnail.jpg`,
		duration: typeof v.data.duration === "number" ? v.data.duration : 0,
		slug: v.data.slug,
		publishedAt: v.data.publishedAt instanceof Date ? v.data.publishedAt.toISOString() : String(v.data.publishedAt),
	}))
	.sort((a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime());

Astro.response.headers.set("Cache-Control", "public, max-age=600, s-maxage=7200, stale-while-revalidate=172800");
Astro.response.headers.set("CDN-Cache-Control", "public, max-age=7200");
Astro.response.headers.set("Cache-Tag", `show-${showEntry.data.id}, shows-page, show-detail`);

const showDescription = showEntry.data.description?.trim() || "Episode guide coming soon.";

const breadcrumbElements = [
	{ title: "Home", link: "/" },
	{ title: "Shows", link: "/shows" },
	{ title: showEntry.data.name, link: `/shows/${showEntry.data.id}` },
];

const pageTitle = `${showEntry.data.name} Episodes`;
const totalDurationSeconds = feedVideos.reduce((s, v) => s + v.duration, 0);
const totalHours = Math.floor(totalDurationSeconds / 3600);

let podcastImageUrl: string | undefined;
if (showEntry.data.podcast?.artworkUrl) {
	podcastImageUrl = showEntry.data.podcast.artworkUrl;
} else if (showEntry.data.cover) {
	try {
		const resolved = await getImage({ src: showEntry.data.cover.image });
		podcastImageUrl = new URL(resolved.src, Astro.site ?? Astro.url).href;
	} catch {}
}

const fmtDate = (s: string) =>
	new Date(s).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });

const fmtDuration = (sec: number) => {
	if (sec <= 0) return "";
	const h = Math.floor(sec / 3600);
	const m = Math.floor((sec % 3600) / 60);
	return h > 0 ? `${h}:${String(m).padStart(2, "0")}` : `${m}m`;
};

const shell = css({ maxWidth: "80rem", mx: "auto", px: { base: "4", md: "6" }, py: "10" });

const heroLayout = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", lg: "1.4fr 1fr" },
	gap: "8",
	alignItems: "center",
	p: { base: "6", md: "10" },
	borderRadius: "3xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	backgroundImage:
		"radial-gradient(circle at 20% 20%, token(colors.brand.500)/12, transparent 50%), radial-gradient(circle at 80% 30%, token(colors.cyan.500)/12, transparent 50%)",
});

const eyebrow = css({
	display: "inline-flex",
	px: "3",
	py: "1",
	borderRadius: "full",
	bg: "bg.brand-subtle",
	color: "fg.brand",
	fontSize: "xs",
	fontWeight: "semibold",
	letterSpacing: "wider",
	textTransform: "uppercase",
	mb: "4",
});

const title = css({
	fontFamily: "display",
	fontSize: { base: "3xl", md: "5xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	lineHeight: "1.1",
	color: "fg.primary",
});

const subtitle = css({ mt: "4", fontSize: "lg", color: "fg.secondary", lineHeight: "1.7" });

const hosts = css({ mt: "5", display: "flex", flexWrap: "wrap", alignItems: "center", gap: "2", fontSize: "sm", color: "fg.muted" });

const hostChip = css({
	display: "inline-flex",
	px: "3",
	py: "1",
	borderRadius: "full",
	bg: "bg.surface",
	borderWidth: "1px",
	borderColor: "border.muted",
	color: "fg.primary",
	fontWeight: "medium",
});

const meta = css({ mt: "5", display: "flex", flexWrap: "wrap", gap: "4", fontSize: "sm", color: "fg.muted" });

const coverWrap = css({
	overflow: "hidden",
	borderRadius: "2xl",
	boxShadow: "lg",
	"& img": { width: "full", height: "auto", display: "block" },
});

const sectionTitle = css({
	fontFamily: "display",
	fontSize: { base: "2xl", md: "3xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	color: "fg.primary",
	mt: "16",
	mb: "8",
});

const grid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", sm: "repeat(2, minmax(0, 1fr))", lg: "repeat(3, minmax(0, 1fr))" },
	gap: "5",
});

const card = css({
	display: "flex",
	flexDirection: "column",
	overflow: "hidden",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textDecoration: "none",
	color: "fg.primary",
	transition: "transform 200ms ease, box-shadow 200ms ease",
	_hover: { transform: "translateY(-2px)", boxShadow: "lg" },
});

const thumb = css({
	position: "relative",
	aspectRatio: "16 / 9",
	overflow: "hidden",
	bg: "bg.sunken",
	"& img": { width: "full", height: "full", objectFit: "cover" },
});

const cardBody = css({ p: "5", display: "flex", flexDirection: "column", gap: "2", flex: "1" });
const cardMeta = css({ fontSize: "xs", fontWeight: "semibold", letterSpacing: "wider", textTransform: "uppercase", color: "fg.muted" });
const cardTitle = css({
	fontSize: "md",
	fontWeight: "semibold",
	color: "fg.primary",
	lineHeight: "tight",
	display: "-webkit-box",
	WebkitLineClamp: "2",
	overflow: "hidden",
});

const emptyState = css({
	mx: "auto",
	maxWidth: "32rem",
	p: "12",
	textAlign: "center",
	borderRadius: "3xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
});

const subscribeSection = css({
	mt: "12",
	p: { base: "6", md: "8" },
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	backgroundImage:
		"radial-gradient(circle at 80% 50%, token(colors.brand.500)/8, transparent 50%)",
});

const subscribeHead = css({
	display: "flex",
	alignItems: "center",
	gap: "4",
	mb: "5",
	flexWrap: "wrap",
});

const subscribeIcon = css({
	display: "inline-flex",
	alignItems: "center",
	justifyContent: "center",
	w: "12",
	h: "12",
	borderRadius: "full",
	bg: "bg.brand-subtle",
	color: "fg.brand",
	flexShrink: 0,
});

const subscribeTitle = css({
	fontFamily: "display",
	fontSize: { base: "lg", md: "xl" },
	fontWeight: "bold",
	color: "fg.primary",
});

const subscribeDesc = css({ fontSize: "sm", color: "fg.secondary", mt: "1" });

const subscribeLinkRow = css({
	display: "flex",
	flexWrap: "wrap",
	gap: "3",
});

const subscribeLink = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "4",
	py: "2.5",
	borderRadius: "lg",
	fontSize: "sm",
	fontWeight: "semibold",
	color: "fg.primary",
	bg: "bg.surface",
	borderWidth: "1px",
	borderColor: "border.muted",
	textDecoration: "none",
	transition: "all 150ms ease",
	_hover: { color: "fg.brand", borderColor: "border.default", bg: "bg.brand-subtle", transform: "translateY(-1px)" },
});

const platformIcons: Record<string, string> = {
	"apple-podcasts": "M11.954.029a12 12 0 100 23.943A12 12 0 0011.954.029zm.058 4.5a4.5 4.5 0 014.5 4.5c0 1.85-1.115 3.443-2.71 4.137a8.974 8.974 0 01-1.79 5.084.75.75 0 01-1.224-.872 7.476 7.476 0 001.502-4.243 4.5 4.5 0 01.222-8.606zm0 1.5a3 3 0 100 6 3 3 0 000-6z",
	"spotify": "M12 0a12 12 0 100 24 12 12 0 000-24zm5.5 17.3a.75.75 0 01-1.03.25c-2.82-1.73-6.37-2.12-10.55-1.17a.75.75 0 11-.34-1.46c4.55-1.03 8.49-.6 11.66 1.36.36.22.47.7.26 1.02zm1.47-3.27a.94.94 0 01-1.29.31c-3.23-1.99-8.16-2.56-11.99-1.4a.94.94 0 11-.55-1.8c4.38-1.34 9.81-.7 13.52 1.6.45.27.59.86.31 1.29zm.13-3.4c-3.87-2.3-10.27-2.51-13.97-1.4a1.13 1.13 0 11-.66-2.16c4.25-1.28 11.32-1.04 15.79 1.6a1.13 1.13 0 01-1.16 1.96z",
	"youtube": "M23.5 6.2a3 3 0 00-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 00.5 6.2C0 8.1 0 12 0 12s0 3.9.5 5.8a3 3 0 002.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 002.1-2.1c.5-1.9.5-5.8.5-5.8s0-3.9-.5-5.8zM9.6 15.6V8.4l6.3 3.6-6.3 3.6z",
	"rss": "M4 11a9 9 0 019 9h-3a6 6 0 00-6-6v-3zm0-7a16 16 0 0116 16h-3A13 13 0 004 7V4zm2 13a2 2 0 110 4 2 2 0 010-4z",
	"pocket-casts": "M12 0a12 12 0 100 24 12 12 0 000-24zm0 4.5a7.5 7.5 0 110 15 7.5 7.5 0 010-15zm0 3a4.5 4.5 0 100 9 4.5 4.5 0 000-9z",
	"amazon-music": "M12 0a12 12 0 100 24A12 12 0 0012 0zm-1 6h2v8h-2V6zm-3 2h2v6H8V8zm6 0h2v6h-2V8zm-9 2h2v2H5v-2zm12 0h2v2h-2v-2z",
	"overcast": "M12 0a12 12 0 100 24A12 12 0 0012 0zm0 4.5a7.5 7.5 0 016.4 11.4l-1.3-.8a6 6 0 10-10.2 0l-1.3.8A7.5 7.5 0 0112 4.5zm0 3a4.5 4.5 0 013.9 6.8l-1.3-.8a3 3 0 10-5.2 0l-1.3.8A4.5 4.5 0 0112 7.5zM10.5 12l1.5 6 1.5-6h-3z",
	"other": "M21 9V7l-2-2h-2l-2-2H9L7 5H5L3 7v2l-2 2v2l2 2v2l2 2h2l2 2h6l2-2h2l2-2v-2l2-2v-2l-2-2zM12 17a5 5 0 110-10 5 5 0 010 10z",
};

const platformLabel = (platform: string, icon: string) => platform || icon.replace(/-/g, " ").replace(/^./, (c) => c.toUpperCase());

const subscribeLinks = (showEntry.data.subscribeLinks as Array<{ platform: string; url: string; icon: string }> | undefined) ?? [];
---

<Page title={pageTitle} description={showDescription}>
	<PodcastSeriesJsonLd slot="extra-head" show={showEntry} hosts={hostEntries} episodeCount={feedVideos.length} {...(podcastImageUrl ? { imageUrl: podcastImageUrl } : {})} />
	<VideoMetadata slot="extra-head" title={pageTitle} description={showDescription} isVideoList={true} />

	<div class={shell}>
		<Breadcrumb elements={breadcrumbElements} />

		<div class={heroLayout}>
			<div>
				<span class={eyebrow}>Show</span>
				<h1 class={title}>{showEntry.data.name}</h1>
				<p class={subtitle}>{showDescription}</p>
				{hostNames.length > 0 && (
					<div class={hosts}>
						<span>Hosted by</span>
						{hostNames.map((host) => <span class={hostChip}>{host}</span>)}
					</div>
				)}
				{feedVideos.length > 0 && (
					<div class={meta}>
						<span>{feedVideos.length} episode{feedVideos.length === 1 ? "" : "s"}</span>
						{totalHours > 0 && <><span>·</span><span>{totalHours}+ hours of content</span></>}
					</div>
				)}
			</div>

			{showEntry.data.cover && (
				<div class={coverWrap}>
					<Image src={showEntry.data.cover.image} alt={showEntry.data.cover.alt} width={800} height={600} />
				</div>
			)}
		</div>

		{subscribeLinks.length > 0 && (
			<section class={subscribeSection}>
				<div class={subscribeHead}>
					<span class={subscribeIcon} aria-hidden="true">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M4 11a9 9 0 019 9h-3a6 6 0 00-6-6v-3zm0-7a16 16 0 0116 16h-3A13 13 0 004 7V4zm2 13a2 2 0 110 4 2 2 0 010-4z"/></svg>
					</span>
					<div>
						<h2 class={subscribeTitle}>Subscribe wherever you listen</h2>
						<p class={subscribeDesc}>Never miss an episode — drop {showEntry.data.name} into your favourite podcast app.</p>
					</div>
				</div>
				<div class={subscribeLinkRow}>
					{subscribeLinks.map((link) => (
						<a href={link.url} target="_blank" rel="noopener noreferrer" class={subscribeLink}>
							<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={platformIcons[link.icon] || platformIcons.other}/></svg>
							{platformLabel(link.platform, link.icon)}
						</a>
					))}
				</div>
			</section>
		)}

		<h2 class={sectionTitle}>Episodes{feedVideos.length > 0 && ` · ${feedVideos.length}`}</h2>
		{feedVideos.length > 0 ? (
			<div class={grid}>
				{feedVideos.map((video) => (
					<a href={`/watch/${video.slug}`} class={card}>
						<div class={thumb}>
							<img src={video.thumbnailUrl} alt={video.title} loading="lazy" />
						</div>
						<div class={cardBody}>
							<div class={cardMeta}>
								{fmtDate(video.publishedAt)}
								{fmtDuration(video.duration) && <> · {fmtDuration(video.duration)}</>}
							</div>
							<h3 class={cardTitle}>{video.title}</h3>
						</div>
					</a>
				))}
			</div>
		) : (
			<div class={emptyState}>
				<p>No episodes yet. Episodes for this show are coming soon — check back later!</p>
			</div>
		)}
	</div>
</Page>
