---
export const prerender = false;

import { getCollection, getEntries } from "astro:content";
import { getPublishedVideos } from "@/lib/content";
import Breadcrumb from "@/components/breadcrumb/Breadcrumb.astro";
import VideoMetadata from "@/components/html/video-metadata.astro";
import VideoFeed from "@/components/video/video-feed.astro";
import SubscribeLinks from "@/components/show/SubscribeLinks.vue";
import NewsletterCTA from "@/components/newsletter/NewsletterCTA.astro";
import Page from "@/wrappers/page.astro";
import { Image } from "astro:assets";
import { createLogger } from "@/lib/logger";

const logger = createLogger("shows");
const { showId } = Astro.params;

if (!showId) {
	logger.error("Missing showId parameter for show page");
	return new Response(null, { status: 404 });
}

const shows = await getCollection("shows");
const showEntry = shows.find((s) => s.data.id === showId);

if (!showEntry) {
	return new Response(null, { status: 404 });
}

// Get published videos only (filters out future-dated for scheduled publishing)
const videos = await getPublishedVideos();

const getShowId = (value: unknown): string | null => {
	if (!value) return null;
	if (typeof value === "string") return value;
	if (typeof value === "object" && value !== null && "id" in value) {
		const id = (value as { id?: unknown }).id;
		return typeof id === "string" ? id : null;
	}
	return null;
};

const videosForShow = videos.filter(
	(video) => getShowId(video.data.show) === showEntry.data.id,
);

const hostEntries = await getEntries(showEntry.data.hosts);
const hostNames = hostEntries
	.map((host) => String(host.data.name).trim())
	.filter((name) => name.length > 0);

const feedVideos = videosForShow
	.map((video) => ({
		id: video.data.id,
		title: video.data.title,
		thumbnailUrl: `https://content.rawkode.academy/videos/${video.data.id}/thumbnail.jpg`,
		streamUrl: `https://content.rawkode.academy/videos/${video.data.id}/stream.m3u8`,
		duration: typeof video.data.duration === "number" ? video.data.duration : 0,
		slug: video.data.slug,
		publishedAt:
			video.data.publishedAt instanceof Date
				? video.data.publishedAt.toISOString()
				: String(video.data.publishedAt),
	}))
	.sort(
		(a, b) =>
			new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime(),
	);

Astro.response.headers.set(
	"Cache-Control",
	"public, max-age=600, s-maxage=7200, stale-while-revalidate=172800",
);
Astro.response.headers.set("CDN-Cache-Control", "public, max-age=7200");
Astro.response.headers.set(
	"Cache-Tag",
	`show-${showEntry.data.id}, shows-page, show-detail`,
);
Astro.response.headers.set("X-Build-Time", new Date().toISOString());

const showDescription =
	showEntry.data.description?.trim() || "Episode guide coming soon.";

const breadcrumbElements = [
	{ title: "Home", link: "/" },
	{ title: "Shows", link: "/shows" },
	{ title: showEntry.data.name, link: `/shows/${showEntry.data.id}` },
];

const pageTitle = `${showEntry.data.name} Episodes`;

const latestEpisode = feedVideos[0];
const totalDurationSeconds = feedVideos.reduce((sum, v) => sum + v.duration, 0);
const totalHours = Math.floor(totalDurationSeconds / 3600);

function formatDate(dateString: string) {
	return new Date(dateString).toLocaleDateString("en-US", {
		year: "numeric",
		month: "short",
		day: "numeric",
	});
}

function formatDuration(seconds: number) {
	if (seconds <= 0) return "--:--";
	const hours = Math.floor(seconds / 3600);
	const minutes = Math.floor((seconds % 3600) / 60);
	const remainingSeconds = Math.floor(seconds % 60);
	if (hours > 0) {
		return `${hours}:${minutes.toString().padStart(2, "0")}:${remainingSeconds.toString().padStart(2, "0")}`;
	}
	return `${minutes}:${remainingSeconds.toString().padStart(2, "0")}`;
}
---

<Page title={pageTitle} description={showDescription}>
        <VideoMetadata
                slot="extra-head"
                title={pageTitle}
                description={showDescription}
                isVideoList={true}
        />

        <!-- Hero -->
        <section class="relative overflow-hidden" style="border-bottom: 1px solid var(--surface-border)">
                <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-transparent to-secondary/5 dark:from-primary/20 dark:to-secondary/10" aria-hidden="true"></div>
                <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(var(--color-primary-rgb,4,181,156),0.15),transparent)] dark:bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(var(--color-primary-rgb,4,181,156),0.25),transparent)]" aria-hidden="true"></div>

                <div class="relative mx-auto max-w-7xl content-px pb-12 pt-8">
                        <Breadcrumb elements={breadcrumbElements} />

                        <div class="mt-8 flex flex-col gap-8 lg:flex-row lg:items-center lg:gap-12">
                                <!-- Show info -->
                                <div class="flex-1 space-y-5">
                                        <div class="inline-flex items-center gap-2 rounded-full bg-primary/10 px-3 py-1 dark:bg-primary/20">
                                                <svg class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 20.25h12m-7.5-3v3m3-3v3m-10.125-3h17.25c.621 0 1.125-.504 1.125-1.125V4.875c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125z" />
                                                </svg>
                                                <span class="text-sm font-semibold text-primary dark:text-primary-300">Show</span>
                                        </div>

                                        <h1 class="text-4xl font-extrabold tracking-tight text-primary-content sm:text-5xl lg:text-6xl">
                                                {showEntry.data.name}
                                        </h1>

                                        {hostNames.length > 0 && (
                                                <div class="flex flex-wrap items-center gap-2">
                                                        <span class="text-sm text-muted">Hosted by</span>
                                                        {hostNames.map((host) => (
                                                                <span class="glass-chip text-sm font-medium text-primary-content">
                                                                        {host}
                                                                </span>
                                                        ))}
                                                </div>
                                        )}

                                        <p class="max-w-2xl text-lg leading-relaxed text-secondary-content">
                                                {showDescription}
                                        </p>

                                        {feedVideos.length > 0 && (
                                                <div class="flex flex-wrap items-center gap-4 text-sm text-muted">
                                                        <div class="flex items-center gap-1.5">
                                                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347a1.125 1.125 0 0 1-1.667-.986V5.653Z" />
                                                                </svg>
                                                                <span>{feedVideos.length} {feedVideos.length === 1 ? "episode" : "episodes"}</span>
                                                        </div>
                                                        {totalHours > 0 && (
                                                                <div class="flex items-center gap-1.5">
                                                                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                                                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                                                                        </svg>
                                                                        <span>{totalHours}+ hours of content</span>
                                                                </div>
                                                        )}
                                                </div>
                                        )}

                                        <SubscribeLinks links={showEntry.data.subscribeLinks} client:load />
                                </div>

                                <!-- Cover image or latest episode thumbnail -->
                                {showEntry.data.cover ? (
                                        <div class="flex-shrink-0 w-full lg:w-2/5 max-w-md">
                                                <div class="overflow-hidden rounded-2xl shadow-xl" style="border: 1px solid var(--surface-border)">
                                                        <Image
                                                                src={showEntry.data.cover.image}
                                                                alt={showEntry.data.cover.alt}
                                                                class="w-full h-auto object-cover"
                                                        />
                                                </div>
                                        </div>
                                ) : latestEpisode ? (
                                        <div class="flex-shrink-0 w-full lg:w-2/5 max-w-md">
                                                <a href={`/watch/${latestEpisode.slug}`} class="group block">
                                                        <div class="relative overflow-hidden rounded-2xl shadow-xl" style="border: 1px solid var(--surface-border)">
                                                                <img
                                                                        src={latestEpisode.thumbnailUrl}
                                                                        alt={`Latest episode: ${latestEpisode.title}`}
                                                                        class="aspect-video w-full object-cover transition-transform duration-200 group-hover:scale-[1.03]"
                                                                        loading="eager"
                                                                />
                                                                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
                                                                <div class="absolute inset-0 flex items-center justify-center opacity-0 transition-opacity group-hover:opacity-100">
                                                                        <div class="flex h-16 w-16 items-center justify-center rounded-full bg-primary/90 text-white shadow-lg backdrop-blur-sm">
                                                                                <svg class="h-7 w-7 ml-1" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                                                                        <path d="M8 5v14l11-7z" />
                                                                                </svg>
                                                                        </div>
                                                                </div>
                                                                <div class="absolute bottom-0 left-0 right-0 p-4">
                                                                        <p class="text-xs font-medium text-white/80">Latest Episode</p>
                                                                        <p class="mt-1 line-clamp-2 text-sm font-semibold text-white">{latestEpisode.title}</p>
                                                                        <div class="mt-2 flex items-center gap-3 text-xs text-white/70">
                                                                                <span>{formatDate(latestEpisode.publishedAt)}</span>
                                                                                {latestEpisode.duration > 0 && (
                                                                                        <span>{formatDuration(latestEpisode.duration)}</span>
                                                                                )}
                                                                        </div>
                                                                </div>
                                                        </div>
                                                </a>
                                        </div>
                                ) : null}
                        </div>

                        <!-- Newsletter - full width, subtle -->
                        <div class="mt-8">
                                <NewsletterCTA
                                        class="!py-0"
                                        audience={`show:${showEntry.data.id}`}
                                        badge="Get notified of new episodes"
                                        headline={`Subscribe to ${showEntry.data.name}`}
                                        subtitle="Be the first to know when new episodes drop."
                                />
                        </div>
                </div>
        </section>

        <!-- Episodes -->
        <section class="section-py" style="background: var(--surface-base)">
                <div class="mx-auto flex max-w-7xl flex-col gap-10 content-px">
                        {feedVideos.length > 0 ? (
                                <VideoFeed
                                        title="Episodes"
                                        description={`Watch all ${feedVideos.length} episodes from ${showEntry.data.name}.`}
                                        videos={feedVideos}
                                />
                        ) : (
                                <div class="mx-auto max-w-2xl rounded-2xl glass-card p-12 text-center">
                                        <svg
                                                class="mx-auto h-16 w-16 text-primary/30 dark:text-primary/20"
                                                fill="none"
                                                viewBox="0 0 24 24"
                                                stroke="currentColor"
                                                aria-hidden="true"
                                        >
                                                <path
                                                        stroke-linecap="round"
                                                        stroke-linejoin="round"
                                                        stroke-width="1.5"
                                                        d="M15.75 10.5l4.72-4.72a.75.75 0 011.28.53v11.38a.75.75 0 01-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 002.25-2.25v-9a2.25 2.25 0 00-2.25-2.25h-9A2.25 2.25 0 002.25 7.5v9a2.25 2.25 0 002.25 2.25z"
                                                />
                                        </svg>
                                        <p class="mt-4 text-lg font-medium text-secondary-content">
                                                No episodes yet
                                        </p>
                                        <p class="mt-2 text-sm text-muted">
                                                Episodes for this show are coming soon. Check back later!
                                        </p>
                                </div>
                        )}
                </div>
        </section>
</Page>
