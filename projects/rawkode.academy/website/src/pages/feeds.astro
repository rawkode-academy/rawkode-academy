---
import { getCollection } from "astro:content";
import Page from "@/wrappers/page.astro";
import { css } from "../../styled-system/css";

export const prerender = true;

const shows = await getCollection("shows");
const publishedShows = shows.filter((show) => show.data.publish);

const cardStyle = css({
	bg: { base: "white", _dark: "gray.800" },
	borderRadius: "lg",
	p: "6",
	borderWidth: "1px",
	borderColor: { base: "gray.200", _dark: "gray.700" },
});

const headingStyle = css({
	fontSize: "2xl",
	fontWeight: "semibold",
	mb: "4",
	color: "green.500",
});

const descStyle = css({
	color: "fg.muted",
	mb: "4",
});

const linkStyle = css({
	display: "flex",
	alignItems: "center",
	gap: "3",
	color: "teal.500",
	_hover: { color: "teal.500/90" },
	transition: "colors",
});
---

<Page title="RSS & Atom Feeds | Rawkode Academy">
	<div class={css({ maxW: "7xl", mx: "auto", px: "4", py: "12" })}>
		<h1 class={css({ fontSize: "4xl", fontWeight: "bold", mb: "8", color: "fg.default" })}>RSS & Atom Feeds</h1>

		<p class={css({ fontSize: "lg", color: "fg.muted", mb: "8" })}>
			Subscribe to our RSS or Atom feeds to stay updated with the latest content from Rawkode Academy.
			Choose from individual feeds for articles and videos, or subscribe to the combined feed for all content.
		</p>

		<div class={css({ display: "grid", gap: "8", md: { gridTemplateColumns: "repeat(2, 1fr)" } })}>
			<!-- All Content Feeds -->
			<div class={cardStyle}>
				<h2 class={headingStyle}>All Content</h2>
				<p class={descStyle}>Get both articles and videos in one feed</p>
				<div class={css({ display: "flex", flexDirection: "column", gap: "3" })}>
					<a href="/api/feeds/all.xml" class={linkStyle}>
						<svg class={css({ w: "5", h: "5" })} fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
							<path d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z"></path>
						</svg>
						RSS Feed
					</a>
					<a href="/api/feeds/all.atom" class={linkStyle}>
						<svg class={css({ w: "5", h: "5" })} fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
							<path d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z"></path>
						</svg>
						Atom Feed
					</a>
				</div>
			</div>

			<!-- Articles Feeds -->
			<div class={cardStyle}>
				<h2 class={headingStyle}>Articles</h2>
				<p class={descStyle}>Subscribe to our latest articles and tutorials</p>
				<div class={css({ display: "flex", flexDirection: "column", gap: "3" })}>
					<a href="/api/feeds/articles.xml" class={linkStyle}>
						<svg class={css({ w: "5", h: "5" })} fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
							<path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"></path>
							<path fill-rule="evenodd" d="M4 5a2 2 0 012-2 1 1 0 000 2H6a2 2 0 00-2 2v6a2 2 0 002 2h2a1 1 0 100-2H6V7h5a1 1 0 011 1v5h2V8a3 3 0 00-3-3H4z" clip-rule="evenodd"></path>
						</svg>
						RSS Feed
					</a>
					<a href="/api/feeds/articles.atom" class={linkStyle}>
						<svg class={css({ w: "5", h: "5" })} fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
							<path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"></path>
							<path fill-rule="evenodd" d="M4 5a2 2 0 012-2 1 1 0 000 2H6a2 2 0 00-2 2v6a2 2 0 002 2h2a1 1 0 100-2H6V7h5a1 1 0 011 1v5h2V8a3 3 0 00-3-3H4z" clip-rule="evenodd"></path>
						</svg>
						Atom Feed
					</a>
				</div>
			</div>

			<!-- Videos Feeds -->
			<div class={cardStyle}>
				<h2 class={headingStyle}>Videos</h2>
				<p class={descStyle}>Subscribe to our latest video content</p>
				<div class={css({ display: "flex", flexDirection: "column", gap: "3" })}>
					<a href="/api/feeds/videos.xml" class={linkStyle}>
						<svg class={css({ w: "5", h: "5" })} fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
							<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd"></path>
						</svg>
						RSS Feed
					</a>
					<a href="/api/feeds/videos.atom" class={linkStyle}>
						<svg class={css({ w: "5", h: "5" })} fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
							<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd"></path>
						</svg>
						Atom Feed
					</a>
				</div>
			</div>

			<!-- Podcast Feeds -->
			{publishedShows.length > 0 && publishedShows.map((show) => (
				<div class={cardStyle}>
					<h2 class={headingStyle}>{show.data.name}</h2>
					<p class={descStyle}>{show.data.description || `Subscribe to ${show.data.name} podcast`}</p>
					<div class={css({ display: "flex", flexDirection: "column", gap: "3" })}>
						<a href={`/api/feeds/shows/${show.data.id}.xml`} class={linkStyle}>
							<svg class={css({ w: "5", h: "5" })} fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
								<path fill-rule="evenodd" d="M18 3a1 1 0 00-1.447-.894L8.763 6H5a3 3 0 000 6h.28l1.771 5.316A1 1 0 008 18h1a1 1 0 001-1v-4.382l6.553 3.276A1 1 0 0018 15V3z" clip-rule="evenodd"></path>
							</svg>
							Podcast RSS Feed
						</a>
					</div>
				</div>
			))}

			<!-- How to Subscribe -->
			<div class={cardStyle}>
				<h2 class={headingStyle}>How to Subscribe</h2>
				<ol class={css({ listStyleType: "decimal", listStylePosition: "inside", display: "flex", flexDirection: "column", gap: "2", color: "fg.muted" })}>
					<li>Copy the feed URL you want to subscribe to</li>
					<li>Open your preferred feed reader (Feedly, Inoreader, etc.)</li>
					<li>Add a new subscription and paste the feed URL</li>
					<li>Enjoy automatic updates from Rawkode Academy!</li>
				</ol>
			</div>
		</div>

		<div class={css({ mt: "12" }) + " " + cardStyle}>
			<h2 class={css({ fontSize: "xl", fontWeight: "semibold", mb: "3", color: "green.500" })}>Feed Formats</h2>
			<div class={css({ display: "flex", flexDirection: "column", gap: "2", color: "fg.muted" })}>
				<p><strong>RSS 2.0:</strong> The most widely supported feed format, compatible with virtually all feed readers.</p>
				<p><strong>Atom 1.0:</strong> A more modern and technically superior format with better support for content types and metadata.</p>
			</div>
		</div>
	</div>
</Page>
