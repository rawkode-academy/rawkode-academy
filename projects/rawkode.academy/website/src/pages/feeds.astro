---
import { getCollection } from "astro:content";
import EditorialShell from "@/components/ui/EditorialShell.astro";
import Page from "@/wrappers/page.astro";

export const prerender = true;

const shows = await getCollection("shows");
const publishedShows = shows.filter((show) => show.data.publish);

const feedGroups = [
	{
		title: "All content",
		body: "Articles, news, videos, and podcasts in one combined feed.",
		links: [
			{ label: "RSS", href: "/api/feeds/all.xml" },
			{ label: "Atom", href: "/api/feeds/all.atom" },
			{ label: "JSON", href: "/api/feeds/all.json" },
		],
	},
	{
		title: "Articles",
		body: "Essays, tutorials, and field notes from the academy.",
		links: [
			{ label: "RSS", href: "/api/feeds/articles.xml" },
			{ label: "Atom", href: "/api/feeds/articles.atom" },
			{ label: "JSON", href: "/api/feeds/articles.json" },
		],
	},
	{
		title: "News",
		body: "Cloud native, Kubernetes, and AI infrastructure news for engineers.",
		links: [
			{ label: "RSS", href: "/api/feeds/news.xml" },
			{ label: "Atom", href: "/api/feeds/news.atom" },
			{ label: "JSON", href: "/api/feeds/news.json" },
		],
	},
	{
		title: "Videos",
		body: "New episodes, live sessions, and video releases.",
		links: [
			{ label: "RSS", href: "/api/feeds/videos.xml" },
			{ label: "Atom", href: "/api/feeds/videos.atom" },
			{ label: "JSON", href: "/api/feeds/videos.json" },
		],
	},
];

const formatNotes = [
	"RSS 2.0 is the broadest reader-compatible format.",
	"Atom 1.0 is a structured XML format with richer metadata.",
	"JSON Feed is useful for modern readers and programmatic consumers.",
	"OPML lets you import many feeds into a reader at once.",
];
---

<Page
	title="Feeds"
	description="Subscribe to Rawkode Academy via RSS, Atom, JSON Feed, or OPML."
>
	<EditorialShell
		eyebrow="Subscribe"
		title="Feeds"
		lede="Use RSS, Atom, JSON Feed, or OPML to follow new Rawkode Academy articles, news, videos, and shows in your reader."
		compact
	>
		<div class="editorial-actions" slot="actions">
			<a class="editorial-button" href="/feeds.opml">Download OPML</a>
			<a class="editorial-button editorial-button--secondary" href="#show-feeds">Show feeds</a>
		</div>

		<section class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">Main feeds</p>
				<h2 class="editorial-section__title">Choose the feed you actually want</h2>
				<p class="editorial-section__lede">
					Subscribe to everything, or keep articles, news, and videos separate.
				</p>
			</div>
			<div class="editorial-grid editorial-grid--2">
				{feedGroups.map((group) => (
					<article class="editorial-card feed-card">
						<h3 class="editorial-card__title">{group.title}</h3>
						<p class="editorial-card__body">{group.body}</p>
						<div class="feed-card__links">
							{group.links.map((link) => (
								<a class="feed-link" href={link.href}>{link.label}</a>
							))}
						</div>
					</article>
				))}
			</div>
		</section>

		<section id="show-feeds" class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">Podcasts</p>
				<h2 class="editorial-section__title">Show feeds</h2>
				<p class="editorial-section__lede">
					Each published show has its own podcast RSS feed.
				</p>
			</div>
			<div class="editorial-grid editorial-grid--2">
				{publishedShows.length > 0 ? (
					publishedShows.map((show) => (
						<article class="editorial-card feed-card">
							<h3 class="editorial-card__title">{show.data.name}</h3>
							<p class="editorial-card__body">{show.data.description || `Subscribe to ${show.data.name}.`}</p>
							<div class="feed-card__links">
								<a class="feed-link" href={`/api/feeds/shows/${show.data.id}.xml`}>Podcast RSS</a>
							</div>
						</article>
					))
				) : (
					<article class="editorial-card">
						<p class="editorial-card__body">No podcast feeds are published yet.</p>
					</article>
				)}
			</div>
		</section>

		<section class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">OPML</p>
				<h2 class="editorial-section__title">Import everything at once</h2>
				<p class="editorial-section__lede">
					Import our OPML file into Feedly, Inoreader, NetNewsWire, or another feed reader to subscribe to all available feeds in one step.
				</p>
			</div>
			<div class="editorial-card">
				<a class="editorial-button" href="/feeds.opml">Download feeds.opml</a>
			</div>
		</section>

		<section class="editorial-section editorial-section--split">
			<div class="editorial-section__header">
				<p class="editorial-kicker">Formats</p>
				<h2 class="editorial-section__title">What each format is for</h2>
			</div>
			<div class="editorial-card">
				<ul class="editorial-list">
					{formatNotes.map((note) => <li>{note}</li>)}
				</ul>
			</div>
		</section>
	</EditorialShell>
</Page>

<style>
	.feed-card__links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-top: 1rem;
	}

	.feed-link {
		display: inline-flex;
		align-items: center;
		min-height: 2rem;
		border: 1px solid var(--editorial-hairline-strong);
		border-radius: 4px;
		padding: 0.45rem 0.65rem;
		font-family: var(--font-jetbrains-mono), ui-monospace, monospace;
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--editorial-ink);
		text-decoration: none;
	}

	.feed-link:hover {
		background: var(--editorial-ink);
		color: var(--editorial-paper);
		border-color: var(--editorial-ink);
	}
</style>
