---
import { getCollection } from "astro:content";
import PageHero from "@/components/layout/PageHero.astro";
import Page from "@/wrappers/page.astro";
import { css } from "../../styled-system/css";

export const prerender = true;

const shows = await getCollection("shows");
const publishedShows = shows.filter((show) => show.data.publish);

interface FeedGroup {
	title: string;
	description: string;
	formats: Array<{ label: string; href: string }>;
}

const groups: FeedGroup[] = [
	{
		title: "All Content",
		description: "Articles, news, and videos in a single feed.",
		formats: [
			{ label: "RSS", href: "/api/feeds/all.xml" },
			{ label: "Atom", href: "/api/feeds/all.atom" },
			{ label: "JSON", href: "/api/feeds/all.json" },
		],
	},
	{
		title: "Articles",
		description: "Latest articles and tutorials.",
		formats: [
			{ label: "RSS", href: "/api/feeds/articles.xml" },
			{ label: "Atom", href: "/api/feeds/articles.atom" },
			{ label: "JSON", href: "/api/feeds/articles.json" },
		],
	},
	{
		title: "News",
		description: "Cloud native, Kubernetes, and AI infra news for engineers.",
		formats: [
			{ label: "RSS", href: "/api/feeds/news.xml" },
			{ label: "Atom", href: "/api/feeds/news.atom" },
			{ label: "JSON", href: "/api/feeds/news.json" },
		],
	},
	{
		title: "Videos",
		description: "Latest video sessions and screencasts.",
		formats: [
			{ label: "RSS", href: "/api/feeds/videos.xml" },
			{ label: "Atom", href: "/api/feeds/videos.atom" },
			{ label: "JSON", href: "/api/feeds/videos.json" },
		],
	},
];

for (const show of publishedShows) {
	groups.push({
		title: show.data.name,
		description: show.data.description || `Subscribe to ${show.data.name}`,
		formats: [{ label: "Podcast RSS", href: `/api/feeds/shows/${show.data.id}.xml` }],
	});
}

const shell = css({ maxWidth: "72rem", mx: "auto", px: { base: "4", md: "6" }, py: "12" });

const intro = css({
	maxWidth: "44rem",
	mx: "auto",
	fontSize: "lg",
	color: "fg.secondary",
	lineHeight: "1.7",
	textAlign: "center",
	mb: "12",
});

const grid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", sm: "repeat(2, minmax(0, 1fr))", lg: "repeat(3, minmax(0, 1fr))" },
	gap: "5",
});

const card = css({
	display: "flex",
	flexDirection: "column",
	gap: "4",
	p: "6",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
});

const cardTitle = css({
	fontFamily: "display",
	fontSize: "lg",
	fontWeight: "bold",
	color: "fg.primary",
});

const cardDesc = css({ fontSize: "sm", color: "fg.secondary", lineHeight: "1.6" });

const formats = css({ mt: "auto", display: "flex", flexWrap: "wrap", gap: "2" });

const formatLink = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "1.5",
	px: "3",
	py: "1.5",
	borderRadius: "md",
	bg: "bg.brand-subtle",
	color: "fg.brand",
	fontSize: "sm",
	fontWeight: "medium",
	textDecoration: "none",
	transition: "all 150ms ease",
	_hover: { bg: "bg.brand", color: "fg.on-brand" },
});

const opmlCard = css({
	mt: "12",
	p: { base: "6", md: "10" },
	borderRadius: "3xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textAlign: "center",
});

const opmlTitle = css({
	fontFamily: "display",
	fontSize: "2xl",
	fontWeight: "bold",
	color: "fg.primary",
	mb: "3",
});

const opmlBody = css({ fontSize: "md", color: "fg.secondary", lineHeight: "1.7", maxWidth: "44rem", mx: "auto", mb: "6" });

const opmlBtn = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "6",
	py: "3",
	borderRadius: "lg",
	fontWeight: "semibold",
	color: "fg.on-brand",
	backgroundImage: "linear-gradient(135deg, token(colors.brand.500), token(colors.cyan.500))",
	textDecoration: "none",
	boxShadow: "md",
	transition: "transform 150ms ease",
	_hover: { transform: "translateY(-1px)" },
});
---

<Page title="RSS & Atom Feeds | Rawkode Academy" description="Subscribe to RSS, Atom and JSON feeds for articles, videos, news, and podcasts.">
	<PageHero eyebrow="Subscribe" title="RSS & Atom Feeds" subtitle="Subscribe to our feeds to stay updated with the latest content from Rawkode Academy." />

	<div class={shell}>
		<div class={grid}>
			{groups.map((group) => (
				<div class={card}>
					<h2 class={cardTitle}>{group.title}</h2>
					<p class={cardDesc}>{group.description}</p>
					<div class={formats}>
						{group.formats.map((format) => (
							<a href={format.href} class={formatLink}>{format.label}</a>
						))}
					</div>
				</div>
			))}
		</div>

		<div class={opmlCard}>
			<h2 class={opmlTitle}>Subscribe to everything in one click</h2>
			<p class={opmlBody}>
				Import our OPML file into your feed reader (Feedly, Inoreader, NetNewsWire, etc.) to
				subscribe to all feeds at once — including per-technology and per-contributor feeds,
				organised in folders.
			</p>
			<a href="/feeds.opml" class={opmlBtn}>
				<svg width="18" height="18" fill="currentColor" viewBox="0 0 20 20">
					<path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd"></path>
				</svg>
				Download feeds.opml
			</a>
		</div>
	</div>
</Page>
