---
import { getCollection } from "astro:content";
import PageHero from "@/components/layout/PageHero.astro";
import Page from "@/wrappers/page.astro";
import { css } from "../../styled-system/css";

export const prerender = true;

const shows = await getCollection("shows");
const publishedShows = shows.filter((show) => show.data.publish);

interface FeedGroup {
	title: string;
	description: string;
	formats: Array<{ label: string; href: string }>;
}

const groups: FeedGroup[] = [
	{
		title: "All Content",
		description: "Articles, news, and videos in a single feed.",
		formats: [
			{ label: "RSS", href: "/api/feeds/all.xml" },
			{ label: "Atom", href: "/api/feeds/all.atom" },
			{ label: "JSON", href: "/api/feeds/all.json" },
		],
	},
	{
		title: "Articles",
		description: "Latest articles and tutorials.",
		formats: [
			{ label: "RSS", href: "/api/feeds/articles.xml" },
			{ label: "Atom", href: "/api/feeds/articles.atom" },
			{ label: "JSON", href: "/api/feeds/articles.json" },
		],
	},
	{
		title: "News",
		description: "Cloud native, Kubernetes, and AI infra news for engineers.",
		formats: [
			{ label: "RSS", href: "/api/feeds/news.xml" },
			{ label: "Atom", href: "/api/feeds/news.atom" },
			{ label: "JSON", href: "/api/feeds/news.json" },
		],
	},
	{
		title: "Videos",
		description: "Latest video sessions and screencasts.",
		formats: [
			{ label: "RSS", href: "/api/feeds/videos.xml" },
			{ label: "Atom", href: "/api/feeds/videos.atom" },
			{ label: "JSON", href: "/api/feeds/videos.json" },
		],
	},
];

for (const show of publishedShows) {
	groups.push({
		title: show.data.name,
		description: show.data.description || `Subscribe to ${show.data.name}`,
		formats: [{ label: "Podcast RSS", href: `/api/feeds/shows/${show.data.id}.xml` }],
	});
}

const formatExplainers = [
	{ label: "RSS 2.0", description: "The most widely supported feed format, compatible with virtually all feed readers.", icon: "M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z" },
	{ label: "Atom 1.0", description: "A more modern and technically superior format with better support for content types and metadata.", icon: "M12 2L2 7l10 5l10-5l-10-5zM2 17l10 5l10-5M2 12l10 5l10-5" },
	{ label: "JSON Feed 1.1", description: "A modern JSON-based feed format supported by NetNewsWire, Feedbin, Inoreader, and others. Easier to consume programmatically.", icon: "M10 20l-1.25 5l1.5-3.5L8 22M14 20l1.25 5l-1.5-3.5L16 22M12 2v20M5 12h14" },
	{ label: "OPML 2.0", description: "An XML format feed readers use to import multiple subscriptions in one go. Our OPML lists every feed we publish, grouped into folders.", icon: "M3 7h18M3 12h18M3 17h12" },
];

const subscribeSteps = [
	"Copy the feed URL you want to subscribe to",
	"Open your preferred feed reader (Feedly, Inoreader, NetNewsWire, etc.)",
	"Add a new subscription and paste the feed URL",
	"Enjoy automatic updates from Rawkode Academy",
];

const shell = css({ maxWidth: "72rem", mx: "auto", px: { base: "4", md: "6" }, py: "12" });

const formatGrid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", sm: "repeat(2, minmax(0, 1fr))", lg: "repeat(4, minmax(0, 1fr))" },
	gap: "4",
});

const howToCard = css({
	mt: "12",
	p: { base: "6", md: "10" },
	borderRadius: "3xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	maxWidth: "56rem",
	mx: "auto",
});

const howToTitle = css({
	fontFamily: "display",
	fontSize: "2xl",
	fontWeight: "bold",
	color: "fg.primary",
	mb: "6",
	textAlign: "center",
});

const howToList = css({
	display: "flex",
	flexDirection: "column",
	gap: "4",
	maxWidth: "40rem",
	mx: "auto",
});

const howToStep = css({
	display: "flex",
	alignItems: "flex-start",
	gap: "4",
});

const howToNum = css({
	display: "inline-flex",
	flexShrink: "0",
	alignItems: "center",
	justifyContent: "center",
	w: "9",
	h: "9",
	borderRadius: "full",
	bg: "bg.brand-subtle",
	color: "fg.brand",
	fontWeight: "bold",
	fontSize: "sm",
});

const howToText = css({
	color: "fg.secondary",
	lineHeight: "1.6",
	pt: "1.5",
});

const formatCard = css({
	display: "flex",
	flexDirection: "column",
	gap: "3",
	p: "5",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
});

const formatIcon = css({
	display: "inline-flex",
	alignItems: "center",
	justifyContent: "center",
	w: "10",
	h: "10",
	borderRadius: "lg",
	bg: "bg.brand-subtle",
	color: "fg.brand",
});

const formatLabel = css({ fontFamily: "display", fontSize: "md", fontWeight: "bold", color: "fg.primary" });
const formatDesc = css({ fontSize: "sm", color: "fg.muted", lineHeight: "1.5" });

const sectionLabel = css({ fontSize: "xs", fontWeight: "bold", letterSpacing: "wider", textTransform: "uppercase", color: "fg.brand", textAlign: "center", mb: "3" });

const sectionHeading = css({
	fontFamily: "display",
	fontSize: { base: "xl", md: "2xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	color: "fg.primary",
	textAlign: "center",
	mb: "8",
});


const grid = css({
	display: "grid",
	gridTemplateColumns: { base: "1fr", sm: "repeat(2, minmax(0, 1fr))", lg: "repeat(3, minmax(0, 1fr))" },
	gap: "5",
});

const card = css({
	display: "flex",
	flexDirection: "column",
	gap: "4",
	p: "6",
	borderRadius: "2xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
});

const cardTitle = css({
	fontFamily: "display",
	fontSize: "lg",
	fontWeight: "bold",
	color: "fg.primary",
});

const cardDesc = css({ fontSize: "sm", color: "fg.secondary", lineHeight: "1.6" });

const formats = css({ mt: "auto", display: "flex", flexWrap: "wrap", gap: "2" });

const formatLink = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "1.5",
	px: "3",
	py: "1.5",
	borderRadius: "md",
	bg: "bg.brand-subtle",
	color: "fg.brand",
	fontSize: "sm",
	fontWeight: "medium",
	textDecoration: "none",
	transition: "all 150ms ease",
	_hover: { bg: "bg.brand", color: "fg.on-brand" },
});

const opmlCard = css({
	mt: "12",
	p: { base: "6", md: "10" },
	borderRadius: "3xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	textAlign: "center",
});

const opmlTitle = css({
	fontFamily: "display",
	fontSize: "2xl",
	fontWeight: "bold",
	color: "fg.primary",
	mb: "3",
});

const opmlBody = css({ fontSize: "md", color: "fg.secondary", lineHeight: "1.7", maxWidth: "44rem", mx: "auto", mb: "6" });

const opmlBtn = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "6",
	py: "3",
	borderRadius: "lg",
	fontWeight: "semibold",
	color: "fg.on-brand",
	backgroundImage: "linear-gradient(135deg, token(colors.brand.500), token(colors.cyan.500))",
	textDecoration: "none",
	boxShadow: "md",
	transition: "transform 150ms ease",
	_hover: { transform: "translateY(-1px)" },
});
---

<Page title="RSS & Atom Feeds | Rawkode Academy" description="Subscribe to RSS, Atom and JSON feeds for articles, videos, news, and podcasts.">
	<PageHero eyebrow="Subscribe" title="RSS & Atom Feeds" subtitle="Subscribe to our feeds to stay updated with the latest content from Rawkode Academy." />

	<div class={shell}>
		<p class={sectionLabel}>Available feeds</p>
		<h2 class={sectionHeading}>Subscribe to what you care about</h2>
		<div class={grid}>
			{groups.map((group) => (
				<div class={card}>
					<h2 class={cardTitle}>{group.title}</h2>
					<p class={cardDesc}>{group.description}</p>
					<div class={formats}>
						{group.formats.map((format) => (
							<a href={format.href} class={formatLink}>{format.label}</a>
						))}
					</div>
				</div>
			))}
		</div>

		<div class={howToCard}>
			<h2 class={howToTitle}>How to Subscribe</h2>
			<ol class={howToList}>
				{subscribeSteps.map((step, i) => (
					<li class={howToStep}>
						<span class={howToNum}>{i + 1}</span>
						<p class={howToText}>{step}</p>
					</li>
				))}
			</ol>
		</div>

		<div class={opmlCard}>
			<h2 class={opmlTitle}>Subscribe to everything in one click</h2>
			<p class={opmlBody}>
				Import our OPML file into your feed reader (Feedly, Inoreader, NetNewsWire, etc.) to
				subscribe to all feeds at once — including per-technology and per-contributor feeds,
				organised in folders.
			</p>
			<a href="/feeds.opml" class={opmlBtn}>
				<svg width="18" height="18" fill="currentColor" viewBox="0 0 20 20">
					<path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd"></path>
				</svg>
				Download feeds.opml
			</a>
		</div>

		<section style="margin-top: 3rem;">
			<p class={sectionLabel}>Reference</p>
			<h2 class={sectionHeading}>Feed Formats</h2>
			<div class={formatGrid}>
				{formatExplainers.map((f) => (
					<div class={formatCard}>
						<span class={formatIcon}>
							<svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d={f.icon} /></svg>
						</span>
						<span class={formatLabel}>{f.label}</span>
						<p class={formatDesc}>{f.description}</p>
					</div>
				))}
			</div>
		</section>
	</div>
</Page>
