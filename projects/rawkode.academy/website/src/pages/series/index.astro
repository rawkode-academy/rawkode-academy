---
export const prerender = true;

import { getCollection } from "astro:content";
import CollectionMasthead from "@/components/ui/CollectionMasthead.astro";
import MLabel from "@/components/ui/MLabel.vue";
import Page from "@/wrappers/page.astro";

const seriesEntries = await getCollection("series");
const articles = await getCollection("articles", ({ data }) => !data.draft);

const dateFormatter = new Intl.DateTimeFormat("en-GB", {
	day: "2-digit",
	month: "short",
	year: "numeric",
});

const seriesList = seriesEntries
	.map((series) => {
		const seriesArticles = articles
			.filter((article) => article.data.series?.id === series.id)
			.sort(
				(a, b) => a.data.publishedAt.getTime() - b.data.publishedAt.getTime(),
			);
		const latest = seriesArticles.at(-1)?.data.publishedAt;
		const first = seriesArticles.at(0);

		return {
			id: series.id,
			title: series.data.title,
			articleCount: seriesArticles.length,
			latest,
			teaser: first?.data.description,
		};
	})
	.sort((a, b) => (b.latest?.getTime() ?? 0) - (a.latest?.getTime() ?? 0));
---

<Page
	title="Article Series"
	description="Multi-part article series from Rawkode Academy: hands-on cloud native and Kubernetes engineering, told one chapter at a time."
	pageType="CollectionPage"
>
	<div class="series-page">
		<CollectionMasthead
			title="Series"
			dek="Multi-part article series, read in order."
		/>

		<section class="series-page__list" aria-label="Article series">
			{seriesList.length === 0 ? (
				<div class="series-page__empty">
					<MLabel>No series published yet.</MLabel>
					<p class="series-page__empty-body">
						Browse <a href="/read">all articles</a> instead.
					</p>
				</div>
			) : (
				<ul class="series-page__grid">
					{seriesList.map((series) => (
						<li class="series-card">
							<a class="series-card__link focus-ring" href={`/series/${series.id}`}>
								<span class="series-card__meta">
									<span class="series-card__count">
										{series.articleCount}{" "}
										{series.articleCount === 1 ? "article" : "articles"}
									</span>
									{series.latest && (
										<>
											<span aria-hidden="true">·</span>
											<time datetime={series.latest.toISOString()}>
												{dateFormatter.format(series.latest)}
											</time>
										</>
									)}
								</span>
								<span class="series-card__title">{series.title}</span>
								{series.teaser && (
									<span class="series-card__teaser">{series.teaser}</span>
								)}
								<span class="series-card__cta">Read this series →</span>
							</a>
						</li>
					))}
				</ul>
			)}
		</section>
	</div>
</Page>

<style>
	.series-page {
		background: var(--editorial-paper);
		color: var(--editorial-ink);
		min-height: 60vh;
	}

	.series-page__list {
		max-width: 70rem;
		margin: 0 auto;
		padding: 2rem 2.5rem 4rem;
	}

	.series-page__grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr));
		gap: 1px;
		list-style: none;
		margin: 0;
		padding: 0;
		background: var(--editorial-hairline);
		border: 1px solid var(--editorial-hairline);
	}

	.series-card {
		background: var(--editorial-paper);
	}

	.series-card__link {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		height: 100%;
		padding: 1.5rem;
		text-decoration: none;
		color: inherit;
		border-top: 2px solid transparent;
		transition: border-color var(--duration-base) var(--ease-standard),
			background-color var(--duration-base) var(--ease-standard);
	}
	.series-card__link:hover {
		border-top-color: var(--editorial-ink);
		background: var(--editorial-paper-deep);
	}

	.series-card__meta {
		display: flex;
		align-items: baseline;
		gap: 0.5rem;
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 0.6875rem;
		font-weight: 500;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--editorial-ink-mute);
	}

	.series-card__count {
		color: var(--editorial-rust);
	}

	.series-card__title {
		font-family: var(--font-instrument-serif), serif;
		font-style: italic;
		font-weight: 400;
		font-size: 1.75rem;
		line-height: 1.1;
		letter-spacing: -0.02em;
		color: var(--editorial-ink);
	}

	.series-card__teaser {
		font-family: var(--font-inter-tight), sans-serif;
		font-size: 0.9375rem;
		line-height: 1.5;
		color: var(--editorial-ink-soft);
	}

	.series-card__cta {
		margin-top: auto;
		padding-top: 0.75rem;
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 0.6875rem;
		font-weight: 500;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--editorial-spruce);
	}

	.series-page__empty {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding: 2rem 0;
	}

	.series-page__empty-body {
		font-family: var(--font-inter-tight), sans-serif;
		font-size: 0.9375rem;
		color: var(--editorial-ink-soft);
		margin: 0;
	}

	.series-page__empty a {
		color: var(--editorial-spruce);
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	@media (max-width: 720px) {
		.series-page__list { padding: 1.5rem 1.25rem 3rem; }
	}
</style>
