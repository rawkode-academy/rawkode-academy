---
import CommandPaletteWrapper from "@/components/command-palette/wrapper.tsx";
import Footer from "@/components/footer/Footer.astro";
import Header from "@/components/header/Header.astro";
import Sidebar from "@/components/sidebar/sidebar.vue";
import SkipLink from "@/components/common/SkipLink.astro";
import { css } from "../../styled-system/css";

const layoutRoot = css({ position: "relative", display: "flex", flexDirection: "column", minHeight: "100vh" });

const body = css({ display: "flex", flex: "1", overflow: "hidden" });

const main = css({
	width: "full",
	height: "auto",
	pt: "28",
	px: { base: "4", md: "6" },
	ml: { base: "0", md: "72" },
	overflowX: "hidden",
	transition: "margin 300ms ease",
});

const footerWrap = css({ ml: { base: "0", md: "72" }, transition: "margin 300ms ease" });

const fab = css({
	display: "inline-flex",
	md: { display: "none" },
	position: "fixed",
	bottom: "6",
	right: "6",
	zIndex: "40",
	width: "14",
	height: "14",
	alignItems: "center",
	justifyContent: "center",
	color: "fg.on-brand",
	backgroundImage: "linear-gradient(135deg, token(colors.brand.500) 0%, token(colors.cyan.500) 100%)",
	borderRadius: "full",
	boxShadow: "lg",
	border: "none",
	cursor: "pointer",
	transition: "transform 150ms ease, box-shadow 150ms ease",
	_hover: { transform: "scale(1.05)", boxShadow: "xl" },
});
---

<SkipLink />

<div class={layoutRoot}>
	<Header />
	<Sidebar client:only="vue" />

	<div class={body}>
		<main id="main-content" class={main}>
			<slot />
		</main>
	</div>
	<div id="footer-container" class={footerWrap}>
		<Footer />
	</div>
</div>

<CommandPaletteWrapper client:only="react" />

<button type="button" id="fab-search" class={fab} aria-label="Open search" aria-haspopup="dialog">
	<svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
		<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
	</svg>
</button>

<script>
	const isMac = navigator.userAgent.toLowerCase().includes("mac");
	const shortcutElement = document.getElementById("command-shortcut");
	if (shortcutElement) shortcutElement.textContent = isMac ? "⌘K" : "Ctrl+K";

	function openCommandPalette() {
		document.dispatchEvent(new CustomEvent("open-command-palette"));
	}

	for (const id of ["topbar-search-trigger", "fab-search"] as const) {
		const el = document.getElementById(id);
		el?.addEventListener("click", (e) => {
			e.preventDefault();
			openCommandPalette();
		});
	}

	function updateMainContentMargin() {
		const mainContent = document.getElementById("main-content");
		const footerContainer = document.getElementById("footer-container");
		const isCollapsed = localStorage.getItem("sidebar-collapsed") === "true";
		const expanded = "18rem";
		const collapsed = "6rem";

		for (const el of [mainContent, footerContainer]) {
			if (!el) continue;
			if (window.matchMedia("(min-width: 768px)").matches) {
				el.style.marginLeft = isCollapsed ? collapsed : expanded;
			} else {
				el.style.marginLeft = "0";
			}
		}
	}

	updateMainContentMargin();

	for (const id of ["sidebar-toggle-btn", "mobile-sidebar-btn"] as const) {
		const el = document.getElementById(id);
		el?.addEventListener("click", (e) => {
			e.preventDefault();
			window.dispatchEvent(new Event("toggle-sidebar"));
			setTimeout(updateMainContentMargin, 50);
		});
	}

	window.addEventListener("storage", (e) => {
		if (e.key === "sidebar-collapsed") updateMainContentMargin();
	});

	window.addEventListener("resize", updateMainContentMargin, { passive: true });
</script>
