---
import LiveDot from "@/components/ui/LiveDot.vue";
import MLabel from "@/components/ui/MLabel.vue";
import { getVideoThumbnailResizedUrl } from "@/lib/video-thumbnail";

interface Video {
	id: string;
	slug: string;
	title: string;
	publishedAt: Date;
	durationSeconds?: number | undefined;
}

interface ScheduleItem {
	href: string;
	dateLabel: string; // e.g. "TUE 22 APR" or "Thu 24"
	title: string;
	timeLabel: string; // e.g. "18:00 UTC" when upcoming, runtime when past
	upcoming: boolean;
}

interface Props {
	state: "live" | "upcoming" | "fallback";
	video: Video;
	schedule?: ScheduleItem[];
}

const { state, video, schedule = [] } = Astro.props as Props;

// Hero thumbnail is the homepage LCP candidate: serve a right-sized,
// auto-format variant via Cloudflare image resizing. Keep this width in
// sync with the <link rel="preload"> emitted by src/pages/index.astro.
const thumbnailUrl = getVideoThumbnailResizedUrl(video.id, 800);

const dateTimeFormatter = new Intl.DateTimeFormat("en-US", {
	weekday: "short",
	month: "short",
	day: "2-digit",
	hour: "2-digit",
	minute: "2-digit",
	hour12: false,
	timeZone: "UTC",
});

const headerLabel =
	state === "live"
		? "On air now"
		: state === "upcoming"
			? `Up next — ${dateTimeFormatter.format(video.publishedAt)} UTC`
			: "Latest video";

const headerTone: "amber" | "spruce" | "ink" =
	state === "live" ? "amber" : state === "upcoming" ? "spruce" : "ink";

const primaryCtaLabel =
	state === "live"
		? "Watch live →"
		: state === "upcoming"
			? "Set reminder →"
			: "Watch now →";

const formatDuration = (s?: number) => {
	if (typeof s !== "number" || s <= 0) return undefined;
	const h = Math.floor(s / 3600);
	const m = Math.floor((s % 3600) / 60);
	if (h > 0) return `${h}h ${m}m`;
	return `${m}m`;
};

const subLabel =
	state === "live" || state === "upcoming"
		? undefined
		: formatDuration(video.durationSeconds);
---

<aside class="on-air">
	<div class="on-air__header">
		<MLabel tone={headerTone}>
			{state === "live" && <LiveDot color="amber" />}
			{headerLabel}
		</MLabel>
		{subLabel && <span class="on-air__elapsed">{subLabel}</span>}
	</div>

	<a class="on-air__screen" href={`/watch/${video.slug}`} aria-label={`Open ${video.title}`}>
		<img
			class="on-air__thumb"
			src={thumbnailUrl}
			alt={video.title}
			width="800"
			height="450"
			loading="eager"
			fetchpriority="high"
			decoding="async"
		/>
		{state === "live" && (
			<div class="on-air__rec">
				<span class="on-air__rec-dot" aria-hidden="true"></span>
				REC · LIVE
			</div>
		)}
	</a>

	<h3 class="on-air__title">{video.title}</h3>

	<a class="on-air__cta" href={`/watch/${video.slug}`}>
		<MLabel tone="ink">{primaryCtaLabel}</MLabel>
	</a>

	{schedule.length > 0 && (
		<div class="on-air__next">
			<MLabel tone="ink">
				{schedule.some((s) => s.upcoming) ? "Next up" : "Catch up"}
			</MLabel>
			<ul class="on-air__schedule">
				{schedule.map((item) => (
					<li class="on-air__slot">
						<a class="on-air__slot-link" href={item.href}>
							<MLabel tone={item.upcoming ? "rust" : "muted"}>{item.dateLabel}</MLabel>
							<span class="on-air__slot-title">{item.title}</span>
							<span class="on-air__slot-time">{item.timeLabel}</span>
						</a>
					</li>
				))}
			</ul>
		</div>
	)}
</aside>

<style>
	.on-air {
		background: var(--editorial-paper-deep);
		padding: clamp(1.25rem, 2.2vw, 1.75rem);
		display: flex;
		flex-direction: column;
		gap: 1.125rem;
		position: relative;
		border-left: 1px solid var(--editorial-hairline);
		align-self: start;
		min-width: 0;
	}

	.on-air__header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
	}

	.on-air__elapsed {
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 11px;
		color: var(--editorial-ink-mute);
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.on-air__screen {
		position: relative;
		aspect-ratio: 16 / 10;
		overflow: hidden;
		background: oklch(0.12 0.01 280);
		border: 1px solid var(--editorial-hairline-strong);
		display: block;
	}

	.on-air__thumb {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform var(--duration-slow) var(--ease-standard);
	}

	.on-air__screen:hover .on-air__thumb {
		transform: scale(1.02);
	}

	.on-air__rec {
		position: absolute;
		top: 12px;
		right: 12px;
		padding: 4px 8px;
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 10px;
		color: var(--editorial-paper);
		background: oklch(0 0 0 / 0.65);
		letter-spacing: 0.12em;
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
	}

	.on-air__rec-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--editorial-amber);
		animation: rk-pulse 1.6s ease-in-out infinite;
	}

	@keyframes rk-pulse {
		0%, 100% { opacity: 1; transform: scale(1); }
		50% { opacity: 0.65; transform: scale(0.9); }
	}

	@media (prefers-reduced-motion: reduce) {
		.on-air__rec-dot { animation: none; }
	}

	.on-air__title {
		font-family: var(--font-instrument-serif), serif;
		font-style: italic;
		font-weight: 400;
		font-size: 1.625rem;
		line-height: 1.08;
		letter-spacing: -0.02em;
		color: var(--editorial-ink);
		margin: 0.5rem 0 0;
	}

	.on-air__cta {
		text-decoration: none;
		display: inline-flex;
		padding-top: 0.125rem;
	}

	.on-air__next {
		margin-top: 0.25rem;
		padding-top: 1rem;
		border-top: 1px solid var(--editorial-hairline);
		display: flex;
		flex-direction: column;
		gap: 0.625rem;
	}

	.on-air__schedule {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.on-air__slot {
		border-top: 1px solid var(--editorial-hairline);
	}
	.on-air__slot:first-child {
		border-top: none;
	}

	.on-air__slot-link {
		display: grid;
		grid-template-columns: 64px 1fr auto;
		gap: 0.75rem;
		padding: 0.625rem 0;
		align-items: baseline;
		font-family: var(--font-inter-tight), sans-serif;
		font-size: 0.84rem;
		color: var(--editorial-ink);
		text-decoration: none;
		transition: color var(--duration-base) var(--ease-standard);
	}

	.on-air__slot-link:hover .on-air__slot-title {
		color: var(--editorial-spruce);
	}

	.on-air__slot-title {
		color: var(--editorial-ink);
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.on-air__slot-time {
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 11px;
		color: var(--editorial-ink-mute);
		letter-spacing: 0.08em;
	}

	@media (max-width: 960px) {
		.on-air {
			border-left: none;
			border-top: 1px solid var(--editorial-hairline);
			padding: 1.5rem;
		}

		.on-air__screen {
			aspect-ratio: 16 / 9;
		}
	}

	@media (max-width: 520px) {
		.on-air__slot-link {
			grid-template-columns: 1fr;
			gap: 0.35rem;
			align-items: start;
		}

		.on-air__slot-time {
			font-size: 10px;
		}
	}
</style>
