---
/**
 * Inline theme initialization script.
 * Single brand theme (Rawkode Blue) — only the light/dark color-scheme
 * needs to be applied early to prevent FOUC.
 */
---

<script is:inline>
	(function () {
		const DARK_STORAGE_KEY = "rawkode-color-scheme";

		let prefersDark = false;
		try {
			const stored = localStorage.getItem(DARK_STORAGE_KEY);
			if (stored === "dark") {
				prefersDark = true;
			} else if (stored === "light") {
				prefersDark = false;
			} else if (window.matchMedia) {
				prefersDark = window.matchMedia(
					"(prefers-color-scheme: dark)",
				).matches;
			}
		} catch (e) {
			// localStorage might not be available
		}

		if (prefersDark) {
			document.documentElement.classList.add("dark");
		}
	})();
</script>
