---
import { css, cx } from "../../../styled-system/css";
import { getCollection, type CollectionEntry } from "astro:content";

interface Props {
	article: CollectionEntry<"articles">;
	limitSideways?: number;
	limitDown?: number;
}

const { article, limitSideways = 2, limitDown = 2 } = Astro.props;

const normalizeTechnologyId = (value: unknown): string | null => {
	let raw: string | null = null;
	if (typeof value === "string" && value.length > 0) {
		raw = value;
	} else if (
		value &&
		typeof value === "object" &&
		"id" in value &&
		typeof (value as { id?: unknown }).id === "string" &&
		(value as { id: string }).id.length > 0
	) {
		raw = (value as { id: string }).id;
	}
	if (!raw) return null;
	return raw.replace(/\/index$/, "");
};

const articleTechnologyIds =
	Array.isArray(article.data.technologies)
		? article.data.technologies
				.map(normalizeTechnologyId)
				.filter((techId): techId is string => Boolean(techId))
		: [];
const articleTechnologySet = new Set(articleTechnologyIds);

const getArticlePublishedAt = (entry: CollectionEntry<"articles">): number =>
	new Date(entry.data.publishedAt).getTime();

const sortArticlesByDateThenTitle = (
	left: CollectionEntry<"articles">,
	right: CollectionEntry<"articles">,
): number =>
	getArticlePublishedAt(right) - getArticlePublishedAt(left) ||
	left.data.title.localeCompare(right.data.title);

const allTechnologies = await getCollection("technologies");
const technologyNameById = new Map(
	allTechnologies.map((technology) => [
		normalizeTechnologyId(technology.id) ?? technology.id,
		technology.data.name,
	]),
);

// Up (hub) links
const upLinks: { href: string; label: string }[] = articleTechnologyIds
	.slice(0, 2)
	.map((technologyId) => ({
		href: `/technology/${technologyId}`,
		label: technologyNameById.get(technologyId) ?? technologyId,
	}));

// Sideways (peers)
const allArticles = await getCollection("articles", ({ data }) => !data.draft);
let sideways: CollectionEntry<"articles">[] = [];
if (article.data.series) {
	sideways = allArticles
		.filter(
			(a) =>
				a.id !== article.id && a.data.series?.id === article.data.series?.id,
		)
		.sort(sortArticlesByDateThenTitle)
		.slice(0, limitSideways);
}
if (sideways.length < limitSideways && articleTechnologySet.size > 0) {
	const remaining = limitSideways - sideways.length;
	const techPeers = allArticles
		.filter(
			(a) =>
				a.id !== article.id &&
				!sideways.some((s) => s.id === a.id),
		)
		.map((candidate) => {
			const normalizedTechnologyIds = (candidate.data.technologies ?? [])
				.map(normalizeTechnologyId)
				.filter(
					(technologyId): technologyId is string => Boolean(technologyId),
				);

			return {
				article: candidate,
				sharedTechnologyCount: normalizedTechnologyIds.filter((technologyId) =>
					articleTechnologySet.has(technologyId),
				).length,
			};
		})
		.filter((candidate) => candidate.sharedTechnologyCount > 0)
		.sort((left, right) => {
			if (left.sharedTechnologyCount !== right.sharedTechnologyCount) {
				return right.sharedTechnologyCount - left.sharedTechnologyCount;
			}
			return sortArticlesByDateThenTitle(left.article, right.article);
		})
		.slice(0, remaining);
	sideways = [...sideways, ...techPeers.map((candidate) => candidate.article)];
}

// Down (deep guides) – prefer videos for the same technology
let downLinks: { href: string; label: string }[] = [];
try {
	const videos = await getCollection("videos");
	if (articleTechnologySet.size > 0) {
		const deepVideos = videos
			.map((video) => {
				const technologyIds = (video.data.technologies ?? [])
					.map(normalizeTechnologyId)
					.filter((technologyId): technologyId is string =>
						Boolean(technologyId),
					);

				const sharedTechnologyCount = technologyIds.filter((technologyId) =>
					articleTechnologySet.has(technologyId),
				).length;

				return { video, sharedTechnologyCount };
			})
			.filter((item) => item.sharedTechnologyCount > 0)
			.sort((left, right) => {
				if (left.sharedTechnologyCount !== right.sharedTechnologyCount) {
					return right.sharedTechnologyCount - left.sharedTechnologyCount;
				}
				return (
					new Date(right.video.data.publishedAt).getTime() -
						new Date(left.video.data.publishedAt).getTime() ||
					left.video.data.title.localeCompare(right.video.data.title)
				);
			})
			.slice(0, limitDown);
		downLinks = deepVideos.map((item) => ({
			href: `/watch/${item.video.data.slug}`,
			label: item.video.data.title,
		}));
	}
} catch {
	// videos collection may be empty in some builds; skip
}

const hasLinks = Boolean(upLinks.length || sideways.length || downLinks.length);
---

{hasLinks && (
  <aside class={css({ mt: '4', mb: '8', borderRadius: 'lg', borderWidth: '1px', borderColor: { base: 'gray.200', _dark: 'gray.700' }, bg: { base: 'gray.50/60', _dark: 'gray.800/40' }, p: '4' })}>
    <div class={css({ display: 'grid', gap: '4', md: { gridTemplateColumns: '3' } })}>
      {/* Up (hub) */}
      {upLinks.length > 0 && (
        <div>
          <h3 class={css({ fontSize: 'sm', fontWeight: 'semibold', color: { base: 'gray.700', _dark: 'gray.300' }, mb: '2' })}>Up: Hubs</h3>
          <ul class={css({ display: 'flex', flexDirection: 'column', gap: '1', listStyleType: 'disc', listStylePosition: 'inside', fontSize: 'sm' })}>
            {upLinks.map((l) => (
              <li><a href={l.href} class={css({ color: 'colorPalette.default', _hover: { textDecoration: 'underline' } })}>{l.label}</a></li>
            ))}
          </ul>
        </div>
      )}

      {/* Sideways (peers) */}
      {sideways.length > 0 && (
        <div>
          <h3 class={css({ fontSize: 'sm', fontWeight: 'semibold', color: { base: 'gray.700', _dark: 'gray.300' }, mb: '2' })}>Sideways: Related</h3>
          <ul class={css({ display: 'flex', flexDirection: 'column', gap: '1', listStyleType: 'disc', listStylePosition: 'inside', fontSize: 'sm' })}>
            {sideways.map((a) => (
              <li><a href={`/read/${a.id}`} class={css({ color: 'colorPalette.default', _hover: { textDecoration: 'underline' } })}>{a.data.title}</a></li>
            ))}
          </ul>
        </div>
      )}

      {/* Down (deep guides) */}
      {downLinks.length > 0 && (
        <div>
          <h3 class={css({ fontSize: 'sm', fontWeight: 'semibold', color: { base: 'gray.700', _dark: 'gray.300' }, mb: '2' })}>Deeper: Guides & Videos</h3>
          <ul class={css({ display: 'flex', flexDirection: 'column', gap: '1', listStyleType: 'disc', listStylePosition: 'inside', fontSize: 'sm' })}>
            {downLinks.map((l) => (
              <li><a href={l.href} class={css({ color: 'colorPalette.default', _hover: { textDecoration: 'underline' } })}>{l.label}</a></li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </aside>
)}
