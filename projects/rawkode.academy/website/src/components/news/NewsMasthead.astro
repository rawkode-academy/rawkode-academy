---
interface Props {
	updatedAt?: Date | string | undefined;
}

const { updatedAt } = Astro.props as Props;
const updatedDate =
	updatedAt instanceof Date ? updatedAt : updatedAt ? new Date(updatedAt) : null;
const updatedLabel = updatedDate
	? new Intl.DateTimeFormat("en-US", {
			hour: "2-digit",
			minute: "2-digit",
			hour12: false,
		}).format(updatedDate)
	: undefined;
---

<div class="news-masthead">
	<span class="news-masthead__left">The Wire · Updated continuously</span>
	<span class="news-masthead__center">
		News <span class="news-masthead__center-muted">— from the cloud-native ecosystem</span>
	</span>
	<span class="news-masthead__right">
		<span class="news-masthead__dot" aria-hidden="true"></span>
		Last updated {updatedLabel ?? "—"}
	</span>
</div>

<style>
	.news-masthead {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: baseline;
		gap: 2rem;
		padding: 1.25rem 2.5rem;
		border-bottom: 2px solid var(--editorial-ink);
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 0.6875rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.news-masthead__left { color: var(--editorial-ink-soft); }

	.news-masthead__center {
		font-family: var(--font-instrument-serif), serif;
		font-style: italic;
		font-weight: 400;
		font-size: 1.5rem;
		letter-spacing: -0.015em;
		text-transform: none;
		color: var(--editorial-ink);
		text-align: center;
	}

	.news-masthead__center-muted { color: var(--editorial-ink-mute); }

	.news-masthead__right {
		color: var(--editorial-ink-soft);
		text-align: right;
		display: inline-flex;
		justify-content: flex-end;
		align-items: center;
		gap: 0.5rem;
	}

	.news-masthead__dot {
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: var(--editorial-spruce);
		animation: rk-pulse 1.6s ease-in-out infinite;
	}

	@keyframes rk-pulse {
		0%, 100% { opacity: 1; transform: scale(1); }
		50% { opacity: 0.7; transform: scale(0.92); }
	}

	@media (max-width: 880px) {
		.news-masthead {
			grid-template-columns: 1fr;
			gap: 0.5rem;
			padding: 1rem 1.25rem;
			text-align: center;
		}
		.news-masthead__left,
		.news-masthead__right {
			text-align: center;
			justify-content: center;
		}
	}
</style>
