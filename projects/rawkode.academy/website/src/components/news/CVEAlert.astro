---
import MLabel from "@/components/ui/MLabel.vue";

interface Props {
	id: string;
	severity: string;
	project: string;
	title: string;
	description: string;
	publishedAt?: string | undefined;
	patchedIn?: string | undefined;
	href?: string | undefined;
}

const {
	id,
	severity,
	project,
	title,
	description,
	publishedAt,
	patchedIn,
	href,
} = Astro.props as Props;
---

<aside class="cve-alert">
	<div class="cve-alert__head">
		<MLabel><span class="cve-alert__warn">⚠</span> Security advisory</MLabel>
		{publishedAt && <MLabel>{publishedAt}</MLabel>}
	</div>

	<div class="cve-alert__id">{id} · {project} · CVSS {severity}</div>

	<h2 class="cve-alert__title">{title}</h2>

	<p class="cve-alert__description">{description}</p>

	<div class="cve-alert__footer">
		{patchedIn && <MLabel>Patched in {patchedIn}</MLabel>}
		<a class="cve-alert__cta" href={href ?? "#"}>Read advisory →</a>
	</div>
</aside>

<style>
	.cve-alert {
		--cve-alert-bg: oklch(0.17 0.055 35);
		--cve-alert-foreground: oklch(0.97 0.01 85);
		--cve-alert-foreground-soft: oklch(0.92 0.018 75);
		--cve-alert-foreground-muted: oklch(0.87 0.012 75);
		--cve-alert-accent: oklch(0.91 0.12 52);
		--cve-alert-rule: oklch(0.92 0.018 75 / 0.34);

		background: var(--cve-alert-bg);
		color: var(--cve-alert-foreground);
		padding: 1.5rem 1.4rem;
		border: 1px solid oklch(0.76 0.13 40);
	}

	.cve-alert__head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		margin-bottom: 1.125rem;
	}

	.cve-alert__head :global(.m-label) {
		color: var(--cve-alert-accent) !important;
	}

	.cve-alert__head :global(.m-label):last-child {
		color: var(--cve-alert-foreground-muted) !important;
	}

	.cve-alert__warn {
		font-style: normal;
		margin-right: 0.25rem;
	}

	.cve-alert__id {
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 0.6875rem;
		letter-spacing: 0.12em;
		color: var(--cve-alert-foreground-soft);
		margin-bottom: 0.625rem;
	}

	.cve-alert__title {
		font-family: var(--font-instrument-serif), serif;
		font-style: italic;
		font-weight: 400;
		font-size: 1.625rem;
		line-height: 1.1;
		letter-spacing: -0.02em;
		color: var(--cve-alert-foreground);
		margin: 0 0 0.875rem;
		text-wrap: balance;
	}

	.cve-alert__description {
		font-family: var(--font-inter-tight), sans-serif;
		font-size: 0.875rem;
		line-height: 1.5;
		color: var(--cve-alert-foreground-soft);
		margin: 0 0 1.125rem;
		text-wrap: pretty;
	}

	.cve-alert__footer {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		padding-top: 0.875rem;
		border-top: 1px solid var(--cve-alert-rule);
	}

	.cve-alert__footer :global(.m-label) {
		color: var(--cve-alert-foreground-muted) !important;
	}

	.cve-alert__cta {
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 0.6875rem;
		font-weight: 500;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--cve-alert-accent);
		text-decoration: none;
	}
	.cve-alert__cta:hover { text-decoration: underline; text-underline-offset: 3px; }
</style>
