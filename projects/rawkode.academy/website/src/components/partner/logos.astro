---
interface Logo {
	image: typeof import("*?raw");
	fillLight: string;
	fillDark: string;
	accentLight?: string;
	accentDark?: string;
}

interface Partner {
	name: string;
	url: string;
	since: string;
	logo: Logo;
	description?: string;
	industry?: string;
}

type Partners = Partner[];

interface Props {
	compact?: boolean;
}

const { compact = false } = Astro.props;

function withUtm(url: string): string {
	const u = new URL(url);
	u.searchParams.set("utm_source", "rawkode-academy");
	u.searchParams.set("utm_medium", "partner-logo");
	u.searchParams.set("utm_campaign", "website");
	return u.toString();
}

const currentPartners: Partners = [
	{
		name: "Spectro Cloud",
		since: "2025",
		logo: {
			image: await import("./logos/spectrocloud.svg?raw"),
			fillLight: "#012121",
			fillDark: "#f7f1ed",
			accentLight: "#43d3bd",
			accentDark: "#2dd4bf",
		},
		url: "https://spectrocloud.com",
		description:
			"Kubernetes management platform for deploying, operating, and securing clusters across environments.",
		industry: "Kubernetes",
	},
	{
		name: "Teleport",
		since: "2026",
		logo: {
			image: await import("./logos/teleport.svg?raw"),
			fillLight: "#512fc9",
			fillDark: "#B39DFF",
			accentLight: "#7c3aed",
			accentDark: "#b39dff",
		},
		url: "https://goteleport.com",
		description:
			"Secure access platform for servers, Kubernetes clusters, databases, and internal applications.",
		industry: "Identity & Access",
	},
];

const previousPartners: Partners = [
	{
		name: "ControlPlane",
		since: "2024",
		logo: {
			image: await import("./logos/controlplane.svg?raw"),
			fillLight: "black",
