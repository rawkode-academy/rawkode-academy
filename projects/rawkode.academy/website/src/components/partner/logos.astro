---
interface Logo {
	image: typeof import("*?raw");
	fillLight: string;
	fillDark: string;
	accentLight?: string;
	accentDark?: string;
}

interface Partner {
	name: string;
	url: string;
	since: string;
	logo: Logo;
	description?: string;
	industry?: string;
}

type Partners = Partner[];

interface Props {
	compact?: boolean;
}

const { compact = false } = Astro.props;

function withUtm(url: string): string {
	const u = new URL(url);
	u.searchParams.set("utm_source", "rawkode-academy");
	u.searchParams.set("utm_medium", "partner-logo");
	u.searchParams.set("utm_campaign", "website");
	return u.toString();
}

const currentPartners: Partners = [
	{
		name: "Spectro Cloud",
		since: "2025",
		logo: {
			image: await import("./logos/spectrocloud.svg?raw"),
			fillLight: "#012121",
			fillDark: "#f7f1ed",
			accentLight: "#43d3bd",
			accentDark: "#2dd4bf",
		},
		url: "https://spectrocloud.com",
		description:
			"Kubernetes management platform for deploying, operating, and securing clusters across environments.",
		industry: "Kubernetes",
	},
	{
		name: "Teleport",
		since: "2026",
		logo: {
			image: await import("./logos/teleport.svg?raw"),
			fillLight: "#512fc9",
			fillDark: "#B39DFF",
			accentLight: "#7c3aed",
			accentDark: "#b39dff",
		},
		url: "https://goteleport.com",
		description:
			"Secure access platform for servers, Kubernetes clusters, databases, and internal applications.",
		industry: "Identity & Access",
	},
];

const previousPartners: Partners = [
	{
		name: "ControlPlane",
		since: "2024",
		logo: {
			image: await import("./logos/controlplane.svg?raw"),
			fillLight: "black",
			fillDark: "white",
			accentLight: "#1d4ed8",
			accentDark: "#60a5fa",
		},
		url: "https://controlplane.io",
		description:
			"Security engineering specialists helping organizations build and operate secure cloud native infrastructure.",
		industry: "Cloud Security",
	},
	{
		name: "Fermyon",
		since: "2024",
		logo: {
			image: await import("./logos/fermyon.svg?raw"),
			fillLight: "#0d203f",
			fillDark: "#34E8BD",
			accentLight: "#0d203f",
			accentDark: "#34E8BD",
		},
		url: "https://www.fermyon.com",
		description:
			"Pioneering serverless WebAssembly platform enabling developers to build microservices with unprecedented efficiency.",
		industry: "WebAssembly",
	},
	{
		name: "Guidepad",
		since: "2024",
		logo: {
			image: await import("./logos/guidepad.svg?raw"),
			fillLight: "black",
			fillDark: "white",
			accentLight: "#1343FB",
			accentDark: "#39DEC6",
		},
		url: "https://guidepad.io",
		description:
			"The Development Framework for managing complexity and expanding capabilities.",
		industry: "Developer Experience",
	},
	{
		name: "Heroku",
		since: "2025",
		logo: {
			image: await import("./logos/heroku.svg?raw"),
			fillLight: "#5A1BA9",
			fillDark: "#D7BFF2",
			accentLight: "#5A1BA9",
			accentDark: "#c4b5fd",
		},
		url: "https://heroku.com",
		description:
			"Pioneering platform-as-a-service provider enabling developers to build, run, and operate applications entirely in the cloud.",
		industry: "Cloud Platform",
	},
	{
		name: "Microsoft Azure",
		since: "2024",
		logo: {
			image: await import("./logos/microsoft.svg?raw"),
			fillLight: "#706d6e",
			fillDark: "#706d6e",
			accentLight: "#00A4EF",
			accentDark: "#38bdf8",
		},
		url: "https://azure.com",
		description:
			"Cloud computing service for building, testing, deploying, and managing applications through Microsoft-managed data centers.",
		industry: "Cloud Services",
	},
	{
		name: "ngrok",
		since: "2024",
		logo: {
			image: await import("./logos/ngrok.svg?raw"),
			fillLight: "#10239E",
			fillDark: "white",
			accentLight: "#10239E",
			accentDark: "#60a5fa",
		},
		url: "https://ngrok.com",
		description:
			"Secure tunneling solution that enables developers to expose local servers to the internet and build secure webhook consumers.",
		industry: "Developer Tools",
	},
	{
		name: "WunderGraph",
		since: "2025",
		logo: {
			image: await import("./logos/wundergraph.svg?raw"),
			fillLight: "#000000",
			fillDark: "#FFFFFF",
			accentLight: "#f97316",
			accentDark: "#fb923c",
		},
