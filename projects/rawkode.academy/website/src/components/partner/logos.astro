---

<div class:list={["partner-showcase", compact ? "space-y-10" : "space-y-12"]}>
	{
		compact ? (
			<div>
				<p class="text-xs font-semibold uppercase tracking-[0.22em] text-primary/75">
					Current Partners
				</p>
			</div>
		) : (
			<div class="space-y-4">
				<div class="flex flex-wrap items-center justify-between gap-3">
					<div>
						<p class="text-xs font-semibold uppercase tracking-[0.22em] text-primary/75">
							Current Partners
						</p>
						<h3 class="mt-2 text-2xl font-semibold tracking-tight text-primary-content">
							Supporting the academy right now
						</h3>
					</div>
					<span class="partner-wall-chip">{currentPartners.length} current</span>
				</div>
				<p class="max-w-[62ch] text-sm leading-7 text-secondary-content sm:text-base">
					These teams currently fund the academy. We still evaluate their tools with
					the same candid, hands-on standard as everything else on Rawkode.
				</p>
			</div>
		)
	}

	<div class:list={["partner-current-list", compact && "partner-current-list-compact"]}>
		{currentPartners.map((partner) => (
			<article
				class="partner-entry group"
				style={`--partner-fill-light: ${partner.logo.fillLight}; --partner-fill-dark: ${partner.logo.fillDark}; --partner-accent-light: ${partner.logo.accentLight ?? partner.logo.fillLight}; --partner-accent-dark: ${partner.logo.accentDark ?? partner.logo.fillDark};`}
			>
				<div class="partner-entry-meta">
					{partner.industry && <span class="partner-industry">{partner.industry}</span>}
					<span class="partner-meta-dot" aria-hidden="true"></span>
					<span class="partner-since-inline">Since {partner.since}</span>
				</div>

				<div class="partner-entry-grid">
					<div class="partner-logo-stage">
						<div
							class="partner-logo"
							style={`color: light-dark(${partner.logo.fillLight}, ${partner.logo.fillDark});`}
						>
							<Fragment set:html={partner.logo.image.default} />
						</div>
					</div>

					<div class="space-y-3">
						<h3 class="text-2xl font-semibold tracking-tight text-primary-content">
							{partner.name}
						</h3>
						{partner.description && (
							<p class="text-sm leading-7 text-secondary-content sm:text-[0.96rem]">
								{partner.description}
							</p>
						)}

						<a
							href={withUtm(partner.url)}
							title={`Visit ${partner.name} website`}
							target="_blank"
							rel="noopener noreferrer"
							class="partner-link inline-flex min-h-11 items-center gap-2 text-sm font-semibold"
						>
							Visit {partner.name}
							<svg
								aria-hidden="true"
								class="w-4 h-4"
								xmlns="http://www.w3.org/2000/svg"
								viewBox="0 0 20 20"
								fill="currentColor"
							>
								<path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z" />
								<path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z" />
							</svg>
						</a>
					</div>
				</div>
			</article>
		))}
	</div>

	{
		compact ? (
			<section class="partner-history partner-history-compact">
				<div class="partner-history-header partner-history-header-compact">
					<p class="text-xs font-semibold uppercase tracking-[0.22em] text-muted">
						Previously supported by
					</p>
				</div>

				<div class="partner-alumni-grid">
					{previousPartners.map((partner) => (
						<a
							href={withUtm(partner.url)}
							title={partner.name}
							aria-label={`Visit ${partner.name}`}
							target="_blank"
							rel="noopener noreferrer"
							class="partner-mark partner-alumni-logo"
							style={`--partner-fill-light: ${partner.logo.fillLight}; --partner-fill-dark: ${partner.logo.fillDark}; --partner-accent-light: ${partner.logo.accentLight ?? partner.logo.fillLight}; --partner-accent-dark: ${partner.logo.accentDark ?? partner.logo.fillDark};`}
						>
							<div class="partner-alumni-mark">
								<Fragment set:html={partner.logo.image.default} />
							</div>
						</a>
					))}
				</div>
			</section>
		) : (
			<section class="partner-history">
				<div class="partner-history-header">
					<div>
						<p class="text-xs font-semibold uppercase tracking-[0.22em] text-muted">
							Past Partners
						</p>
						<h3 class="mt-2 text-xl font-semibold tracking-tight text-primary-content">
							Teams we've partnered with before
						</h3>
						<p class="mt-2 max-w-2xl text-sm leading-7 text-secondary-content">
							Companies we've worked with on earlier sponsorships and educational
							projects.
						</p>
					</div>
					<span class="partner-wall-chip">{previousPartners.length} past</span>
				</div>

				<div class="partner-history-grid">
					{previousPartners.map((partner) => (
						<a
							href={withUtm(partner.url)}
							title={partner.name}
							aria-label={`Visit ${partner.name}`}
							target="_blank"
							rel="noopener noreferrer"
							class="partner-mark partner-wall-logo"
							style={`--partner-fill-light: ${partner.logo.fillLight}; --partner-fill-dark: ${partner.logo.fillDark}; --partner-accent-light: ${partner.logo.accentLight ?? partner.logo.fillLight}; --partner-accent-dark: ${partner.logo.accentDark ?? partner.logo.fillDark};`}
						>
							<div class="partner-alumni-mark">
								<Fragment set:html={partner.logo.image.default} />
							</div>
						</a>
					))}
				</div>
			</section>
		)
	}
</div>

<style is:global>
	.partner-current-list {
		border-top: 1px solid var(--surface-border-strong);
	}

	.partner-entry {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		padding-block: 1.5rem;
	}

	.partner-entry + .partner-entry {
		border-top: 1px solid var(--surface-border);
	}

	.partner-entry-grid {
		display: grid;
		gap: 1.25rem;
	}

	.partner-entry-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75rem;
	}

	.partner-industry {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: color-mix(in srgb, var(--partner-fill-dark) 68%, rgb(15 23 42));
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	html.dark .partner-industry {
		color: color-mix(in srgb, white 82%, var(--partner-fill-light) 18%);
	}

	.partner-meta-dot {
		width: 0.25rem;
		height: 0.25rem;
		border-radius: 999px;
		background: color-mix(in srgb, var(--partner-fill-dark) 32%, var(--surface-border));
	}

	.partner-since-inline {
		color: var(--text-muted);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	.partner-logo-stage {
		display: grid;
		place-items: center;
		min-height: 7rem;
		padding: 1rem 1.25rem;
		border: 1px solid color-mix(in srgb, var(--partner-fill-dark) 14%, var(--surface-border));
		border-radius: 1.15rem;
		background:
			linear-gradient(
				135deg,
				color-mix(in srgb, var(--partner-fill-light) 10%, white 90%),
				color-mix(in srgb, var(--partner-fill-dark) 6%, white 94%)
			);
	}

	html.dark .partner-logo-stage {
		background:
			linear-gradient(
				135deg,
				color-mix(in srgb, var(--partner-fill-light) 12%, rgb(15 23 42) 88%),
				color-mix(in srgb, var(--partner-fill-dark) 12%, rgb(15 23 42) 88%)
			);
	}

	.partner-logo {
		width: 100%;
		height: 4rem;
		display: flex;
		align-items: center;
		justify-content: center;
		min-width: 0;
	}

	.partner-logo svg {
		width: 100%;
		height: 100%;
		max-width: 100%;
		max-height: 100%;
		display: block;
		color: inherit;
	}

	.partner-logo svg path:not([style*="url("]),
	.partner-logo svg circle,
	.partner-logo svg rect:not([style*="fill: none"]),
	.partner-logo svg polygon {
		fill: currentColor !important;
	}

	.partner-link {
		color: rgb(15 23 42);
		position: relative;
		width: fit-content;
	}

	html.dark .partner-link {
		color: rgba(255, 255, 255, 0.92);
	}

	.partner-link::after {
		content: "";
		position: absolute;
		left: 0;
		right: 0;
		bottom: -2px;
		height: 1px;
		background: color-mix(in srgb, currentColor 60%, transparent);
		transition: transform 0.2s ease;
		transform-origin: left;
	}

	.partner-link:hover::after {
		transform: scaleX(1.1);
	}

	.partner-history {
		padding-top: 0.5rem;
	}

	.partner-history-header {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		border-top: 1px solid var(--surface-border-strong);
		padding-top: 1.5rem;
		padding-bottom: 1rem;
	}

	.partner-current-list-compact {
		border-top: 0;
	}

	.partner-history-header-compact {
		padding-bottom: 0.25rem;
	}

	.partner-alumni-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		column-gap: 1rem;
		row-gap: 0;
	}

	.partner-wall-chip {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.5rem 1.25rem;
		border-radius: 999px;
		background: rgba(15, 23, 42, 0.04);
		color: rgba(15, 23, 42, 0.7);
		font-size: 0.85rem;
		font-weight: 600;
	}

	.dark .partner-wall-chip {
		background: rgba(255, 255, 255, 0.08);
		color: rgba(255, 255, 255, 0.85);
	}

	.partner-history-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		column-gap: 1.25rem;
		row-gap: 0;
	}

	.partner-mark {
		padding: 0.95rem 0;
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 4.5rem;
		border-bottom: 1px solid var(--surface-border);
		opacity: 0.85;
		transition:
			transform 220ms cubic-bezier(0.22, 1, 0.36, 1),
			opacity 220ms cubic-bezier(0.22, 1, 0.36, 1),
			border-color 220ms cubic-bezier(0.22, 1, 0.36, 1);
	}

	.partner-history-compact .partner-alumni-grid {
		row-gap: 0.85rem;
	}

	.partner-history-compact .partner-mark {
		border-bottom: 0;
		padding-block: 0.35rem;
		min-height: 3.5rem;
	}

	.partner-alumni-mark {
		width: 100%;
		height: 2.3rem;
		display: flex;
		align-items: center;
		justify-content: center;
		min-width: 0;
		color: light-dark(
			color-mix(in srgb, rgb(15 23 42) 86%, var(--partner-fill-light) 14%),
			color-mix(in srgb, white 84%, var(--partner-fill-dark) 16%)
		);
	}

	.partner-wall-logo svg,
	.partner-alumni-mark svg {
		width: 100%;
		height: 100%;
		max-width: 100%;
		max-height: 100%;
		display: block;
	}

	.partner-alumni-mark svg path:not([style*="url("]),
	.partner-alumni-mark svg circle,
	.partner-alumni-mark svg rect:not([style*="fill: none"]),
	.partner-alumni-mark svg polygon,
	.partner-alumni-mark svg ellipse {
		fill: currentColor !important;
	}

	.partner-alumni-mark svg [stroke]:not([stroke="none"]) {
		stroke: currentColor !important;
	}

	.partner-mark:hover {
		transform: translateX(2px);
		opacity: 1;
	}

	.partner-mark:focus-visible {
		outline: none;
		opacity: 1;
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--partner-accent-dark, var(--partner-fill-dark, #94a3b8)) 18%, transparent);
	}

	@media (min-width: 768px) {
		.partner-entry-grid {
			grid-template-columns: minmax(0, 18rem) minmax(0, 1fr);
			align-items: center;
		}
	}

	@media (min-width: 640px) {
		.partner-alumni-grid {
			grid-template-columns: repeat(4, minmax(0, 1fr));
		}

		.partner-history-grid {
			grid-template-columns: repeat(4, minmax(0, 1fr));
		}
	}
</style>
