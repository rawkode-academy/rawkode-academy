		description:
			"The API Gateway that understands GraphQL, REST and more. Build, publish and maintain APIs with a unified workflow.",
		industry: "API Development",
	},
	{
		name: "Zitadel",
		since: "2025",
		logo: {
			image: await import("./logos/zitadel.svg?raw"),
