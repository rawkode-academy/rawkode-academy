---
import { css } from "styled-system/css";

const section = css({ bg: { base: 'white', _dark: 'gray.900' } });
const container = css({ py: { base: '8', sm: '16' }, px: { base: '4', lg: '6' }, mx: 'auto', maxW: 'breakpoint-xl' });
const inner = css({ maxW: 'breakpoint-md', mx: 'auto' });
const heading = css({ mb: '6', fontSize: '4xl', letterSpacing: 'tight', fontWeight: 'extrabold', color: { base: 'gray.900', _dark: 'white' } });
const row = css({ display: 'flex', alignItems: 'flex-start', mb: '6' });
const rowLast = css({ display: 'flex', alignItems: 'flex-start' });
const iconWrap = css({ mr: '4', mt: '1', flexShrink: '0' });
const iconRed = css({ h: '6', w: '6', color: 'red.500' });
const iconGreen = css({ h: '6', w: '6', color: 'brandAccent.text' });
const textLight = css({ fontWeight: 'light', color: { base: 'gray.600', _dark: 'gray.300' }, fontSize: { sm: 'lg' } });
const textMedium = css({ fontWeight: 'medium', color: { base: 'gray.700', _dark: 'gray.200' }, fontSize: { sm: 'lg' } });
---

<section class={section}>
	<div class={container}>
		<div class={inner}>
			<h2 class={heading}>
				Beyond Traditional Conference Sponsorships
			</h2>

			<div class={row}>
				<div class={iconWrap}>
					<svg
						class={iconRed}
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
					</svg>
				</div>
				<p class={textLight}>
					Traditional conference sponsorships often involve significant
					investments--booth setup, team travel, event coordination, and
					hospitality expenses--for just a few days of visibility.
				</p>
			</div>

			<div class={row}>
				<div class={iconWrap}>
					<svg
						class={iconRed}
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
					</svg>
				</div>
				<p class={textLight}>
					After the event concludes, the challenge of converting brief
					interactions into meaningful business relationships begins, with
					uncertain ROI on your investment.
				</p>
			</div>

			<div class={row}>
				<div class={iconWrap}>
					<svg
						class={iconGreen}
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M5 13l4 4L19 7"></path>
					</svg>
				</div>
				<p class={textMedium}>
					Our partnership model offers a strategic alternative: a year-long
					collaboration that provides continuous engagement with our developer
					community, targeted content creation, and sustained visibility for
					your brand.
				</p>
			</div>

			<div class={rowLast}>
				<div class={iconWrap}>
					<svg
						class={iconGreen}
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M5 13l4 4L19 7"></path>
					</svg>
				</div>
				<p class={textMedium}>
					We're committed to your success, creating authentic connections
					between your solutions and our developer audience through expert
					content that showcases your technology's true value.
				</p>
			</div>
		</div>
	</div>
</section>
