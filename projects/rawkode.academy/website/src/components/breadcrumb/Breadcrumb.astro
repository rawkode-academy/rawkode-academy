---
import BreadcrumbJsonLd from "./BreadcrumbJsonLd.astro";
import { css } from "styled-system/css";

interface BreadcrumbElement {
	title: string;
	link: string;
}

type Props = {
	elements: BreadcrumbElement[];
};

const { elements } = Astro.props;

// Remove the last element (current page) - we only show the path
const pathElements = elements.slice(0, -1);

const navStyle = css({ mb: '5' });

const olStyle = css({
	display: 'inline-flex',
	alignItems: 'center',
	listStyle: 'none',
	m: '0',
	py: '1.5',
	px: '3',
	gap: '1',
	bg: 'surface.card',
	border: '1px solid',
	borderColor: 'border.subtle',
	borderRadius: 'full',
	fontSize: '0.8125rem',
});

const liStyle = css({
	display: 'flex',
	alignItems: 'center',
});

const homeLinkStyle = css({
	display: 'flex',
	alignItems: 'center',
	justifyContent: 'center',
	w: '6',
	h: '6',
	color: { base: 'gray.500', _dark: 'gray.400' },
	bg: { base: 'teal.500/10', _dark: 'teal.500/15' },
	borderRadius: 'full',
	transition: 'all',
	transitionDuration: '150ms',
	_hover: {
		color: 'teal.500',
		bg: 'teal.500/20',
		transform: 'scale(1.1)',
	},
});

const homeSvgStyle = css({ w: '3.5', h: '3.5' });

const chevronStyle = css({
	w: '4',
	h: '4',
	color: { base: 'gray.300', _dark: 'gray.600' },
	mx: '0.5',
});

const linkStyle = css({
	color: { base: 'gray.500', _dark: 'gray.400' },
	textDecoration: 'none',
	fontWeight: 'medium',
	py: '1',
	px: '2',
	borderRadius: 'md',
	transition: 'all',
	transitionDuration: '150ms',
	_hover: {
		color: 'teal.500',
		bg: 'teal.500/10',
	},
});
---

<BreadcrumbJsonLd elements={elements} />

{pathElements.length > 0 && (
	<nav class={navStyle} aria-label="Breadcrumb">
		<ol class={olStyle}>
			{pathElements.map((el, i) => (
				<li class={liStyle}>
					{i === 0 ? (
						<a href={el.link} class={homeLinkStyle}>
							<svg class={homeSvgStyle} viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
								<path fill-rule="evenodd" d="M9.293 2.293a1 1 0 011.414 0l7 7A1 1 0 0117 11h-1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-3a1 1 0 00-1-1H9a1 1 0 00-1 1v3a1 1 0 01-1 1H5a1 1 0 01-1-1v-6H3a1 1 0 01-.707-1.707l7-7z" clip-rule="evenodd" />
							</svg>
						</a>
					) : (
						<>
							<svg class={chevronStyle} viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
								<path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
							</svg>
							<a href={el.link} class={linkStyle}>{el.title}</a>
						</>
					)}
				</li>
			))}
		</ol>
	</nav>
)}
