---
import BreadcrumbJsonLd from "./BreadcrumbJsonLd.astro";
import { css } from "../../../styled-system/css";

interface BreadcrumbElement {
	title: string;
	link: string;
}

type Props = { elements: BreadcrumbElement[] };

const { elements } = Astro.props;
const pathElements = elements.slice(0, -1);

const nav = css({ mb: "5" });

const list = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "1",
	listStyle: "none",
	m: "0",
	px: "3",
	py: "1.5",
	bg: "bg.raised",
	borderWidth: "1px",
	borderColor: "border.muted",
	borderRadius: "full",
	fontSize: "sm",
});

const item = css({ display: "flex", alignItems: "center" });

const homeLink = css({
	display: "inline-flex",
	alignItems: "center",
	justifyContent: "center",
	w: "6",
	h: "6",
	color: "fg.muted",
	bg: "bg.brand-subtle",
	borderRadius: "full",
	textDecoration: "none",
	transition: "transform 150ms ease, color 150ms ease",
	_hover: { color: "fg.brand", transform: "scale(1.1)" },
	"& svg": { width: "14px", height: "14px" },
});

const chevron = css({ color: "fg.muted", mx: "0.5" });
const chevronStyle = "width: 16px; height: 16px; flex-shrink: 0;";

const linkClass = css({
	color: "fg.muted",
	textDecoration: "none",
	fontWeight: "medium",
	px: "2",
	py: "1",
	borderRadius: "md",
	transition: "color 150ms ease, background-color 150ms ease",
	_hover: { color: "fg.brand", bg: "bg.brand-subtle" },
});
---

<BreadcrumbJsonLd elements={elements} />

{pathElements.length > 0 && (
	<nav class={nav} aria-label="Breadcrumb">
		<ol class={list}>
			{pathElements.map((el, i) => (
				<li class={item}>
					{i === 0 ? (
						<a href={el.link} class={homeLink} aria-label="Home">
							<svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
								<path fill-rule="evenodd" d="M9.293 2.293a1 1 0 011.414 0l7 7A1 1 0 0117 11h-1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-3a1 1 0 00-1-1H9a1 1 0 00-1 1v3a1 1 0 01-1 1H5a1 1 0 01-1-1v-6H3a1 1 0 01-.707-1.707l7-7z" clip-rule="evenodd" />
							</svg>
						</a>
					) : (
						<>
							<svg class={chevron} style={chevronStyle} viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
								<path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
							</svg>
							<a href={el.link} class={linkClass}>{el.title}</a>
						</>
					)}
				</li>
			))}
		</ol>
	</nav>
)}
