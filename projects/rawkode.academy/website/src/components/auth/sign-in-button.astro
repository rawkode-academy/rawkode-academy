---
import { css } from "../../../styled-system/css";

const linkStyle = css({ display: 'inline-flex' });
const btnStyle = css({ display: 'inline-flex', alignItems: 'center', justifyContent: 'center', borderRadius: 'xl', px: '5', py: '2.5', fontSize: 'sm', fontWeight: 'semibold', letterSpacing: 'wide', color: 'white', shadow: 'lg', borderWidth: '1px', borderColor: { base: 'white/40', _dark: 'white/10' }, transition: 'all', transitionDuration: '200ms', _hover: { shadow: 'xl', translateY: '-0.5' }, _focusVisible: { outline: 'none', ring: '2px', ringOffset: '2px', ringColor: 'colorPalette.default/60', ringOffsetColor: { base: 'white', _dark: 'transparent' } } });
---

<a href="/api/auth/sign-in" class={linkStyle}>
	<button
		class={`${btnStyle} bg-gradient-primary`}
	>
		Sign in
	</button>
</a>
