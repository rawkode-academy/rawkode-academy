---
import { css, cx } from "../../../styled-system/css";
import type { ShowSummary } from "@/types/show";
import { Image } from "astro:assets";

interface Props {
	show: ShowSummary;
}

const { show } = Astro.props as Props;

const hostNames = (show.hosts ?? [])
	.map((host) => [host.forename, host.surname].filter(Boolean).join(" "))
	.filter(Boolean);

const episodes = (show.episodes ?? []).filter(
	(ep): ep is NonNullable<typeof ep> => ep !== null && ep.video !== null,
);

const latestEpisode = episodes
	.filter((ep) => ep.video?.thumbnailUrl && ep.video?.publishedAt)
	.sort((a, b) => {
		const aTime = new Date(a.video!.publishedAt!).getTime();
		const bTime = new Date(b.video!.publishedAt!).getTime();
		return bTime - aTime;
	})[0];

const thumbnailUrl = latestEpisode?.video?.thumbnailUrl;
const latestEpisodeTitle = latestEpisode?.video?.title;
const latestEpisodePublishedAt = latestEpisode?.video?.publishedAt;
const latestEpisodeDate = latestEpisodePublishedAt
	? new Intl.DateTimeFormat("en-US", { dateStyle: "medium" }).format(
			new Date(latestEpisodePublishedAt),
		)
	: null;
---

<a
        href={`/shows/${show.id}`}
        class={cx('glass-card', css({
	display: 'flex',
	h: 'full',
	flexDir: 'column',
	overflow: 'hidden',
	rounded: 'xl',
	transition: 'all',
	transitionDuration: '200ms',
	_hover: {
		translateY: '-1',
		shadow: 'lg',
	},
	_focusVisible: {
		outline: 'none',
		ringWidth: '2px',
		ringColor: 'primary/50',
		ringOffsetWidth: '2px',
	},
}))}
        style="cursor:pointer"
>
        {show.cover ? (
                <div class={css({
	pos: 'relative',
	aspectRatio: 'video',
	w: 'full',
	overflow: 'hidden',
})} style="background: var(--surface-card-muted)">
                        <Image
                                src={show.cover.image}
                                alt={show.cover.alt}
                                class={css({
	h: 'full',
	w: 'full',
	objectFit: 'cover',
	transition: 'transform',
	transitionDuration: '200ms',
	_groupHover: {
		scale: '1.03',
	},
})}
                        />
                        {episodes.length > 0 && (
                                <div class={css({
	pos: 'absolute',
	bottom: '2',
	right: '2',
	rounded: 'md',
	bg: 'black/75',
	px: '2',
	py: '1',
	fontSize: 'xs',
	fontWeight: 'medium',
	color: 'white',
	backdropFilter: 'blur(4px)',
})}>
                                        {episodes.length} {episodes.length === 1 ? "episode" : "episodes"}
                                </div>
                        )}
                </div>
        ) : thumbnailUrl ? (
                <div class={css({
	pos: 'relative',
	aspectRatio: 'video',
	w: 'full',
	overflow: 'hidden',
})} style="background: var(--surface-card-muted)">
                        <img
                                src={thumbnailUrl}
                                alt={`Latest episode from ${show.name}`}
                                class={css({
	h: 'full',
	w: 'full',
	objectFit: 'cover',
	transition: 'transform',
	transitionDuration: '200ms',
	_groupHover: {
		scale: '1.03',
	},
})}
                                loading="lazy"
                        />
                        {episodes.length > 0 && (
                                <div class={css({
	pos: 'absolute',
	bottom: '2',
	right: '2',
	rounded: 'md',
	bg: 'black/75',
	px: '2',
	py: '1',
	fontSize: 'xs',
	fontWeight: 'medium',
	color: 'white',
	backdropFilter: 'blur(4px)',
})}>
                                        {episodes.length} {episodes.length === 1 ? "episode" : "episodes"}
                                </div>
                        )}
                </div>
        ) : (
                <div class={css({
	pos: 'relative',
	aspectRatio: 'video',
	w: 'full',
	bgGradient: 'to-br',
	gradientFrom: 'primary/10',
	gradientTo: 'secondary/10',
	_dark: {
		gradientFrom: 'primary/20',
		gradientTo: 'secondary/20',
	},
})}>
                        <div class={css({
	display: 'flex',
	h: 'full',
	alignItems: 'center',
	justifyContent: 'center',
})}>
                                <svg
                                        class={css({
	h: '16',
	w: '16',
	color: 'primary/30',
	_dark: {
		color: 'primary/20',
	},
})}
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                        aria-hidden="true"
                                >
                                        <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="1.5"
                                                d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z"
                                        />
                                </svg>
                        </div>
                        {episodes.length > 0 && (
                                <div class={css({
	pos: 'absolute',
	bottom: '2',
	right: '2',
	rounded: 'md',
	bg: 'black/75',
	px: '2',
	py: '1',
	fontSize: 'xs',
	fontWeight: 'medium',
	color: 'white',
	backdropFilter: 'blur(4px)',
})}>
                                        {episodes.length} {episodes.length === 1 ? "episode" : "episodes"}
                                </div>
                        )}
                </div>
        )}
        <div class={css({
	display: 'flex',
	flex: '1',
	flexDir: 'column',
	justifyContent: 'space-between',
	p: '6',
})}>
                <div class={css({
	'& > * + *': {
		mt: '2',
	},
})}>
                        <h3 class={cx('text-primary-content', css({
	lineClamp: '2',
	fontSize: 'xl',
	fontWeight: 'semibold',
}))}>
                                {show.name}
                        </h3>
                        <p class={cx('text-muted', css({
	lineClamp: '2',
	fontSize: 'sm',
}))}>
                                {hostNames.length > 0 ? (
                                        <>
                                                <span class={css({ fontWeight: 'medium' })}>Hosted by:</span> {hostNames.join(", ")}
                                        </>
                                ) : (
                                        "Hosts to be announced"
                                )}
                        </p>
                        {latestEpisodeTitle && (
                                <p class={cx('text-muted', css({
	lineClamp: '2',
	fontSize: 'xs',
}))}>
                                        Latest: {latestEpisodeTitle}
                                        {latestEpisodeDate && (
                                                <>
                                                        {" "}
                                                        <span aria-hidden="true">·</span> {latestEpisodeDate}
                                                </>
                                        )}
                                </p>
                        )}
                </div>
                <div class={css({
	mt: '4',
	display: 'flex',
	alignItems: 'center',
	fontSize: 'sm',
	fontWeight: 'medium',
	color: 'primary',
	_dark: {
		color: 'primary.300',
	},
})}>
                        <span>View episodes</span>
                        <svg
                                class={css({
	ml: '2',
	h: '4',
	w: '4',
	transition: 'transform',
	_groupHover: {
		translateX: '1',
	},
})}
                                viewBox="0 0 20 20"
                                fill="none"
                                xmlns="http://www.w3.org/2000/svg"
                                aria-hidden="true"
                        >
                                <path
                                        d="M7.5 5L12.5 10L7.5 15"
                                        stroke="currentColor"
                                        stroke-width="1.5"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                />
                        </svg>
                </div>
        </div>
</a>
