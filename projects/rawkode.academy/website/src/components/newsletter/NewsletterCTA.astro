---
import { css } from "styled-system/css";
export const prerender = false;

import { env } from "cloudflare:workers";
import NewsletterWidget from "./NewsletterWidget.vue";
import { createLearnerId } from "@/actions/newsletter";
import { withTimeout } from "@/utils/timeout";

interface Props {
	class?: string;
	style?: string;
	badge?: string;
	headline?: string;
	subtitle?: string;
	audience?: string;
}

const {
	class: className,
	style: inlineStyle,
	badge = "Weekly Cloud Native insights",
	headline = "Stay ahead in cloud native",
	subtitle = "Tutorials, deep dives, and curated events—no fluff.",
	audience = "academy",
} = Astro.props;

const user = Astro.locals.user;
let isSubscribed = false;

if (user && import.meta.env.PROD) {
	try {
		const prefixedUserId = createLearnerId(user.id);
		const prefs = await withTimeout(
			() => env.EMAIL_PREFERENCES.getPreferences(prefixedUserId, "newsletter", audience),
			{
				timeoutMs: 3000,
				label: "Newsletter preference lookup",
			},
		);
		isSubscribed = prefs.length > 0;
	} catch (e) {
		console.error("Failed to fetch preferences", e);
	}
}

const pagePath = Astro.url.pathname;
const signInUrl = `/sign-in?returnTo=${encodeURIComponent(pagePath)}`;

// Check for the newsletter subscription cookie (server-side)
const hasNewsletterCookie =
	Astro.cookies.get(`newsletter:${audience}:updates`)?.value === "true";

// For anonymous users with the cookie, hide the CTA entirely
const shouldHide = !user && hasNewsletterCookie;

const sectionStyle = css({ w: 'full', py: '12', pos: 'relative', zIndex: '10' });
const cardWrapper = css({ p: { base: '4', sm: '6' } });
const flexRow = css({
	display: 'flex',
	flexDir: { base: 'column', sm: 'row' },
	alignItems: { sm: 'center' },
	gap: { base: '4', sm: '6' },
});
const contentCol = css({ flex: '1', minW: '0', display: 'flex', flexDir: 'column', gap: '1' });
const badgeRow = css({ display: 'flex', alignItems: 'center', gap: '2' });
const badgeDot = css({ h: '2', w: '2', rounded: 'full', bg: 'primary' });
const badgeText = css({ fontSize: 'xs', fontWeight: 'medium', color: 'primary' });
const headlineStyle = css({
	fontSize: { base: 'lg', sm: 'xl' },
	fontFamily: 'display',
	fontWeight: 'semibold',
	letterSpacing: 'tight',
});
const widgetCol = css({ w: { sm: '64' }, flexShrink: '0' });
---

{!shouldHide && (
<section class:list={[sectionStyle, className]} style={inlineStyle}>
	<div class:list={["glass-card bg-gradient-card card-shadow", cardWrapper]}>
		<div class={flexRow}>
			<div class={contentCol}>
				<div class={badgeRow}>
					<span class={badgeDot}></span>
					<span class={badgeText}>{badge}</span>
				</div>
				<h2 class:list={["text-primary-content", headlineStyle]}>
					{headline}
				</h2>
				<p class:list={["text-muted", css({ fontSize: 'sm' })]}>
					{subtitle}
				</p>
			</div>

			<div class={widgetCol}>
				<NewsletterWidget
					client:visible
					isSignedIn={!!user}
					isSubscribed={isSubscribed}
					signInUrl={signInUrl}
					pagePath={pagePath}
					audience={audience}
				/>
			</div>
		</div>
	</div>
</section>
)}
