---
export const prerender = false;

import { env } from "cloudflare:workers";
import NewsletterWidget from "./NewsletterWidget.vue";
import { createLearnerId } from "@/actions/newsletter";
import { css } from "../../../styled-system/css";

interface Props {
	class?: string;
	badge?: string;
	headline?: string;
	subtitle?: string;
	audience?: string;
	variant?: "card" | "section";
}

const {
	class: className,
	badge = "Weekly Cloud Native insights",
	headline = "Stay ahead in cloud native",
	subtitle = "Tutorials, deep dives, and curated events — no fluff.",
	audience = "academy",
} = Astro.props;

const user = Astro.locals.user;
let isSubscribed = false;

if (user && import.meta.env.PROD) {
	try {
		const prefixedUserId = createLearnerId(user.id);
		const prefs = await env.EMAIL_PREFERENCES.getPreferences(
			prefixedUserId,
			"newsletter",
			audience,
		);
		isSubscribed = prefs.length > 0;
	} catch (e) {
		console.error("Failed to fetch preferences", e);
	}
}

const pagePath = Astro.url.pathname;
const signInUrl = `/sign-in?returnTo=${encodeURIComponent(pagePath)}`;

const hasNewsletterCookie =
	Astro.cookies.get(`newsletter:${audience}:updates`)?.value === "true";

const shouldHide = !user && hasNewsletterCookie;

const wrap = css({
	position: "relative",
	zIndex: "10",
	width: "full",
	py: { base: "8", md: "12" },
});

const card = css({
	position: "relative",
	mx: "auto",
	maxWidth: "80rem",
	overflow: "hidden",
	borderRadius: "3xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised",
	px: { base: "6", md: "10" },
	py: { base: "7", md: "10" },
});

const grid = css({
	position: "relative",
	display: "grid",
	gap: "6",
	gridTemplateColumns: { base: "1fr", lg: "minmax(0, 1fr) 20rem" },
	alignItems: "center",
});

const eyebrowRow = css({ display: "flex", alignItems: "center", gap: "2" });
const eyebrowDot = css({ w: "2", h: "2", borderRadius: "full", bg: "fg.brand" });
const eyebrowText = css({
	fontSize: "xs",
	fontWeight: "semibold",
	letterSpacing: "wider",
	textTransform: "uppercase",
	color: "fg.brand",
});

const headlineStyle = css({
	mt: "2",
	fontFamily: "display",
	fontSize: { base: "2xl", md: "3xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	color: "fg.primary",
	textWrap: "balance",
	maxWidth: "30ch",
});

const subStyle = css({
	mt: "3",
	fontSize: { base: "md", md: "lg" },
	color: "fg.secondary",
	lineHeight: "1.6",
	maxWidth: "48ch",
});

const widgetWrap = css({ width: "full", maxWidth: "28rem", lg: { justifySelf: "end" } });
---

{!shouldHide && (
	<section class:list={[wrap, "hero-aurora", className]}>
		<div class={card}>
			<div class={grid}>
				<div>
					<div class={eyebrowRow}>
						<span class={eyebrowDot}></span>
						<span class={eyebrowText}>{badge}</span>
					</div>
					<h2 class={headlineStyle}>{headline}</h2>
					<p class={subStyle}>{subtitle}</p>
				</div>
				<div class={widgetWrap}>
					<NewsletterWidget
						client:visible
						isSignedIn={!!user}
						isSubscribed={isSubscribed}
						signInUrl={signInUrl}
						pagePath={pagePath}
						audience={audience}
					/>
				</div>
			</div>
		</div>
	</section>
)}
