---
import { css } from "styled-system/css";
import AuthorAvatarGroup from "@/components/common/AuthorAvatarGroup.vue";
import Badge from "@/components/common/Badge.vue";
import Button from "@/components/common/Button.astro";
import FormattedDate from "@/components/common/FormattedDate.vue";
import type { CollectionEntry } from "astro:content";

type Props = {
	title: string;
	description: string;
	difficulty: "beginner" | "intermediate" | "advanced";
	durationLabel: string;
	technologies: string[];
	prerequisites: string[];
	authors: CollectionEntry<"people">[];
	publishedAt: Date;
};

const {
	title,
	description,
	difficulty,
	durationLabel,
	technologies,
	prerequisites,
	authors,
	publishedAt,
} = Astro.props;

function getDifficultyVariant(
	difficulty: string,
): "success" | "warning" | "danger" | "default" {
	switch (difficulty) {
		case "beginner":
			return "success";
		case "intermediate":
			return "warning";
		case "advanced":
			return "danger";
		default:
			return "default";
	}
}

const difficultyLabel =
	difficulty.charAt(0).toUpperCase() + difficulty.slice(1);
const hasTechnologies = technologies.length > 0;
const hasPrerequisites = prerequisites.length > 0;

const sectionStyle = css({
	position: 'relative',
	overflow: 'hidden',
	rounded: '3xl',
	borderWidth: '1px',
	borderColor: { base: 'gray.200', _dark: 'gray.800' },
	bg: { base: 'white', _dark: 'gray.900' },
});
const bgOverlayStyle = css({
	position: 'absolute',
	inset: '0',
	bgGradient: 'to-br',
	gradientFrom: { base: 'primary/10', _dark: 'primary/20' },
	gradientVia: 'transparent',
	gradientTo: { base: 'secondary/20', _dark: 'secondary/30' },
});
const innerStyle = css({
	position: 'relative',
	zIndex: '10',
	px: { base: '6', md: '10', lg: '16' },
	py: { base: '12', lg: '16' },
});
const layoutStyle = css({
	display: 'flex',
	flexDirection: { base: 'column', lg: 'row' },
	gap: '8',
	lg: { alignItems: 'flex-start', justifyContent: 'space-between' },
});
const mainContentStyle = css({ maxW: '3xl' });
const badgeWrapStyle = css({
	display: 'flex',
	flexWrap: 'wrap',
	alignItems: 'center',
	gap: '3',
	mb: '6',
});
const badgeExtraStyle = css({ shadow: 'sm', backdropFilter: 'blur(4px)' });
const titleStyle = css({
	fontSize: { base: '3xl', md: '4xl' },
	fontWeight: 'extrabold',
	letterSpacing: 'tight',
	color: { base: 'gray.900', _dark: 'white' },
	mb: '4',
});
const descStyle = css({
	fontSize: 'lg',
	color: { base: 'gray.600', _dark: 'gray.300' },
	lineHeight: 'relaxed',
	mb: '6',
});
const techLabelStyle = css({
	fontSize: 'sm',
	fontWeight: 'semibold',
	textTransform: 'uppercase',
	letterSpacing: 'wide',
	color: { base: 'gray.500', _dark: 'gray.400' },
	mb: '2',
});
const techListStyle = css({ display: 'flex', flexWrap: 'wrap', gap: '2' });
const sidebarStyle = css({
	w: 'full',
	maxW: 'sm',
	lg: { w: 'auto', minW: '280px' },
});
const sidebarCardStyle = css({
	rounded: '2xl',
	borderWidth: '1px',
	borderColor: { base: 'gray.200', _dark: 'gray.800' },
	bg: { base: 'white/80', _dark: 'gray.900/70' },
	backdropFilter: 'blur(4px)',
	p: '6',
	shadow: 'lg',
});
const sidebarHeaderStyle = css({
	display: 'flex',
	alignItems: 'center',
	justifyContent: 'space-between',
	mb: '4',
});
const sidebarLabelStyle = css({
	fontSize: 'sm',
	fontWeight: 'semibold',
	textTransform: 'uppercase',
	letterSpacing: 'wide',
	color: { base: 'gray.500', _dark: 'gray.400' },
});
const ctaWrapStyle = css({ mt: '6' });
const prereqWrapStyle = css({ mt: '6' });
const prereqLabelStyle = css({
	fontSize: 'sm',
	fontWeight: 'semibold',
	textTransform: 'uppercase',
	letterSpacing: 'wide',
	color: { base: 'gray.500', _dark: 'gray.400' },
	mb: '2',
});
const prereqListStyle = css({
	display: 'flex',
	flexDirection: 'column',
	gap: '2',
	fontSize: 'sm',
	color: { base: 'gray.600', _dark: 'gray.300' },
});
const prereqItemStyle = css({
	display: 'flex',
	alignItems: 'flex-start',
	gap: '2',
});
const prereqDotStyle = css({
	mt: '1',
	display: 'inline-flex',
	h: '1.5',
	w: '1.5',
	rounded: 'full',
	bg: 'primary',
});
---

<section class={sectionStyle}>
	<div class={bgOverlayStyle}></div>
	<div class={innerStyle}>
		<div class={layoutStyle}>
			<div class={mainContentStyle}>
				<div class={badgeWrapStyle}>
					<Badge
						variant={getDifficultyVariant(difficulty)}
						size="sm"
						class={badgeExtraStyle}
					>
						{difficultyLabel}
					</Badge>
					<Badge variant="info" size="sm" class={badgeExtraStyle}>
						{durationLabel}
					</Badge>
				</div>
				<h1 class={titleStyle}>
					{title}
				</h1>
				<p class={descStyle}>
					{description}
				</p>

				{hasTechnologies && (
					<div>
						<h2 class={techLabelStyle}>
							Technologies Covered
						</h2>
						<div class={techListStyle}>
							{technologies.map((technology) => (
								<Badge variant="secondary" size="xs">
									{technology}
								</Badge>
							))}
						</div>
					</div>
				)}
			</div>

			<div class={sidebarStyle}>
				<div class={sidebarCardStyle}>
					<div class={sidebarHeaderStyle}>
						<h2 class={sidebarLabelStyle}>
							Your Guides
						</h2>
						<FormattedDate date={publishedAt} format="long" />
					</div>
					<AuthorAvatarGroup authors={authors} showActiveIndicator={false} />
					<div class={ctaWrapStyle}>
						<slot name="cta">
							<Button href="#learning-path-content" size="md" fullWidth>
								Start Learning
							</Button>
						</slot>
					</div>
					{hasPrerequisites && (
						<div class={prereqWrapStyle}>
							<h3 class={prereqLabelStyle}>
								Prerequisites
							</h3>
							<ul class={prereqListStyle}>
								{prerequisites.map((item) => (
									<li class={prereqItemStyle}>
										<span class={prereqDotStyle}></span>
										<span>{item}</span>
									</li>
								))}
							</ul>
						</div>
					)}
				</div>
			</div>
		</div>
	</div>
</section>
