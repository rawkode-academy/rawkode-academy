---
import AuthorAvatarGroup from "@/components/common/AuthorAvatarGroup.vue";
import Badge from "@/components/common/Badge.vue";
import Button from "@/components/common/Button.astro";
import FormattedDate from "@/components/common/FormattedDate.vue";
import type { CollectionEntry } from "astro:content";
import { css } from "../../../styled-system/css";

type Props = {
	title: string;
	description: string;
	difficulty: "beginner" | "intermediate" | "advanced";
	durationLabel: string;
	technologies: string[];
	prerequisites: string[];
	authors: CollectionEntry<"people">[];
	publishedAt: Date;
};

const {
	title,
	description,
	difficulty,
	durationLabel,
	technologies,
	prerequisites,
	authors,
	publishedAt,
} = Astro.props;

function getDifficultyVariant(
	difficulty: string,
): "success" | "warning" | "danger" | "default" {
	switch (difficulty) {
		case "beginner":
			return "success";
		case "intermediate":
			return "warning";
		case "advanced":
			return "danger";
		default:
			return "default";
	}
}

const difficultyLabel =
	difficulty.charAt(0).toUpperCase() + difficulty.slice(1);
const hasTechnologies = technologies.length > 0;
const hasPrerequisites = prerequisites.length > 0;
---

<section class={css({
	position: "relative",
	overflow: "hidden",
	borderRadius: "3xl",
	borderWidth: "1px",
	borderColor: { base: "gray.200", _dark: "gray.800" },
	bg: { base: "white", _dark: "gray.900" },
})}>
	<div class={css({
		position: "absolute",
		inset: "0",
		backgroundImage: { base: "linear-gradient(to bottom right, token(colors.teal.500/10), transparent, token(colors.green.500/20))", _dark: "linear-gradient(to bottom right, token(colors.teal.500/20), transparent, token(colors.green.500/30))" },
	})}></div>
	<div class={css({
		position: "relative",
		zIndex: "10",
		px: { base: "6", md: "10", lg: "16" },
		py: { base: "12", lg: "16" },
	})}>
		<div class={css({
			display: "flex",
			flexDirection: "column",
			gap: "8",
			lg: { flexDirection: "row", alignItems: "flex-start", justifyContent: "space-between" },
		})}>
			<div class={css({ maxW: "3xl" })}>
				<div class={css({
					display: "flex",
					flexWrap: "wrap",
					alignItems: "center",
					gap: "3",
					mb: "6",
				})}>
					<Badge
						variant={getDifficultyVariant(difficulty)}
						size="sm"
						class={css({ shadow: "sm", backdropFilter: "blur(4px)" })}
					>
						{difficultyLabel}
					</Badge>
					<Badge variant="info" size="sm" class={css({ shadow: "sm", backdropFilter: "blur(4px)" })}>
						{durationLabel}
					</Badge>
				</div>
				<h1 class={css({
					fontSize: { base: "3xl", md: "4xl" },
					fontWeight: "extrabold",
					letterSpacing: "tight",
					color: "fg.default",
					mb: "4",
				})}>
					{title}
				</h1>
				<p class={css({
					fontSize: "lg",
					color: "fg.muted",
					lineHeight: "relaxed",
					mb: "6",
				})}>
					{description}
				</p>

				{hasTechnologies && (
					<div>
						<h2 class={css({
							fontSize: "sm",
							fontWeight: "semibold",
							textTransform: "uppercase",
							letterSpacing: "wide",
							color: "fg.subtle",
							mb: "2",
						})}>
							Technologies Covered
						</h2>
						<div class={css({ display: "flex", flexWrap: "wrap", gap: "2" })}>
							{technologies.map((technology) => (
								<Badge variant="secondary" size="xs">
									{technology}
								</Badge>
							))}
						</div>
					</div>
				)}
			</div>

			<div class={css({
				w: "full",
				maxW: "sm",
				lg: { w: "auto", minW: "280px" },
			})}>
				<div class={css({
					borderRadius: "2xl",
					borderWidth: "1px",
					borderColor: { base: "gray.200", _dark: "gray.800" },
					bg: { base: "white/80", _dark: "gray.900/70" },
					backdropFilter: "blur(4px)",
					p: "6",
					shadow: "lg",
				})}>
					<div class={css({
						display: "flex",
						alignItems: "center",
						justifyContent: "space-between",
						mb: "4",
					})}>
						<h2 class={css({
							fontSize: "sm",
							fontWeight: "semibold",
							textTransform: "uppercase",
							letterSpacing: "wide",
							color: "fg.subtle",
						})}>
							Your Guides
						</h2>
						<FormattedDate date={publishedAt} format="long" />
					</div>
					<AuthorAvatarGroup authors={authors} showActiveIndicator={false} />
					<div class={css({ mt: "6" })}>
						<slot name="cta">
							<Button href="#learning-path-content" size="md" fullWidth>
								Start Learning
							</Button>
						</slot>
					</div>
					{hasPrerequisites && (
						<div class={css({ mt: "6" })}>
							<h3 class={css({
								fontSize: "sm",
								fontWeight: "semibold",
								textTransform: "uppercase",
								letterSpacing: "wide",
								color: "fg.subtle",
								mb: "2",
							})}>
								Prerequisites
							</h3>
							<ul class={css({
								display: "flex",
								flexDirection: "column",
								gap: "2",
								fontSize: "sm",
								color: "fg.muted",
							})}>
								{prerequisites.map((item) => (
									<li class={css({
										display: "flex",
										alignItems: "flex-start",
										gap: "2",
									})}>
										<span class={css({
											mt: "1",
											display: "inline-flex",
											h: "1.5",
											w: "1.5",
											borderRadius: "full",
											bg: "teal.500",
										})}></span>
										<span>{item}</span>
									</li>
								))}
							</ul>
						</div>
					)}
				</div>
			</div>
		</div>
	</div>
</section>
