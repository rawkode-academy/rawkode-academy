---
import { css } from "../../../styled-system/css";

interface Update {
	date: Date;
	description: string;
}

interface Props {
	updates?: Update[] | undefined;
}

const { updates } = Astro.props;

const formatDate = (date: Date) => {
	return new Intl.DateTimeFormat("en-US", {
		year: "numeric",
		month: "long",
		day: "numeric",
	}).format(date);
};

const wrapperStyle = css({
	mb: '4',
	fontSize: 'sm',
	color: 'fg.subtle',
	bg: 'bg.subtle',
	rounded: 'md',
	px: '3',
	py: '2',
	borderWidth: '1px',
	borderStyle: 'solid',
	borderColor: 'border.subtle',
});

const flexStyle = css({
	display: 'flex',
	alignItems: 'flex-start',
	gap: '2',
});

const iconStyle = css({
	w: '4',
	h: '4',
	mt: '0.5',
	flexShrink: '0',
	color: 'fg.subtle',
});

const labelStyle = css({
	fontWeight: '500',
	color: 'fg.default',
});

const separatorStyle = css({
	color: { base: 'gray.400', _dark: 'gray.600' },
});
---

{
	updates && updates.length > 0 && (
		<div class={wrapperStyle}>
			<div class={flexStyle}>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					fill="none"
					viewBox="0 0 24 24"
					stroke-width="1.5"
					stroke="currentColor"
					class={iconStyle}
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99"
					/>
				</svg>
				<div class={css({ flex: '1' })}>
					<span class={labelStyle}>Updated:</span>
					{updates.map((update, index) => (
						<span class={css({ ml: '1' })}>
							{formatDate(update.date)} - {update.description}
							{index < updates.length - 1 && <span class={separatorStyle}> &bull; </span>}
						</span>
					))}
				</div>
			</div>
		</div>
	)
}