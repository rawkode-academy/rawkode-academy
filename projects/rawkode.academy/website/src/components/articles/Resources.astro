---
import type { CollectionEntry } from "astro:content";
import { css } from "styled-system/css";

type Resource = NonNullable<
	CollectionEntry<"articles">["data"]["resources"]
>[number];

interface Props {
	resources?: Resource[] | undefined;
}

const { resources } = Astro.props;

const getCategoryIcon = (category: string) => {
	switch (category) {
		case "documentation":
			return "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z";
		case "code":
			return "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4";
		case "slides":
			return "M7 4v16M17 4v16M3 12h18M8 12h8";
		case "demos":
			return "M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z";
		default:
			return "M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1";
	}
};

const groupResourcesByCategory = (resources: Resource[]) => {
	const grouped: Record<string, Resource[]> = {};
	resources.forEach((resource) => {
		const category = resource.category || "other";
		if (!grouped[category]) {
			grouped[category] = [];
		}
		grouped[category].push(resource);
	});
	return grouped;
};

const getCategoryLabel = (category: string) => {
	switch (category) {
		case "documentation":
			return "Documentation";
		case "code":
			return "Code";
		case "slides":
			return "Slides";
		case "demos":
			return "Demos";
		default:
			return "Additional Resources";
	}
};

const wrapperStyle = css({ mt: '12', pt: '8', borderTopWidth: '1px', borderColor: { base: 'gray.200', _dark: 'gray.700' } });
const headingStyle = css({ fontSize: 'xl', fontWeight: 'bold', mb: '6' });
const spaceStyle = css({ display: 'flex', flexDirection: 'column', gap: '6' });
const catLabelStyle = css({ fontSize: 'sm', fontWeight: 'semibold', textTransform: 'uppercase', letterSpacing: 'wider', mb: '3' });
const gridStyle = css({ display: 'grid', gap: '3' });
const linkStyle = css({ display: 'flex', alignItems: 'flex-start', gap: '3', p: '3', borderRadius: 'lg', bg: { base: 'gray.50', _dark: 'gray.800/50' }, transition: 'all', transitionDuration: '200ms', _hover: { bg: { base: 'gray.100', _dark: 'gray.800' } } });
const iconStyle = css({ w: '5', h: '5', mt: '0.5', color: { base: 'gray.400', _dark: 'gray.500' }, flexShrink: '0', _groupHover: { color: 'brandAccent.text' } });
const contentStyle = css({ flex: '1', minW: '0' });
const titleStyle = css({ fontWeight: 'medium', _groupHover: { color: 'brandAccent.text' } });
const descStyle = css({ fontSize: 'sm', mt: '0.5' });
const extIconStyle = css({ w: '4', h: '4', mt: '1', color: { base: 'gray.400', _dark: 'gray.500' }, flexShrink: '0', _groupHover: { color: 'brandAccent.text' } });
---

{
	resources && resources.length > 0 && (
		<div class={wrapperStyle}>
			<h2 class={`${headingStyle} text-primary-content`}>Resources & References</h2>

			<style>
				@keyframes highlight-pulse {
					0% {
						background-color: rgb(99 102 241 / 0.2);
						transform: scale(1);
					}
					30% {
						background-color: rgb(99 102 241 / 0.3);
						transform: scale(1.005);
					}
					70% {
						background-color: rgb(99 102 241 / 0.2);
						transform: scale(1.002);
					}
					100% {
						background-color: rgb(99 102 241 / 0);
						transform: scale(1);
					}
				}

				.resource-link {
					text-decoration: none !important;
				}

				.resource-wrapper:target .resource-link {
					animation: highlight-pulse 3s ease-out;
				}

				.resource-wrapper {
					scroll-margin-top: 6rem;
				}
			</style>

			<div class={spaceStyle}>
				{Object.entries(groupResourcesByCategory(resources)).map(([category, categoryResources]) => (
					<div>
						<h3 class={`${catLabelStyle} text-muted`}>
							{getCategoryLabel(category)}
						</h3>
						<div class={gridStyle}>
							{categoryResources.map(resource => {
								// Find the original index of this resource in the flat array
								const resourceIndex = resources.findIndex(r => r === resource) + 1;
								// Use explicit ID if available, otherwise use index
								const resourceId = resource.id || `${resourceIndex}`;
								return (
									<div id={`resource-${resourceId}`} class="resource-wrapper">
										<a
											href={resource.url || resource.filePath || "#"}
											target={resource.type === "url" ? "_blank" : undefined}
											rel={resource.type === "url" ? "noopener noreferrer" : undefined}
											class={`resource-link group ${linkStyle}`}
										>
									<svg
										class={iconStyle}
										fill="none"
										stroke="currentColor"
										viewBox="0 0 24 24"
									>
										<path
											stroke-linecap="round"
											stroke-linejoin="round"
											stroke-width="2"
											d={getCategoryIcon(category)}
										/>
									</svg>
									<div class={contentStyle}>
										<div class={`${titleStyle} text-primary-content`}>
											{resource.title}
										</div>
										{resource.description && (
											<div class={`${descStyle} text-muted`}>
												{resource.description}
											</div>
										)}
									</div>
									{resource.type === "url" && (
										<svg
											class={extIconStyle}
											fill="none"
											stroke="currentColor"
											viewBox="0 0 24 24"
										>
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												stroke-width="2"
												d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
											/>
										</svg>
									)}
								</a>
								</div>
								);
							})}
						</div>
					</div>
				))}
			</div>
		</div>
	)
}
