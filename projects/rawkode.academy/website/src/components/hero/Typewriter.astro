---
import { css } from "../../../styled-system/css";

interface Button {
	text: string;
	link: string;
	newWindow?: boolean;
}

interface TechLogo {
	name: string;
	iconUrl: string;
}

interface SocialProofStat {
	icon?: string;
	value: string;
	label: string;
}

export interface Props {
	rotatedPrefixes: string[];
	suffix: string;
	highlight?: string;
	logos: TechLogo[];
	primaryButton: Button;
	secondaryButton: Button;
	socialProof?: SocialProofStat[];
}

const {
	rotatedPrefixes,
	suffix,
	highlight,
	logos,
	primaryButton,
	secondaryButton,
	socialProof = [],
} = Astro.props;

// Sort once on server so initial paint is stable.
const initialPrefix = rotatedPrefixes[0] ?? "";

const highlightedSuffix = highlight
	? suffix.split(highlight)
	: [suffix];

const section = css({
	position: "relative",
	overflow: "hidden",
	borderRadius: "3xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.canvas/50",
	mt: { base: "6", md: "8" },
	mx: { base: "2", md: "0" },
});

const inner = css({
	position: "relative",
	zIndex: "1",
	display: "grid",
	gap: { base: "8", lg: "5" },
	gridTemplateColumns: { base: "1fr", lg: "minmax(0, 1.22fr) minmax(14rem, 0.68fr)" },
	alignItems: "center",
	maxWidth: "72rem",
	mx: "auto",
	px: { base: "5", md: "8", lg: "12" },
	py: { base: "14", md: "18", lg: "22" },
});

const eyebrow = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "3",
	py: "1.5",
	borderRadius: "full",
	bg: "bg.brand-subtle",
	color: "fg.brand",
	fontSize: "xs",
	fontWeight: "semibold",
	letterSpacing: "0.18em",
	textTransform: "uppercase",
	mb: "5",
});

const eyebrowDot = css({
	w: "2",
	h: "2",
	borderRadius: "full",
	bg: "fg.brand",
});

const headingBlock = css({
	color: "fg.primary",
	mb: "5",
});

const rotatingLine = css({
	display: "block",
	fontFamily: "display",
	fontSize: { base: "4xl", md: "5xl", lg: "6xl" },
	fontWeight: "bold",
	lineHeight: "1.02",
	letterSpacing: "-0.04em",
	color: "fg.brand",
	minHeight: "1.2em",
});

const cursor = css({
	display: "inline-block",
	width: "0.08em",
	height: "0.85em",
	backgroundColor: "currentColor",
	verticalAlign: "baseline",
	ml: "0.05em",
	animation: "typewriter-cursor 1s steps(2) infinite",
});

const suffixLine = css({
	display: "block",
	mt: "2",
	fontFamily: "display",
	fontSize: { base: "3xl", md: "4xl", lg: "5xl" },
	fontWeight: "bold",
	lineHeight: "0.98",
	letterSpacing: "-0.03em",
	color: "fg.primary",
	textWrap: "balance",
	maxWidth: "20ch",
});

const highlightSpan = css({
	backgroundImage: "linear-gradient(135deg, #5f5ed7, #00ceff)",
	backgroundClip: "text",
	color: "transparent",
});

const subStyle = css({
	fontSize: { base: "md", md: "lg" },
	lineHeight: "1.6",
	color: "fg.secondary",
	maxWidth: "42rem",
	mb: "8",
});

const buttonsRow = css({
	display: "flex",
	flexWrap: "wrap",
	gap: "3",
	alignItems: "center",
});

const primaryBtn = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	minH: "12",
	px: "6",
	py: "3",
	borderRadius: "xl",
	fontWeight: "semibold",
	color: "fg.on-brand",
	backgroundImage: "linear-gradient(135deg, #5f5ed7, #00ceff)",
	textDecoration: "none",
	boxShadow: "lg",
	transition: "transform 150ms ease, box-shadow 150ms ease",
	_hover: { transform: "translateY(-1px)", boxShadow: "xl" },
});

const secondaryBtn = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	minH: "12",
	px: "6",
	py: "3",
	borderRadius: "xl",
	fontWeight: "medium",
	color: "fg.primary",
	bg: "bg.surface",
	borderWidth: "1px",
	borderColor: "border.default",
	textDecoration: "none",
	transition: "all 150ms ease",
	_hover: { bg: "bg.sunken", borderColor: "fg.brand" },
});

const statsRow = css({
	mt: "8",
	display: "flex",
	flexWrap: "wrap",
	gap: "3",
});

const statChip = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "3",
	px: "4",
	py: "2.5",
	borderRadius: "full",
	bg: "bg.surface",
	borderWidth: "1px",
	borderColor: "border.muted",
});

const statValue = css({
	fontFamily: "display",
	fontSize: "md",
	fontWeight: "bold",
	letterSpacing: "tight",
	color: "fg.primary",
	lineHeight: "1",
});

const statLabel = css({
	fontSize: "2xs",
	fontWeight: "semibold",
	letterSpacing: "0.18em",
	textTransform: "uppercase",
	color: "fg.muted",
	lineHeight: "1.2",
});

const logoCol = css({
	display: { base: "none", lg: "grid" },
	gridTemplateColumns: "repeat(2, 1fr)",
	gap: "4",
});

const arrowIcon = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>`;
---

<section class:list={[section, "hero-aurora-strong"]}>
	<div class={inner}>
		<div>
			<span class={eyebrow}>
				<span class={eyebrowDot}></span>
				Hands-on cloud native education
			</span>

			<h1 class={headingBlock}>
				<span class="sr-only">{rotatedPrefixes.join(", ")} {suffix}</span>
				<span aria-hidden="true" class={rotatingLine}>
					<span data-rotator-text>{initialPrefix}</span><span class={cursor} aria-hidden="true"></span>
				</span>
				<span aria-hidden="true" class={suffixLine}>
					{highlightedSuffix.map((part, i) => (
						i === highlightedSuffix.length - 1
							? <span>{part}</span>
							: <>{part}<span class={highlightSpan}>{highlight}</span></>
					))}
				</span>
			</h1>

			<p class={subStyle}>
				Hands-on lessons, candid trade-offs, and real build sessions for engineers who want signal instead of slideware.
			</p>

			<div class={buttonsRow}>
				<a href={primaryButton.link} target={primaryButton.newWindow ? "_blank" : "_self"} class={primaryBtn}>
					{primaryButton.text}
					<Fragment set:html={arrowIcon} />
				</a>
				<a href={secondaryButton.link} target={secondaryButton.newWindow ? "_blank" : "_self"} class={secondaryBtn}>
					{secondaryButton.text}
				</a>
			</div>

			{socialProof.length > 0 && (
				<div class={statsRow}>
					{socialProof.map((s) => (
						<div class={statChip}>
							{s.icon && <span style="font-size: 1rem;">{s.icon}</span>}
							<div style="display: flex; flex-direction: column; gap: 0.125rem;">
								<span class={statValue}>{s.value}</span>
								<span class={statLabel}>{s.label}</span>
							</div>
						</div>
					))}
				</div>
			)}
		</div>

		<div class={logoCol}>
			{logos.slice(0, 4).map((logo) => (
				<div class="hero-logo-card" title={logo.name}>
					<div class="hero-logo-scanlines">
						<div class="hero-logo-mask-cyan" style={`--icon-url: url(${logo.iconUrl});`}></div>
						<div class="hero-logo-mask-purple" style={`--icon-url: url(${logo.iconUrl});`}></div>
					</div>
					<img src={logo.iconUrl} alt={logo.name} class="hero-logo-img" loading="lazy" />
				</div>
			))}
		</div>
	</div>
</section>

<style is:global>
	@keyframes typewriter-cursor {
		to {
			opacity: 0;
		}
	}

	@keyframes scanline-scroll {
		from { mask-position: 0 0; -webkit-mask-position: 0 0; }
		to { mask-position: 0 4px; -webkit-mask-position: 0 4px; }
	}

	.hero-logo-card {
		position: relative;
		aspect-ratio: 1 / 1;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 1.25rem;
		border-radius: 1.5rem;
		background: color-mix(in srgb, #5f5ed7 5%, transparent);
		border: 1px solid var(--colors-border-muted);
		overflow: hidden;
		transition: transform 250ms cubic-bezier(0.22, 1, 0.36, 1), border-color 250ms ease, background 250ms ease;
	}
	.hero-logo-card::before {
		content: "";
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, color-mix(in srgb, #fff 4%, transparent), transparent 60%);
		pointer-events: none;
	}
	.hero-logo-card:hover {
		transform: translateY(-3px) scale(1.02);
		border-color: color-mix(in srgb, #5f5ed7 40%, transparent);
		background: color-mix(in srgb, #5f5ed7 10%, transparent);
	}

	.hero-logo-scanlines {
		position: absolute;
		inset: 1.25rem;
		mask-image: repeating-linear-gradient(to bottom, black 0px, black 2px, transparent 2px, transparent 4px);
		-webkit-mask-image: repeating-linear-gradient(to bottom, black 0px, black 2px, transparent 2px, transparent 4px);
		mask-size: 100% 4px;
		-webkit-mask-size: 100% 4px;
		animation: scanline-scroll 1s linear infinite;
		transition: opacity 250ms ease;
	}
	.hero-logo-card:hover .hero-logo-scanlines {
		opacity: 0;
	}
	@media (prefers-reduced-motion: reduce) {
		.hero-logo-scanlines { animation: none; }
	}

	.hero-logo-mask-cyan,
	.hero-logo-mask-purple {
		position: absolute;
		inset: 0;
		mask-image: var(--icon-url);
		-webkit-mask-image: var(--icon-url);
		mask-repeat: no-repeat;
		-webkit-mask-repeat: no-repeat;
		mask-position: center;
		-webkit-mask-position: center;
		mask-size: contain;
		-webkit-mask-size: contain;
	}
	.hero-logo-mask-cyan {
		background-color: #00ceff;
		opacity: 0.28;
		mask-mode: alpha;
		-webkit-mask-mode: alpha;
	}
	.hero-logo-mask-purple {
		background-color: #5f5ed7;
		mask-mode: luminance;
		-webkit-mask-mode: luminance;
	}

	.hero-logo-img {
		position: absolute;
		inset: 1.25rem;
		width: calc(100% - 2.5rem);
		height: calc(100% - 2.5rem);
		object-fit: contain;
		opacity: 0;
		transition: opacity 250ms ease;
		pointer-events: none;
	}
	.hero-logo-card:hover .hero-logo-img {
		opacity: 1;
	}
</style>

<script
	is:inline
	define:vars={{
		prefixes: rotatedPrefixes,
		typeSpeed: 60,
		deleteSpeed: 30,
		holdMs: 1300,
	}}
>
	(() => {
		const el = document.querySelector("[data-rotator-text]");
		if (!el || prefixes.length <= 1) return;

		// Shuffle order so each load isn't identical
		const shuffled = [...prefixes].sort(() => Math.random() - 0.5);
		let i = 0;
		let phase = "hold"; // "type" | "hold" | "delete"
		let text = el.textContent || shuffled[0];
		let target = shuffled[0];

		const tick = () => {
			if (phase === "hold") {
				phase = "delete";
				setTimeout(tick, holdMs);
				return;
			}

			if (phase === "delete") {
				if (text.length > 0) {
					text = text.slice(0, -1);
					el.textContent = text;
					setTimeout(tick, deleteSpeed);
					return;
				}
				i = (i + 1) % shuffled.length;
				target = shuffled[i];
				phase = "type";
				setTimeout(tick, 80);
				return;
			}

			if (phase === "type") {
				if (text.length < target.length) {
					text = target.slice(0, text.length + 1);
					el.textContent = text;
					setTimeout(tick, typeSpeed);
					return;
				}
				phase = "hold";
				setTimeout(tick, holdMs);
				return;
			}
		};

		// First tick: schedule after a hold so the SSR'd text holds first
		setTimeout(tick, holdMs);
	})();
</script>
