---
interface Props {
	leftLabel: string;
	title: string;
	titleTail?: string | undefined;
	liveCount?: number | undefined;
	rightLabel?: string | undefined;
}

const { leftLabel, title, titleTail, liveCount, rightLabel } = Astro.props as Props;
---

<div class="video-masthead">
	<span class="video-masthead__left">{leftLabel}</span>
	<span class="video-masthead__center">
		{title}
		{titleTail && <span class="video-masthead__center-muted"> — {titleTail}</span>}
	</span>
	<span class="video-masthead__right">
		{liveCount !== undefined && liveCount > 0 ? (
			<>
				<span class="video-masthead__dot" aria-hidden="true"></span>
				<span class="video-masthead__live">On air now</span>
				<span>— {liveCount.toLocaleString()} watching</span>
			</>
		) : (
			rightLabel
		)}
	</span>
</div>

<style>
	.video-masthead {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: baseline;
		gap: 2rem;
		padding: 1.25rem 2.5rem;
		border-bottom: 2px solid var(--editorial-ink);
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 0.6875rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.video-masthead__left { color: var(--editorial-ink-soft); }

	.video-masthead__center {
		font-family: var(--font-instrument-serif), serif;
		font-style: italic;
		font-weight: 400;
		font-size: 1.5rem;
		letter-spacing: -0.015em;
		text-transform: none;
		color: var(--editorial-ink);
		text-align: center;
	}

	.video-masthead__center-muted { color: var(--editorial-ink-mute); }

	.video-masthead__right {
		color: var(--editorial-ink-soft);
		text-align: right;
		display: inline-flex;
		gap: 0.5rem;
		justify-content: flex-end;
		align-items: center;
	}

	.video-masthead__dot {
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: var(--editorial-amber);
		animation: rk-pulse 1.6s ease-in-out infinite;
	}

	.video-masthead__live { color: var(--editorial-amber); font-weight: 600; }

	@keyframes rk-pulse {
		0%, 100% { opacity: 1; transform: scale(1); }
		50% { opacity: 0.7; transform: scale(0.92); }
	}

	@media (max-width: 880px) {
		.video-masthead {
			grid-template-columns: 1fr;
			gap: 0.5rem;
			padding: 1rem 1.25rem;
			text-align: center;
		}
		.video-masthead__left,
		.video-masthead__right { text-align: center; justify-content: center; }
	}
</style>
