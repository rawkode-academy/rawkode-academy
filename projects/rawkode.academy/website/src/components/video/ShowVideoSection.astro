---
import type { CollectionEntry } from "astro:content";
import { formatVideoRuntimeLabel } from "@/lib/video-runtime";

interface Props {
	show: CollectionEntry<"shows">;
	videos: Array<{
		id: string;
		title: string;
		thumbnailUrl: string;
		slug: string;
		duration: number | undefined;
		publishedAt?: Date | string | undefined;
		type?: string | undefined;
	}>;
	totalVideos?: number;
}

const { show, videos, totalVideos } = Astro.props;

const hasMoreVideos =
	typeof totalVideos === "number" && totalVideos > videos.length;
---

{videos.length > 0 && (
	<section class="mt-8">
		<div class="flex items-center justify-between mb-4">
			<h3 class="text-lg font-semibold text-primary-content">
				More from {show.data.name}
			</h3>
			<a
				href={`/shows/${show.id}`}
				class="text-sm text-primary hover:text-primary/80 transition-colors flex items-center gap-1"
			>
				{hasMoreVideos ? `View all ${totalVideos} episodes` : "View show"}
				<svg
					class="w-4 h-4"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M9 5l7 7-7 7"
					/>
				</svg>
			</a>
		</div>

		<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
			{videos.map((video) => (
				<a
					href={`/watch/${video.slug}`}
					class="group block paper-card-muted rounded-sm overflow-hidden"
				>
					<div class="relative aspect-video overflow-hidden bg-gray-100 dark:bg-gray-800">
						<img
							src={video.thumbnailUrl}
							alt={video.title}
							class="w-full h-full object-cover group-hover:scale-105 "
							width="1280"
							height="720"
							loading="lazy"
							decoding="async"
						/>
						<div class="absolute bottom-2 right-2 bg-black/80 text-white text-xs px-2 py-1 rounded">
							{formatVideoRuntimeLabel(video)}
						</div>
					</div>
					<div class="p-3">
						<h4 class="font-medium text-secondary-content group-hover:text-primary-content line-clamp-2 transition-colors text-sm">
							{video.title}
						</h4>
					</div>
				</a>
			))}
		</div>
	</section>
)}
