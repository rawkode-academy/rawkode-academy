---
import type { CollectionEntry } from "astro:content";
import { css } from "../../../styled-system/css";
import { resolveTechnologyIconUrl } from "@/utils/resolve-technology-icon";

interface Props {
	technology: CollectionEntry<"technologies">;
	videos: Array<{
		id: string;
		title: string;
		thumbnailUrl: string;
		slug: string;
		duration: number | undefined;
	}>;
	totalVideos?: number;
}

const { technology, videos, totalVideos } = Astro.props;

const techId = technology.id.replace(/\/index$/, "");
const techName = technology.data.name;
const iconUrl = resolveTechnologyIconUrl(technology.id, technology.data.logos);

const formatDuration = (seconds?: number | null) => {
	if (typeof seconds !== "number" || seconds <= 0 || Number.isNaN(seconds)) {
		return "--:--";
	}
	const hours = Math.floor(seconds / 3600);
	const minutes = Math.floor((seconds % 3600) / 60);
	const secs = seconds % 60;

	if (hours > 0) {
		return `${hours}:${minutes.toString().padStart(2, "0")}:${secs.toString().padStart(2, "0")}`;
	}
	return `${minutes}:${secs.toString().padStart(2, "0")}`;
};

const hasMoreVideos = totalVideos && totalVideos > videos.length;

const sectionStyle = css({ mt: "8" });

const headerStyle = css({
	display: "flex",
	alignItems: "center",
	justifyContent: "space-between",
	mb: "4",
});

const titleGroupStyle = css({
	display: "flex",
	alignItems: "center",
	gap: "3",
});

const iconWrapStyle = css({
	w: "6",
	h: "6",
	position: "relative",
	overflow: "hidden",
	borderRadius: "md",
});

const iconImgStyle = css({
	w: "full",
	h: "full",
	objectFit: "contain",
});

const sectionTitleStyle = css({
	fontSize: "lg",
	fontWeight: "semibold",
}) + " text-primary-content";

const viewAllLinkStyle = css({
	fontSize: "sm",
	color: "rgb(var(--brand-primary))",
	_hover: { opacity: 0.8 },
	transition: "colors",
	display: "flex",
	alignItems: "center",
	gap: "1",
});

const gridStyle = css({
	display: "grid",
	gap: "4",
	gridTemplateColumns: { sm: "repeat(2, 1fr)", lg: "repeat(3, 1fr)" },
});

const cardLinkStyle = css({
	display: "block",
	borderRadius: "lg",
	overflow: "hidden",
});

const thumbWrapStyle = css({
	position: "relative",
	aspectRatio: "16/9",
	overflow: "hidden",
	bg: { base: "gray.100", _dark: "gray.800" },
});

const thumbImgStyle = css({
	w: "full",
	h: "full",
	objectFit: "cover",
	transition: "transform 0.2s",
});

const durationBadgeStyle = css({
	position: "absolute",
	bottom: "2",
	right: "2",
	bg: "rgba(0, 0, 0, 0.8)",
	color: "white",
	fontSize: "xs",
	px: "2",
	py: "1",
	borderRadius: "md",
});

const videoTitleStyle = css({
	fontWeight: "medium",
	lineClamp: 2,
	transition: "colors",
	fontSize: "sm",
}) + " text-secondary-content";

const chevronStyle = css({ w: "4", h: "4" });
---

{videos.length > 0 && (
	<section class={sectionStyle}>
		<div class={headerStyle}>
			<div class={titleGroupStyle}>
				{iconUrl && (
					<div class={iconWrapStyle}>
						<img
							src={iconUrl}
							alt={techName}
							class={iconImgStyle}
							onerror="this.onerror=null; this.src='/apple-touch-icon.png'"
						/>
					</div>
				)}
				<h3 class={sectionTitleStyle}>
					More about {techName}
				</h3>
			</div>
			<a
				href={`/technology/${techId}`}
				class={viewAllLinkStyle}
			>
				{hasMoreVideos ? `View all ${totalVideos} videos` : "View technology"}
				<svg class={chevronStyle} fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
				</svg>
			</a>
		</div>

		<div class={gridStyle}>
			{videos.map((video) => (
				<a
					href={`/watch/${video.slug}`}
					class={cardLinkStyle + " group glass-interactive"}
				>
					<div class={thumbWrapStyle}>
						<img
							src={video.thumbnailUrl}
							alt={video.title}
							class={thumbImgStyle + " group-hover:scale-105"}
							loading="lazy"
						/>
						<div class={durationBadgeStyle}>
							{formatDuration(video.duration)}
						</div>
					</div>
					<div class={css({ p: "3" })}>
						<h4 class={videoTitleStyle + " group-hover:text-primary-content"}>
							{video.title}
						</h4>
					</div>
				</a>
			))}
		</div>
	</section>
)}
