---
import { css, cx } from "../../../styled-system/css";
import type { CollectionEntry } from "astro:content";
import { resolveTechnologyIconUrl } from "@/utils/resolve-technology-icon";

interface Props {
	technology: CollectionEntry<"technologies">;
	videos: Array<{
		id: string;
		title: string;
		thumbnailUrl: string;
		slug: string;
		duration: number | undefined;
	}>;
	totalVideos?: number;
}

const { technology, videos, totalVideos } = Astro.props;

const techId = technology.id.replace(/\/index$/, "");
const techName = technology.data.name;
const iconUrl = resolveTechnologyIconUrl(technology.id, technology.data.logos);

const formatDuration = (seconds?: number | null) => {
	if (typeof seconds !== "number" || seconds <= 0 || Number.isNaN(seconds)) {
		return "--:--";
	}
	const hours = Math.floor(seconds / 3600);
	const minutes = Math.floor((seconds % 3600) / 60);
	const secs = seconds % 60;

	if (hours > 0) {
		return `${hours}:${minutes.toString().padStart(2, "0")}:${secs.toString().padStart(2, "0")}`;
	}
	return `${minutes}:${secs.toString().padStart(2, "0")}`;
};

const hasMoreVideos = totalVideos && totalVideos > videos.length;
---

{videos.length > 0 && (
	<section class={css({ mt: '8' })}>
		<div class={css({ display: 'flex', alignItems: 'center', justifyContent: 'space-between', mb: '4' })}>
			<div class={css({ display: 'flex', alignItems: 'center', gap: '3' })}>
				{iconUrl && (
					<div class={css({ w: '6', h: '6', pos: 'relative', overflow: 'hidden', rounded: 'base' })}>
						<img
							src={iconUrl}
							alt={techName}
							class={css({ w: 'full', h: 'full', objectFit: 'contain' })}
							onerror="this.onerror=null; this.src='/apple-touch-icon.png'"
						/>
					</div>
				)}
				<h3 class={cx('text-primary-content', css({ fontSize: 'lg', fontWeight: 'semibold' }))}>
					More about {techName}
				</h3>
			</div>
			<a
				href={`/technology/${techId}`}
				class={css({ fontSize: 'sm', color: 'primary', _hover: { color: 'primary/80' }, transition: 'colors', display: 'flex', alignItems: 'center', gap: '1' })}
			>
				{hasMoreVideos ? `View all ${totalVideos} videos` : "View technology"}
				<svg class={css({ w: '4', h: '4' })} fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
				</svg>
			</a>
		</div>

		<div class={css({ display: 'grid', gap: '4', sm: { gridTemplateColumns: '2' }, lg: { gridTemplateColumns: '3' } })}>
			{videos.map((video) => (
				<a
					href={`/watch/${video.slug}`}
					class={cx('glass-interactive', css({ display: 'block', rounded: 'lg', overflow: 'hidden' }))}
					style="cursor:pointer"
				>
					<div class={css({ pos: 'relative', aspectRatio: 'video', overflow: 'hidden', bg: 'gray.100', _dark: { bg: 'gray.800' } })}>
						<img
							src={video.thumbnailUrl}
							alt={video.title}
							class={css({ w: 'full', h: 'full', objectFit: 'cover', _groupHover: { scale: '1.05' }, transition: 'transform', transitionDuration: '200ms' })}
							loading="lazy"
						/>
						<div class={css({ pos: 'absolute', bottom: '2', right: '2', bg: 'black/80', color: 'white', fontSize: 'xs', px: '2', py: '1', rounded: 'base' })}>
							{formatDuration(video.duration)}
						</div>
					</div>
					<div class={css({ p: '3' })}>
						<h4 class={cx('text-secondary-content', css({ fontWeight: 'medium', _groupHover: { color: 'primary' }, lineClamp: '2', transition: 'colors', fontSize: 'sm' }))}>
							{video.title}
						</h4>
					</div>
				</a>
			))}
		</div>
	</section>
)}
