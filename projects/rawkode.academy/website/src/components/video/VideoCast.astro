---
import type { CollectionEntry } from "astro:content";
import { css } from "../../../styled-system/css";

interface Props {
	hosts: CollectionEntry<"people">[];
	guests: CollectionEntry<"people">[];
}

const { hosts, guests } = Astro.props;
const hasSpeakers = hosts.length > 0 || guests.length > 0;

const sectionStyle = css({
	display: "flex",
	flexDirection: "column",
	gap: { base: "3", sm: "4", lg: "6" },
	pt: "8",
	borderTopWidth: "1px",
	borderColor: "rgba(var(--brand-secondary), 0.2)",
});

const headingStyle = css({
	fontSize: "2xl",
	fontWeight: "bold",
	mb: "6",
}) + " text-primary-content";

const gridStyle = css({
	display: "grid",
	gap: "4",
	gridTemplateColumns: { sm: "repeat(2, 1fr)", lg: "repeat(3, 1fr)", xl: "repeat(4, 1fr)" },
});

const personCardStyle = (type: "host" | "guest") => css({
	display: "flex",
	alignItems: "center",
	p: "4",
	gap: "4",
	transition: "colors",
	_hover: {
		borderColor: type === "host" ? "rgba(var(--brand-primary), 0.5)" : "rgb(var(--brand-secondary))",
	},
}) + " glass-panel group";

const avatarStyle = (type: "host" | "guest") => css({
	w: "12",
	h: "12",
	borderRadius: "full",
	objectFit: "cover",
	borderWidth: "2px",
	borderColor: type === "host" ? "rgb(var(--brand-primary))" : "rgba(var(--brand-secondary), 0.5)",
});

const badgeStyle = (type: "host" | "guest") => css({
	position: "absolute",
	bottom: "-1",
	right: "-1",
	fontSize: "10px",
	fontWeight: "bold",
	px: "1.5",
	py: "0.5",
	borderRadius: "full",
	borderWidth: "1px",
	shadow: "sm",
	bg: type === "host" ? "rgb(var(--brand-primary))" : "rgb(var(--brand-secondary))",
	color: type === "host" ? "white" : "rgb(55 65 81)",
	borderColor: type === "host" ? "rgba(255, 255, 255, 0.1)" : "rgba(0, 0, 0, 0.1)",
});

const nameStyle = css({
	fontWeight: "medium",
	truncate: true,
	transition: "colors",
}) + " text-primary-content";

const handleStyle = css({
	fontSize: "xs",
	truncate: true,
}) + " text-secondary-content";
---

{hasSpeakers && (
	<section class={sectionStyle}>
		<h2 class={headingStyle}>
			Meet the Cast
		</h2>
		<div class={gridStyle}>
			{hosts.map((person) => (
				<div class={personCardStyle("host")}>
					<div class={css({ position: "relative", flexShrink: 0 })}>
						<img
							src={person.data.avatarUrl || '/images/avatars/default.png'}
							alt={person.data.name}
							class={avatarStyle("host")}
							loading="lazy"
						/>
						<span class={badgeStyle("host")}>
							HOST
						</span>
					</div>
					<div class={css({ minWidth: 0 })}>
						<h3 class={nameStyle + " group-hover:text-primary"}>
							{person.data.name}
						</h3>
						<p class={handleStyle}>
							@{person.data.github ? person.data.github.split('/').pop() : person.data.id}
						</p>
					</div>
				</div>
			))}

			{guests.map((person) => (
				<div class={personCardStyle("guest")}>
					<div class={css({ position: "relative", flexShrink: 0 })}>
						<img
							src={person.data.avatarUrl || '/images/avatars/default.png'}
							alt={person.data.name}
							class={avatarStyle("guest")}
							loading="lazy"
						/>
						<span class={badgeStyle("guest")}>
							GUEST
						</span>
					</div>
					<div class={css({ minWidth: 0 })}>
						<h3 class={nameStyle + " group-hover:text-secondary"}>
							{person.data.name}
						</h3>
						<p class={handleStyle}>
							@{person.data.github ? person.data.github.split('/').pop() : person.data.id}
						</p>
					</div>
				</div>
			))}
		</div>
	</section>
)}
