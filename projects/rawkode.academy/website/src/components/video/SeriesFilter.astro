---
import MLabel from "@/components/ui/MLabel.vue";

interface SeriesItem { label: string; count: number; href?: string }

interface Props {
	label?: string;
	items: SeriesItem[];
	activeIndex?: number;
	rightLabel?: string;
}

const {
	label = "Series",
	items,
	activeIndex = 0,
	rightLabel,
} = Astro.props as Props;
---

<div class="series-filter">
	<MLabel>{label}</MLabel>
	{items.map((t, i) => (
		<a
			class={`series-filter__chip ${i === activeIndex ? "series-filter__chip--active" : ""}`}
			href={t.href ?? "#"}
		>
			{t.label}
			<span class="series-filter__count">{t.count}</span>
		</a>
	))}
	<span class="series-filter__spacer"></span>
	{rightLabel && <MLabel><span set:html={rightLabel}></span></MLabel>}
</div>

<style>
	.series-filter {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		flex-wrap: wrap;
		padding: 1.125rem 2.5rem;
		border-bottom: 1px solid var(--editorial-hairline);
	}

	.series-filter__chip {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.375rem 0.625rem;
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 0.6875rem;
		font-weight: 500;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--editorial-ink-soft);
		background: transparent;
		border: 1px solid var(--editorial-hairline-strong);
		border-radius: 2px;
		text-decoration: none;
		transition: color var(--duration-base) var(--ease-standard),
			border-color var(--duration-base) var(--ease-standard),
			background-color var(--duration-base) var(--ease-standard);
	}

	.series-filter__chip:hover {
		color: var(--editorial-ink);
		border-color: var(--editorial-ink);
	}

	.series-filter__chip--active {
		color: var(--editorial-paper);
		background: var(--editorial-ink);
		border-color: var(--editorial-ink);
	}

	.series-filter__count { font-size: 0.625rem; opacity: 0.55; }
	.series-filter__chip--active .series-filter__count { opacity: 0.8; }

	.series-filter__spacer { flex: 1; min-width: 1rem; }

	@media (max-width: 720px) {
		.series-filter { padding: 1rem 1.25rem; }
	}
</style>
