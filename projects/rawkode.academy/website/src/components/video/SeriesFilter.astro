---
import MLabel from "@/components/ui/MLabel.vue";

interface SeriesItem { label: string; href: string; count?: number }

interface Props {
	label?: string;
	items: SeriesItem[];
	activeIndex?: number;
	rightLabel?: string;
}

const {
	label = "Series",
	items,
	activeIndex = 0,
} = Astro.props as Props;
---

<div class="series-filter">
	<div class="series-filter__label">
		<MLabel>{label}</MLabel>
	</div>
	<nav class="series-filter__links" aria-label="Video series">
		{items.map((t, i) => (
			<a
				class={`series-filter__link ${i === activeIndex ? "series-filter__link--active" : ""}`}
				href={t.href}
				aria-current={i === activeIndex ? "page" : undefined}
			>
				{t.label}
			</a>
		))}
	</nav>
</div>

<style>
	.series-filter {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr);
		align-items: baseline;
		gap: 1.25rem;
		padding: 0.875rem 2.5rem 0.75rem;
		border-bottom: 1px solid var(--editorial-hairline);
	}

	.series-filter__links {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.375rem 1rem;
		min-width: 0;
	}

	.series-filter__link {
		display: inline-flex;
		align-items: center;
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 0.6875rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--editorial-ink-soft);
		text-decoration: none;
		transition: color var(--duration-base) var(--ease-standard),
			text-decoration-color var(--duration-base) var(--ease-standard);
	}

	.series-filter__link:hover {
		color: var(--editorial-ink);
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 0.35em;
	}

	.series-filter__link--active {
		color: var(--editorial-ink);
		text-decoration: underline;
		text-decoration-thickness: 2px;
		text-underline-offset: 0.35em;
	}

	@media (max-width: 720px) {
		.series-filter {
			grid-template-columns: 1fr;
			gap: 0.5rem;
			padding: 0.75rem 1rem 0.625rem;
		}
		.series-filter__links {
			flex-wrap: nowrap;
			gap: 0.875rem;
			margin-inline: -1rem;
			padding-inline: 1rem;
			overflow-x: auto;
			overscroll-behavior-x: contain;
			scrollbar-width: none;
		}
		.series-filter__links::-webkit-scrollbar {
			display: none;
		}
	}
</style>
