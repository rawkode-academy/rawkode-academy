---
/**
 * Primary site navigation — server-rendered so the links exist in the
 * HTML without client-side JavaScript (SEO + the project's no-JS
 * principle). A small vanilla script layers on the interactive
 * behaviours: desktop collapse, width resize, and the mobile drawer.
 */
interface NavLink {
	name: string;
	href: string;
	iconPath: string;
}

const navItems: NavLink[] = [
	{
		name: "News",
		href: "/news",
		iconPath:
