---
import { Image } from "astro:assets";
import MLabel from "@/components/ui/MLabel.vue";

interface Props {
	href: string;
	kicker: string;
	dispatchNum: number | string;
	title: string;
	dek: string;
	author?: string | undefined;
	date: string;
	readingTime: string;
	cover?:
		| {
				image: ImageMetadata;
				alt: string;
		  }
		| undefined;
}

const {
	href,
	kicker,
	dispatchNum,
	title,
	dek,
	author,
	date,
	readingTime,
	cover,
} = Astro.props as Props;
---

<article class="featured-article">
	<a class="featured-article__link" href={href}>
		{cover && (
			<div class="featured-article__media">
				<Image
					src={cover.image}
					alt={cover.alt}
					class="featured-article__image"
					widths={[480, 720, 960, 1280]}
					sizes="(max-width: 880px) 100vw, 42vw"
					loading="eager"
				/>
			</div>
		)}

		<div class="featured-article__main">
			<MLabel tone="spruce">
				<span class="featured-article__dot" aria-hidden="true"></span>
				Featured · Dispatch №{dispatchNum}
			</MLabel>

			<h1 class="featured-article__title">{title}</h1>
			<p class="featured-article__dek">{dek}</p>

			<div class="featured-article__meta">
				<span>{kicker}</span>
				<span aria-hidden="true">·</span>
				<span>{readingTime}</span>
				<span aria-hidden="true">·</span>
				<span>{date}</span>
				{author && <span class="featured-article__author">By {author}</span>}
			</div>

			<span class="featured-article__cta">Read feature</span>
		</div>
	</a>
</article>

<style>
	.featured-article {
		padding: clamp(1.5rem, 4vw, 3rem) 2.5rem;
		border-bottom: 1px solid var(--editorial-hairline);
	}

	.featured-article__link {
		display: grid;
		grid-template-columns: minmax(17rem, 0.88fr) minmax(0, 1.12fr);
		gap: clamp(1.5rem, 4vw, 4rem);
		align-items: center;
		text-decoration: none;
		color: inherit;
	}

	.featured-article__main {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.featured-article__media {
		position: relative;
		overflow: hidden;
		aspect-ratio: 16 / 10;
		border: 1px solid var(--editorial-hairline);
		background: var(--editorial-paper-deep);
	}

	.featured-article__image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 420ms var(--ease-standard);
	}

	.featured-article__link:hover .featured-article__image {
		transform: scale(1.025);
	}

	.featured-article__dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--editorial-spruce);
	}

	.featured-article__title {
		font-family: var(--font-instrument-serif), serif;
		font-style: italic;
		font-weight: 400;
		font-size: clamp(2.5rem, 5.5vw, 5rem);
		line-height: 0.92;
		letter-spacing: -0.025em;
		color: var(--editorial-ink);
		margin: 0;
		text-wrap: balance;
	}

	.featured-article__dek {
		font-family: var(--font-inter-tight), sans-serif;
		font-size: clamp(1rem, 1.5vw, 1.1875rem);
		line-height: 1.45;
		color: var(--editorial-ink-soft);
		margin: 0;
		max-width: 42rem;
		text-wrap: pretty;
	}

	.featured-article__meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		align-items: center;
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 0.6875rem;
		font-weight: 500;
		letter-spacing: 0.1em;
		line-height: 1.4;
		text-transform: uppercase;
		color: var(--editorial-ink-soft);
		margin-top: 0.25rem;
	}

	.featured-article__meta span:first-child {
		color: var(--editorial-spruce);
	}

	.featured-article__author {
		width: 100%;
		color: var(--editorial-ink-mute);
	}

	.featured-article__cta {
		align-self: flex-start;
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 0.6875rem;
		font-weight: 600;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--editorial-ink);
		border-bottom: 1px solid currentColor;
		padding-bottom: 0.125rem;
	}

	@media (max-width: 880px) {
		.featured-article {
			padding: 1.25rem;
		}
		.featured-article__link {
			grid-template-columns: 1fr;
			gap: 1rem;
		}
		.featured-article__media {
			aspect-ratio: 16 / 8.5;
		}
		.featured-article__title {
			font-size: clamp(2rem, 10vw, 3rem);
			line-height: 0.96;
		}
		.featured-article__dek {
			display: -webkit-box;
			-webkit-line-clamp: 2;
			-webkit-box-orient: vertical;
			overflow: hidden;
		}
		.featured-article__main {
			gap: 0.875rem;
		}
		.featured-article__author,
		.featured-article__cta {
			display: none;
		}
	}

	@media (max-width: 420px) {
		.featured-article {
			padding: 1rem;
		}
		.featured-article__media {
			aspect-ratio: 16 / 7.5;
		}
		.featured-article__meta {
			font-size: 0.625rem;
			letter-spacing: 0.08em;
		}
	}
</style>
