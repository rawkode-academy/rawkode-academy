---
interface Props {
	cite?: string;
}

const { cite } = Astro.props as Props;
---

<blockquote class="article-pullquote" cite={cite}>
	<p class="article-pullquote__body"><slot /></p>
</blockquote>

<style>
	.article-pullquote {
		margin: 2.25rem 0;
		padding: 1.5rem 1.75rem;
		border-left: 2px solid var(--editorial-spruce);
		background: var(--editorial-paper-deep);
	}

	.article-pullquote__body {
		font-family: var(--font-instrument-serif), serif;
		font-style: italic;
		font-size: 1.625rem;
		line-height: 1.3;
		color: var(--editorial-ink);
		margin: 0;
		text-wrap: pretty;
	}
</style>
