---
import { Image } from "astro:assets";

interface Props {
	href: string;
	dispatchNum: number | string;
	kicker: string;
	title: string;
	dek: string;
	author?: string | undefined;
	date: string;
	readingTime: string;
	cover?:
		| {
				image: ImageMetadata;
				alt: string;
		  }
		| undefined;
}

const {
	href,
	dispatchNum,
	kicker,
	title,
	dek,
	author,
	date,
	readingTime,
	cover,
} = Astro.props as Props;
---

<a class="article-grid-item" href={href}>
	<div class={`article-grid-item__media ${cover ? "" : "article-grid-item__media--placeholder"}`}>
		{cover ? (
			<Image
				src={cover.image}
				alt={cover.alt}
				class="article-grid-item__image"
				widths={[160, 240, 320, 480]}
				sizes="(max-width: 640px) 5rem, 9rem"
				loading="lazy"
			/>
		) : (
			<span>№{dispatchNum}</span>
		)}
	</div>

	<div class="article-grid-item__body">
		<div class="article-grid-item__meta">
			<span class="article-grid-item__type">{kicker}</span>
			<span aria-hidden="true">·</span>
			<span>{readingTime}</span>
			<span aria-hidden="true">·</span>
			<span>{date}</span>
			{author && <span class="article-grid-item__author">By {author}</span>}
		</div>

		<h2 class="article-grid-item__title">{title}</h2>
		<p class="article-grid-item__dek">{dek}</p>
	</div>

	<span class="article-grid-item__number" aria-hidden="true">№{dispatchNum}</span>
</a>

<style>
	.article-grid-item {
		display: grid;
		grid-template-columns: 9rem minmax(0, 1fr);
		gap: 1rem;
		padding: 1.25rem 1.25rem 1.25rem 0;
		border-top: 1px solid var(--editorial-hairline);
		text-decoration: none;
		color: inherit;
		position: relative;
		transition: background-color var(--duration-base) var(--ease-standard);
	}

	.article-grid-item:hover {
		background: var(--surface-card-muted);
	}

	.article-grid-item__media {
		aspect-ratio: 4 / 3;
		overflow: hidden;
		background: var(--editorial-paper-deep);
		border: 1px solid var(--editorial-hairline);
		align-self: start;
	}

	.article-grid-item__media--placeholder {
		display: grid;
		place-items: center;
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 0.6875rem;
		font-weight: 600;
		letter-spacing: 0.12em;
		color: var(--editorial-ink-mute);
	}

	.article-grid-item__image {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 360ms var(--ease-standard);
	}

	.article-grid-item:hover .article-grid-item__image {
		transform: scale(1.035);
	}

	.article-grid-item__body {
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.article-grid-item__meta {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.375rem;
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 0.625rem;
		font-weight: 500;
		letter-spacing: 0.08em;
		line-height: 1.35;
		text-transform: uppercase;
		color: var(--editorial-ink-mute);
	}

	.article-grid-item__type {
		color: var(--editorial-spruce);
	}

	.article-grid-item__author {
		color: var(--editorial-ink-soft);
	}

	.article-grid-item__title {
		font-family: var(--font-inter-tight), sans-serif;
		font-weight: 650;
		font-size: clamp(1.05rem, 1.55vw, 1.35rem);
		line-height: 1.1;
		letter-spacing: 0;
		color: var(--editorial-ink);
		margin: 0;
		text-wrap: balance;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.article-grid-item__dek {
		font-family: var(--font-inter-tight), sans-serif;
		font-size: 0.875rem;
		line-height: 1.42;
		color: var(--editorial-ink-soft);
		margin: 0;
		text-wrap: pretty;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.article-grid-item__number {
		position: absolute;
		right: 1rem;
		bottom: 1rem;
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 0.625rem;
		font-weight: 600;
		letter-spacing: 0.12em;
		color: var(--editorial-hairline-strong);
	}

	@media (max-width: 960px) {
		.article-grid-item {
			padding-right: 0;
		}
	}

	@media (max-width: 640px) {
		.article-grid-item {
			grid-template-columns: 5rem minmax(0, 1fr);
			gap: 0.875rem;
			padding: 1rem 0;
		}
		.article-grid-item__media {
			aspect-ratio: 1 / 1;
		}
		.article-grid-item__meta {
			font-size: 0.5625rem;
			letter-spacing: 0.06em;
		}
		.article-grid-item__author,
		.article-grid-item__number,
		.article-grid-item__dek {
			display: none;
		}
		.article-grid-item__title {
			font-size: 1rem;
			line-height: 1.12;
			-webkit-line-clamp: 3;
		}
	}
</style>
