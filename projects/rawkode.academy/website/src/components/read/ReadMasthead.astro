---
interface Props {
	issueNum: number | string;
	shownCount: number;
	totalCount: number;
}

const { issueNum, shownCount, totalCount } = Astro.props as Props;
---

<div class="read-masthead">
	<span class="read-masthead__left">The Reading Room · est. 2019</span>
	<span class="read-masthead__center">
		Field Notes <span class="read-masthead__center-muted">— from the platform team</span>
	</span>
	<span class="read-masthead__right">
		Issue {issueNum} · {shownCount} of {totalCount} dispatches
	</span>
</div>

<style>
	.read-masthead {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: baseline;
		gap: 2rem;
		padding: 1.25rem 2.5rem;
		border-bottom: 2px solid var(--editorial-ink);
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 0.6875rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.read-masthead__left {
		color: var(--editorial-ink-soft);
	}

	.read-masthead__center {
		font-family: var(--font-instrument-serif), serif;
		font-style: italic;
		font-weight: 400;
		font-size: 1.5rem;
		letter-spacing: -0.015em;
		text-transform: none;
		color: var(--editorial-ink);
		text-align: center;
	}

	.read-masthead__center-muted {
		color: var(--editorial-ink-mute);
	}

	.read-masthead__right {
		color: var(--editorial-ink-soft);
		text-align: right;
	}

	@media (max-width: 880px) {
		.read-masthead {
			grid-template-columns: 1fr;
			gap: 0.5rem;
			padding: 1rem 1.25rem;
			text-align: center;
		}
		.read-masthead__left,
		.read-masthead__right {
			text-align: center;
		}
	}
</style>
