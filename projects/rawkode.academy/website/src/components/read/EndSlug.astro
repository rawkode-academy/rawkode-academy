---
import MLabel from "@/components/ui/MLabel.vue";

interface Props {
	dispatchNum: number | string;
	date: string;
	discussHref?: string;
}

const {
	dispatchNum,
	date,
	discussHref = "https://discord.gg/rawkode",
} = Astro.props as Props;
---

<div class="end-slug">
	<MLabel>· Fin · Dispatch №{dispatchNum} · {date} ·</MLabel>
	<a class="end-slug__discuss" href={discussHref} target="_blank" rel="noopener noreferrer">
		<MLabel tone="ink">Discuss in the Discord →</MLabel>
	</a>
</div>

<style>
	.end-slug {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		margin-top: 3.5rem;
		padding-top: 1.75rem;
		border-top: 1px solid var(--editorial-ink);
	}

	.end-slug__discuss {
		text-decoration: none;
	}

	@media (max-width: 640px) {
		.end-slug {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.75rem;
		}
	}
</style>
