---
export interface Props {
	href?: string;
	text?: string;
}

const { href = "#main-content", text = "Skip to main content" } = Astro.props;
---

<a class="skip-link" {href}>{text}</a>

<style>
	.skip-link {
		position: absolute;
		top: -100px;
		left: 1rem;
		z-index: 100;
		display: inline-flex;
		align-items: center;
		padding: 0.5rem 1rem;
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--colors-fg-on-brand);
		background: var(--colors-bg-brand);
		border-radius: var(--radii-md);
		text-decoration: none;
		transition: top 0.15s ease;
	}
	.skip-link:focus,
	.skip-link:focus-visible {
		top: 1rem;
		outline: 2px solid var(--colors-border-focus);
		outline-offset: 2px;
	}
</style>
