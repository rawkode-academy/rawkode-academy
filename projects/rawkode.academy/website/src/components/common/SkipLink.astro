---
import { css } from "styled-system/css";

export interface Props {
	href?: string;
	text?: string;
}

const { href = "#main-content", text = "Skip to main content" } = Astro.props;

const skipLinkClass = css({
	srOnly: true,
	_focus: {
		srOnly: false,
		position: "absolute",
		top: "4",
		left: "4",
		zIndex: 50,
		px: "4",
		py: "2",
		backgroundImage:
			"linear-gradient(135deg, rgb(var(--brand-primary)) 0%, rgb(var(--brand-secondary)) 100%)",
		color: "brandAccent.contrast",
		borderRadius: "md",
		outline: "none",
		ringWidth: "2px",
		ringOffset: "2px",
		ringColor: "brandAccent.ring",
	},
});
---

<a
	href={href}
	class={skipLinkClass}
>
	{text}
</a>

<style>
	a:focus {
		clip: auto;
		clip-path: none;
		height: auto;
		width: auto;
		margin: 0;
		overflow: visible;
		position: absolute;
		white-space: nowrap;
	}
</style>
