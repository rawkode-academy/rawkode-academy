---
import { Image } from "astro:assets";
import { css, cx } from "../../../styled-system/css";
import { getTypeBadgeConfig } from "@/utils/article-types";

interface Props {
	type: "article" | "video";
	title: string;
	description?: string | undefined;
	thumbnailUrl: string;
	thumbnailAlt: string;
	author?: string | undefined;
	date: string;
	duration?: string | undefined;
	readTime?: string | undefined;
	href: string;
	ctaText: string;
	articleType?:
		| "tutorial"
		| "article"
		| "guide"
		| "news"
		| "architecture"
		| "tools"
		| "practices"
		| "features"
		| "case-study"
		| "editorial";
	class?: string;
}

const {
	type,
	title,
	description,
	thumbnailUrl,
	thumbnailAlt,
	author,
	date,
	duration,
	href,
	ctaText,
	articleType,
} = Astro.props;

const sectionClass = Astro.props.class ?? "";

const badgeConfig = articleType && getTypeBadgeConfig(articleType);

function formatDate(dateString: string): string {
	return new Date(dateString).toLocaleDateString("en-US", {
		year: "numeric",
		month: "short",
		day: "numeric",
	});
}

function formatDuration(seconds: string | undefined): string | undefined {
	if (!seconds) return undefined;
	const totalSeconds = parseInt(seconds);
	if (isNaN(totalSeconds)) return seconds;

	const hours = Math.floor(totalSeconds / 3600);
	const minutes = Math.floor((totalSeconds % 3600) / 60);
	const remainingSeconds = totalSeconds % 60;

	if (hours > 0) {
		return `${hours}:${minutes.toString().padStart(2, "0")}:${remainingSeconds.toString().padStart(2, "0")}`;
	} else {
		return `${minutes}:${remainingSeconds.toString().padStart(2, "0")}`;
	}
}

function truncateDescription(
	text: string | undefined,
	maxLength = 150,
): string | undefined {
	if (!text) return undefined;
	if (text.length <= maxLength) return text;
	return `${text.substring(0, maxLength).trim()}...`;
}

const displayDate = formatDate(date);
const isVideo = type === "video";
const formattedDuration = formatDuration(duration);
const truncatedDescription = truncateDescription(
	description,
	isVideo ? 120 : 160,
);

/* ---- Panda styles ---- */

const mobileLink = css({ display: { base: "block", lg: "none" } });
const desktopLink = css({ display: { base: "none", lg: "block" } });

const mobileCard = css({
	overflow: "hidden",
	borderRadius: "2xl",
});

const imageSection = css({
	position: "relative",
	aspectRatio: "16/9",
	overflow: "hidden",
});

const imgFull = css({
	width: "full",
	height: "full",
	objectFit: "cover",
	transition: "transform",
	transitionDuration: "500ms",
});

const gradientOverlay = css({
	position: "absolute",
	inset: "0",
	backgroundImage: {
		base: "linear-gradient(to top, rgba(0,0,0,0.6), transparent, transparent)",
		_dark: "linear-gradient(to top, rgba(0,0,0,0.8), transparent, transparent)",
	},
});

const badgePos = css({
	position: "absolute",
	top: "3",
	left: "3",
});

const badgeStyle = css({
	fontSize: "xs",
	fontWeight: "semibold",
	px: "2.5",
	py: "1",
	borderRadius: "full",
	backdropFilter: "blur(4px)",
	shadow: "lg",
});

const durationBadge = css({
	position: "absolute",
	top: "3",
	right: "3",
	bg: "rgba(0,0,0,0.7)",
	backdropFilter: "blur(12px)",
	color: "white",
	px: "2.5",
	py: "1",
	borderRadius: "lg",
	fontSize: "xs",
	fontWeight: "semibold",
});

const contentSection = css({
	position: "relative",
	p: "5",
	display: "flex",
	flexDirection: "column",
	gap: "4",
});

const accentLine = css({
	position: "absolute",
	top: "0",
	left: "5",
	right: "5",
	height: "1px",
	backgroundImage: "linear-gradient(to right, rgb(var(--brand-primary)), rgb(var(--brand-secondary)), rgb(var(--brand-primary)))",
	opacity: 0.5,
});

const featuredLabel = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "1.5",
	fontSize: "0.6rem",
	textTransform: "uppercase",
	letterSpacing: "0.2em",
	color: "colorPalette.default",
	fontWeight: "semibold",
});

const titleStyle = css({
	fontSize: "xl",
	fontWeight: "bold",
	color: "fg.default",
	lineHeight: "tight",
	letterSpacing: "tight",
});

const descStyle = css({
	color: "fg.muted",
	fontSize: "sm",
	lineHeight: "relaxed",
	display: "-webkit-box",
	WebkitLineClamp: "2",
	WebkitBoxOrient: "vertical",
	overflow: "hidden",
});

const metaRow = css({
	display: "flex",
	alignItems: "center",
	gap: "4",
	fontSize: "xs",
	color: "fg.subtle",
	pt: "1",
});

const authorAvatar = css({
	width: "6",
	height: "6",
	borderRadius: "full",
	backgroundImage: "linear-gradient(to bottom right, rgb(var(--brand-primary)), rgb(var(--brand-secondary)))",
	display: "flex",
	alignItems: "center",
	justifyContent: "center",
	color: "white",
	fontSize: "0.6rem",
	fontWeight: "bold",
});

const ctaBtn = css({
	display: "inline-flex",
	alignItems: "center",
	justifyContent: "center",
	gap: "2",
	width: "full",
	px: "5",
	py: "3",
	bg: "colorPalette.default",
	color: "white",
	fontSize: "sm",
	fontWeight: "semibold",
	borderRadius: "xl",
	shadow: "lg",
	_active: { transform: "scale(0.98)" },
	transition: "transform",
	transitionDuration: "200ms",
});

/* Desktop styles */
const desktopCard = css({
	display: "flex",
	borderRadius: "2rem",
	overflow: "hidden",
	minHeight: { base: "400px", xl: "450px" },
});

const leftPanel = css({
	position: "relative",
	display: "flex",
	flexDirection: "column",
	justifyContent: "center",
	p: { base: "8", xl: "12" },
	bg: "surface.card/50",
	width: { base: "40%", xl: "35%" },
	flexShrink: 0,
});

const accentBar = css({
	position: "absolute",
	top: "0",
	left: "0",
	width: "1",
	height: "full",
	backgroundImage: "linear-gradient(to bottom, rgb(var(--brand-primary)), rgb(var(--brand-secondary)), rgb(var(--brand-primary) / 0.5))",
});

const dotsGrid = css({
	position: "absolute",
	top: "8",
	right: "8",
	display: "grid",
	gridTemplateColumns: "repeat(3, 1fr)",
	gap: "1.5",
	opacity: 0.2,
});

const dotStyle = css({
	width: "1.5",
	height: "1.5",
	borderRadius: "full",
	bg: "currentColor",
	color: "fg.default",
});

const leftContent = css({
	position: "relative",
	zIndex: 10,
	display: "flex",
	flexDirection: "column",
	gap: "5",
});

const desktopTitle = css({
	fontSize: { base: "xl", xl: "2xl", "2xl": "3xl" },
	fontWeight: "bold",
	color: "fg.default",
	lineHeight: "tight",
	letterSpacing: "tight",
});

const desktopDesc = css({
	color: "fg.muted",
	fontSize: { base: "sm", xl: "base" },
	lineHeight: "relaxed",
	display: "-webkit-box",
	WebkitLineClamp: "2",
	WebkitBoxOrient: "vertical",
	overflow: "hidden",
});

const dividerLine = css({
	width: "12",
	height: "0.5",
	backgroundImage: "linear-gradient(to right, rgb(var(--brand-primary)), rgb(var(--brand-secondary)))",
	borderRadius: "full",
});

const desktopMeta = css({
	display: "flex",
	flexWrap: "wrap",
	alignItems: "center",
	gap: "4",
	fontSize: "sm",
	color: "fg.subtle",
});

const desktopAuthorAvatar = css({
	width: "7",
	height: "7",
	borderRadius: "full",
	backgroundImage: "linear-gradient(to bottom right, rgb(var(--brand-primary)), rgb(var(--brand-secondary)))",
	display: "flex",
	alignItems: "center",
	justifyContent: "center",
	color: "white",
	fontSize: "xs",
	fontWeight: "bold",
	ringWidth: "2px",
	ringColor: "surface.card",
});

const desktopCta = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "2",
	px: "5",
	py: "2.5",
	bg: "colorPalette.default",
	color: "white",
	fontSize: "sm",
	fontWeight: "semibold",
	borderRadius: "xl",
	transition: "all",
	transitionDuration: "300ms",
	shadow: "lg",
});

const rightPanel = css({
	position: "relative",
	flex: "1",
	overflow: "hidden",
});

const rightImg = css({
	position: "absolute",
	inset: "0",
	width: "full",
	height: "full",
	objectFit: "cover",
	transition: "transform",
	transitionDuration: "700ms",
	transitionTimingFunction: "ease-out",
});

const rightOverlay = css({
	position: "absolute",
	inset: "0",
	transition: "colors",
	transitionDuration: "500ms",
});

const desktopDuration = css({
	position: "absolute",
	top: "4",
	right: "4",
	bg: "rgba(0,0,0,0.7)",
	backdropFilter: "blur(12px)",
	color: "white",
	px: "3",
	py: "1.5",
	borderRadius: "lg",
	fontSize: "sm",
	fontWeight: "semibold",
	letterSpacing: "wide",
	border: "1px solid",
	borderColor: "rgba(255,255,255,0.1)",
});
---

<section class={`section-py-tight ${sectionClass}`.trim()}>
	<!-- Mobile/Tablet layout -->
	<a href={href} class={cx(mobileLink, "group")}>
		<div class={cx("glass-card-shimmer", mobileCard)}>
			<!-- Image section -->
			<div class={imageSection}>
				{typeof thumbnailUrl === "string" ? (
					<img
						src={thumbnailUrl}
						alt={thumbnailAlt}
						class={cx(imgFull, "group-active:scale-105")}
					/>
				) : (
					<Image
						src={thumbnailUrl}
						alt={thumbnailAlt}
						class={cx(imgFull, "group-active:scale-105")}
					/>
				)}

				<!-- Gradient overlay -->
				<div class={gradientOverlay}></div>

				<!-- Badge -->
				{type === "article" && badgeConfig && (
					<div class={badgePos}>
						<span class={cx(badgeStyle, badgeConfig.bg, badgeConfig.text)}>
							{badgeConfig.label}
						</span>
					</div>
				)}

				<!-- Duration for videos -->
				{formattedDuration && (
					<div class={durationBadge}>
						{formattedDuration}
					</div>
				)}
			</div>

			<!-- Content section -->
			<div class={contentSection}>
				<!-- Accent line -->
				<div class={accentLine}></div>

				<!-- Featured label -->
				<div class={css({ display: 'flex', alignItems: 'center', gap: '2' })}>
					<span class={featuredLabel}>
						<svg class={css({ width: '3', height: '3' })} fill="currentColor" viewBox="0 0 24 24">
							<path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" />
						</svg>
						Featured
					</span>
				</div>

				<!-- Title -->
				<h2 class={titleStyle}>
					{title}
				</h2>

				<!-- Description -->
				{truncatedDescription && (
					<p class={descStyle}>
						{truncatedDescription}
					</p>
				)}

				<!-- Meta row -->
				<div class={metaRow}>
					{author && (
						<div class={css({ display: 'flex', alignItems: 'center', gap: '2' })}>
							<div class={authorAvatar}>
								{author.charAt(0)}
							</div>
							<span class={css({ color: 'fg.default', fontWeight: 'medium' })}>{author}</span>
						</div>
					)}
					<div class={css({ display: 'flex', alignItems: 'center', gap: '1.5', color: 'fg.subtle' })}>
						<svg class={css({ width: '3.5', height: '3.5' })} fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
						</svg>
						<span>{displayDate}</span>
					</div>
				</div>

				<!-- CTA Button -->
				<div class={css({ pt: '2' })}>
					<span class={ctaBtn}>
						{isVideo ? (
							<svg class={css({ width: '4', height: '4' })} fill="currentColor" viewBox="0 0 24 24">
								<path d="M8 5v14l11-7z" />
							</svg>
						) : (
							<svg class={css({ width: '4', height: '4' })} fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
							</svg>
						)}
						{ctaText}
						<svg class={css({ width: '4', height: '4' })} fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
						</svg>
					</span>
				</div>
			</div>
		</div>
	</a>

	<!-- Desktop layout -->
	<a href={href} class={cx(desktopLink, "group")}>
		<div class={cx("glass-card-shimmer", desktopCard)}>

			<!-- Left: Content Panel -->
			<div class={leftPanel}>
				<!-- Decorative accent line -->
				<div class={accentBar}></div>

				<!-- Decorative dots pattern -->
				<div class={dotsGrid}>
					<div class={dotStyle}></div>
					<div class={dotStyle}></div>
					<div class={dotStyle}></div>
					<div class={dotStyle}></div>
					<div class={dotStyle}></div>
					<div class={dotStyle}></div>
					<div class={dotStyle}></div>
					<div class={dotStyle}></div>
					<div class={dotStyle}></div>
				</div>

				<!-- Content -->
				<div class={leftContent}>
					<!-- Featured label + Badge -->
					<div class={css({ display: 'flex', alignItems: 'center', gap: '3', flexWrap: 'wrap' })}>
						<span class={cx(featuredLabel, css({ fontSize: 'xs', letterSpacing: '0.2em' }))}>
							<svg class={css({ width: '4', height: '4' })} fill="currentColor" viewBox="0 0 24 24">
								<path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" />
							</svg>
							Featured
						</span>
						{type === "article" && badgeConfig && (
							<span class={cx(badgeStyle, badgeConfig.bg, badgeConfig.text)}>
								{badgeConfig.label}
							</span>
						)}
					</div>

					<!-- Title -->
					<h1 class={desktopTitle}>
						{title}
					</h1>

					<!-- Description -->
					{truncatedDescription && (
						<p class={desktopDesc}>
							{truncatedDescription}
						</p>
					)}

					<!-- Divider -->
					<div class={dividerLine}></div>

					<!-- Meta info -->
					<div class={desktopMeta}>
						{author && (
							<div class={css({ display: 'flex', alignItems: 'center', gap: '2' })}>
								<div class={desktopAuthorAvatar}>
									{author.charAt(0)}
								</div>
								<span class={css({ fontWeight: 'medium', color: 'fg.default' })}>{author}</span>
							</div>
						)}
						<div class={css({ display: 'flex', alignItems: 'center', gap: '1.5', color: 'fg.subtle' })}>
							<svg class={css({ width: '4', height: '4' })} fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
							</svg>
							<span>{displayDate}</span>
						</div>
					</div>

					<!-- CTA Button -->
					<div class={css({ pt: '1' })}>
						<span class={cx(desktopCta, "group-hover:shadow-xl group-hover:translate-x-1")}>
							{isVideo ? (
								<svg class={css({ width: '4', height: '4' })} fill="currentColor" viewBox="0 0 24 24">
									<path d="M8 5v14l11-7z" />
								</svg>
							) : (
								<svg class={css({ width: '4', height: '4' })} fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
								</svg>
							)}
							{ctaText}
							<svg class={cx(css({ width: '4', height: '4', transition: 'transform', transitionDuration: '300ms' }), "group-hover:translate-x-1")} fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
							</svg>
						</span>
					</div>
				</div>
			</div>

			<!-- Right: Image Panel -->
			<div class={rightPanel}>
				{typeof thumbnailUrl === "string" ? (
					<img
						src={thumbnailUrl}
						alt={thumbnailAlt}
						class={cx(rightImg, "group-hover:scale-105")}
					/>
				) : (
					<Image
						src={thumbnailUrl}
						alt={thumbnailAlt}
						class={cx(rightImg, "group-hover:scale-105")}
					/>
				)}

				<!-- Subtle overlay on hover -->
				<div class={rightOverlay}></div>

				<!-- Duration badge for videos -->
				{formattedDuration && (
					<div class={desktopDuration}>
						{formattedDuration}
					</div>
				)}
			</div>
		</div>
	</a>
</section>
