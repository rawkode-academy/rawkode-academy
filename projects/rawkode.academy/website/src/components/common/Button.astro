---
import { css, cx } from "styled-system/css";

type Props = {
	variant?: "primary" | "secondary" | "ghost" | "danger";
	size?: "sm" | "md" | "lg";
	href?: string;
	type?: "button" | "submit" | "reset";
	class?: string;
	disabled?: boolean;
	fullWidth?: boolean;
};

const {
	variant = "primary",
	size = "md",
	href,
	type = "button",
	class: className = "",
	disabled = false,
	fullWidth = false,
} = Astro.props;

const variantStyles: Record<string, Record<string, any>> = {
	primary: {
		color: "brandAccent.contrast",
		backgroundImage:
			"linear-gradient(135deg, rgb(var(--brand-primary)) 0%, rgb(var(--brand-secondary)) 100%)",
		border: "1px solid",
		borderColor: "brandAccent.border",
		_hover: { filter: "brightness(1.05)" },
		_focus: { ringWidth: "4px", ringColor: "brandAccent.ring" },
	},
	secondary: {
		color: { base: "gray.900", _dark: "white" },
		bg: { base: "white", _dark: "gray.800" },
		border: "1px solid",
		borderColor: { base: "gray.300", _dark: "gray.600" },
		_hover: {
			bg: { base: "gray.100", _dark: "gray.700" },
		},
		_focus: {
			ringWidth: "4px",
			ringColor: { base: "gray.200", _dark: "gray.700" },
		},
	},
	ghost: {
		color: { base: "gray.700", _dark: "gray.300" },
		_hover: {
			color: { base: "gray.900", _dark: "white" },
			bg: { base: "gray.100", _dark: "gray.700" },
		},
		_focus: {
			ringWidth: "4px",
			ringColor: { base: "gray.200", _dark: "gray.700" },
		},
	},
	danger: {
		color: "white",
		bg: { base: "red.600", _dark: "red.500" },
		_hover: { bg: { base: "red.700", _dark: "red.600" } },
		_focus: { ringWidth: "4px", ringColor: { base: "red.300", _dark: "red.800" } },
	},
};

const sizeStyles: Record<string, Record<string, any>> = {
	sm: { fontSize: "sm", px: "3", py: "2" },
	md: { fontSize: "base", px: "5", py: "2.5" },
	lg: { fontSize: "lg", px: "6", py: "3" },
};

const classes = cx(
	css({
		display: "inline-flex",
		alignItems: "center",
		justifyContent: "center",
		fontWeight: "medium",
		borderRadius: "lg",
		transition: "all",
		transitionDuration: "200ms",
		outline: "none",
		...sizeStyles[size],
		...variantStyles[variant],
		...(disabled ? { opacity: 0.5, cursor: "not-allowed" } : {}),
		...(fullWidth ? { width: "full" } : {}),
	}),
	className,
);

const Tag = href ? "a" : "button";
const props = href
	? { href, class: classes }
	: { type, disabled, class: classes };
---

<Tag {...props}>
	<slot name="icon-left" />
	<slot />
	<slot name="icon-right" />
</Tag>
