---
import { css } from "../../../styled-system/css";
import { getCollection } from "astro:content";
import ArticleCard from "@/components/articles/ArticleCard.astro";
import SectionHeader from "@/components/common/SectionHeader.vue";

export interface Props {
	technologyId: string;
	technologyName: string;
	videos: Array<{
		id: string;
		title: string;
		thumbnailUrl: string;
		slug: string;
	}>;
}

const { technologyId, technologyName, videos = [] } = Astro.props;

// Get all articles that mention this technology
const allArticles = await getCollection("articles", ({ data }) => {
	return !data.draft && data.technologies?.includes(technologyId);
});

// Sort articles by date
const articles = allArticles.sort(
	(a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);
---

<div class={css({ display: "flex", flexDirection: "column", gap: "3rem" })}>
  <!-- Articles Section -->
  {articles.length > 0 && (
    <section>
      <SectionHeader
        title={`Articles about ${technologyName}`}
        showSeparator={false}
        class={css({ marginBottom: "1.5rem" })}
      />
      <div class={css({ display: "grid", gap: "1.5rem", gridTemplateColumns: { base: "1", md: "2", lg: "3" } })}>
        {articles.map((article) => (
          <ArticleCard article={article} />
        ))}
      </div>
    </section>
  )}

  <!-- Videos Section -->
  {videos.length > 0 && (
    <section>
      <SectionHeader
        title={`Videos about ${technologyName}`}
        showSeparator={false}
        class={css({ marginBottom: "1.5rem" })}
      />
      <div class={css({ display: "grid", gap: "1.5rem", gridTemplateColumns: { base: "1", md: "2", lg: "3" } })}>
        {videos.map((video) => (
          <a
            href={`/watch/${video.slug}`}
            class={css({ position: "relative", display: "block", overflow: "hidden", borderRadius: "lg", aspectRatio: "16/9", backgroundColor: { base: "gray.100", _dark: "gray.800" }, "& img": { transition: "transform 0.3s ease" }, _hover: { "& img": { transform: "scale(1.05)" }, "& .video-overlay": { opacity: "1" }, "& .video-info": { transform: "translateY(0)" } } })}
          >
            <img
              src={video.thumbnailUrl}
              alt={video.title}
              class={css({ width: "100%", height: "100%", objectFit: "cover" })}
              loading="lazy"
            />
            <div class={css({ position: "absolute", inset: "0", background: "linear-gradient(to top, rgba(0,0,0,0.7), transparent)", opacity: "0", transition: "opacity 0.3s ease" })} />
            <div class={css({ position: "absolute", bottom: "0", left: "0", right: "0", padding: "1rem", color: "white", transform: "translateY(100%)", transition: "transform 0.3s ease" })}>
              <h3 class={css({ fontWeight: "600", lineClamp: "2" })}>{video.title}</h3>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Empty State -->
  {articles.length === 0 && videos.length === 0 && (
    <div class={css({ textAlign: "center", paddingBlock: "3rem" })}>
      <p class={css({ color: { base: "gray.500", _dark: "gray.400" } })}>
        No content found for {technologyName} yet. Check back soon!
      </p>
    </div>
  )}
</div>
