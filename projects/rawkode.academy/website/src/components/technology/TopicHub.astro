---
import { css } from "../../../styled-system/css";
import { getCollection } from "astro:content";
import ArticleCard from "@/components/articles/ArticleCard.astro";
import SectionHeader from "@/components/common/SectionHeader.vue";

export interface Props {
	technologyId: string;
	technologyName: string;
	videos: Array<{
		id: string;
		title: string;
		thumbnailUrl: string;
		slug: string;
	}>;
}

const { technologyId, technologyName, videos = [] } = Astro.props;

// Get all articles that mention this technology
const allArticles = await getCollection("articles", ({ data }) => {
	return !data.draft && data.technologies?.includes(technologyId);
});

// Sort articles by date
const articles = allArticles.sort(
	(a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);
---

<div class={css({ display: 'flex', flexDirection: 'column', gap: '12' })}>
  <!-- Articles Section -->
  {articles.length > 0 && (
    <section>
      <SectionHeader
        title={`Articles about ${technologyName}`}
        showSeparator={false}
        class={css({ mb: '6' })}
      />
      <div class={css({ display: 'grid', gap: '6', md: { gridTemplateColumns: '2' }, lg: { gridTemplateColumns: '3' } })}>
        {articles.map((article) => (
          <ArticleCard article={article} />
        ))}
      </div>
    </section>
  )}

  <!-- Videos Section -->
  {videos.length > 0 && (
    <section>
      <SectionHeader
        title={`Videos about ${technologyName}`}
        showSeparator={false}
        class={css({ mb: '6' })}
      />
      <div class={css({ display: 'grid', gap: '6', md: { gridTemplateColumns: '2' }, lg: { gridTemplateColumns: '3' } })}>
        {videos.map((video) => (
          <a
            href={`/watch/${video.slug}`}
            class={css({
              position: 'relative',
              display: 'block',
              overflow: 'hidden',
              borderRadius: 'lg',
              bg: { base: 'gray.100', _dark: 'gray.800' },
              aspectRatio: '16/9',
              '& img': {
                transition: 'transform',
                transitionDuration: '300ms',
              },
              _hover: {
                '& img': {
                  transform: 'scale(1.05)',
                },
                '& .video-overlay': {
                  opacity: '1',
                },
                '& .video-title-bar': {
                  transform: 'translateY(0)',
                },
              },
            })}
          >
            <img
              src={video.thumbnailUrl}
              alt={video.title}
              class={css({ w: 'full', h: 'full', objectFit: 'cover' })}
              loading="lazy"
            />
            <div class:list={["video-overlay", css({ position: 'absolute', inset: '0', backgroundImage: 'linear-gradient(to top, rgba(0,0,0,0.7), transparent)', opacity: '0', transition: 'opacity', transitionDuration: '300ms' })]} />
            <div class:list={["video-title-bar", css({ position: 'absolute', bottom: '0', left: '0', right: '0', p: '4', color: 'white', transform: 'translateY(100%)', transition: 'transform', transitionDuration: '300ms' })]}>
              <h3 class={css({ fontWeight: 'semibold', lineClamp: '2' })}>{video.title}</h3>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Empty State -->
  {articles.length === 0 && videos.length === 0 && (
    <div class={css({ textAlign: 'center', py: '12' })}>
      <p class={css({ color: { base: 'gray.500', _dark: 'gray.400' } })}>
        No content found for {technologyName} yet. Check back soon!
      </p>
    </div>
  )}
</div>
