---
import { css, cx } from "styled-system/css";
import { getCollection } from "astro:content";
import ArticleCard from "@/components/articles/ArticleCard.astro";
import SectionHeader from "@/components/common/SectionHeader.vue";

export interface Props {
	technologyId: string;
	technologyName: string;
	videos: Array<{
		id: string;
		title: string;
		thumbnailUrl: string;
		slug: string;
	}>;
}

const { technologyId, technologyName, videos = [] } = Astro.props;

// Get all articles that mention this technology
const allArticles = await getCollection("articles", ({ data }) => {
	return !data.draft && data.technologies?.includes(technologyId);
});

// Sort articles by date
const articles = allArticles.sort(
	(a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);

const wrapperStyle = css({ display: 'flex', flexDirection: 'column', gap: '12' });
const gridStyle = css({ display: 'grid', gap: '6', gridTemplateColumns: { md: 'repeat(2, minmax(0, 1fr))', lg: 'repeat(3, minmax(0, 1fr))' } });
const videoLinkStyle = css({ position: 'relative', display: 'block', overflow: 'hidden', rounded: 'lg', bg: { base: 'gray.100', _dark: 'gray.800' }, aspectRatio: 'video' });
const videoImgStyle = css({ w: 'full', h: 'full', objectFit: 'cover', transition: 'transform', transitionDuration: '300ms', _groupHover: { transform: 'scale(1.05)' } });
const videoOverlayStyle = css({ position: 'absolute', inset: '0', bgGradient: 'to-t', gradientFrom: 'black/70', gradientTo: 'transparent', opacity: '0', transition: 'opacity', transitionDuration: '300ms', _groupHover: { opacity: '1' } });
const videoTitleWrapStyle = css({ position: 'absolute', bottom: '0', left: '0', right: '0', p: '4', color: 'white', transform: 'translateY(100%)', transition: 'transform', transitionDuration: '300ms', _groupHover: { transform: 'translateY(0)' } });
const videoTitleStyle = css({ fontWeight: 'semibold', lineClamp: '2' });
const emptyStyle = css({ textAlign: 'center', py: '12' });
const emptyTextStyle = css({ color: { base: 'gray.500', _dark: 'gray.400' } });
---

<div class={wrapperStyle}>
  <!-- Articles Section -->
  {articles.length > 0 && (
    <section>
      <SectionHeader
        title={`Articles about ${technologyName}`}
        showSeparator={false}
        class={css({ mb: '6' })}
      />
      <div class={gridStyle}>
        {articles.map((article) => (
          <ArticleCard article={article} />
        ))}
      </div>
    </section>
  )}

  <!-- Videos Section -->
  {videos.length > 0 && (
    <section>
      <SectionHeader
        title={`Videos about ${technologyName}`}
        showSeparator={false}
        class={css({ mb: '6' })}
      />
      <div class={gridStyle}>
        {videos.map((video) => (
          <a
            href={`/watch/${video.slug}`}
            class={cx('group', videoLinkStyle)}
          >
            <img
              src={video.thumbnailUrl}
              alt={video.title}
              class={videoImgStyle}
              loading="lazy"
            />
            <div class={videoOverlayStyle} />
            <div class={videoTitleWrapStyle}>
              <h3 class={videoTitleStyle}>{video.title}</h3>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Empty State -->
  {articles.length === 0 && videos.length === 0 && (
    <div class={emptyStyle}>
      <p class={emptyTextStyle}>
        No content found for {technologyName} yet. Check back soon!
      </p>
    </div>
  )}
</div>
