---
import { getCollection } from "astro:content";
import ArticleCard from "@/components/articles/ArticleCard.astro";
import SectionHeader from "@/components/common/SectionHeader.vue";

export interface Props {
	technologyId: string;
	technologyName: string;
	videos: Array<{
		id: string;
		title: string;
		thumbnailUrl: string;
		slug: string;
	}>;
	showArticles?: boolean;
	showVideos?: boolean;
	showNews?: boolean;
	showLearningPaths?: boolean;
	newsLimit?: number;
	learningPathLimit?: number;
}

const {
	technologyId,
	technologyName,
	videos = [],
	showArticles = true,
	showVideos = true,
	showNews = true,
	showLearningPaths = true,
	newsLimit = 6,
	learningPathLimit = 6,
} = Astro.props;

// Technology IDs from the collection look like "kubernetes/index"; raw IDs
// (as used in news/article frontmatter) drop the suffix. Match both forms.
const normalizedTechnologyId = technologyId.replace(/\/index$/, "");
const matchesTechnology = (technologies: ReadonlyArray<string> | undefined) =>
	Array.isArray(technologies) &&
	(technologies.includes(technologyId) ||
		technologies.includes(normalizedTechnologyId));

// Get all articles that mention this technology
const allArticles = await getCollection("articles", ({ data }) => {
	return !data.draft && matchesTechnology(data.technologies);
});

// Sort articles by date
const articles = allArticles.sort(
	(a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);

// Get news matching this technology
const allNews = showNews
	? (await getCollection("news"))
			.filter((story) => matchesTechnology(story.data.technologies))
			.sort(
				(a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
			)
			.slice(0, newsLimit)
	: [];

const learningPaths = showLearningPaths
	? (await getCollection("learningPaths"))
			.filter((path) => matchesTechnology(path.data.technologies))
			.sort(
				(a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
			)
			.slice(0, learningPathLimit)
	: [];

const hasArticles = showArticles && articles.length > 0;
const hasVideos = showVideos && videos.length > 0;
const hasNews = showNews && allNews.length > 0;
const hasLearningPaths = showLearningPaths && learningPaths.length > 0;
const isEmpty = !hasArticles && !hasVideos && !hasNews && !hasLearningPaths;

const newsDateFormatter = new Intl.DateTimeFormat("en-US", {
	month: "short",
	day: "numeric",
	year: "numeric",
});

const difficultyLabel: Record<string, string> = {
	beginner: "Beginner",
	intermediate: "Intermediate",
	advanced: "Advanced",
};
function formatLearningPathDuration(minutes: number): string {
	if (!minutes) return "Self-paced";
	const h = Math.floor(minutes / 60);
	const m = minutes % 60;
	if (!h) return `${m}m`;
	if (!m) return `${h}h`;
	return `${h}h ${m}m`;
}
---

<div class="space-y-12">
 <!-- Learning Paths Section -->
 {hasLearningPaths && (
 <section>
 <SectionHeader
 title={`${technologyName} learning paths`}
 showSeparator={false}
 class="mb-6"
 />
 <div class="grid gap-6 md:grid-cols-2">
 {learningPaths.map((path) => (
 <a
 href={`/learning-paths/${path.id}`}
 class="group block rounded-sm border border-black/10 dark:border-white/10 bg-white dark:bg-gray-900 p-6 shadow-sm hover:border-primary/40 hover:bg-primary/[0.03] transition-colors"
 >
 <div class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-muted mb-2">
 <span>{difficultyLabel[path.data.difficulty] ?? path.data.difficulty}</span>
 <span aria-hidden="true">·</span>
 <span>{formatLearningPathDuration(path.data.estimatedDuration)}</span>
 </div>
 <h3 class="font-display text-xl font-semibold leading-tight tracking-tight text-primary-content group-hover:text-primary transition-colors">
 {path.data.title}
 </h3>
 <p class="mt-2 max-w-[60ch] text-sm leading-6 text-secondary-content">
 {path.data.description}
 </p>
 </a>
 ))}
 </div>
 </section>
 )}

 <!-- News Section -->
 {hasNews && (
 <section>
 <SectionHeader
 title={`Recent ${technologyName} news`}
 showSeparator={false}
 class="mb-6"
 />
 <ul class="divide-y divide-black/10 border-y border-black/10 dark:divide-white/10 dark:border-white/10">
 {allNews.map((story) => (
 <li class="py-5 sm:py-6">
 <article class="space-y-2">
 <div class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-muted">
 <time datetime={story.data.publishedAt.toISOString()}>
 {newsDateFormatter.format(story.data.publishedAt)}
 </time>
 </div>
 <h3 class="font-display text-xl md:text-2xl font-semibold leading-tight tracking-tight text-primary-content">
 <a href={`/news/${story.id}`} class="transition-colors hover:text-primary">
 {story.data.title}
 </a>
 </h3>
 <p class="max-w-[66ch] text-base leading-7 text-secondary-content">
 {story.data.description}
 </p>
 </article>
 </li>
 ))}
 </ul>
 </section>
 )}

 <!-- Articles Section -->
 {hasArticles && (
 <section>
 <SectionHeader
 title={`Articles about ${technologyName}`}
 showSeparator={false}
 class="mb-6"
 />
 <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
 {articles.map((article) => (
 <ArticleCard article={article} />
 ))}
 </div>
 </section>
 )}

 <!-- Videos Section -->
 {hasVideos && (
 <section>
 <SectionHeader
 title={`Videos about ${technologyName}`}
 showSeparator={false}
 class="mb-6"
 />
 <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
 {videos.map((video) => (
 <a
 href={`/watch/${video.slug}`}
 class="group relative block overflow-hidden rounded-sm bg-gray-100 dark:bg-gray-800 aspect-video"
 >
 <img
 src={video.thumbnailUrl}
 alt={video.title}
 class="w-full h-full object-cover group-hover:scale-105 "
 loading="lazy"
 />
 <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
 <div class="absolute bottom-0 left-0 right-0 p-4 text-white transform translate-y-full group- ">
 <h3 class="font-semibold line-clamp-2">{video.title}</h3>
 </div>
 </a>
 ))}
 </div>
 </section>
 )}

 <!-- Empty State -->
 {isEmpty && (
 <div class="text-center py-12">
 <p class="text-muted">
 No content found for {technologyName} yet. Check back soon!
 </p>
 </div>
 )}
</div>
