---
interface Props {
	showInAllPages?: boolean;
}

const { showInAllPages = false } = Astro.props;

// Only show on homepage or if explicitly requested
const shouldShow = Astro.url.pathname === "/" || showInAllPages;

if (!shouldShow) return;

const organizationSchema = {
	"@context": "https://schema.org",
	"@type": "Organization",
	"@id": "https://rawkode.academy/#organization",
	name: "Rawkode Academy",
	url: "https://rawkode.academy",
	logo: {
		"@type": "ImageObject",
		url: "https://rawkode.academy/android-chrome-512x512.png",
		width: 512,
		height: 512,
	},
	description:
		"Rawkode Academy provides cloud-native education and partnerships for companies building technical products for practitioners.",
	sameAs: [
		"https://github.com/rawkode-academy",
		"https://www.youtube.com/@RawkodeAcademy",
		"https://x.com/RawkodeAcademy",
		"https://www.linkedin.com/company/rawkode-academy",
	],
	contactPoint: {
		"@type": "ContactPoint",
		contactType: "partnerships",
		email: "david@rawkode.academy",
		url: "https://rawkode.academy/organizations/lets-chat",
	},
	founder: {
		"@type": "Person",
		name: "David Flanagan",
		url: "https://github.com/rawkode",
		sameAs: ["https://x.com/rawkode", "https://www.linkedin.com/in/rawkode"],
	},
	foundingDate: "2021",
	areaServed: {
		"@type": "Place",
		name: "Global",
	},
	knowsAbout: [
		"Cloud Native",
		"Kubernetes",
		"DevOps",
		"Platform Engineering",
		"Infrastructure as Code",
		"GitOps",
		"Observability",
		"Site Reliability Engineering",
	],
	offers: [
		{
			"@type": "Offer",
			name: "Adoption Risk Audit",
			url: "https://rawkode.academy/organizations/partnerships",
			itemOffered: {
				"@type": "Service",
				name: "Adoption Risk Audit",
				description:
					"Focused technical adoption review for one launch, docs, demo, sales, or named DevRel decision",
			},
		},
		{
			"@type": "Offer",
			name: "Monthly Partnership",
			url: "https://rawkode.academy/organizations/partnerships",
			itemOffered: {
				"@type": "Service",
				name: "Monthly Partnership",
				description:
					"Monthly partnership for positioning, launches, docs, demos, DevRel, technical proof, and sales enablement",
			},
		},
		{
			"@type": "Offer",
			name: "Launch Review Sprint",
			url: "https://rawkode.academy/organizations/partnerships",
			itemOffered: {
				"@type": "Service",
				name: "Launch Review Sprint",
				description:
					"Bounded technical adoption review sprint for urgent launch or repositioning risk",
			},
		},
		{
			"@type": "Offer",
			itemOffered: {
				"@type": "Course",
				name: "Online Courses",
				description: "Self-paced online courses for cloud native technologies",
			},
		},
	],
};
---

<script
	type="application/ld+json"
	set:html={JSON.stringify(organizationSchema)}
	is:inline
></script>
