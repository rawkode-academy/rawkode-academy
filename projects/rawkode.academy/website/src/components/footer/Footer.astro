---
import { css } from "../../../styled-system/css";
import RawkodeLogo from "../brand/RawkodeLogo.astro";

type FooterLink = { name: string; href: string; external?: boolean };
type FooterSection = { title: string; links: FooterLink[] };

const sections: FooterSection[] = [
	{
		title: "Learning",
		links: [
			{ name: "News", href: "/news" },
			{ name: "Articles", href: "/read" },
			{ name: "Videos", href: "/watch" },
			{ name: "Shows", href: "/shows" },
			{ name: "Learning Paths", href: "/learning-paths" },
			{ name: "Courses", href: "/courses" },
			{ name: "Technologies", href: "/technology" },
		],
	},
	{
		title: "For Organizations",
		links: [
			{ name: "Partnerships", href: "/organizations/partnerships" },
			{ name: "Branding", href: "/organizations/branding" },
			{ name: "Consulting", href: "/organizations/consulting" },
			{ name: "Training", href: "/organizations/training" },
		],
	},
	{
		title: "Community",
		links: [
			{ name: "Community Day", href: "/community-day" },
			{ name: "People", href: "/people" },
		],
	},
	{
		title: "Contributors",
		links: [
			{ name: "ADRs", href: "/adrs" },
			{ name: "Share Your Project", href: "/maintainers/share-your-project" },
		],
	},
	{
		title: "About",
		links: [
			{ name: "About Us", href: "/about" },
			{ name: "Changelog", href: "/changelog" },
			{ name: "Feeds", href: "/feeds" },
			{ name: "Privacy Policy", href: "/privacy" },
		],
	},
];

const socials = [
	{
		label: "GitHub",
		href: "https://github.com/rawkode-academy/rawkode-academy",
		path: "M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z",
	},
	{
		label: "X (Twitter)",
		href: "https://x.com/RawkodeAcademy",
		path: "M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z",
	},
	{
		label: "Bluesky",
		href: "https://bsky.app/profile/rawkode.academy",
		path: "M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.206-.659-.298-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8Z",
	},
	{
		label: "LinkedIn",
		href: "https://uk.linkedin.com/company/rawkodeacademy",
		path: "M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z",
	},
];

const currentYear = new Date().getFullYear();

const wrapper = css({ position: "relative", mt: "16", px: "4", pb: "10" });
const glow = css({
	position: "absolute",
	insetInline: "0",
	bottom: "0",
	height: "16rem",
	filter: "blur(180px)",
	opacity: "0.4",
	backgroundImage:
		"linear-gradient(to top, token(colors.brand.500)/30, transparent 50%, token(colors.cyan.500)/20)",
	pointerEvents: "none",
});
const card = css({
	position: "relative",
	mx: "auto",
	maxWidth: "80rem",
	overflow: "hidden",
	borderRadius: "3xl",
	borderWidth: "1px",
	borderColor: "border.muted",
	bg: "bg.raised/70",
	backdropFilter: "blur(24px)",
	boxShadow: "lg",
});
const inner = css({ px: { base: "4", sm: "6", lg: "10" }, py: "12" });
const grid = css({
	display: "grid",
	gridTemplateColumns: { base: "repeat(2, minmax(0, 1fr))", md: "repeat(5, minmax(0, 1fr))" },
	gap: "8",
});
const sectionTitle = css({
	fontSize: "sm",
	fontWeight: "semibold",
	color: "fg.primary",
	letterSpacing: "wider",
	textTransform: "uppercase",
	mb: "4",
});
const list = css({ display: "flex", flexDirection: "column", gap: "3" });
const link = css({
	fontSize: "sm",
	color: "fg.secondary",
	textDecoration: "none",
	transition: "color 150ms ease",
	_hover: { color: "fg.brand" },
});
const bottom = css({
	mt: "8",
	pt: "8",
	borderTopWidth: "1px",
	borderTopColor: "border.muted",
	display: "flex",
	flexDirection: { base: "column", md: "row" },
	justifyContent: "space-between",
	alignItems: "center",
	gap: "4",
});
const copy = css({ fontSize: "sm", color: "fg.muted" });
const socialRow = css({ display: "flex", gap: "6", alignItems: "center" });
const socialLink = css({
	color: "fg.muted",
	transition: "color 150ms ease",
	_hover: { color: "fg.brand" },
});
const logoLink = css({ color: "fg.secondary", display: "inline-flex" });
---

<footer class={wrapper}>
	<div class={glow} aria-hidden="true"></div>
	<div class={card}>
		<div class={inner}>
			<div class={grid}>
				{
					sections.map((section) => (
						<div>
							<h3 class={sectionTitle}>{section.title}</h3>
							<ul class={list}>
								{section.links.map((entry) => (
									<li>
										<a
											href={entry.href}
											class={link}
											target={entry.external ? "_blank" : undefined}
											rel={entry.external ? "noopener noreferrer" : undefined}
										>
											{entry.name}
										</a>
									</li>
								))}
							</ul>
						</div>
					))
				}
			</div>

			<div class={bottom}>
				<a href="/" class={logoLink} aria-label="Return to the home page">
					<RawkodeLogo height="1.5rem" />
				</a>
				<div class={copy}>© {currentYear} Rawkode Academy. All rights reserved.</div>
				<div class={socialRow}>
					{
						socials.map((s) => (
							<a
								href={s.href}
								target="_blank"
								rel="noopener noreferrer"
								class={socialLink}
								aria-label={s.label}
							>
								<svg class={css({ h: "5", w: "5" })} fill="currentColor" viewBox="0 0 24 24">
									<path d={s.path} />
								</svg>
							</a>
						))
					}
				</div>
			</div>
		</div>
	</div>
</footer>
