---
import { css, cx } from "styled-system/css";
import { Image } from "astro:assets";
import { type CollectionEntry, getCollection, getEntries } from "astro:content";
import AuthorAvatarGroup from "../common/AuthorAvatarGroup.vue";
import Badge from "../common/Badge.vue";
import BaseCard from "../common/BaseCard.vue";
import FormattedDate from "../common/FormattedDate.vue";

type Props = {
	course: CollectionEntry<"courses">;
};

const { course } = Astro.props;
const authors = await getEntries(course.data.authors);

// Get course modules count (including drafts)
const courseModules = (await getCollection("courseModules")).filter(
	(module) => module.data.course.id === course.id,
);

const totalModules = courseModules.length;

const cardLinkStyle = css({
	height: "full",
	_hover: {
		shadow: "xl",
		transform: "scale(1.02)",
	},
});

const coverImageStyle = css({
	w: "full",
	h: { base: "40", md: "36", lg: "32" },
	objectFit: "cover",
});

const titleStyle = css({
	mb: "3",
	fontSize: "xl",
	fontWeight: "bold",
	letterSpacing: "tight",
	color: { base: "gray.900", _dark: "white" },
	lineClamp: "2",
});

const descriptionStyle = css({
	mb: "4",
	fontWeight: "light",
	color: { base: "gray.600", _dark: "gray.400" },
	lineClamp: "3",
	flexGrow: "1",
});

// Function to get difficulty badge variant
function getDifficultyVariant(
	difficulty: string,
): "success" | "warning" | "danger" | "default" {
	switch (difficulty) {
		case "beginner":
			return "success";
		case "intermediate":
			return "warning";
		case "advanced":
			return "danger";
		default:
			return "default";
	}
}
---

<BaseCard href={`/courses/${course.id}`} class={cardLinkStyle}>
	<Fragment slot="cover">
		<div class={cx(css({ position: 'absolute', inset: '0', zIndex: '10' }), 'bg-gradient-overlay')}></div>
		{
			course.data.cover ? (
				<Image
					class={coverImageStyle}
					src={course.data.cover.image}
					alt={course.data.cover.alt}
					loading="lazy"
				/>
			) : (
				<div class={css({ w: 'full', h: { base: '40', md: '36', lg: '32' }, background: 'linear-gradient(135deg, rgb(var(--brand-primary)) 0%, rgb(var(--brand-secondary)) 100%)', display: 'flex', alignItems: 'center', justifyContent: 'center' })}>
					<svg class={css({ w: '16', h: '16', color: 'white' })} fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
					</svg>
				</div>
			)
		}
		<div class={css({ position: 'absolute', top: '3', left: '3', right: '3', zIndex: '20', display: 'flex', justifyContent: 'space-between' })}>
			<Badge
				variant={getDifficultyVariant(course.data.difficulty)}
				size="sm"
				class={css({ backdropFilter: 'blur(4px)', shadow: 'md' })}
			>
				{course.data.difficulty.charAt(0).toUpperCase() + course.data.difficulty.slice(1)}
			</Badge>
			<Badge
				variant="default"
				size="sm"
				class={cx(css({ backdropFilter: 'blur(4px)', shadow: 'md', bg: { base: 'white/90', _dark: 'gray.800/90' } }), 'text-secondary-content')}
			>
				{totalModules === 1 ? `${totalModules} module` : `${totalModules} modules`}
			</Badge>
		</div>
	</Fragment>
	<Fragment slot="content">
		<h2 class={titleStyle}>
			{course.data.title}
		</h2>
		<p class={descriptionStyle}>
			{course.data.description}
		</p>
	</Fragment>
	<Fragment slot="footer">
		<div class={css({ display: 'flex', alignItems: 'center', justifyContent: 'space-between' })}>
			<AuthorAvatarGroup authors={authors} showActiveIndicator={false} />
			<FormattedDate date={course.data.publishedAt} format="short" />
		</div>
	</Fragment>
</BaseCard>
