---
import { Image } from "astro:assets";
import { type CollectionEntry, getCollection, getEntries } from "astro:content";
import AuthorAvatarGroup from "../common/AuthorAvatarGroup.vue";
import Badge from "../common/Badge.vue";
import BaseCard from "../common/BaseCard.vue";
import FormattedDate from "../common/FormattedDate.vue";

type Props = {
	course: CollectionEntry<"courses">;
};

const { course } = Astro.props;
const authors = await getEntries(course.data.authors);

// Get course modules count (including drafts)
const courseModules = (await getCollection("courseModules")).filter(
	(module) => module.data.course.id === course.id,
);

const totalModules = courseModules.length;

// Function to get difficulty badge variant
function getDifficultyVariant(
	difficulty: string,
): "success" | "warning" | "danger" | "default" {
	switch (difficulty) {
		case "beginner":
			return "success";
		case "intermediate":
			return "warning";
		case "advanced":
			return "danger";
		default:
			return "default";
	}
}
---

<BaseCard href={`/courses/${course.id}`} class="group">
	<Fragment slot="cover">
		<div class="absolute inset-0 z-10 bg-gradient-to-t from-slate-950/70 via-slate-950/10 to-transparent"></div>
		{
			course.data.cover ? (
				<Image
					class="h-48 w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
					src={course.data.cover.image}
					alt={course.data.cover.alt}
					loading="lazy"
				/>
			) : (
				<div class="flex h-48 w-full items-end bg-gradient-to-br from-primary via-primary/80 to-secondary p-6">
					<div class="max-w-[14rem]">
						<p class="text-xs font-semibold uppercase tracking-[0.22em] text-white/75">Course</p>
						<p class="mt-3 text-2xl font-bold leading-tight text-white">{course.data.title}</p>
					</div>
				</div>
			)
		}
		<div class="absolute left-4 right-4 top-4 z-20 flex flex-wrap items-start justify-between gap-2">
			<Badge
				variant={getDifficultyVariant(course.data.difficulty)}
				size="sm"
				class="shadow-md"
			>
				{course.data.difficulty.charAt(0).toUpperCase() + course.data.difficulty.slice(1)}
			</Badge>
			<Badge
				variant="default"
				size="sm"
				class="bg-white/90 text-secondary-content shadow-md dark:bg-gray-900/85"
			>
				{totalModules === 1 ? `${totalModules} module` : `${totalModules} modules`}
			</Badge>
		</div>
	</Fragment>
	<Fragment slot="content">
		<div class="flex h-full flex-col gap-4">
			<div class="space-y-3">
				<h2 class="text-2xl font-bold tracking-tight text-primary-content transition-colors group-hover:text-primary">
					{course.data.title}
				</h2>
				<p class="line-clamp-4 text-sm leading-7 text-secondary-content sm:text-base">
					{course.data.description}
				</p>
			</div>

			{course.data.learningPath.length > 0 && (
				<div class="rounded-[1.15rem] border border-white/40 bg-white/55 px-4 py-4 dark:border-white/8 dark:bg-gray-950/25">
					<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">You’ll cover</p>
					<p class="mt-2 line-clamp-2 text-sm leading-6 text-primary-content">
						{course.data.learningPath.slice(0, 2).join(" • ")}
					</p>
				</div>
			)}
		</div>
	</Fragment>
	<Fragment slot="footer">
		<div class="flex items-center justify-between gap-4">
			<AuthorAvatarGroup authors={authors} showActiveIndicator={false} />
			<div class="text-right">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Published</p>
				<FormattedDate date={course.data.publishedAt} format="short" />
			</div>
		</div>
	</Fragment>
</BaseCard>
