---
import MLabel from "@/components/ui/MLabel.vue";
import EditorialButton from "@/components/ui/EditorialButton.vue";

type AuthorSummary = {
	name: string;
	avatarUrl?: string | undefined;
};

type Props = {
	courseId: string;
	courseName: string;
	courseDescription: string;
	moduleCount: number;
	availableModuleCount: number;
	difficulty: string;
	firstModuleSlug?: string | undefined;
	learningPath: string[];
	authors: AuthorSummary[];
	publishedLabel?: string | undefined;
};

const {
	courseId,
	courseName,
	courseDescription,
	moduleCount,
	availableModuleCount,
	difficulty,
	firstModuleSlug,
	learningPath,
	authors,
	publishedLabel,
} = Astro.props;

const primaryHref = firstModuleSlug
	? `/courses/${courseId}/${firstModuleSlug}`
	: `/courses/${courseId}`;
---

<section class="courses-hero">
	<div class="courses-hero__head">
		<MLabel tone="spruce">Latest course</MLabel>
		{publishedLabel && <MLabel>Published {publishedLabel}</MLabel>}
		{availableModuleCount > 0 && availableModuleCount < moduleCount && (
			<MLabel tone="amber">{availableModuleCount} live now</MLabel>
		)}
	</div>

	<h1 class="courses-hero__title">{courseName}</h1>
	<p class="courses-hero__lede">{courseDescription}</p>

	<div class="courses-hero__byline">
		{authors.length > 0 && (
			<div class="courses-hero__authors">
				<div class="courses-hero__avatars">
					{authors.map((author) =>
						author.avatarUrl ? (
							<img
								src={author.avatarUrl}
								alt={author.name}
								class="courses-hero__avatar"
								loading="lazy"
							/>
						) : (
							<span class="courses-hero__avatar courses-hero__avatar--fallback">
								{author.name.charAt(0)}
							</span>
						),
					)}
				</div>
				<div class="courses-hero__author-meta">
					<MLabel>Taught by</MLabel>
					<span class="courses-hero__author-name">
						{authors.map((author) => author.name).join(", ")}
					</span>
				</div>
			</div>
		)}

		<div class="courses-hero__actions">
			<EditorialButton variant="solid" size="md" href={primaryHref} arrow>
				{availableModuleCount > 0 ? "Start learning" : "View outline"}
			</EditorialButton>
			<EditorialButton variant="outline" size="md" href="#all-courses">
				Browse all courses
			</EditorialButton>
		</div>
	</div>

	<dl class="courses-hero__stats">
		<div class="courses-hero__stat">
			<dt><MLabel>Curriculum</MLabel></dt>
			<dd class="courses-hero__stat-value">{moduleCount}</dd>
			<p class="courses-hero__stat-note">
				Structured modules with clear progression.
			</p>
		</div>
		<div class="courses-hero__stat">
			<dt><MLabel>Availability</MLabel></dt>
			<dd class="courses-hero__stat-value">
				{availableModuleCount || moduleCount}
			</dd>
			<p class="courses-hero__stat-note">
				{availableModuleCount > 0
					? "Ready to start today."
					: "Course outline in progress."}
			</p>
		</div>
		<div class="courses-hero__stat">
			<dt><MLabel>Level</MLabel></dt>
			<dd class="courses-hero__stat-value">{difficulty}</dd>
			<p class="courses-hero__stat-note">
				Hands-on guidance without vendor fluff.
			</p>
		</div>
	</dl>

	{learningPath.length > 0 && (
		<div class="courses-hero__path">
			<div class="courses-hero__path-head">
				<div>
					<MLabel tone="spruce">§ What you'll cover</MLabel>
					<p class="courses-hero__path-body">
						The course is laid out as a practical path, not a pile of disconnected videos.
					</p>
				</div>
				<MLabel>Self-paced</MLabel>
			</div>
			<div class="courses-hero__path-grid">
				{learningPath.slice(0, 3).map((step, index) => (
					<div class="courses-hero__step">
						<MLabel tone="spruce">§{String(index + 1).padStart(2, "0")}</MLabel>
						<p class="courses-hero__step-body">{step}</p>
					</div>
				))}
			</div>
		</div>
	)}
</section>

<style>
	.courses-hero {
		background: var(--editorial-paper);
		color: var(--editorial-ink);
		padding: var(--space-section-pad-y) var(--space-section-pad-x) var(--space-page-pad-bottom);
		border-bottom: 1px solid var(--editorial-hairline);
		max-width: 90rem;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.courses-hero__head {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		align-items: center;
	}

	.courses-hero__title {
		font-family: var(--font-instrument-serif), serif;
		font-style: italic;
		font-weight: 400;
		font-size: clamp(2.75rem, 6vw, 5rem);
		line-height: 0.97;
		letter-spacing: -0.025em;
		color: var(--editorial-ink);
		margin: 0;
		text-wrap: balance;
	}

	.courses-hero__lede {
		font-family: var(--font-inter-tight), sans-serif;
		font-size: 1.1875rem;
		line-height: 1.45;
		color: var(--editorial-ink-soft);
		margin: 0;
		max-width: 48rem;
		text-wrap: pretty;
	}

	.courses-hero__byline {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		align-items: center;
		gap: 1.5rem;
		padding-top: 1.25rem;
		border-top: 1px solid var(--editorial-hairline);
	}

	.courses-hero__authors {
		display: flex;
		align-items: center;
		gap: 0.875rem;
	}

	.courses-hero__avatars {
		display: flex;
		margin-right: 0.25rem;
	}

	.courses-hero__avatar {
		width: 40px;
		height: 40px;
		border-radius: 50%;
		object-fit: cover;
		border: 1px solid var(--editorial-hairline-strong);
		margin-left: -8px;
	}
	.courses-hero__avatar:first-child {
		margin-left: 0;
	}

	.courses-hero__avatar--fallback {
		display: grid;
		place-items: center;
		background: var(--editorial-ink);
		color: var(--editorial-paper);
		font-family: var(--font-instrument-serif), serif;
		font-style: italic;
		font-size: 1rem;
	}

	.courses-hero__author-meta {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}

	.courses-hero__author-name {
		font-family: var(--font-inter-tight), sans-serif;
		font-size: 0.95rem;
		color: var(--editorial-ink);
	}

	.courses-hero__actions {
		display: flex;
		gap: 0.625rem;
		flex-wrap: wrap;
	}

	.courses-hero__stats {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
		padding-top: 1.25rem;
		border-top: 1px solid var(--editorial-hairline);
		margin: 0;
	}

	.courses-hero__stat {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}
	.courses-hero__stat dt { margin: 0; }
	.courses-hero__stat dd { margin: 0; }

	.courses-hero__stat-value {
		font-family: var(--font-instrument-serif), serif;
		font-style: italic;
		font-size: 2rem;
		line-height: 1;
		color: var(--editorial-ink);
		text-transform: capitalize;
	}

	.courses-hero__stat-note {
		font-family: var(--font-inter-tight), sans-serif;
		font-size: 0.875rem;
		line-height: 1.45;
		color: var(--editorial-ink-soft);
		margin: 0;
	}

	.courses-hero__path {
		padding-top: 1.25rem;
		border-top: 1px solid var(--editorial-hairline);
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.courses-hero__path-head {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		align-items: end;
		gap: 1rem;
	}

	.courses-hero__path-body {
		font-family: var(--font-inter-tight), sans-serif;
		font-size: 0.95rem;
		line-height: 1.5;
		color: var(--editorial-ink-soft);
		max-width: 36rem;
		margin: 0.5rem 0 0;
	}

	.courses-hero__path-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0.75rem;
	}

	.courses-hero__step {
		background: var(--editorial-paper-deep);
		border: 1px solid var(--editorial-hairline);
		padding: 1rem 1.125rem;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.courses-hero__step-body {
		font-family: var(--font-inter-tight), sans-serif;
		font-size: 0.9375rem;
		line-height: 1.45;
		color: var(--editorial-ink);
		margin: 0;
	}

	@media (max-width: 880px) {
		.courses-hero {
			padding: 2.25rem 1.25rem;
		}
		.courses-hero__stats,
		.courses-hero__path-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
