---
import MLabel from "@/components/ui/MLabel.vue";
import EditorialButton from "@/components/ui/EditorialButton.vue";

type AuthorSummary = {
	name: string;
	avatarUrl?: string | undefined;
};

type Props = {
	courseId: string;
	courseName: string;
	courseDescription: string;
	moduleCount: number;
	availableModuleCount: number;
	difficulty: string;
	firstModuleSlug?: string | undefined;
	learningPath: string[];
	authors: AuthorSummary[];
	publishedLabel?: string | undefined;
};

const {
	courseId,
	courseName,
	courseDescription,
	moduleCount,
	availableModuleCount,
	difficulty,
	firstModuleSlug,
	learningPath,
	authors,
	publishedLabel,
} = Astro.props;

const primaryHref = firstModuleSlug
	? `/courses/${courseId}/${firstModuleSlug}`
	: `/courses/${courseId}`;
---

<section class="courses-hero">
	<div class="courses-hero__head">
		<MLabel tone="spruce">Featured course</MLabel>
		<MLabel>{difficulty}</MLabel>
		<MLabel>{moduleCount} {moduleCount === 1 ? "module" : "modules"}</MLabel>
	</div>

	<div class="courses-hero__layout">
		<div class="courses-hero__copy">
			<h2 class="courses-hero__title">{courseName}</h2>
			<p class="courses-hero__lede">{courseDescription}</p>
			<div class="courses-hero__meta">
				{availableModuleCount > 0 && (
					<span>
						{availableModuleCount} live {availableModuleCount === 1 ? "module" : "modules"}
					</span>
				)}
				{publishedLabel && <span>Published {publishedLabel}</span>}
				{learningPath.length > 0 && <span>{learningPath.length} topic path</span>}
			</div>
		</div>

		<div class="courses-hero__aside">
			{authors.length > 0 && (
				<div class="courses-hero__authors">
					<div class="courses-hero__avatars">
						{authors.map((author) =>
							author.avatarUrl ? (
								<img
									src={author.avatarUrl}
									alt={author.name}
									class="courses-hero__avatar"
									loading="lazy"
								/>
							) : (
								<span class="courses-hero__avatar courses-hero__avatar--fallback">
									{author.name.charAt(0)}
								</span>
							),
						)}
					</div>
					<div class="courses-hero__author-meta">
						<MLabel>Taught by</MLabel>
						<span class="courses-hero__author-name">
							{authors.map((author) => author.name).join(", ")}
						</span>
					</div>
				</div>
			)}

			<div class="courses-hero__actions">
				<EditorialButton variant="solid" size="md" href={primaryHref} arrow>
					{availableModuleCount > 0 ? "Start learning" : "View outline"}
				</EditorialButton>
				<EditorialButton variant="outline" size="md" href="#all-courses">
					All courses
				</EditorialButton>
			</div>
		</div>
	</div>
</section>

<style>
	.courses-hero {
		background: var(--editorial-paper);
		color: var(--editorial-ink);
		padding: 2rem var(--space-section-pad-x);
		max-width: 90rem;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.courses-hero__head {
		display: flex;
		flex-wrap: wrap;
		gap: 0.875rem;
		align-items: center;
	}

	.courses-hero__layout {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(17rem, 26rem);
		gap: 2rem;
		align-items: end;
	}

	.courses-hero__copy {
		max-width: 48rem;
	}

	.courses-hero__title {
		font-family: var(--font-inter-tight), sans-serif;
		font-weight: 700;
		font-size: clamp(2rem, 4vw, 3.25rem);
		line-height: 1.02;
		letter-spacing: 0;
		color: var(--editorial-ink);
		margin: 0 0 0.875rem;
		text-wrap: balance;
	}

	.courses-hero__lede {
		font-family: var(--font-inter-tight), sans-serif;
		font-size: 1.1875rem;
		line-height: 1.45;
		color: var(--editorial-ink-soft);
		margin: 0;
		text-wrap: pretty;
	}

	.courses-hero__meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem 1rem;
		margin-top: 1.125rem;
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 0.6875rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--editorial-ink-mute);
	}

	.courses-hero__aside {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		align-items: flex-start;
	}

	.courses-hero__authors {
		display: flex;
		align-items: center;
		gap: 0.875rem;
	}

	.courses-hero__avatars {
		display: flex;
		margin-right: 0.25rem;
	}

	.courses-hero__avatar {
		width: 40px;
		height: 40px;
		border-radius: 50%;
		object-fit: cover;
		border: 1px solid var(--editorial-hairline-strong);
		margin-left: -8px;
	}
	.courses-hero__avatar:first-child {
		margin-left: 0;
	}

	.courses-hero__avatar--fallback {
		display: grid;
		place-items: center;
		background: var(--editorial-ink);
		color: var(--editorial-paper);
		font-family: var(--font-instrument-serif), serif;
		font-style: italic;
		font-size: 1rem;
	}

	.courses-hero__author-meta {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}

	.courses-hero__author-name {
		font-family: var(--font-inter-tight), sans-serif;
		font-size: 0.95rem;
		color: var(--editorial-ink);
	}

	.courses-hero__actions {
		display: flex;
		gap: 0.625rem;
		flex-wrap: wrap;
	}

	@media (max-width: 880px) {
		.courses-hero {
			padding: 2.25rem 1.25rem;
		}
		.courses-hero__layout {
			grid-template-columns: 1fr;
			gap: 1.25rem;
		}
		.courses-hero__aside {
			align-items: stretch;
		}
		.courses-hero__actions {
			width: 100%;
		}
	}
</style>
