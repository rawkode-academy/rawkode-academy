---
import { css } from "../../../styled-system/css";

export interface Props {
	eyebrow?: string;
	title: string;
	subtitle?: string;
	align?: "center" | "left";
	size?: "sm" | "md" | "lg";
}

const { eyebrow, title, subtitle, align = "center", size = "md" } = Astro.props;

const padY: Record<NonNullable<Props["size"]>, string> = { sm: "10", md: "14", lg: "20" };

const wrap = css({
	position: "relative",
	overflow: "hidden",
	py: padY[size],
	px: { base: "4", md: "6" },
	textAlign: align,
});

const inner = css({
	maxWidth: "60rem",
	mx: align === "center" ? "auto" : "0",
	display: "flex",
	flexDirection: "column",
	gap: "4",
	alignItems: align === "center" ? "center" : "flex-start",
});

const eyebrowClass = css({
	display: "inline-flex",
	px: "3",
	py: "1",
	borderRadius: "full",
	bg: "bg.brand-subtle",
	color: "fg.brand",
	fontSize: "xs",
	fontWeight: "semibold",
	letterSpacing: "wider",
	textTransform: "uppercase",
});

const titleClass = css({
	fontFamily: "display",
	fontSize: { base: "3xl", md: "5xl" },
	fontWeight: "bold",
	letterSpacing: "tight",
	lineHeight: "1.1",
	color: "fg.primary",
	textWrap: "balance",
});

const subtitleClass = css({
	fontSize: { base: "md", md: "lg" },
	color: "fg.secondary",
	lineHeight: "1.6",
	maxWidth: "44rem",
	textWrap: "pretty",
});
---

<section class:list={[wrap, "hero-aurora"]}>
	<div class={inner}>
		{eyebrow && <span class={eyebrowClass}>{eyebrow}</span>}
		<h1 class={titleClass}>{title}</h1>
		{subtitle && <p class={subtitleClass}>{subtitle}</p>}
		<slot />
	</div>
</section>
