---
import {
	ExclamationTriangleIcon,
	FireIcon,
	InformationCircleIcon,
	LightBulbIcon,
} from "@heroicons/vue/24/outline";
import { css } from "../../styled-system/css";

interface Props {
	variant: "tip" | "caution" | "danger" | "info";
}

const { variant } = Astro.props as Props;

// Define styles based on variant
const variantStyles = {
	tip: {
		container: css({ background: "linear-gradient(to right, token(colors.green.50), token(colors.emerald.50))", color: { base: "green.900", _dark: "green.100" }, _dark: { background: "linear-gradient(to right, rgba(20,83,45,0.4), rgba(6,78,59,0.4))" } }),
		icon: css({ color: { base: "green.700", _dark: "green.300" } }),
		iconBg: css({ bg: { base: "green.100", _dark: "green.900/50" } }),
		border: css({ borderColor: { base: "green.200", _dark: "green.800" } }),
	},
	caution: {
		container: css({ background: "linear-gradient(to right, token(colors.amber.50), token(colors.yellow.50))", color: { base: "amber.900", _dark: "amber.100" }, _dark: { background: "linear-gradient(to right, rgba(120,53,15,0.4), rgba(113,63,18,0.4))" } }),
		icon: css({ color: { base: "amber.700", _dark: "amber.300" } }),
		iconBg: css({ bg: { base: "amber.100", _dark: "amber.900/50" } }),
		border: css({ borderColor: { base: "amber.200", _dark: "amber.800" } }),
	},
	danger: {
		container: css({ background: "linear-gradient(to right, token(colors.red.50), token(colors.rose.50))", color: { base: "red.900", _dark: "red.100" }, _dark: { background: "linear-gradient(to right, rgba(127,29,29,0.4), rgba(136,19,55,0.4))" } }),
		icon: css({ color: { base: "red.700", _dark: "red.300" } }),
		iconBg: css({ bg: { base: "red.100", _dark: "red.900/50" } }),
		border: css({ borderColor: { base: "red.200", _dark: "red.800" } }),
	},
	info: {
		container: css({ background: "linear-gradient(to right, rgba(var(--brand-primary),0.05), rgba(var(--brand-secondary),0.1))", color: "rgb(var(--brand-primary))", _dark: { background: "linear-gradient(to right, rgba(var(--brand-primary),0.2), rgba(var(--brand-secondary),0.3))" } }),
		icon: css({ color: "rgb(var(--brand-primary))" }),
		iconBg: css({ bg: "rgba(var(--brand-primary), 0.1)", _dark: { bg: "rgba(var(--brand-primary), 0.2)" } }),
		border: css({ borderColor: "rgba(var(--brand-primary), 0.2)", _dark: { borderColor: "rgba(var(--brand-primary), 0.6)" } }),
	},
};

const styles = variantStyles[variant];

const containerStyle = css({
	my: "3",
	borderRadius: "lg",
	border: "1px solid",
	px: "4",
	py: "3",
	position: "relative",
	overflow: "hidden",
	transition: "all",
	transitionDuration: "200ms",
	_hover: { shadow: "md" },
	boxShadow: "0 1px 3px 0 rgb(0 0 0 / 0.05)",
});
---

<div
	class:list={["aside", containerStyle, styles.border, styles.container]}
>
	<!-- Subtle accent line -->
	<div class:list={[css({ position: "absolute", left: "0", top: "0", bottom: "0", w: "0.5", opacity: "0.6", transition: "opacity", transitionDuration: "200ms" }), styles.iconBg]}></div>

	<!-- Content with inline icon -->
	<div class={css({ display: "flex", alignItems: "flex-start", gap: "3" })}>
		<div class:list={[css({ p: "1.5", borderRadius: "md", flexShrink: "0", transition: "transform", transitionDuration: "200ms" }), styles.iconBg, styles.icon]}>
			{
				variant === "tip" && (
					<LightBulbIcon
						class={css({ h: "4", w: "4" })}
						aria-hidden="true"
						client:only="vue"
					/>
				)
			}
			{
				variant === "caution" && (
					<ExclamationTriangleIcon
						class={css({ h: "4", w: "4" })}
						aria-hidden="true"
						client:only="vue"
					/>
				)
			}
			{
				variant === "danger" && (
					<FireIcon
						class={css({ h: "4", w: "4" })}
						aria-hidden="true"
						client:only="vue"
					/>
				)
			}
			{
				variant === "info" && (
					<InformationCircleIcon
						class={css({ h: "4", w: "4" })}
						aria-hidden="true"
						client:only="vue"
					/>
				)
			}
		</div>
		<div class={css({ flex: "1", minW: "0", mt: "-0.5" })}>
			<div class={css({ display: "flex", alignItems: "center", gap: "2", mb: "1" })}>
				<span class={css({ fontSize: "2.5", fontWeight: "semibold", letterSpacing: "wider", opacity: "0.6", textTransform: "uppercase" })}>
					{variant}
				</span>
			</div>
			<slot />
		</div>
	</div>
</div>

<style>
	/* Ensure proper prose spacing */
	.aside :global(p) {
		line-height: 1.625;
	}

	.aside :global(p:not(:first-child)) {
		margin-top: 0.5rem;
	}

	/* Refined link styling */
	.aside :global(a) {
		font-weight: 500;
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 2px;
		transition: all 0.2s;
	}

	/* Subtle shadow on hover */
	.aside:hover {
		box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
	}
</style>
