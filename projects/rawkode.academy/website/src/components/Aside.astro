---
import {
	ExclamationTriangleIcon,
	FireIcon,
	InformationCircleIcon,
	LightBulbIcon,
} from "@heroicons/vue/24/outline";
import { css } from "../../styled-system/css";

interface Props {
	variant: "tip" | "caution" | "danger" | "info";
}

const { variant } = Astro.props as Props;

const variantStyles = {
	tip: {
		container: css({ bgGradient: 'to-r', gradientFrom: { base: 'green.50', _dark: 'green.950/40' }, gradientTo: { base: 'emerald.50', _dark: 'emerald.950/40' }, color: { base: 'green.900', _dark: 'green.100' } }),
		icon: css({ color: { base: 'green.700', _dark: 'green.300' } }),
		iconBg: css({ bg: { base: 'green.100', _dark: 'green.900/50' } }),
		border: css({ borderColor: { base: 'green.200', _dark: 'green.800' } }),
	},
	caution: {
		container: css({ bgGradient: 'to-r', gradientFrom: { base: 'amber.50', _dark: 'amber.950/40' }, gradientTo: { base: 'yellow.50', _dark: 'yellow.950/40' }, color: { base: 'amber.900', _dark: 'amber.100' } }),
		icon: css({ color: { base: 'amber.700', _dark: 'amber.300' } }),
		iconBg: css({ bg: { base: 'amber.100', _dark: 'amber.900/50' } }),
		border: css({ borderColor: { base: 'amber.200', _dark: 'amber.800' } }),
	},
	danger: {
		container: css({ bgGradient: 'to-r', gradientFrom: { base: 'red.50', _dark: 'red.950/40' }, gradientTo: { base: 'rose.50', _dark: 'rose.950/40' }, color: { base: 'red.900', _dark: 'red.100' } }),
		icon: css({ color: { base: 'red.700', _dark: 'red.300' } }),
		iconBg: css({ bg: { base: 'red.100', _dark: 'red.900/50' } }),
		border: css({ borderColor: { base: 'red.200', _dark: 'red.800' } }),
	},
	info: {
		container: css({ bgGradient: 'to-r', gradientFrom: { base: 'colorPalette.default/5', _dark: 'colorPalette.default/20' }, gradientTo: { base: 'colorPalette.default/10', _dark: 'colorPalette.default/30' }, color: 'colorPalette.default' }),
		icon: css({ color: 'colorPalette.default' }),
		iconBg: css({ bg: { base: 'colorPalette.default/10', _dark: 'colorPalette.default/20' } }),
		border: css({ borderColor: { base: 'colorPalette.default/20', _dark: 'colorPalette.default/60' } }),
	},
};

const styles = variantStyles[variant];

const wrapperStyle = css({ my: '3', borderRadius: 'lg', borderWidth: '1px', px: '4', py: '3', position: 'relative', overflow: 'hidden', transition: 'all', transitionDuration: '200ms', _hover: { shadow: 'md' } });
const accentLineStyle = css({ position: 'absolute', left: '0', top: '0', bottom: '0', w: '0.5', opacity: '0.6', _groupHover: { opacity: '1' }, transition: 'opacity', transitionDuration: '200ms' });
const contentWrapStyle = css({ display: 'flex', alignItems: 'flex-start', gap: '3' });
const iconWrapStyle = css({ p: '1.5', borderRadius: 'md', flexShrink: '0', transition: 'transform', transitionDuration: '200ms', _groupHover: { transform: 'scale(1.05)' } });
const svgStyle = css({ h: '4', w: '4' });
const bodyStyle = css({ flex: '1', minW: '0', mt: '-0.5' });
const labelWrapStyle = css({ display: 'flex', alignItems: 'center', gap: '2', mb: '1' });
const labelStyle = css({ fontSize: '10px', fontWeight: 'semibold', letterSpacing: 'wider', opacity: '0.6', textTransform: 'uppercase' });
---

<div
	class={`aside group ${wrapperStyle} ${styles.border} ${styles.container}`}
>
	<!-- Subtle accent line -->
	<div class={`${accentLineStyle} ${styles.iconBg}`}></div>

	<!-- Content with inline icon -->
	<div class={contentWrapStyle}>
		<div class={`${iconWrapStyle} ${styles.iconBg} ${styles.icon}`}>
			{
				variant === "tip" && (
					<LightBulbIcon
						class={svgStyle}
						aria-hidden="true"
						client:only="vue"
					/>
				)
			}
			{
				variant === "caution" && (
					<ExclamationTriangleIcon
						class={svgStyle}
						aria-hidden="true"
						client:only="vue"
					/>
				)
			}
			{
				variant === "danger" && (
					<FireIcon
						class={svgStyle}
						aria-hidden="true"
						client:only="vue"
					/>
				)
			}
			{
				variant === "info" && (
					<InformationCircleIcon
						class={svgStyle}
						aria-hidden="true"
						client:only="vue"
					/>
				)
			}
		</div>
		<div class={bodyStyle}>
			<div class={labelWrapStyle}>
				<span class={labelStyle}>
					{variant}
				</span>
			</div>
			<slot />
		</div>
	</div>
</div>

<style>
	/* Ensure proper prose spacing */
	.aside :global(p) {
		line-height: 1.625;
	}

	.aside :global(p:not(:first-child)) {
		margin-top: 0.5rem;
	}

	/* Refined link styling */
	.aside :global(a) {
		font-weight: 500;
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 2px;
		transition: all 200ms;
	}

	/* Subtle shadow on hover */
	.aside {
		box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.05);
	}

	.aside:hover {
		box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
	}
</style>
