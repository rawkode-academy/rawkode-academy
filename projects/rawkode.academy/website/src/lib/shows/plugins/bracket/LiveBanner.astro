---
import type { BracketMatch } from "./queries";

interface Props {
	match: BracketMatch | null;
}

const { match } = Astro.props;
---

{
	match && (
		<div class="bg-primary">
			<div class="mx-auto flex max-w-7xl items-center gap-3 content-px py-2 text-sm text-white">
				<span class="font-semibold uppercase tracking-wide">● Live now</span>
				<span class="truncate">
					{match.sideA?.displayName ?? "TBD"} vs{" "}
					{match.sideB?.displayName ?? "TBD"}
				</span>
			</div>
		</div>
	)
}
