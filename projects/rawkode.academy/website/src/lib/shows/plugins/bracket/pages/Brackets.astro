---
import type { Bracket, BracketMatch } from "../queries";

interface Props {
	brackets: Bracket[];
}

const { brackets } = Astro.props;

function roundsOf(matches: BracketMatch[]): [number, BracketMatch[]][] {
	const byRound = new Map<number, BracketMatch[]>();
	for (const m of matches) {
		const list = byRound.get(m.roundNumber) ?? [];
		list.push(m);
		byRound.set(m.roundNumber, list);
	}
	return [...byRound.entries()]
		.sort((a, b) => a[0] - b[0])
		.map(
			([round, ms]) =>
				[round, ms.sort((a, b) => a.positionInRound - b.positionInRound)] as [
					number,
					BracketMatch[],
				],
		);
}

const sideLabel = (s: BracketMatch["sideA"]) => s?.displayName ?? "TBD";

function fmt(iso?: string | null): string {
	if (!iso) return "TBD";
	return new Date(iso).toLocaleString("en-GB", {
		weekday: "short",
		day: "numeric",
		month: "short",
		hour: "2-digit",
		minute: "2-digit",
	});
}
---

{
	brackets.length === 0 ? (
		<div class="mx-auto max-w-2xl rounded-sm paper-card p-12 text-center">
			<p class="text-lg font-medium text-secondary-content">No brackets yet</p>
			<p class="mt-2 text-sm text-muted">
				Brackets appear here once a season is underway. Check back soon.
			</p>
		</div>
	) : (
		<div class="flex flex-col gap-12">
			{brackets.map((bracket) => (
				<div>
					<div class="mb-4 flex flex-wrap items-center gap-3">
						<h2 class="text-2xl font-bold text-primary-content">
							{bracket.name}
						</h2>
						<span class="hairline-chip text-xs font-medium uppercase text-muted">
							{bracket.kind} · {bracket.status}
						</span>
						<span class="text-sm text-muted">
							Starts {fmt(bracket.startsAt)}
						</span>
					</div>
					<div class="flex gap-6 overflow-x-auto pb-2">
						{roundsOf(bracket.matches).map(([round, ms]) => (
							<div class="min-w-64 flex-shrink-0">
								<h3 class="mb-3 text-sm font-semibold uppercase tracking-wide text-muted">
									Round {round}
								</h3>
								<div class="flex flex-col gap-3">
									{ms.map((m) => (
										<div class="rounded-sm paper-card p-3">
											<div
												class:list={[
													"flex items-center justify-between text-sm",
													m.winner?.id && m.winner.id === m.sideA?.id
														? "font-semibold text-primary-content"
														: "text-secondary-content",
												]}
											>
												<span class="truncate">{sideLabel(m.sideA)}</span>
												{m.sideA?.seed != null && (
													<span class="ml-2 text-xs text-muted">
														#{m.sideA.seed}
													</span>
												)}
											</div>
											<div class="my-1 text-center text-xs text-muted">vs</div>
											<div
												class:list={[
													"flex items-center justify-between text-sm",
													m.winner?.id && m.winner.id === m.sideB?.id
														? "font-semibold text-primary-content"
														: "text-secondary-content",
												]}
											>
												<span class="truncate">{sideLabel(m.sideB)}</span>
												{m.sideB?.seed != null && (
													<span class="ml-2 text-xs text-muted">
														#{m.sideB.seed}
													</span>
												)}
											</div>
											{m.status === "live" && (
												<div class="mt-2 text-center text-xs font-semibold text-secondary">
													● LIVE
												</div>
											)}
										</div>
									))}
								</div>
							</div>
						))}
					</div>
				</div>
			))}
		</div>
	)
}
