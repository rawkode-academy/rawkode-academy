{
	"$schema": "https://unpkg.com/wrangler/config-schema.json",
	"name": "video-thumbnails",
	"main": "src/main.ts",
	"workers_dev": true,
	"compatibility_date": "2026-06-06",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"keep_vars": false,
	"minify": true,
	"observability": {
		"traces": {
			"enabled": true,
			"destinations": ["grafana-traces"]
		},
		"logs": {
			"enabled": true,
			"destinations": ["grafana-logs"]
		}
	},
	"r2_buckets": [
		{
			"binding": "CONTENT_BUCKET",
			"bucket_name": "rawkode-academy-content"
		}
	],
	"ai": {
		"binding": "AI"
	},
	"browser": {
		"binding": "BROWSER"
	},
	"workflows": [
		{
			"name": "generate-video-thumbnail",
			"binding": "GENERATE_VIDEO_THUMBNAIL",
			"class_name": "GenerateVideoThumbnailWorkflow",
			"script_name": "src/workflow.ts"
		}
	]
}
