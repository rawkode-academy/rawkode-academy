{
	"name": "notifications",
	"private": true,
	"type": "module",
	"scripts": {
		"check": "tsc --noEmit",
		"deploy": "bun x wrangler deploy --config ./wrangler.jsonc",
		"deploy:dry-run": "bun x wrangler deploy --dry-run --config ./wrangler.jsonc",
		"migrate": "bun x wrangler d1 migrations apply platform-notifications --remote --config ./wrangler.jsonc",
		"queues:ensure": "WRANGLER_CONFIG=./wrangler.jsonc bun scripts/ensure-queues.ts",
		"test": "vitest run"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260602.1",
		"@types/bun": "latest",
		"@types/node": "^24.10.1",
		"typescript": "^5.9.3",
		"vitest": "^4.1.8",
		"wrangler": "^4.96.0"
	}
}
