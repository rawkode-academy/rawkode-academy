---
import { actions } from "astro:actions";
import {
	isStudioSessionActive,
	type StudioDashboard,
	type StudioEventSummary,
} from "../server/studio";

interface Props {
	authError?: string | null;
	createSessionError?: string | null;
	dashboard: StudioDashboard;
	endSessionError?: string | null;
	invite?: {
		expiresAt: number;
		inviteUrl: string;
		sessionId: string;
		sessionTitle: string;
	} | null;
	inviteError?: string | null;
}

const {
	authError = null,
	createSessionError = null,
	dashboard,
	endSessionError = null,
	invite = null,
	inviteError = null,
} = Astro.props;

const authErrorMessages: Record<string, string> = {
	access_denied: "GitHub sign-in was cancelled or denied.",
	missing_auth_state: "The sign-in request expired or was incomplete. Please try again.",
	session_store_unavailable: "Studio cannot create a session right now. Please try again shortly.",
	token_exchange_failed: "GitHub sign-in could not be completed. Please try again.",
	userinfo_failed: "Studio could not load your Rawkode identity. Please try again.",
};
const authErrorMessage = authError
	? authErrorMessages[authError] ?? "Studio sign-in failed. Please try again."
	: null;
const eventSessionIds = new Set(
	dashboard.events.flatMap((event) => event.sessions.map((session) => session.id)),
);
const historySessions = dashboard.sessions
	.filter((session) => !isStudioSessionActive(session) || !eventSessionIds.has(session.id))
	.sort((left, right) => right.startsAt.localeCompare(left.startsAt));

function eventTiming(event: StudioEventSummary): string {
	if (!event.startsAt) return "Unscheduled";
	return new Date(event.startsAt).toLocaleString();
}

function eventState(event: StudioEventSummary): string {
	if (!event.startsAt) return "Event";
	return Date.parse(event.startsAt) >= Date.now() ? "Upcoming" : "Previous";
}
---

{
	!dashboard.user ? (
		<section class="signed-out-panel" aria-label="Rawkode Studio sign in">
			<h1>Welcome to Rawkode Studio</h1>
			{authErrorMessage ? <p class="form-error" role="alert">{authErrorMessage}</p> : null}
			<a class="button primary" href="/login">Log in</a>
		</section>
	) : (
		<>
			<section class="dashboard-grid">
				<div class="dashboard-panel dashboard-primary">
					<div>
						<p class="eyebrow">
							{dashboard.isOperator ? "Host / Producer" : "Participant"}
						</p>
						<h1>
							{
								dashboard.isOperator
									? "Upcoming events"
									: "Your events"
							}
						</h1>
					</div>
					<p>
							{
								dashboard.isOperator
									? "Create RealtimeKit green rooms and choose whether the later go-live is a test or prod stream."
									: "Join active Studio rooms for events where your GitHub handle is listed."
							}
					</p>
				</div>

				<div class="dashboard-panel">
					<p class="eyebrow">Identity</p>
					<h2>{dashboard.user.username ?? dashboard.user.name}</h2>
				</div>
			</section>

			{
				authErrorMessage ? (
					<p class="form-error" role="alert">{authErrorMessage}</p>
				) : null
			}
			{
				dashboard.contentError ? (
					<p class="form-error" role="alert">{dashboard.contentError}</p>
				) : null
			}
			{
				createSessionError ? (
					<p class="form-error" role="alert">{createSessionError}</p>
				) : null
			}
			{
				endSessionError ? (
					<p class="form-error" role="alert">{endSessionError}</p>
				) : null
			}
			{
				inviteError ? (
					<p class="form-error" role="alert">{inviteError}</p>
				) : null
			}
			{
				invite ? (
					<section class="studio-form-panel" aria-label="Guest invite">
						<p class="eyebrow">Guest invite</p>
						<h2>{invite.sessionTitle}</h2>
						<label>
							Invite URL
							<input data-invite-url readonly value={invite.inviteUrl} />
						</label>
						<p>Expires {new Date(invite.expiresAt * 1000).toLocaleString()}</p>
						<div class="session-actions">
							<button class="button" type="button" data-copy-invite>Copy invite</button>
							<a class="button" href={invite.inviteUrl}>Open invite</a>
						</div>
					</section>
				) : null
			}

			<section class="session-list" aria-label={dashboard.isOperator ? "Upcoming events" : "Assigned events"}>
				{
					dashboard.events.length === 0 ? (
						<p class="session-empty">
							{
								dashboard.isOperator
									? "No upcoming content events are available."
									: "No previous or upcoming events are assigned to this GitHub handle."
							}
						</p>
					) : dashboard.events.map((event) => {
						const activeSessions = event.sessions.filter(isStudioSessionActive);
						return (
							<article class="session-row" id={`event-${event.id}`}>
								<div>
									<p class="eyebrow">{event.show} / {eventState(event)}</p>
									<h2>{event.title}</h2>
									<p>{eventTiming(event)}</p>
								</div>
								<div class="session-status">
									<span>{event.sessions.length} rooms</span>
									<span>{activeSessions.length} active</span>
								</div>
								<div class="session-actions">
									{
										dashboard.isOperator ? (
											<form method="POST" action={actions.createSession}>
												<input name="videoId" type="hidden" value={event.id} />
												<label class="stream-environment-field">
													<span>Stream mode</span>
													<select name="streamEnvironment">
														<option value="test" selected>Test</option>
														<option value="prod">Prod</option>
													</select>
												</label>
												<button class="button primary" type="submit">
													Create room
												</button>
											</form>
										) : activeSessions.length === 0 ? (
											<span class="session-muted">No active room</span>
										) : null
									}
								</div>
								{
									event.sessions.length > 0 ? (
										<div class="event-session-list">
											{event.sessions.map((session) => (
												<div class="event-session-row">
													<div>
														<strong>{session.id}</strong>
														<span>{session.status}</span>
														<span>{session.streamEnvironment}</span>
														<span>{session.streamStatus}</span>
													</div>
													<div class="session-actions">
														{
															dashboard.isOperator ? (
																isStudioSessionActive(session) ? (
																	<>
																		<a class="button" href={`/studio/${session.id}/host`}>Host</a>
																		<a class="button" href={`/studio/${session.id}/producer`}>Produce</a>
																		<a class="button" href={`/studio/${session.id}/recordings`}>Recordings</a>
																		<form method="POST" action={actions.createInvite}>
																			<input name="sessionId" type="hidden" value={session.id} />
																			<button class="button" type="submit">Guest invite</button>
																		</form>
																		<form method="POST" action={actions.endSession} data-end-session>
																			<input name="sessionId" type="hidden" value={session.id} />
																			<button class="button" type="submit">End session</button>
																		</form>
																	</>
																) : (
																	<a class="button" href={`/studio/${session.id}/recordings`}>Recordings</a>
																)
															) : isStudioSessionActive(session) ? (
																<a class="button primary" href={`/studio/${session.id}/guest`}>
																	Join room
																</a>
															) : null
														}
													</div>
												</div>
											))}
										</div>
									) : null
								}
							</article>
						);
					})
				}
			</section>

			{
				historySessions.length > 0 ? (
					<section class="session-history" aria-labelledby="session-history-heading">
						<div class="session-section-heading">
							<p class="eyebrow">Operations</p>
							<h2 id="session-history-heading">Room history</h2>
							<p>Completed and ad-hoc rooms remain available for recording recovery.</p>
						</div>
						<div class="session-list">
							{historySessions.map((session) => (
								<article class="session-row">
									<div>
										<p class="eyebrow">{session.show}</p>
										<h2>{session.title}</h2>
										<p>{new Date(session.startsAt).toLocaleString()}</p>
									</div>
									<div class="session-status">
										<span>{session.status}</span>
										<span>{session.recordingStatus}</span>
										<span>{session.streamStatus}</span>
									</div>
									<div class="session-actions">
										{dashboard.isOperator && isStudioSessionActive(session) ? (
											<>
												<a class="button" href={`/studio/${session.id}/host`}>Host</a>
												<a class="button" href={`/studio/${session.id}/producer`}>Produce</a>
											</>
										) : null}
										{dashboard.isOperator ? (
											<a class="button" href={`/studio/${session.id}/recordings`}>Recordings</a>
										) : null}
									</div>
								</article>
							))}
						</div>
					</section>
				) : null
			}
		</>
	)
}

<script>
	for (const form of document.querySelectorAll<HTMLFormElement>("form[data-end-session]")) {
		form.addEventListener("submit", (event) => {
			if (!window.confirm("End this Studio session? Live publishing and contributor access will stop.")) {
				event.preventDefault();
			}
		});
	}

	for (const button of document.querySelectorAll<HTMLButtonElement>("button[data-copy-invite]")) {
		button.addEventListener("click", async () => {
			const input = button.closest("section")?.querySelector<HTMLInputElement>("input[data-invite-url]");
			if (!input) return;
			try {
				await navigator.clipboard.writeText(input.value);
				button.textContent = "Copied";
			} catch {
				input.select();
				button.textContent = "Select and copy";
			}
		});
	}
</script>
