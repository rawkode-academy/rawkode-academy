---
import { actions } from "astro:actions";
import {
	isStudioSessionActive,
	type StudioDashboard,
	type StudioEventSummary,
} from "../server/studio";

interface Props {
	createSessionError?: string | null;
	dashboard: StudioDashboard;
	endSessionError?: string | null;
	invite?: {
		expiresAt: number;
		inviteUrl: string;
		sessionId: string;
		sessionTitle: string;
	} | null;
	inviteError?: string | null;
}

const {
	createSessionError = null,
	dashboard,
	endSessionError = null,
	invite = null,
	inviteError = null,
} = Astro.props;

function eventTiming(event: StudioEventSummary): string {
	if (!event.startsAt) return "Unscheduled";
	return new Date(event.startsAt).toLocaleString();
}

function eventState(event: StudioEventSummary): string {
	if (!event.startsAt) return "Event";
	return Date.parse(event.startsAt) >= Date.now() ? "Upcoming" : "Previous";
}
---

{
	!dashboard.user ? (
		<section class="signed-out-panel" aria-label="Rawkode Studio sign in">
			<h1>Welcome to Rawkode Studio</h1>
			<a class="button primary" href="/login">Log in</a>
		</section>
	) : (
		<>
			<section class="dashboard-grid">
				<div class="dashboard-panel dashboard-primary">
					<div>
						<p class="eyebrow">
							{dashboard.isOperator ? "Private operator appliance" : "Guest access"}
						</p>
						<h1>
							{
								dashboard.isOperator
									? "Studio control rooms"
									: "Your rooms"
							}
						</h1>
					</div>
					<p>
							{
								dashboard.isOperator
									? "Rehearse with an unlisted operator-only Test URL, then create a separate explicitly armed Prod room when the show is ready."
									: "Join an active RealtimeKit room from your invite. Production controls remain private to the operator."
							}
					</p>
				</div>

				<div class="dashboard-panel">
					<p class="eyebrow">Identity</p>
					<h2>{dashboard.user.username ?? dashboard.user.name}</h2>
				</div>
			</section>

			{
				dashboard.contentError ? (
					<p class="form-error" role="alert">{dashboard.contentError}</p>
				) : null
			}
			{
				createSessionError ? (
					<p class="form-error" role="alert">{createSessionError}</p>
				) : null
			}
			{
				endSessionError ? (
					<p class="form-error" role="alert">{endSessionError}</p>
				) : null
			}
			{
				inviteError ? (
					<p class="form-error" role="alert">{inviteError}</p>
				) : null
			}
			{
				invite ? (
					<section class="studio-form-panel" aria-label="Guest invite">
						<p class="eyebrow">Guest invite</p>
						<h2>{invite.sessionTitle}</h2>
						<label>
							Invite URL
							<input readonly value={invite.inviteUrl} />
						</label>
						<p>Expires {new Date(invite.expiresAt * 1000).toLocaleString()}</p>
						<a class="button" href={invite.inviteUrl}>Open invite</a>
					</section>
				) : null
			}

			<section class="session-list" aria-label={dashboard.isOperator ? "Upcoming events" : "Assigned events"}>
				{
					dashboard.events.length === 0 ? (
						<p class="session-empty">
							{
								dashboard.isOperator
									? "No upcoming content events are available."
									: "No previous or upcoming events are assigned to this GitHub handle."
							}
						</p>
					) : dashboard.events.map((event) => {
						const activeSessions = event.sessions.filter(isStudioSessionActive);
						return (
							<article class="session-row" id={`event-${event.id}`}>
								<div>
									<p class="eyebrow">{event.show} / {eventState(event)}</p>
									<h2>{event.title}</h2>
									<p>{eventTiming(event)}</p>
								</div>
								<div class="session-status">
									<span>{event.sessions.length} rooms</span>
									<span>{activeSessions.length} active</span>
								</div>
								<div class="session-actions">
									{
										dashboard.isOperator ? (
											<form
												class="create-room-form"
												method="POST"
												action={actions.createSession}
												data-create-room-form
											>
												<input name="videoId" type="hidden" value={event.id} />
												<label class="stream-environment-field">
													<span>Room mode</span>
													<select name="streamEnvironment" data-stream-environment>
														<option value="test" selected>Test</option>
														<option value="prod">Prod (public)</option>
													</select>
												</label>
												<p class="test-mode-note" data-test-mode-note>
											Unlisted rehearsal. The URL is returned only to the signed-in operator and is not publicly advertised; it is not cryptographically signed.
												</p>
												<label class="prod-confirmation-field" data-prod-confirmation-field hidden>
													<span>Type <strong>PROD</strong> to arm public production</span>
													<input
														autocomplete="off"
														disabled
														name="prodConfirmation"
														spellcheck="false"
														data-prod-confirmation
													/>
												</label>
												<button class="button primary" type="submit" data-create-room-button>
											Create Unlisted Test room
												</button>
											</form>
										) : (
											<span class="session-muted">Join from your guest invite</span>
										)
									}
								</div>
								{
									event.sessions.length > 0 ? (
										<div class="event-session-list">
											{event.sessions.map((session) => (
												<div class="event-session-row">
													<div>
														<strong>{session.id}</strong>
														<span>{session.status}</span>
														<span>{session.streamEnvironment}</span>
														<span>{session.streamStatus}</span>
											</div>
											<div class="session-actions">
												{
													dashboard.isOperator ? (
														<>
															<a class="button primary" href={`/studio/${session.id}/control`}>Control room</a>
															<a class="button" href={`/studio/${session.id}/recordings`}>Recordings</a>
															<form method="POST" action={actions.createInvite}>
																		<input name="sessionId" type="hidden" value={session.id} />
																		<button class="button" type="submit">Guest invite</button>
																	</form>
																	{
																		isStudioSessionActive(session) ? (
																			<form method="POST" action={actions.endSession}>
																				<input name="sessionId" type="hidden" value={session.id} />
																				<button class="button" type="submit">End session</button>
																			</form>
																		) : null
																	}
																</>
															) : isStudioSessionActive(session) ? (
																<span class="session-muted">Guest invite required</span>
															) : null
														}
													</div>
												</div>
											))}
										</div>
									) : null
								}
							</article>
						);
					})
				}
			</section>
		</>
	)
}

<script is:inline>
	for (const form of document.querySelectorAll("[data-create-room-form]")) {
		const environment = form.querySelector("[data-stream-environment]");
		const testNote = form.querySelector("[data-test-mode-note]");
		const confirmationField = form.querySelector("[data-prod-confirmation-field]");
		const confirmation = form.querySelector("[data-prod-confirmation]");
		const button = form.querySelector("[data-create-room-button]");

		if (!environment || !confirmationField || !confirmation || !button) continue;

		const syncMode = () => {
			const isProd = environment.value === "prod";
			confirmationField.hidden = !isProd;
			confirmation.disabled = !isProd;
			confirmation.required = isProd;
			if (!isProd) {
				confirmation.value = "";
				confirmation.setCustomValidity("");
			}
			if (testNote) testNote.hidden = isProd;
			button.textContent = isProd ? "Create public Prod room" : "Create Unlisted Test room";
		};

		environment.addEventListener("change", syncMode);
		confirmation.addEventListener("input", () => confirmation.setCustomValidity(""));
		form.addEventListener("submit", (event) => {
			if (environment.value !== "prod" || confirmation.value === "PROD") return;
			event.preventDefault();
			confirmation.setCustomValidity("Type PROD exactly to create a public production room.");
			confirmation.reportValidity();
		});
		syncMode();
	}
</script>
