---
import "@/styles/global.css";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Rawkode Studio",
	description = "Cloudflare-first live streaming studio for Rawkode Live.",
} = Astro.props;
const user = Astro.locals.user;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
	</head>
	<body>
		<header class="studio-topbar">
			<a href="/" class="studio-brand" aria-label="Rawkode Studio home">
				<span class="studio-brand-mark">RS</span>
				<span>
					<strong>Rawkode Studio</strong>
					<small>Cloudflare Stream control room</small>
				</span>
			</a>
			<nav class="studio-nav" aria-label="Primary navigation">
				<a href="/">Watch</a>
				<a href="/studio">Studio</a>
				<a href="https://rawkode.chat" target="_blank" rel="noreferrer">Chat</a>
				{user ? (
					<a href="/api/auth/sign-out?returnTo=/" class="studio-nav-action">Sign out</a>
				) : (
					<a href="/api/auth/sign-in?returnTo=/studio" class="studio-nav-action">Operator sign in</a>
				)}
			</nav>
		</header>
		<slot />
	</body>
</html>

<style>
	.studio-topbar {
		position: sticky;
		top: 0;
		z-index: 20;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		min-height: 4.25rem;
		padding: 0.75rem clamp(1rem, 3vw, 2rem);
		background: rgb(255 255 255 / 86%);
		border-bottom: 1px solid var(--studio-border);
		backdrop-filter: blur(14px);
	}

	.studio-brand {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		min-width: 0;
		color: var(--studio-text);
	}

	.studio-brand-mark {
		display: inline-grid;
		place-items: center;
		width: 2.4rem;
		height: 2.4rem;
		border-radius: 0.5rem;
		background: var(--studio-bg-deep);
		color: white;
		font-family: var(--font-display, "Sora"), ui-sans-serif, system-ui, sans-serif;
		font-size: 0.88rem;
		font-weight: 700;
	}

	.studio-brand strong,
	.studio-brand small {
		display: block;
		white-space: nowrap;
	}

	.studio-brand strong {
		font-family: var(--font-display, "Sora"), ui-sans-serif, system-ui, sans-serif;
		font-size: 0.98rem;
		line-height: 1.1;
	}

	.studio-brand small {
		margin-top: 0.12rem;
		color: var(--studio-muted);
		font-size: 0.76rem;
	}

	.studio-nav {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.35rem;
		flex-wrap: wrap;
	}

	.studio-nav a {
		display: inline-flex;
		align-items: center;
		min-height: 2.25rem;
		padding: 0 0.75rem;
		border-radius: 0.45rem;
		color: var(--studio-muted);
		font-size: 0.86rem;
		font-weight: 600;
	}

	.studio-nav a:hover {
		background: var(--studio-surface-soft);
		color: var(--studio-text);
	}

	.studio-nav .studio-nav-action {
		background: var(--studio-bg-deep);
		color: white;
	}

	@media (max-width: 720px) {
		.studio-topbar {
			position: relative;
			align-items: flex-start;
			flex-direction: column;
		}

		.studio-nav {
			width: 100%;
			justify-content: flex-start;
		}
	}
</style>
