---
import App from "../../../App.vue";
import StudioLayout from "../../../layouts/StudioLayout.astro";
import {
	getStudioSession,
	userCanManageStudioSession,
} from "../../../server/studio";
import { env } from "cloudflare:workers";

if (!Astro.locals.user) {
	return Astro.redirect(`/login?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
}

const sessionId = Astro.params.sessionId ?? "";
const session = await getStudioSession(env, sessionId);
if (!session) {
	return new Response("Studio session not found", { status: 404 });
}
if (!(await userCanManageStudioSession(env, session, Astro.locals.user))) {
	return new Response("Studio session management access is required", {
		status: 403,
	});
}
const providerStatus = session.realtimeKitMeetingId ? "RealtimeKit ready" : "Meeting pending";
---

<StudioLayout
	title={`Host ${session.title} | Rawkode Studio`}
	active="host"
	bodyClass="studio-canvas-page"
>
	<section
		class="studio-canvas-shell"
		aria-label="Host studio room"
		data-meeting-id={session.realtimeKitMeetingId ?? ""}
		data-session-id={session.id}
	>
		<App
			client:only="vue"
			providerStatus={providerStatus}
			recordingStatus={session.recordingStatus}
			roomRole="Host"
			sessionId={session.id}
			sessionTitle={session.title}
		/>
	</section>
</StudioLayout>
