---
import GuestRoom from "../../../components/GuestRoom.vue";
import StudioLayout from "../../../layouts/StudioLayout.astro";
import {
	getStudioSession,
	resolveStudioInvite,
	userCanManageStudioSession,
} from "../../../server/studio";
import { env } from "cloudflare:workers";

if (!Astro.locals.user) {
	return Astro.redirect(`/login?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
}

const sessionId = Astro.params.sessionId ?? "";
const session = await getStudioSession(env, sessionId);
if (!session) {
	return new Response("Studio session not found", { status: 404 });
}
const inviteToken = Astro.url.searchParams.get("invite");
const resolvedInvite = inviteToken
	? await resolveStudioInvite(env, inviteToken, Astro.locals.user)
	: null;
const canManage = await userCanManageStudioSession(env, session, Astro.locals.user);
if (!canManage && resolvedInvite?.session.id !== session.id) {
	return new Response("Guest invite token is required", { status: 403 });
}
const providerStatus = session.realtimeKitMeetingId ? "RealtimeKit ready" : "Meeting pending";
---

<StudioLayout
	title={`${session.title} | Guest room`}
	active="guest"
	bodyClass="guest-room-page"
	showChrome={false}
>
	<section
		class="guest-room-shell"
		aria-label="RealtimeKit guest room"
		data-guest-room
		data-meeting-id={session.realtimeKitMeetingId ?? ""}
		data-session-id={session.id}
	>
		<header class="guest-room-header">
			<div>
				<p class="eyebrow">Rawkode Studio guest room</p>
				<h1>{session.title}</h1>
				<p>Join the call, check your camera and microphone, then leave from this page when the show ends.</p>
			</div>
			<div class="guest-room-status" aria-label="Room status">
				<span>{providerStatus}</span>
				<span>{session.status}</span>
			</div>
		</header>
		<GuestRoom
			client:only="vue"
		/>
	</section>
</StudioLayout>
