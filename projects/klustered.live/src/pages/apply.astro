---
import { env } from "cloudflare:workers";
import { desc, ne } from "drizzle-orm";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { getDb, schema } from "@/db/client";

const submitted = Astro.url.searchParams.get("submitted") === "1";

const db = getDb(env.DB);
const seasons = await db
	.select({
		id: schema.seasons.id,
		name: schema.seasons.name,
		status: schema.seasons.status,
	})
	.from(schema.seasons)
	.where(ne(schema.seasons.status, "finished"))
	.orderBy(desc(schema.seasons.createdAt))
	.all();
---

<SiteLayout
	title="Apply to compete"
	description="Want to fix a broken cluster on stage? Apply to compete on Klustered."
>
	<section class="pt-12">
		<p class="text-xs font-semibold uppercase tracking-[0.3em] text-fuchsia-400">
			Compete
		</p>
		<h1 class="mt-2 text-4xl font-black tracking-tight md:text-5xl">
			Apply to compete.
		</h1>
		<p class="mt-3 max-w-2xl text-slate-300">
			Klustered competitors are senior engineers, SREs, and platform folks
			who've earned their stripes in production. Tell us about yourself.
		</p>
	</section>

	{
		submitted ? (
			<section class="mt-10 rounded-2xl border border-emerald-500/30 bg-emerald-500/10 p-6 text-emerald-100">
				Thanks — your application is in. We'll be in touch.
			</section>
		) : (
			<form
				method="POST"
				action="/api/apply"
				class="mt-10 grid gap-4 rounded-2xl border border-white/10 bg-white/5 p-6"
			>
				{
					seasons.length === 0 ? (
						<p class="text-sm text-slate-400">
							No active or upcoming seasons. Watch this space.
						</p>
					) : (
						<label class="flex flex-col gap-1">
							<span class="text-xs uppercase tracking-wider text-slate-400">
								Season
							</span>
							<select
								name="seasonId"
								required
								class="rounded-lg border border-white/15 bg-black/40 px-3 py-2 text-sm text-white focus:border-fuchsia-500 focus:outline-none"
							>
								{seasons.map((s) => (
									<option value={s.id}>
										{s.name} ({s.status})
									</option>
								))}
							</select>
						</label>
					)
				}

				<label class="flex flex-col gap-1">
					<span class="text-xs uppercase tracking-wider text-slate-400">
						Your name
					</span>
					<input
						name="displayName"
						required
						class="rounded-lg border border-white/15 bg-black/40 px-3 py-2 text-sm text-white focus:border-fuchsia-500 focus:outline-none"
					/>
				</label>

				<label class="flex flex-col gap-1">
					<span class="text-xs uppercase tracking-wider text-slate-400">Email</span>
					<input
						type="email"
						name="email"
						required
						class="rounded-lg border border-white/15 bg-black/40 px-3 py-2 text-sm text-white focus:border-fuchsia-500 focus:outline-none"
					/>
				</label>

				<label class="flex flex-col gap-1">
					<span class="text-xs uppercase tracking-wider text-slate-400">
						Tell us about yourself
					</span>
					<textarea
						name="message"
						rows="5"
						maxlength="2000"
						data-counter-input
						placeholder="What you do, what cluster horrors you've seen, why you want to do this on a livestream…"
						class="rounded-lg border border-white/15 bg-black/40 px-3 py-2 text-sm text-white focus:border-fuchsia-500 focus:outline-none"
					/>
					<span class="self-end text-[10px] uppercase tracking-wider text-slate-500" data-counter-output>
						0 / 2000
					</span>
				</label>

				<button
					disabled={seasons.length === 0}
					class="mt-2 inline-flex w-fit rounded-full bg-white px-5 py-2.5 text-sm font-semibold text-slate-900 transition hover:bg-slate-100 disabled:cursor-not-allowed disabled:opacity-40"
				>
					Send application
				</button>
			</form>

			<script is:inline>
				(() => {
					const input = document.querySelector("[data-counter-input]");
					const out = document.querySelector("[data-counter-output]");
					if (!input || !out) return;
					const max = input.maxLength;
					function update() {
						out.textContent = `${input.value.length} / ${max}`;
					}
					input.addEventListener("input", update);
					update();
				})();
			</script>
		)
	}
</SiteLayout>
