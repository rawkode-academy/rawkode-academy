---
import SiteLayout from "@/layouts/SiteLayout.astro";

export const prerender = true;
---

<SiteLayout
	title="Sponsors"
	description="Klustered sponsors — companies who keep the show on the air."
>
	<section class="pt-12">
		<p class="text-xs font-semibold uppercase tracking-[0.3em] text-fuchsia-400">
			Sponsors
		</p>
		<h1 class="mt-2 text-4xl font-black tracking-tight md:text-5xl">
			The show is on because of these folks.
		</h1>
		<p class="mt-3 max-w-2xl text-slate-300">
			Klustered runs on real infrastructure, real engineering time, and real
			marketing budgets. If your company would like to be on this page, get in
			touch.
		</p>
	</section>

	<section class="mt-10 rounded-2xl border border-white/10 bg-white/5 p-8 text-center">
		<p class="text-slate-300">No active sponsors right now.</p>
		<a
			href="mailto:hello@klustered.live?subject=Sponsorship%20inquiry"
			class="mt-4 inline-flex rounded-full border border-white/15 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-white/10"
		>
			Sponsor the show →
		</a>
	</section>
</SiteLayout>
