---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Klustered — Break the cluster. Fix it on stage.</title>
		<meta
			name="description"
			content="The live Kubernetes troubleshooting game show. Real engineers. Sabotaged clusters. One hour to fix the chaos."
		/>
	</head>
	<body class="min-h-dvh bg-black font-sans text-white antialiased">
		<main class="relative mx-auto flex min-h-dvh max-w-5xl flex-col justify-center px-6 py-20">
			<div
				class="absolute inset-x-0 top-1/4 -z-10 mx-auto h-72 w-3/4 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-fuchsia-500/30 via-cyan-500/10 to-transparent blur-3xl"
			>
			</div>

			<p class="text-xs font-semibold uppercase tracking-[0.4em] text-fuchsia-400">
				Coming back · season 2026
			</p>

			<h1
				class="mt-4 text-balance text-5xl font-black leading-[0.95] tracking-tight md:text-7xl"
			>
				Break the cluster.<br />
				<span
					class="bg-gradient-to-r from-fuchsia-400 via-pink-400 to-amber-300 bg-clip-text text-transparent"
				>
					Fix it on stage.
				</span>
			</h1>

			<p class="mt-6 max-w-2xl text-lg text-slate-300 md:text-xl">
				The Kubernetes troubleshooting game show. Two competitors. One sabotaged
				cluster. Sixty minutes. Live, on YouTube.
			</p>
		</main>
	</body>
</html>
