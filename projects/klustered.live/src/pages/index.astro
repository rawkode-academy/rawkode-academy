---
import SiteLayout from "@/layouts/SiteLayout.astro";
import { getEpisodes } from "@/lib/content";

const episodes = await getEpisodes();
const latest = episodes[0];
---

<SiteLayout title="Break the cluster. Fix it on stage." heroVariant="subtle">
	<section class="pt-16 md:pt-24">
		<p class="text-xs font-semibold uppercase tracking-[0.4em] text-fuchsia-400">
			Coming back · season 2026
		</p>

		<h1
			class="mt-4 text-balance text-5xl font-black leading-[0.9] tracking-tight md:text-7xl"
		>
			Break the cluster.<br />
			<span
				class="bg-gradient-to-r from-fuchsia-400 via-pink-400 to-amber-300 bg-clip-text text-transparent"
			>
				Fix it on stage.
			</span>
		</h1>

		<p class="mt-6 max-w-2xl text-lg text-slate-300 md:text-xl">
			The Kubernetes troubleshooting game show. Two competitors. One sabotaged
			cluster. Sixty minutes. Live, on YouTube.
		</p>

		<div class="mt-8 flex flex-wrap gap-3">
			<a
				href="/schedule"
				class="rounded-full bg-white px-5 py-2.5 text-sm font-semibold text-slate-900 transition hover:bg-slate-100"
			>
				See the schedule
			</a>
			<a
				href="/apply"
				class="rounded-full border border-white/20 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-white/10"
			>
				Apply to compete →
			</a>
		</div>
	</section>

	{
		latest && (
			<section class="mt-24">
				<div class="flex items-end justify-between">
					<h2 class="text-xs font-semibold uppercase tracking-[0.3em] text-slate-400">
						Latest episode
					</h2>
					<a href="/episodes" class="text-xs text-slate-300 hover:text-white">
						All episodes →
					</a>
				</div>

				<a
					href={`/episodes/${latest.id}`}
					class="mt-3 block overflow-hidden rounded-3xl border border-white/10 bg-gradient-to-br from-slate-900/80 to-slate-950 p-8 transition hover:border-fuchsia-500/40"
				>
					<p class="text-xs uppercase tracking-[0.3em] text-fuchsia-400">
						{new Intl.DateTimeFormat("en", { dateStyle: "long" }).format(
							latest.data.publishedAt,
						)}
					</p>
					<h3 class="mt-2 text-3xl font-bold tracking-tight md:text-4xl">
						{latest.data.title}
					</h3>
					{latest.data.description && (
						<p class="mt-3 line-clamp-3 max-w-3xl text-sm text-slate-400">
							{latest.data.description.split("\n")[0]}
						</p>
					)}
				</a>
			</section>
		)
	}

	<section class="mt-24 grid gap-6 sm:grid-cols-3">
		<div class="rounded-2xl border border-white/10 bg-white/5 p-6">
			<p class="text-3xl font-bold text-fuchsia-300">{episodes.length}</p>
			<p class="mt-1 text-sm text-slate-400">Episodes in the archive</p>
		</div>
		<div class="rounded-2xl border border-white/10 bg-white/5 p-6">
			<p class="text-3xl font-bold text-cyan-300">60</p>
			<p class="mt-1 text-sm text-slate-400">Minutes on the clock</p>
		</div>
		<div class="rounded-2xl border border-white/10 bg-white/5 p-6">
			<p class="text-3xl font-bold text-amber-300">YouTube</p>
			<p class="mt-1 text-sm text-slate-400">Live, every show</p>
		</div>
	</section>
</SiteLayout>
