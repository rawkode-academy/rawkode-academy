---
import "../styles/global.css";

interface Props {
	title: string;
	description?: string;
	heroVariant?: "none" | "subtle";
}

const {
	title,
	description = "The live Kubernetes troubleshooting game show.",
	heroVariant = "subtle",
} = Astro.props;

const pathname = Astro.url.pathname;
const navLinks = [
	{ href: "/episodes", label: "Episodes" },
	{ href: "/schedule", label: "Schedule" },
	{ href: "/leaderboard", label: "Leaderboard" },
	{ href: "/about", label: "About" },
	{ href: "/rules", label: "Rules" },
	{ href: "/apply", label: "Apply" },
	{ href: "/sponsors", label: "Sponsors" },
];
---

<!doctype html>
<html lang="en" class="bg-black">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title} · Klustered</title>
		<meta name="description" content={description} />
		<meta property="og:title" content={`${title} · Klustered`} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta name="theme-color" content="#000000" />
		<meta name="twitter:card" content="summary_large_image" />
		<link rel="alternate" type="application/calendar" href="/schedule.ics" title="Klustered schedule" />
	</head>
	<body class="min-h-dvh bg-black font-sans text-white antialiased">
		<a
			href="#main"
			class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-full focus:bg-white focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-slate-900"
		>
			Skip to content
		</a>
		{
			heroVariant === "subtle" && (
				<div
					aria-hidden="true"
					class="pointer-events-none fixed inset-x-0 top-0 -z-10 mx-auto h-[40rem] w-full max-w-6xl bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-fuchsia-500/25 via-cyan-500/10 to-transparent blur-3xl"
				/>
			)
		}

		<header class="mx-auto flex max-w-6xl items-center justify-between px-6 py-6">
			<a href="/" class="flex items-baseline gap-2">
				<span
					class="bg-gradient-to-r from-fuchsia-400 via-pink-400 to-amber-300 bg-clip-text text-2xl font-black tracking-tight text-transparent"
				>
					Klustered
				</span>
				<span class="hidden text-xs uppercase tracking-[0.3em] text-slate-400 md:inline">
					/ Live
				</span>
			</a>
			<nav class="hidden gap-1 md:flex" aria-label="Primary">
				{
					navLinks.map((link) => {
						const active = pathname === link.href || pathname.startsWith(`${link.href}/`);
						return (
							<a
								href={link.href}
								aria-current={active ? "page" : undefined}
								class={`rounded-full px-3 py-1.5 text-xs font-medium uppercase tracking-wider transition focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-fuchsia-400 ${
									active
										? "bg-fuchsia-500/15 text-fuchsia-200"
										: "text-slate-300 hover:bg-white/5 hover:text-white"
								}`}
							>
								{link.label}
							</a>
						);
					})
				}
			</nav>
		</header>

		<main id="main" class="mx-auto max-w-6xl px-6 pb-24">
			<slot />
		</main>

		<footer class="border-t border-white/10 px-6 py-10">
			<div class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-3 text-xs text-slate-400 md:flex-row md:items-center">
				<p>
					© {new Date().getFullYear()} Rawkode Academy. Klustered is a live
					Kubernetes troubleshooting game show.
				</p>
				<div class="flex items-center gap-4">
					<a href="/about" class="hover:text-white">About</a>
					<a href="/rules" class="hover:text-white">Rules</a>
					<a href="/apply" class="hover:text-white">Apply to compete</a>
				</div>
			</div>
		</footer>
	</body>
</html>
